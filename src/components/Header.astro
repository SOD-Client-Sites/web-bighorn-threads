---
import { Image } from 'astro:assets'
import logoColor from '@/assets/logos/bighorn-logo-color.png'

const navLinks = [
  { href: '/catalog/', label: 'Catalog' },
  { href: '/services/', label: 'Services' },
  { href: '/company-stores/', label: 'Company Stores' },
  { href: '/industries/', label: 'Industries' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
]

const currentPath = Astro.url.pathname
---

<header class="fixed top-0 z-50 w-full border-b border-navy-700/50 bg-navy-950/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <Image
        src={logoColor}
        alt="Bighorn Threads ram logo"
        width={88}
        height={88}
        densities={[1, 2]}
        format="webp"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-11 w-11 transition-transform group-hover:scale-105"
      />
      <div>
        <span class="block font-heading text-base font-bold leading-tight tracking-tight text-white sm:text-lg">BIGHORN <span class="text-gold-500">THREADS</span></span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            currentPath === link.href || currentPath.startsWith(link.href + '/')
              ? 'bg-navy-800 text-gold-500'
              : 'text-navy-200 hover:bg-navy-800/50 hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right Cluster -->
    <div class="flex items-center gap-3">
      <a
        href="/catalog/search/"
        class="inline-flex items-center justify-center rounded-lg p-2 text-navy-200 transition-colors hover:bg-navy-800/50 hover:text-gold-500"
        aria-label="Search products"
        title="Search catalog"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
      <a
        href="tel:+17252356196"
        class="hidden items-center gap-2 font-mono text-sm font-medium text-navy-200 transition-colors hover:text-gold-500 md:flex"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        725.235.6196
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-4 py-2.5 text-sm font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20"
      >
        Get a Quote
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="inline-flex items-center justify-center rounded-lg p-2 text-navy-200 transition-colors hover:bg-navy-800 hover:text-white lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-navy-700/50 bg-navy-950 lg:hidden">
    <nav class="mx-auto max-w-7xl space-y-1 px-4 py-4" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block rounded-lg px-4 py-3 text-base font-medium transition-colors',
            currentPath === link.href
              ? 'bg-navy-800 text-gold-500'
              : 'text-navy-200 hover:bg-navy-800/50 hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="tel:+17252356196"
        class="flex items-center gap-2 rounded-lg px-4 py-3 font-mono text-base font-medium text-gold-500"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        725.235.6196
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true'
    btn.setAttribute('aria-expanded', String(!expanded))
    menu?.classList.toggle('hidden')
  })
</script>

<!-- Sticky mobile bottom bar -->
<div class="fixed bottom-0 left-0 right-0 z-40 flex border-t border-navy-700/50 bg-navy-950/95 backdrop-blur-md lg:hidden">
  <a
    href="tel:+17252356196"
    class="flex flex-1 items-center justify-center gap-2 py-3.5 text-sm font-medium text-navy-200 transition-colors hover:text-gold-400"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    Call Us
  </a>
  <div class="w-px bg-navy-700/50"></div>
  <a
    href="/contact/"
    class="flex flex-1 items-center justify-center gap-2 bg-gold-500 py-3.5 text-sm font-bold text-navy-950 transition-colors hover:bg-gold-400"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    Get a Quote
  </a>
</div>
