---
import { Image } from 'astro:assets'
import logoColor from '@/assets/logos/bighorn-logo-color.png'

const navLinks = [
 { href: '/catalog/', label: 'Catalog' },
 { href: '/services/', label: 'Services' },
 { href: '/company-stores/', label: 'Company Stores' },
 { href: '/industries/', label: 'Industries' },
 { href: '/blog/', label: 'Blog' },
 { href: '/about/', label: 'About' },
 { href: '/contact/', label: 'Contact' },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href)
---

<header class="fixed top-0 z-50 w-full border-b border-hairline bg-concrete/95 backdrop-blur-md">
 <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2 sm:px-6 lg:px-8">
 <!-- Logo -->
 <a href="/" class="group flex items-center gap-3">
 <Image
 src={logoColor}
 alt="Bighorn Threads ram logo"
 width={140}
 height={112}
 densities={[1, 2]}
 format="webp"
 loading="eager"
 fetchpriority="high"
 decoding="async"
 class="h-11 w-auto transition-transform group-hover:scale-105"
 />
 <span class="block font-heading text-lg font-extrabold uppercase leading-none tracking-tight text-charcoal">
 Bighorn <span class="text-gold-600">Threads</span>
 </span>
 </a>

 <!-- Desktop Nav -->
 <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
 {navLinks.map((link) => (
 <a
 href={link.href}
 class:list={[
 'border-b-2 px-3 py-2 font-mono text-xs font-medium uppercase tracking-wider transition-colors',
 isActive(link.href)
 ? 'border-gold-500 text-gold-700'
 : 'border-transparent text-ash hover:border-hairline hover:text-charcoal',
 ]}
 >
 {link.label}
 </a>
 ))}
 </nav>

 <!-- Right Cluster -->
 <div class="flex items-center gap-2">
 <a
 href="/catalog/search/"
 class="inline-flex items-center justify-center p-2 text-ash transition-colors hover:text-gold-700"
 aria-label="Search products"
 title="Search catalog"
 >
 <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
 </svg>
 </a>
 <a
 href="tel:+17029048923"
 class="hidden items-center gap-2 font-mono text-sm font-medium text-ash transition-colors hover:text-gold-700 md:flex"
 >
 <svg class="h-4 w-4 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
 </svg>
 702.904.8923
 </a>
 <a
 href="/get-a-quote/"
 class="hidden items-center gap-2 bg-gold-500 px-4 py-2.5 font-subheading text-sm font-semibold uppercase tracking-wide text-charcoal transition-colors hover:bg-gold-600 sm:inline-flex"
 style="border-radius:4px"
 >
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
 </svg>
 </a>

 <!-- Mobile Menu Button -->
 <button
 id="mobile-menu-btn"
 class="inline-flex items-center justify-center p-2 text-ash transition-colors hover:text-charcoal lg:hidden"
 aria-label="Open menu"
 aria-expanded="false"
 >
 <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
 </svg>
 </button>
 </div>
 </div>

 <!-- Mobile Menu -->
 <div id="mobile-menu" class="hidden border-t border-hairline bg-concrete lg:hidden">
 <nav class="mx-auto max-w-7xl space-y-1 px-4 py-4" aria-label="Mobile navigation">
 {navLinks.map((link) => (
 <a
 href={link.href}
 class:list={[
 'block px-4 py-3 font-mono text-sm font-medium uppercase tracking-wider transition-colors',
 isActive(link.href)
 ? 'bg-paper text-gold-700'
 : 'text-ash hover:bg-paper hover:text-charcoal',
 ]}
 >
 {link.label}
 </a>
 ))}
 <a
 href="tel:+17029048923"
 class="flex items-center gap-2 px-4 py-3 font-mono text-sm font-medium text-gold-700"
 >
 <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
 </svg>
 702.904.8923
 </a>
 </nav>
 </div>
</header>

<script>
 const btn = document.getElementById('mobile-menu-btn')
 const menu = document.getElementById('mobile-menu')
 btn?.addEventListener('click', () => {
 const expanded = btn.getAttribute('aria-expanded') === 'true'
 btn.setAttribute('aria-expanded', String(!expanded))
 menu?.classList.toggle('hidden')
 })
</script>

<!-- Sticky mobile bottom bar -->
<div class="fixed bottom-0 left-0 right-0 z-40 flex border-t border-hairline bg-concrete/95 backdrop-blur-md lg:hidden">
 <a
 href="tel:+17029048923"
 class="flex flex-1 items-center justify-center gap-2 py-3.5 font-mono text-sm font-medium text-charcoal transition-colors hover:text-gold-700"
 >
 <svg class="h-4 w-4 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
 </svg>
 Call Us
 </a>
 <a
 href="/get-a-quote/"
 class="flex flex-1 items-center justify-center gap-2 bg-gold-500 py-3.5 font-subheading text-sm font-semibold uppercase tracking-wide text-charcoal transition-colors hover:bg-gold-600"
 >
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
 </svg>
 </a>
</div>
