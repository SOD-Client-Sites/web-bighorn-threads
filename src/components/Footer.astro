---
const serviceLinks = [
  { href: '/services#screen-printing', label: 'Screen Printing' },
  { href: '/services#embroidery', label: 'Embroidery' },
  { href: '/services#branded-apparel', label: 'Branded Apparel' },
  { href: '/services#promotional-products', label: 'Promotional Products' },
  { href: '/company-stores', label: 'Company Stores' },
]

const industryLinks = [
  { href: '/industries#construction', label: 'Construction' },
  { href: '/industries#electrical', label: 'Electrical' },
  { href: '/industries#plumbing-hvac', label: 'Plumbing & HVAC' },
  { href: '/industries#roofing-solar', label: 'Roofing & Solar' },
  { href: '/industries#landscaping', label: 'Landscaping' },
]

const companyLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Get a Quote' },
]

const year = new Date().getFullYear()
---

<footer class="border-t border-navy-700/30 bg-navy-950">
  <!-- Main Footer -->
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-12">
      <!-- Brand Column -->
      <div class="lg:col-span-4">
        <a href="/" class="flex items-center gap-3">
          <svg class="h-9 w-9" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="40" height="40" rx="8" fill="#c8960e"/>
            <path d="M14 14c-2-3-5-3-6-1s-1 5 1 6c-1-2-1-4 0-5s3-1 4 1" stroke="#0b1a2f" stroke-width="2.2" fill="none" stroke-linecap="round"/>
            <path d="M26 14c2-3 5-3 6-1s1 5-1 6c1-2 1-4 0-5s-3-1-4 1" stroke="#0b1a2f" stroke-width="2.2" fill="none" stroke-linecap="round"/>
            <ellipse cx="20" cy="21" rx="6" ry="7.5" fill="#0b1a2f"/>
            <ellipse cx="20" cy="20.5" rx="5" ry="6" fill="#1a2d4a"/>
            <circle cx="17.5" cy="19" r="1.2" fill="#0b1a2f"/><circle cx="22.5" cy="19" r="1.2" fill="#0b1a2f"/>
            <ellipse cx="20" cy="23" rx="2" ry="1.3" fill="#0b1a2f"/>
          </svg>
          <div>
            <span class="block font-heading text-lg font-bold text-white">BIGHORN <span class="text-amber-500">THREADS</span></span>
            <span class="block text-[10px] font-medium uppercase tracking-[0.2em] text-navy-400">A VP Promos Brand</span>
          </div>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-navy-300">
          Branded apparel and promotional products for the companies that build Las Vegas. 15+ years of outfitting crews that mean business.
        </p>
        <div class="mt-6 space-y-3">
          <a href="tel:+17252356196" class="flex items-center gap-3 text-sm text-navy-300 transition-colors hover:text-amber-500">
            <svg class="h-4 w-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="font-mono">725.235.6196</span>
          </a>
          <a href="mailto:info@vp-promos.com" class="flex items-center gap-3 text-sm text-navy-300 transition-colors hover:text-amber-500">
            <svg class="h-4 w-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            info@vp-promos.com
          </a>
          <div class="flex items-center gap-3 text-sm text-navy-300">
            <svg class="h-4 w-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Las Vegas, NV
          </div>
        </div>
      </div>

      <!-- Services -->
      <div class="lg:col-span-3">
        <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">Services</h3>
        <ul class="space-y-2.5">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-300 transition-colors hover:text-amber-500">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div class="lg:col-span-3">
        <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">Industries</h3>
        <ul class="space-y-2.5">
          {industryLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-300 transition-colors hover:text-amber-500">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="lg:col-span-2">
        <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">Company</h3>
        <ul class="space-y-2.5">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-300 transition-colors hover:text-amber-500">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-navy-400">Hours</p>
          <p class="mt-1 text-sm text-navy-300">Mon–Fri 8am–5pm</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-navy-800/50">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row sm:px-6 lg:px-8">
      <p class="text-xs text-navy-500">
        &copy; {year} Bighorn Threads. A <a href="https://www.vp-promos.com" class="text-navy-400 hover:text-amber-500" rel="noopener noreferrer" target="_blank">VP Promos</a> brand. All rights reserved.
      </p>
      <p class="text-xs text-navy-500">
        Las Vegas, Nevada
      </p>
    </div>
  </div>
</footer>
