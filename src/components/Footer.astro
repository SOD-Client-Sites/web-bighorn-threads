---
import { Image } from 'astro:assets'
import logoColor from '@/assets/logos/bighorn-logo-color.png'

const serviceLinks = [
 { href: '/services/screen-printing-las-vegas/', label: 'Screen Printing' },
 { href: '/services/embroidery-las-vegas/', label: 'Embroidery' },
 { href: '/dtf-printing-las-vegas/', label: 'DTF Printing' },
 { href: '/services/rush-orders-las-vegas/', label: 'Rush Orders' },
 { href: '/promo-products-las-vegas/', label: 'Promotional Products' },
 { href: '/company-stores/', label: 'Company Stores' },
]

const industryLinks = [
 { href: '/industries/construction-trades/', label: 'Construction & Trades' },
 { href: '/industries/corporate/', label: 'Corporate' },
 { href: '/industries/education/', label: 'Education' },
 { href: '/industries/healthcare/', label: 'Healthcare' },
 { href: '/industries/government/', label: 'Government' },
 { href: '/industries/gaming-hospitality/', label: 'Gaming & Hospitality' },
 { href: '/industries/events/', label: 'Events & Teams' },
]

const companyLinks = [
 { href: '/about/', label: 'About Us' },
 { href: '/blog/', label: 'Field Notes' },
 { href: '/get-a-quote/', label: 'Get a Quote' },
]

// Sitewide internal links to high-intent landing pages — passes PageRank from
// every page on the site to the buyer-intent LPs. Strongest single internal-
// linking lever available.
const popularPages = [
 { href: '/company-stores/', label: 'Company Stores' },
 { href: '/services/embroidery-las-vegas/', label: 'Embroidery' },
 { href: '/custom-polo-shirts-las-vegas/', label: 'Custom Polos' },
 { href: '/custom-team-shirts-las-vegas/', label: 'Custom Team Shirts' },
 { href: '/promo-products-las-vegas/', label: 'Promo Products' },
 { href: '/trade-show-apparel-las-vegas/', label: 'Trade Show Apparel' },
 { href: '/custom-hard-hats-las-vegas/', label: 'Custom Hard Hats' },
 { href: '/welder-uniforms-las-vegas/', label: 'Welder Uniforms' },
 { href: '/dtf-printing-las-vegas/', label: 'DTF Printing' },
 { href: '/custom-yeti-drinkware-las-vegas/', label: 'Custom Yeti Drinkware' },
]

const year = new Date().getFullYear()
---

<footer class="border-t border-navy-700/30 bg-navy-950">
 <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-12">
 <!-- Brand Column -->
 <div class="lg:col-span-4">
 <a href="/" class="flex items-center gap-3">
 <Image src={logoColor} alt="Bighorn Threads" width={96} height={96} densities={[1, 2]} format="webp" loading="lazy" decoding="async" class="h-12 w-12" />
 <div>
 <span class="block font-heading text-lg font-bold text-white">BIGHORN <span class="text-gold-500">THREADS</span></span>
 <span class="block text-[9px] font-medium uppercase tracking-[0.2em] text-gray-400">Las Vegas, NV</span>
 </div>
 </a>
 <p class="mt-4 max-w-sm text-sm leading-relaxed text-gray-400">
 Branded apparel, uniforms, and company stores. Las Vegas based — serving teams nationwide.
 </p>
 <div class="mt-6 space-y-3">
 <a href="tel:+17029048923" class="flex items-center gap-3 text-sm text-gray-400 transition-colors hover:text-gold-500">
 <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
 </svg>
 <span class="font-mono">702.904.8923</span>
 </a>
 <a href="mailto:info@bighornthreads.com" class="flex items-center gap-3 text-sm text-gray-400 transition-colors hover:text-gold-500">
 <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
 </svg>
 info@bighornthreads.com
 </a>
 <div class="flex items-center gap-3 text-sm text-gray-400">
 <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
 <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
 </svg>
 Las Vegas, NV
 </div>
 </div>
 </div>

 <!-- Services -->
 <div class="lg:col-span-3">
 <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-gray-400">Services</h3>
 <ul class="space-y-2.5">
 {serviceLinks.map((link) => (
 <li>
 <a href={link.href} class="text-sm text-gray-400 transition-colors hover:text-gold-500">
 {link.label}
 </a>
 </li>
 ))}
 </ul>
 </div>

 <!-- Industries -->
 <div class="lg:col-span-3">
 <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-gray-400">Industries</h3>
 <ul class="space-y-2.5">
 {industryLinks.map((link) => (
 <li>
 <a href={link.href} class="text-sm text-gray-400 transition-colors hover:text-gold-500">
 {link.label}
 </a>
 </li>
 ))}
 </ul>
 </div>

 <!-- Company -->
 <div class="lg:col-span-2">
 <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-gray-400">Company</h3>
 <ul class="space-y-2.5">
 {companyLinks.map((link) => (
 <li>
 <a href={link.href} class="text-sm text-gray-400 transition-colors hover:text-gold-500">
 {link.label}
 </a>
 </li>
 ))}
 </ul>
 <div class="mt-6">
 <p class="text-xs font-bold uppercase tracking-[0.15em] text-gray-400">Hours</p>
 <p class="mt-1 text-sm text-gray-400">Mon–Fri 8am–5pm</p>
 </div>
 </div>
 </div>
 </div>

 <!-- Popular Pages — sitewide internal links to LPs (PageRank distribution) -->
 <div class="border-t border-navy-800/50">
 <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
 <h3 class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-gray-400">Popular Searches</h3>
 <ul class="flex flex-wrap gap-x-5 gap-y-2">
 {popularPages.map((link) => (
 <li>
 <a href={link.href} class="text-sm text-gray-400 transition-colors hover:text-gold-500">
 {link.label}
 </a>
 </li>
 ))}
 </ul>
 </div>
 </div>

 <!-- Bottom Bar -->
 <div class="border-t border-navy-800/50">
 <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row sm:px-6 lg:px-8">
 <div class="flex flex-col items-center gap-1.5 text-xs text-gray-400 sm:items-start">
 <p>&copy; {year} VP Promos LLC, d/b/a Bighorn Threads. All rights reserved.</p>
 <p class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 sm:justify-start">
 <a href="/legal/privacy-policy/" class="transition-colors hover:text-gold-500">Privacy Policy</a>
 <span class="text-navy-700" aria-hidden="true">&middot;</span>
 <a href="/legal/terms/" class="transition-colors hover:text-gold-500">Terms &amp; Conditions</a>
 </p>
 <p class="text-[10px] text-gray-400">
 Product data &copy; {year} SAGE&reg;. Used under license.
 </p>
 </div>
 <div class="flex items-center gap-3">
 <a href="https://www.youtube.com/@bighornthreads" target="_blank" rel="noopener" aria-label="Bighorn Threads on YouTube" class="text-gray-400 transition-colors hover:text-gold-500">
 <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
 <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
 </svg>
 </a>
 </div>
 </div>
 </div>

 <div style="text-align:center;padding:0.75rem 0 1rem;border-top:1px solid rgba(128,128,128,0.15);">
 <p style="font-size:0.7rem;opacity:0.5;">Built by <a href="https://salesondemand.io" style="opacity:0.8;text-decoration:underline;" rel="dofollow">Sales On Demand</a></p>
 </div>
</footer>
