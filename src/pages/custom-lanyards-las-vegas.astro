---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Lanyards in Las Vegas | Trade Show, Conference, Staff ID — Bighorn Threads',
 description:
 'Custom lanyards in Las Vegas — woven, screen-printed, dye-sublimated. For trade show badges, conference attendees, corporate ID, hospital and school staff. Breakaway safety hardware. Get a quote.',
 hero: '/images/generated/service-branded-apparel.jpg',
 url: 'https://bighornthreads.com/custom-lanyards-las-vegas/',
}

const stack = [
 { label: 'The decoration', body: 'Three core methods — silk-screen for solid logos, full-color dye-sublimation for photographic art, and woven for premium logo-into-fabric finish. Method matches the design and the budget tier.' },
 { label: 'The hardware', body: 'Bulldog clip, swivel hook, lobster claw, breakaway safety release, badge reel attachment, double-end clip. Picked to match the badge weight and venue safety policy.' },
 { label: 'Width range', body: '3/8", 1/2", 5/8", 3/4", and 1" widths. Wider lanyards for heavier badges or larger logo prints. 5/8" is the convention default.' },
 { label: 'Materials', body: 'Polyester (the workhorse), recycled rPET (sustainability-focused programs), and bamboo or cotton for premium events.' },
]

const decorations = [
 { row: 'Silk-screen print', use: 'One- to four-color spot logos on solid lanyard color', notes: 'Cleanest result for simple logos. Lowest setup cost. Most-ordered method.' },
 { row: 'Dye-sublimation (full color)', use: 'Photographic, gradient, or multi-color art', notes: 'Edge-to-edge full-color print. No color-count limit. Standard for trade shows.' },
 { row: 'Woven', use: 'Premium events, executive lanyards, association awards', notes: 'Logo woven into the fabric — looks and feels textile-tier. Highest perceived quality.' },
 { row: 'Heat transfer', use: 'Small runs with full-color art', notes: 'Lower setup than dye-sub for short runs. Less durable on heavy-wash programs.' },
]

const useCases = [
 { name: 'Trade show attendee badges', detail: 'Vegas hosts the biggest shows in North America. Lanyards are the highest-volume convention SWAG. Branded by the show, the host org, or a sponsor.' },
 { name: 'Corporate office ID', detail: 'Daily-wear staff ID with clip or badge reel. Branded with company logo, often paired with a printed name badge.' },
 { name: 'Hospital and clinical staff', detail: 'Medical and clinical ID with breakaway safety release (required by most hospital safety policies). Color-coded by department or shift.' },
 { name: 'School and university', detail: 'Student, faculty, and visitor ID. Often dye-sublimated with school logo and color scheme. Breakaway hardware standard.' },
 { name: 'Conference and event staff', detail: '"STAFF" or "CREW" lanyards differentiating event team from attendees. Often a different color from the attendee lanyard.' },
 { name: 'VIP and sponsor tiers', detail: 'Premium woven lanyards for VIP, speaker, sponsor, or executive attendee tiers. Visual differentiation at distance.' },
]

const faqs = [
 { q: 'What\'s the most popular lanyard width?', a: '5/8" is the convention and corporate ID default — wide enough to fit a 1-color or basic 2-color logo cleanly, narrow enough to feel comfortable around the neck for a full event day. 3/4" and 1" are used for heavier badges or larger logo prints. 3/8" and 1/2" are tighter, often used in school and clinical settings.' },
 { q: 'Should I use silk-screen, dye-sublimation, or woven?', a: 'Silk-screen wins on cost for simple solid-color logos. Dye-sublimation is required for photographic or gradient art and for edge-to-edge full-color prints — standard at trade shows. Woven is the premium choice for VIP, sponsor, executive, or association lanyards where the textile-tier feel matters.' },
 { q: 'What lanyard hardware do I need for a heavy badge?', a: 'For heavy plastic badges, RFID badges, or badges with multiple inserts, use a swivel hook or lobster claw rather than a bulldog clip. The bulldog clip can come loose under repeated weight. For badge reels (retractable), pair with a swivel hook lanyard so the reel can rotate.' },
 { q: 'Are breakaway safety lanyards required?', a: 'Required at most hospitals, schools, and many manufacturing or industrial sites — breakaway hardware releases under load to prevent strangulation if the lanyard catches on equipment or doors. Some venues mandate it; safety-conscious programs spec it by default. Adds a small per-piece cost.' },
 { q: 'Can I order eco-friendly or sustainable lanyards?', a: 'Yes. Recycled rPET polyester (made from recycled plastic bottles), bamboo, and organic cotton are the three most-ordered sustainable lanyard materials. rPET is the most cost-comparable to standard polyester and the easiest to print on.' },
 { q: 'What\'s the minimum lanyard order?', a: 'Most lanyard programs run 100 pieces minimum on silk-screen and dye-sublimation methods because of overseas production economics. Smaller runs (under 100) are possible with domestic short-run vendors at a higher per-piece cost.' },
 { q: 'How long does a lanyard order take?', a: 'Standard production runs through overseas manufacturing — lead time depends on production calendar and shipping. Domestic short-run options exist for faster turnaround. Send your event date with your inquiry and we\'ll quote a real timeline against the calendar.' },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Custom Lanyards Las Vegas', item: page.url },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Lanyards in Las Vegas',
 serviceType: 'Branded lanyards for trade shows, conferences, corporate ID, and staff identification',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Paradise' },
 { '@type': 'City', name: 'Summerlin' },
 ],
 description: page.description,
 url: page.url,
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical={page.url}
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
