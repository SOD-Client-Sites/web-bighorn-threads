---
import BaseLayout from '@/layouts/BaseLayout.astro'

const industries = [
  {
    slug: 'general-contractors',
    name: 'General Contractors & Construction',
    href: '#industry-general-contractors',
  },
  {
    slug: 'electrical',
    name: 'Electrical Contractors',
    href: '#industry-electrical',
  },
  {
    slug: 'plumbing-hvac',
    name: 'Plumbing & HVAC',
    href: '#industry-plumbing-hvac',
  },
  {
    slug: 'roofing-solar',
    name: 'Roofing & Solar',
    href: '#industry-roofing-solar',
  },
  {
    slug: 'landscaping',
    name: 'Landscaping & Outdoor Services',
    href: '#industry-landscaping',
  },
  {
    slug: 'concrete-masonry',
    name: 'Concrete & Masonry',
    href: '#industry-concrete-masonry',
  },
  {
    slug: 'steel-iron',
    name: 'Steel & Iron Workers',
    href: '#industry-steel-iron',
  },
  {
    slug: 'oil-gas-mechanical',
    name: 'Oil, Gas & Mechanical',
    href: '#industry-oil-gas-mechanical',
  },
]

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Industries We Serve | Bighorn Threads',
  description:
    'Branded apparel, hi-vis safety gear, screen printing, embroidery, and promotional products for Las Vegas construction, electrical, plumbing, HVAC, roofing, solar, landscaping, concrete, steel, and oil & gas trades.',
  url: 'https://bighornthreads.com/industries',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: industries.map((industry, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Service',
        name: industry.name,
        provider: {
          '@type': 'LocalBusiness',
          name: 'Bighorn Threads',
        },
        areaServed: {
          '@type': 'City',
          name: 'Las Vegas',
        },
        url: `https://bighornthreads.com/industries${industry.href}`,
      },
    })),
  },
}
---

<BaseLayout
  title="Industries We Serve | Branded Apparel for Las Vegas Trades"
  description="Branded apparel, hi-vis safety gear, screen printing, and embroidery for Las Vegas construction, electrical, plumbing, HVAC, roofing, solar, landscaping, concrete, steel, and oil & gas trades."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-950 to-navy-900" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_70%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_40%_30%_at_10%_110%,_rgba(193,155,61,0.08),_transparent)]" />
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Industries We Serve</span>
      <h1 class="mb-6 max-w-4xl text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Built for the Trades That <span class="text-gold-500">Build Vegas</span>
      </h1>
      <p class="mb-8 max-w-3xl text-lg text-navy-200 sm:text-xl">
        We don't just slap a logo on a shirt. We specialize in outfitting construction crews, field technicians, and trade pros with gear that survives the job site, meets OSHA and NFPA standards, and keeps your brand visible from the curb to the cul-de-sac.
      </p>
      <div class="flex flex-wrap gap-3">
        {industries.map((industry) => (
          <a
            href={industry.href}
            class="inline-flex items-center gap-2 rounded-full border border-navy-700/60 bg-navy-800/40 px-4 py-2 text-sm font-medium text-navy-200 transition-all hover:border-gold-500/60 hover:bg-gold-500/10 hover:text-gold-400 min-h-[44px]"
          >
            {industry.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Industry 1: General Contractors (Featured) -->
  <section id="industry-general-contractors" class="scroll-mt-20 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border-2 border-gold-500/40 bg-gradient-to-br from-navy-900/60 via-navy-900/40 to-navy-800/30 p-8 sm:p-12">
        <div class="grid items-start gap-10 lg:grid-cols-[auto_1fr]">
          <div class="flex h-20 w-20 flex-shrink-0 items-center justify-center rounded-2xl bg-gold-500/15 ring-1 ring-gold-500/30">
            <svg class="h-10 w-10 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
            </svg>
          </div>
          <div>
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold-500">General Contractors & Construction</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-gold-500 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-navy-950">
                <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                Our Specialty
              </span>
            </div>
            <h2 class="mb-5 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
              The crew that builds Vegas deserves gear that holds up.
            </h2>
            <div class="space-y-4 text-lg text-navy-200">
              <p>
                General contractors are the backbone of everything we do at Bighorn. If your crew is pouring foundations, framing walls, hanging drywall, or running a multi-site build, you need branded apparel that survives heat, sweat, concrete dust, and the kind of abuse office clothes never see. That means heavyweight 6oz+ tees with plastisol prints that don't crack after one wash, hi-vis safety shirts that meet ANSI Class 2 or Class 3 requirements, and hard hats printed or stickered with your company mark so your crew is identifiable on a shared job site.
              </p>
              <p>
                The challenge most GCs bring us: ordering in waves. You need 50 shirts now for the summer crew, another 30 next month when a superintendent starts, and a one-off hoodie for the owner's nephew who just joined. We solve that with company stores — a private online portal where your team orders approved gear in approved colors with your logo, at your negotiated pricing. No more emails. No more spreadsheets. No more wrong sizes showing up the day before the OSHA walk.
              </p>
              <p>
                Most common orders from GCs: hi-vis tees and long-sleeves, embroidered polos for PMs and estimators, hard hats and hard hat stickers, branded Carhartt-style jackets for winter, company-store reorders, and site-specific safety vests for subs and visitors.
              </p>
            </div>
            <div class="mt-7 flex flex-wrap gap-2">
              {['Hi-Vis ANSI Class 2/3', 'Hard Hats', 'Heavyweight Tees', 'Embroidered Polos', 'Branded Jackets', 'Company Stores', 'Safety Vests'].map((tag) => (
                <span class="inline-flex items-center rounded-full border border-gold-500/40 bg-gold-500/5 px-3 py-1 text-sm font-medium text-gold-400">
                  {tag}
                </span>
              ))}
            </div>
            <div class="mt-8">
              <a href="/contact?industry=general-contractors" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5 min-h-[44px]">
                Get a Quote for General Contractors
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry 2: Electrical -->
  <section id="industry-electrical" class="scroll-mt-20 border-y border-navy-700/30 bg-navy-900/50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-10 lg:grid-cols-[auto_1fr]">
        <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-gold-500/10">
          <svg class="h-8 w-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <div>
          <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Electrical Contractors</span>
          <h2 class="mb-5 text-3xl font-bold tracking-tight sm:text-4xl">
            Arc-rated apparel that meets NFPA 70E. Branded the way you want it.
          </h2>
          <div class="space-y-4 text-lg text-navy-200">
            <p>
              Electrical contractors don't have the luxury of grabbing whatever shirt is on sale. NFPA 70E compliance isn't optional, and if your apparel isn't rated for the arc flash hazard of the task, your crew is exposed — and so is your liability. We source and brand FR (flame resistant) and AR (arc rated) apparel with CAT 1, CAT 2, and CAT 3 ratings that hold up to the real work your team does every day.
            </p>
            <p>
              The tricky part is branding it right. Standard screen printing inks and vinyl heat transfers can actually compromise the FR rating of a garment. We use FR-compatible decoration methods — woven embroidered patches stitched to the garment, or FR-rated direct embroidery — so your brand shows up without voiding the certification. Beyond the field-grade FR gear, we also outfit electrical companies with regular embroidered polos for office staff and sales reps, branded beanies and knit caps for early morning service calls, and promotional leave-behinds like magnets and pens for residential panel upgrades and service work.
            </p>
            <p>
              Common orders: FR/AR button-downs and tees, embroidered FR jackets, hi-vis FR hoodies, branded polos for service techs, beanies, and work hats.
            </p>
          </div>
          <div class="mt-7 flex flex-wrap gap-2">
            {['FR/AR Rated (NFPA 70E)', 'CAT 1 & CAT 2', 'Embroidered Polos', 'FR Patches', 'Branded Beanies', 'Service Tech Uniforms', 'Leave-Behind Promo'].map((tag) => (
              <span class="inline-flex items-center rounded-full border border-gold-500/40 bg-gold-500/5 px-3 py-1 text-sm font-medium text-gold-400">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-8">
            <a href="/contact?industry=electrical" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5 min-h-[44px]">
              Get a Quote for Electrical
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry 3: Plumbing & HVAC -->
  <section id="industry-plumbing-hvac" class="scroll-mt-20 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-10 lg:grid-cols-[auto_1fr]">
        <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-gold-500/10">
          <svg class="h-8 w-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5M12 19.5V21M4.22 4.22l1.06 1.06M18.72 18.72l1.06 1.06M3 12h1.5M19.5 12H21M4.22 19.78l1.06-1.06M18.72 5.28l1.06-1.06M16.5 12a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" />
          </svg>
        </div>
        <div>
          <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Plumbing & HVAC</span>
          <h2 class="mb-5 text-3xl font-bold tracking-tight sm:text-4xl">
            Moisture-wicking work shirts and branded trucks that win the driveway.
          </h2>
          <div class="space-y-4 text-lg text-navy-200">
            <p>
              Plumbing and HVAC techs spend half their day in attics that hit 140 degrees and the other half under sinks with their elbow in a puddle. Cotton tees aren't going to cut it. We outfit Vegas plumbing and HVAC companies with moisture-wicking performance work shirts that breathe, dry fast, and don't hold the smell of a crawlspace after a long call. Polos and button-downs with your logo embroidered on the chest create an instant "I'm a pro, not a handyman with a truck" first impression when your tech walks up to a homeowner's door.
            </p>
            <p>
              Branded merch matters more in this trade than most. A homeowner who just got a $9,000 HVAC replacement is going to remember your truck magnet, your branded notepad, your company pen left on their kitchen counter — and they're going to hand your info to the neighbor three weeks later when their unit goes out. We build leave-behind promotional kits designed specifically for residential service trades: fridge magnets with your logo and 24/7 phone number, notepads, branded pens, water bottles for the crew, and embroidered service-tech jackets that look sharp in every driveway visit.
            </p>
            <p>
              Common orders: performance work shirts, embroidered polos, branded service-tech jackets, truck magnets, notepads, pens, water bottles, and seasonal promo giveaways.
            </p>
          </div>
          <div class="mt-7 flex flex-wrap gap-2">
            {['Moisture-Wicking Shirts', 'Embroidered Polos', 'Service Tech Jackets', 'Truck Magnets', 'Branded Notepads', 'Promo Pens', 'Leave-Behind Kits'].map((tag) => (
              <span class="inline-flex items-center rounded-full border border-gold-500/40 bg-gold-500/5 px-3 py-1 text-sm font-medium text-gold-400">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-8">
            <a href="/contact?industry=plumbing-hvac" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5 min-h-[44px]">
              Get a Quote for Plumbing & HVAC
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry 4: Roofing & Solar -->
  <section id="industry-roofing-solar" class="scroll-mt-20 border-y border-navy-700/30 bg-navy-900/50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-10 lg:grid-cols-[auto_1fr]">
        <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-gold-500/10">
          <svg class="h-8 w-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </div>
        <div>
          <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Roofing & Solar</span>
          <h2 class="mb-5 text-3xl font-bold tracking-tight sm:text-4xl">
            Hi-vis on every rooftop. Sun-proof gear for 115-degree Vegas summers.
          </h2>
          <div class="space-y-4 text-lg text-navy-200">
            <p>
              OSHA doesn't make hi-vis a suggestion on a roof. If your crew is working at height where overhead lifts, material drops, or ground-level equipment is moving, ANSI Class 2 or Class 3 hi-vis gear is the law, and it's also just common sense. We supply branded hi-vis tees, long-sleeves, hoodies, and safety vests in sizes from S to 5XL with your logo screen-printed or embroidered so your crew is identifiable from the street and from the sky.
            </p>
            <p>
              Vegas adds a second problem: UV. Roofing and solar installers spend 8 to 10 hours a day under direct sun at altitude, and standard cotton tees offer almost no UV protection. We source sun-protective long-sleeve performance shirts with UPF 30+ ratings that keep crews cool and shielded without sacrificing hi-vis visibility. Add custom-printed hard hats, branded trucker hats, and logo-embroidered softshell jackets for sales reps knocking doors, and you've got every touchpoint covered. Trade shows are big for solar — we handle branded giveaways, booth apparel, and lead-capture promo items.
            </p>
            <p>
              Common orders: hi-vis ANSI tees and hoodies, UPF long-sleeves, custom hard hats, embroidered sales-rep softshells, trade show giveaways, and branded safety vests.
            </p>
          </div>
          <div class="mt-7 flex flex-wrap gap-2">
            {['ANSI Class 2/3 Hi-Vis', 'UPF 30+ Long-Sleeves', 'Custom Hard Hats', 'Sales Rep Softshells', 'Trade Show Swag', 'Branded Trucker Hats', 'Safety Vests'].map((tag) => (
              <span class="inline-flex items-center rounded-full border border-gold-500/40 bg-gold-500/5 px-3 py-1 text-sm font-medium text-gold-400">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-8">
            <a href="/contact?industry=roofing-solar" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5 min-h-[44px]">
              Get a Quote for Roofing & Solar
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry 5: Landscaping -->
  <section id="industry-landscaping" class="scroll-mt-20 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-10 lg:grid-cols-[auto_1fr]">
        <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-gold-500/10">
          <svg class="h-8 w-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <div>
          <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Landscaping & Outdoor Services</span>
          <h2 class="mb-5 text-3xl font-bold tracking-tight sm:text-4xl">
            Sun-proof, dust-proof gear for crews that live outside.
          </h2>
          <div class="space-y-4 text-lg text-navy-200">
            <p>
              Landscaping, lawn care, and outdoor service crews are in the sun six days a week. The gear has to work harder than a standard uniform. We outfit Vegas landscaping companies with wide-brim sun protection hats (not baseball caps — actual sun hats with neck coverage), moisture-wicking performance tees and tanks for the mowing crews, and embroidered polos for sales reps, account managers, and the crew lead who shows up to estimate.
            </p>
            <p>
              Branded gear for landscaping isn't just about the crew — it's a rolling billboard. Every truck that drives through a neighborhood with branded team gear and a matching logo on the trailer wrap is a lead generator. We handle branded work gloves, logo water bottles and coolers for the crew (Vegas heat is a real safety issue and hydration gear with your logo is both useful and visible), embroidered quarter-zips for the office, and promo items for client gifting after a big install.
            </p>
            <p>
              Common orders: wide-brim sun hats, performance tees and tanks, embroidered sales polos, branded work gloves, logo water bottles and coolers, embroidered quarter-zips, and client gifting sets.
            </p>
          </div>
          <div class="mt-7 flex flex-wrap gap-2">
            {['Wide-Brim Sun Hats', 'Performance Tees & Tanks', 'Embroidered Polos', 'Branded Work Gloves', 'Logo Coolers', 'Crew Water Bottles', 'Quarter-Zips'].map((tag) => (
              <span class="inline-flex items-center rounded-full border border-gold-500/40 bg-gold-500/5 px-3 py-1 text-sm font-medium text-gold-400">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-8">
            <a href="/contact?industry=landscaping" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5 min-h-[44px]">
              Get a Quote for Landscaping
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry 6: Concrete & Masonry -->
  <section id="industry-concrete-masonry" class="scroll-mt-20 border-y border-navy-700/30 bg-navy-900/50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-10 lg:grid-cols-[auto_1fr]">
        <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-gold-500/10">
          <svg class="h-8 w-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
          </svg>
        </div>
        <div>
          <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Concrete & Masonry</span>
          <h2 class="mb-5 text-3xl font-bold tracking-tight sm:text-4xl">
            Heavyweight workwear built to take a beating.
          </h2>
