---
import BaseLayout from '@/layouts/BaseLayout.astro'

const steps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'Your Logo Goes On File',
    desc: 'Send us your logo once. We digitize it for embroidery and set up your print files. Free first digitizing. From then on, every order matches — no matter where it ships.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Your Team Orders Their Own Sizes',
    desc: 'Each person logs into your branded store, picks their own size, and submits. No spreadsheets, no size-guessing, no email chains for whoever runs ops.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships Direct — Anywhere In The US',
    desc: 'Gear ships to each person’s address or to a central office. Remote staff, multiple sites, and field crews all order the same way.',
  },
]

const cards = [
  {
    href: '/locations/nationwide/',
    tag: 'Nationwide',
    name: 'Nationwide Fulfillment',
    blurb:
      'Company stores and branded apparel for distributed teams. Logo on file, each person orders their own size, ships direct to any US address. Built the same way whether your team sits in one building or twenty cities.',
  },
  {
    href: '/service-areas/',
    tag: 'Las Vegas Valley',
    name: 'Local In Las Vegas',
    blurb:
      'We’re Las Vegas based with crews on the ground who know the job sites. Henderson, North Las Vegas, Summerlin, Spring Valley, and Boulder City — with local delivery across the valley.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: 'https://bighornthreads.com/locations/' },
  ],
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
  title="Where We Serve — Las Vegas Based, Nationwide Reach"
  description="Bighorn Threads is Las Vegas based and serves teams nationwide. Your logo on file, your people order their own sizes, ships direct to any address in the US. Local delivery across the Las Vegas valley."
  canonical="https://bighornthreads.com/locations/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- ════ HERO — concrete ════ -->
  <section class="bg-concrete pt-16 pb-20 sm:pt-16 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-600">Home</a>
        <span class="px-2 text-ash/60">/</span>
        <span class="text-gold-600">Locations</span>
      </nav>

      <div class="max-w-3xl">
        <p class="kicker mb-5 flex items-center gap-2.5">
          <span class="h-px w-8 bg-gold-500"></span>
          Where We Serve
        </p>
        <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
          Vegas roots.
          <span class="text-gold-600"> Nationwide reach.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ash sm:text-xl">
          We’re Las Vegas based, and we serve teams across the country. Put your logo on file once,
          let your people order their own sizes, and ship gear direct to any address in the US.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="/get-a-quote/" class="btn-primary text-base">
            Build my company store plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-charcoal transition-colors hover:text-gold-600">
            <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ HOW NATIONWIDE FULFILLMENT WORKS — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          How nationwide fulfillment <span class="text-gold-600">works.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Distance doesn’t change the model. Your logo lives on file, your team orders their own sizes,
          and gear ships direct to wherever each person is.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {steps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ════ LOCATIONS CARDS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">Two Ways To Work With Us</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Near or far, <span class="text-gold-600">same gear.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Local in Las Vegas, national everywhere else. Pick the path that fits your team.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {cards.map((c) => (
          <a href={c.href} class="group flex flex-col border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
            <span class="spec mb-3 inline-block self-start border border-hairline px-2 py-1 text-ash">{c.tag}</span>
            <h3 class="mb-3 font-heading text-xl font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">{c.name}</h3>
            <p class="mb-5 flex-1 text-sm leading-relaxed text-ash">{c.blurb}</p>
            <span class="inline-flex items-center gap-1.5 font-mono text-[11px] font-bold uppercase tracking-wider text-gold-600">
              View details
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ LOCAL IN LAS VEGAS CALLOUT — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="border-l-4 border-gold-500 bg-panel">
        <div class="border border-l-0 border-hairline p-8 sm:p-10">
          <p class="kicker mb-3">Local In Las Vegas</p>
          <h2 class="mb-3 font-heading text-2xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-3xl">
            On the ground across <span class="text-gold-600">the valley.</span>
          </h2>
          <p class="mb-6 max-w-2xl text-base leading-relaxed text-ash">
            Based in Las Vegas with crews who know the job sites — Henderson, North Las Vegas, Summerlin,
            Spring Valley, and Boulder City. Local delivery across the valley, plus everything the
            nationwide model offers.
          </p>
          <div class="flex flex-col items-start gap-3 sm:flex-row sm:gap-4">
            <a href="/service-areas/" class="btn-primary text-base">
              See Las Vegas service areas
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
            </a>
            <a href="tel:+17029048923" class="btn-secondary text-base">Call 702.904.8923</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ CTA BAND — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start gap-6 border border-hairline bg-charcoal p-8 sm:flex-row sm:items-center sm:justify-between sm:p-12">
        <div class="max-w-xl">
          <p class="kicker mb-3">Get Started</p>
          <h2 class="font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-4xl">
            Ready to outfit your team <span class="text-gold-400">wherever they are?</span>
          </h2>
          <p class="mt-4 text-base leading-relaxed text-navy-200">
            Free store setup. First digitizing on us. Your people order their own sizes and it ships
            direct. Tell us about your team and we’ll build your plan.
          </p>
        </div>
        <a href="/get-a-quote/" class="btn-primary shrink-0 text-base">
          Build my company store plan
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
