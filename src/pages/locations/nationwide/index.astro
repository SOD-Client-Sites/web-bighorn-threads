---
import BaseLayout from '@/layouts/BaseLayout.astro'

const steps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We Build Your Store — Free',
    desc: 'Your logo, your colors, your approved products. We set up your branded company store and hold your logo on file. First digitizing is on us, so reorders always match.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Each Person Orders Their Own Size',
    desc: 'Your team logs in, picks the right size, and submits. No spreadsheets, no size-guessing — the same flow for someone down the hall or across the country.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships Direct To Any US Address',
    desc: 'Gear ships to each person’s home or to a central office. Remote staff, multiple sites, and field crews all order the same way and ship direct.',
  },
]

const offerings = [
  {
    tag: 'Apparel',
    title: 'Embroidered Apparel',
    desc: 'Embroidered polos, button-ups, quarter-zips, and softshell jackets. Your logo digitized once and held on file for consistent reorders nationwide.',
  },
  {
    tag: 'Print',
    title: 'Screen Printing & DTF',
    desc: 'Screen-printed and direct-to-film tees, hoodies, and event apparel for distributed teams. Order what you need and ship it where it needs to go.',
  },
  {
    tag: 'Promo',
    title: 'Promo Products',
    desc: 'Drinkware, bags, and branded extras your team and clients actually use. Add them to your store and reorder in a click.',
  },
  {
    tag: 'Onboarding',
    title: 'New-Hire Kits',
    desc: 'A branded welcome kit ready to ship the day someone starts — sized by the new hire, not guessed by you. Ships to their address, anywhere in the country.',
  },
  {
    tag: 'Multi-Site',
    title: 'Multi-Location Teams',
    desc: 'One store, one logo on file, consistent gear across every office and region. No vendor sprawl, no brand drift between locations.',
  },
  {
    tag: 'Remote',
    title: 'Remote & Field Staff',
    desc: 'Remote employees and field crews each pick their size and ship to their own address. Everyone outfitted the same way, wherever they work.',
  },
]

const faqs = [
  {
    q: 'Do you serve teams outside Las Vegas?',
    a: 'Yes. We’re Las Vegas based, and the company-store model works the same anywhere. Your logo stays on file, each person orders their own size, and gear ships direct to any address in the US.',
  },
  {
    q: 'How does ordering work for a team spread across the country?',
    a: 'Everyone uses the same branded store. Each person logs in, picks their own size, and ships to their own address. Remote staff, multiple offices, and field crews all order the same way.',
  },
  {
    q: 'Can gear ship to each employee’s home?',
    a: 'Yes. Each person picks their size and ships to their home address. That makes it simple to outfit remote teams and distributed staff without routing everything through one office.',
  },
  {
    q: 'Can you keep our branding consistent across multiple locations?',
    a: 'Yes. Your logo, colors, and approved products live on file in one store. Every location orders from the same setup, so your brand looks the same in every city.',
  },
  {
    q: 'What does it cost to set up a company store?',
    a: 'Store setup is free, and your first logo digitizing is on us. You stock the products you want, your people order within the budget you set, and you can add or swap products any time.',
  },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: 'https://bighornthreads.com/locations/' },
    { '@type': 'ListItem', position: 3, name: 'Nationwide', item: 'https://bighornthreads.com/locations/nationwide/' },
  ],
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
  title="Company Stores & Branded Apparel, Shipped Nationwide"
  description="Branded apparel and company stores for teams across the US. Logo on file, each person orders their own size, ships direct to any address. Embroidery, screen printing, and promo for remote, multi-site, and distributed teams."
  canonical="https://bighornthreads.com/locations/nationwide/"
>
  <!-- ════ HERO — concrete ════ -->
  <section class="bg-concrete pt-16 pb-20 sm:pt-16 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-600">Home</a>
        <span class="px-2 text-ash/60">/</span>
        <a href="/locations/" class="hover:text-gold-600">Locations</a>
        <span class="px-2 text-ash/60">/</span>
        <span class="text-gold-600">Nationwide</span>
      </nav>

      <div class="max-w-3xl">
        <p class="kicker mb-5 flex items-center gap-2.5">
          <span class="h-px w-8 bg-gold-500"></span>
          Nationwide Fulfillment
        </p>
        <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
          Company stores &amp; branded apparel,
          <span class="text-gold-600"> shipped nationwide.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ash sm:text-xl">
          The company-store model works the same anywhere. Put your logo on file, let each person order
          their own size, and ship gear direct to any address in the US.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="/get-a-quote/" class="btn-primary text-base">
            Build my company store plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-charcoal transition-colors hover:text-gold-600">
            <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ HOW IT WORKS ANYWHERE — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          The same store, <span class="text-gold-600">anywhere your team is.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          One logo on file, one branded store, and gear that ships direct. Whether your people sit in
          one building or twenty cities, they order the same way.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {steps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-8">
        <a href="/get-a-quote/" class="btn-secondary text-sm">
          Build my company store plan
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ WHAT WE DO FOR DISTRIBUTED TEAMS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">For Distributed Teams</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Built for teams that <span class="text-gold-600">aren’t in one place.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Embroidery, screen printing, and promo for remote staff, multi-site companies, and field
          crews. Stock as much or as little as you want and swap products any time.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {offerings.map((item) => (
          <div class="flex flex-col border border-hairline bg-panel p-6">
            <span class="spec mb-3 inline-block self-start border border-hairline px-2 py-1 text-ash">{item.tag}</span>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ FAQ — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <p class="kicker mb-3">FAQ</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Nationwide fulfillment, <span class="text-gold-600">answered.</span>
        </h2>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CTA BAND — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start gap-6 border border-hairline bg-charcoal p-8 sm:flex-row sm:items-center sm:justify-between sm:p-12">
        <div class="max-w-xl">
          <p class="kicker mb-3">Get Started</p>
          <h2 class="font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-4xl">
            Outfit your team, <span class="text-gold-400">coast to coast.</span>
          </h2>
          <p class="mt-4 text-base leading-relaxed text-navy-200">
            Free store setup. First digitizing on us. Each person orders their own size and it ships
            direct. Tell us about your team and we’ll build your plan.
          </p>
        </div>
        <a href="/get-a-quote/" class="btn-primary shrink-0 text-base">
          Build my company store plan
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
