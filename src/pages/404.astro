---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
 title="Page Not Found"
 description="That page doesn't exist on Bighorn Threads. Head back to the homepage or get a quote for branded apparel for your Las Vegas crew."
 noindex={true}
>
 <section class="flex min-h-[70vh] items-center justify-center bg-concrete px-4 py-24 sm:py-32">
 <div class="mx-auto max-w-2xl text-center">
 <p class="kicker mb-4 justify-center">Error 404</p>
 <h1 class="mb-6 font-heading text-5xl font-extrabold uppercase leading-[1.0] tracking-tight text-charcoal sm:text-6xl lg:text-7xl">
 This page took a <span class="text-gold-600">smoke break.</span>
 </h1>
 <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-ash sm:text-xl">
 The link's broken, the URL's mistyped, or the page never existed. Either way, let's get you back to outfitting your crew.
 </p>

 <div class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
 <a href="/" class="btn-primary text-base">Back to Home</a>
 <a href="/contact/" class="btn-secondary text-base">Get a Quote</a>
 </div>

 <div class="mt-16 border-t border-hairline pt-10">
 <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-ash">Or jump to</p>
 <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-ash">
 <li><a href="/services/" class="transition-colors hover:text-gold-600">Services</a></li>
 <li><a href="/industries/" class="transition-colors hover:text-gold-600">Industries</a></li>
 <li><a href="/company-stores/" class="transition-colors hover:text-gold-600">Company Stores</a></li>
 <li><a href="/blog/" class="transition-colors hover:text-gold-600">Field Notes</a></li>
 <li><a href="/about/" class="transition-colors hover:text-gold-600">About</a></li>
 </ul>
 </div>
 </div>
 </section>
</BaseLayout>
