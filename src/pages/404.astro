---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Page Not Found"
  description="That page doesn't exist on Bighorn Threads. Head back to the homepage or get a quote for branded apparel for your Las Vegas crew."
  noindex={true}
>
  <section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden bg-navy-950 px-4 py-24 sm:py-32">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_30%,_rgba(193,155,61,0.06),_transparent)]"></div>

    <div class="relative mx-auto max-w-2xl text-center">
      <p class="mb-4 font-mono text-sm font-bold uppercase tracking-[0.3em] text-gold-500">Error 404</p>
      <h1 class="mb-6 font-heading text-5xl font-bold leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl">
        This page took a <span class="text-gold-500">smoke break.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        The link's broken, the URL's mistyped, or the page never existed. Either way, let's get you back to outfitting your crew.
      </p>

      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <a
          href="/"
          class="inline-flex min-h-[48px] items-center justify-center rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20"
        >
          Back to Home
        </a>
        <a
          href="/contact/"
          class="inline-flex min-h-[48px] items-center justify-center rounded-lg border border-gray-600 px-7 py-3 text-base font-bold text-white transition-all hover:border-gold-500 hover:text-gold-500"
        >
          Get a Quote
        </a>
      </div>

      <div class="mt-16 border-t border-navy-800 pt-10">
        <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-gray-500">Or jump to</p>
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-300">
          <li><a href="/services/" class="transition-colors hover:text-gold-500">Services</a></li>
          <li><a href="/industries/" class="transition-colors hover:text-gold-500">Industries</a></li>
          <li><a href="/company-stores/" class="transition-colors hover:text-gold-500">Company Stores</a></li>
          <li><a href="/blog/" class="transition-colors hover:text-gold-500">Field Notes</a></li>
          <li><a href="/about/" class="transition-colors hover:text-gold-500">About</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
