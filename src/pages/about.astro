---
import { Image } from 'astro:assets'
import BaseLayout from '@/layouts/BaseLayout.astro'
import foremanCloseup from '@/assets/generated/foreman-closeup.jpg'
import productStack from '@/assets/generated/product-stack.jpg'
import workwearFlatlay from '@/assets/generated/workwear-flatlay.jpg'

const values = [
 {
 title: "If it doesn't survive the job site, we don't sell it",
 body: "We've seen the tees that fall apart after two washes and the hi-vis vests where the print peels off in a week. That junk doesn't leave our production floor. Every garment we offer has been worn, washed, and scuffed up in real Nevada conditions before it earns a spot in our catalog.",
 icon: 'shield',
 },
 {
 title: 'A phone call beats a contact form',
 body: "Promo is a relationship business. You want to reach a human who knows your account, your artwork, and your rush history — not a ticket queue. Our number rings a real person at a real desk in Las Vegas. Pick up the phone. We'll pick up ours.",
 icon: 'phone',
 },
 {
 title: 'Your deadline is our deadline',
 body: "Job walks don't wait. Ribbon cuttings don't wait. Neither do new hires showing up Monday. When you give us a date, we treat it like a pour schedule — hit or miss, no in-between. If we can't make it, we'll tell you before you commit.",
 icon: 'clock',
 },
 {
 title: "We'd rather be the Vegas local than the cheapest online option",
 body: "There's always a website out there a few bucks cheaper. Go use them once — you'll understand why we're still here. Local means pickup, local means proofs in hand, local means we drive the order out to your office if the courier drops the ball.",
 icon: 'pin',
 },
]

const comparison = [
 { category: 'Who you talk to', online: 'A chatbot and a ticket queue', bighorn: 'A local rep who knows your account by name' },
 { category: 'Customization', online: 'Pre-built templates you drop a logo into', bighorn: 'Dedicated art team that builds your design from scratch' },
 { category: 'Proofing', online: 'No proof — you approve a thumbnail', bighorn: 'Free digital mockups before anything hits the press' },
 { category: 'Rush orders', online: '"Not guaranteed" or surprise upcharges', bighorn: 'Quoted up front — you know the cost and the date before you commit' },
 { category: 'Delivery', online: 'Ships from a warehouse three states away', bighorn: 'Local Las Vegas delivery to your office, job trailer, or crew addresses' },
 { category: 'Industry knowledge', online: 'Generic — sells to everyone from dentists to daycares', bighorn: 'Deep on the details — from hi-vis classes and FR ratings to brand standards for client-facing teams' },
 { category: 'Pricing', online: 'Setup fees, color fees, art fees hidden at checkout', bighorn: 'Transparent quote — what we quote is what you pay' },
 { category: 'Long-term fit', online: 'Transactional — one order, then forgotten', bighorn: 'Ongoing partnership — company stores, reorders, new hires' },
]

const founder = {
 initials: 'SD',
 name: 'Steven Dodson',
 role: 'Founder',
 bio: "Built VP Promos in Las Vegas from a one-desk operation into a working promotional apparel shop. Bighorn Threads is the branded-apparel arm — same shop, same presses, same hands-on experience, building programs for teams of every kind across the country.",
 quote: "I still pick up the phone myself. If your team needs gear, you're talking to me.",
 phone: '702.904.8923',
}

const serviceAreas = ['Las Vegas', 'Henderson', 'North Las Vegas', 'Boulder City', 'Pahrump', 'Summerlin', 'Spring Valley', 'Enterprise']

const jsonLd = {
 '@context': 'https://schema.org',
 '@graph': [
 {
 '@type': 'AboutPage',
 '@id': 'https://bighornthreads.com/about#aboutpage',
 url: 'https://bighornthreads.com/about',
 name: 'About Bighorn Threads — Las Vegas Branded Apparel & Company Stores',
 description: "Bighorn Threads is a DBA of VP Promos — a Las Vegas promotional apparel shop specialized for the construction vertical. Screen printing, embroidery, branded workwear, and company stores.",
 isPartOf: { '@id': 'https://bighornthreads.com/#website' },
 about: { '@id': 'https://bighornthreads.com/#organization' },
 },
 {
 '@type': 'Organization',
 '@id': 'https://bighornthreads.com/#organization',
 name: 'Bighorn Threads',
 alternateName: 'VP Promos',
 founder: { '@id': 'https://bighornthreads.com/#founder' },
 url: 'https://bighornthreads.com',
 logo: 'https://bighornthreads.com/images/logo.png',
 description: "Las Vegas branded apparel and promotional products for the construction industry. Screen printing, embroidery, hi-vis gear, and company stores built for crews that actually work for a living.",
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Boulder City' },
 { '@type': 'City', name: 'Pahrump' },
 ],
 address: {
 '@type': 'PostalAddress',
 streetAddress: '9205 W. Russell Rd Ste 305',
 addressLocality: 'Las Vegas',
 addressRegion: 'NV',
 postalCode: '89149',
 addressCountry: 'US',
 },
 knowsAbout: [
 'Screen printing',
 'Embroidery',
 'Branded apparel',
 'Hi-vis workwear',
 'Flame-resistant clothing',
 'Company stores',
 'Promotional products',
 'Construction apparel',
 ],
 },
 {
 '@type': 'Person',
 '@id': 'https://bighornthreads.com/#founder',
 name: 'Steven Dodson',
 jobTitle: 'Founder',
 worksFor: { '@id': 'https://bighornthreads.com/#organization' },
 description: "Founder of Bighorn Threads and its parent VP Promos. Built VP Promos in Las Vegas from a one-desk operation into a working promotional apparel shop; Bighorn Threads is its construction-focused arm, run hands-on by Steve himself.",
 knowsAbout: [
 'Screen printing for construction trades',
 'Embroidery for workwear',
 'ANSI/ISEA 107 hi-vis apparel',
 'NFPA 70E flame-resistant clothing',
 'Branded company stores for contractors',
 ],
 telephone: '+17029048923',
 },
 ],
}
---

<BaseLayout
 title="About Bighorn Threads — Las Vegas Branded Apparel & Company Stores"
 description="How a Las Vegas promo shop became the go-to for Vegas construction crews. Our story, our values, how we're different from online catalogs, and the team behind Bighorn Threads."
>
 <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <Image
 src={foremanCloseup}
 alt=""
 aria-hidden="true"
 widths={[768, 1280, 1920]}
 sizes="100vw"
 formats={['avif', 'webp']}
 fallbackFormat="jpg"
 quality={72}
 class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
 loading="eager"
 fetchpriority="high"
 decoding="async"
 />
 <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-950 via-navy-950/88 to-navy-950/45"></div>
 <div class="mx-auto max-w-7xl px-4 pb-20 pt-32 sm:px-6 sm:pt-44 lg:px-8 lg:pb-28">
 <p class="kicker mb-5 flex items-center gap-2.5">
 <span class="h-px w-8 bg-gold-500"></span>
 Our Story
 </p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 We Build Branded Programs for <span class="text-gold-400">Teams of Every Kind</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 Bighorn Threads is the branded-apparel arm of VP Promos — Las Vegas based, serving teams nationwide. Screen printing, embroidery, and company stores for crews, offices, and field teams alike. Construction is where we cut our teeth; it's one vertical we serve, not the whole story.
 </p>
 <div class="mt-8 flex flex-wrap items-center gap-2">
 {['Las Vegas based', 'Serving nationwide', 'A DBA of VP Promos'].map((tag) => (
 <span class="spec inline-flex items-center gap-2 border border-navy-700 px-2.5 py-1.5 text-navy-200">
 <span class="h-1.5 w-1.5 bg-gold-500"></span>
 {tag}
 </span>
 ))}
 </div>
 </div>
 </section>

 <!-- Origin Story — concrete -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
 <div class="lg:col-span-7">
 <p class="kicker mb-3">How we got here</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-4xl lg:text-5xl">
 From general promo to <span class="text-gold-600">programs that hold up</span>
 </h2>
 <div class="space-y-6 text-lg leading-relaxed text-charcoal">
 <p>
 VP Promos opened in Las Vegas doing what most promo shops do — branded pens for real estate offices, logo polos for insurance brokers, tradeshow giveaways for anybody with a booth to fill. We printed for dentists, daycares, gyms, and half the HOAs in Henderson. Good work, steady work, never the same thing twice.
 </p>
 <p>
 Then the construction accounts started stacking up. A framing crew here, a concrete contractor there, an electrical shop that needed hi-vis for a Strip project. And something got obvious fast: these weren't the same customers as everyone else. They needed gear that survived 115-degree summers and 30-degree night pours. They needed ink that didn't peel after the first wash with a month of drywall dust in it. They needed rush turns when a new hire showed up Monday and OSHA said "PPE first day." And they needed somebody who could tell Class 2 from Class 3 without Googling it.
 </p>
 <p>
 Most online promo catalogs couldn't do that. Heck, most local shops couldn't either — they'd sell a construction company the same 4.2-ounce soft cotton tee they sold to a yoga studio, and then act surprised when it came back destroyed. We started keeping a different inventory for our construction clients. Then a different workflow. Then a different quoting process that accounted for rush-hire timelines and multi-crew sizing grids.
 </p>
 <p>
 That trades work taught us how to build a branded program that actually holds up — durable gear, ink that survives the wash, sizing grids for whole teams, rush turns when new hires start Monday. So we built Bighorn Threads: same shop, same team, same presses, that same standard applied to every team we outfit. Construction is one vertical where it shows — hi-vis that meets ANSI, FR-rated layers that meet NFPA 2112, crew tees that don't look like corporate golf shirts — but the same care goes into a field crew, an office staff, or a company store full of polos.
 </p>
 <p>
 We cover full uniforms for <a href="/industries/electrical-contractors-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-600">electrical</a>, <a href="/industries/plumbing-hvac-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-600">plumbing/HVAC</a>, <a href="/industries/data-center-contractors-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-600">data center</a>, and other Las Vegas construction crews. See <a href="/blog/ppe-branded-workwear-regulations-construction-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-600">PPE regulations</a> for our compliance approach.
 </p>
 </div>
 </div>
 <div class="lg:col-span-5">
 <div class="sticky top-24 space-y-6">
 <div class="border border-hairline bg-panel p-2">
 <Image
 src={workwearFlatlay}
 alt="Branded apparel laid out — embroidered polos, tees, and caps ready to ship"
 loading="lazy"
 class="h-auto w-full"
 />
 </div>
 <blockquote class="border-l-4 border-gold-500 bg-panel p-6 pl-8">
 <p class="font-heading text-lg italic leading-relaxed text-charcoal">
 "The shirt that works for a software company at a lunch-and-learn is not the shirt that works for a concrete crew in July. We stopped pretending it was."
 </p>
 <footer class="mt-4 font-mono text-xs font-bold uppercase tracking-[0.15em] text-gold-600">
 — Steven Dodson, Founder
 </footer>
 </blockquote>
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- Values — paper -->
 <section class="border-y border-hairline bg-paper py-16 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-14 max-w-3xl">
 <p class="kicker mb-3">What we believe</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl lg:text-5xl">
 Four rules we don't break
 </h2>
 <p class="mt-4 text-lg text-ash">
 These aren't wall posters. They're how we pick inventory, quote jobs, hire staff, and fire the accounts that don't fit. If you've worked with a promo shop that didn't operate this way — yeah, that's why.
 </p>
 </div>

 <div class="grid gap-6 sm:grid-cols-2">
 {values.map((v) => (
 <article class="border border-hairline bg-panel p-8 transition-colors hover:border-gold-500">
 <div class="mb-5 flex h-14 w-14 items-center justify-center bg-gold-500/15 text-gold-700">
 {v.icon === 'shield' && (
 <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
 </svg>
 )}
 {v.icon === 'phone' && (
 <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
 </svg>
 )}
 {v.icon === 'clock' && (
 <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
 </svg>
 )}
 {v.icon === 'pin' && (
 <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
 <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
 </svg>
 )}
 </div>
 <h3 class="mb-3 font-heading text-xl font-bold uppercase tracking-tight text-charcoal">{v.title}</h3>
 <p class="leading-relaxed text-ash">{v.body}</p>
 </article>
 ))}
 </div>
 </div>
 </section>

 <!-- Comparison — concrete -->
 <section class="bg-concrete py-24 sm:py-32">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-14 max-w-3xl">
 <p class="kicker mb-3">How we're different</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl lg:text-5xl">
 Online promo catalogs vs. <span class="text-gold-600">Bighorn Threads</span>
 </h2>
 <p class="mt-4 text-lg text-ash">
 We're not the cheapest option and we never will be. Here's what you get instead.
 </p>
 </div>

 <div class="overflow-hidden border border-hairline">
 <!-- Header row -->
 <div class="grid grid-cols-1 gap-px bg-hairline md:grid-cols-3">
 <div class="bg-paper p-5 md:p-6">
 <div class="spec text-ash">Category</div>
 </div>
 <div class="bg-paper p-5 md:p-6">
 <div class="flex items-center gap-2">
 <svg class="h-5 w-5 text-ash" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
 </svg>
 <div class="spec text-ash">Online promo catalogs</div>
 </div>
 </div>
 <div class="bg-gold-500/15 p-5 md:p-6">
 <div class="flex items-center gap-2">
 <svg class="h-5 w-5 text-gold-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
 </svg>
 <div class="spec text-gold-700">Bighorn Threads</div>
 </div>
 </div>
 </div>
 <!-- Body rows -->
 {comparison.map((row) => (
 <div class="grid grid-cols-1 gap-px bg-hairline md:grid-cols-3">
 <div class="bg-paper p-5 md:p-6">
 <div class="font-heading text-sm font-bold uppercase tracking-tight text-charcoal">{row.category}</div>
 </div>
 <div class="bg-panel p-5 md:p-6">
 <div class="flex items-start gap-2">
 <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-ash" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
 <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
 </svg>
 <div class="text-sm text-ash">{row.online}</div>
 </div>
 </div>
 <div class="bg-panel p-5 md:p-6">
 <div class="flex items-start gap-2">
 <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
 </svg>
 <div class="text-sm text-charcoal">{row.bighorn}</div>
 </div>
 </div>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Founder — paper -->
 <section class="border-y border-hairline bg-paper py-24 sm:py-32">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-14 max-w-3xl">
 <p class="kicker mb-3">Meet the founder</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl lg:text-5xl">
 The guy who <span class="text-gold-600">picks up the phone</span>
 </h2>
 <p class="mt-4 text-lg text-ash">
 Bighorn Threads isn't a call center and it isn't a template site. It's Steve, still running the shop.
 </p>
 </div>

 <article class="border border-hairline bg-panel">
 <div class="grid gap-0 lg:grid-cols-[minmax(280px,_380px)_1fr]">
 <!-- Avatar column -->
 <div class="flex flex-col items-center justify-center gap-5 border-b border-hairline bg-concrete p-10 lg:border-b-0 lg:border-r lg:p-14">
 <div class="h-48 w-48 overflow-hidden border border-hairline sm:h-56 sm:w-56">
 <img
 src="/images/generated/founder-steve.jpg"
 alt="Steven Dodson, founder of Bighorn Threads."
 width="448"
 height="448"
 loading="eager"
 class="h-full w-full object-cover"
 />
 </div>
 <div class="text-center">
 <div class="kicker">{founder.role}</div>
 <h3 class="mt-1 font-heading text-2xl font-bold uppercase tracking-tight text-charcoal">{founder.name}</h3>
 <div class="mt-2 font-mono text-xs text-ash">Las Vegas, NV</div>
 </div>
 </div>

 <!-- Bio column -->
 <div class="flex flex-col justify-center gap-6 p-10 lg:p-14">
 <blockquote class="font-heading text-xl leading-relaxed text-charcoal sm:text-2xl">
 <svg class="mb-4 h-8 w-8 text-gold-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
 <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
 </svg>
 {founder.quote}
 </blockquote>
 <p class="leading-relaxed text-ash">{founder.bio}</p>
 <div class="flex flex-wrap items-center gap-4 pt-2">
 <a href="tel:+17029048923" class="inline-flex min-h-[44px] items-center gap-2 border border-charcoal px-5 py-2.5 font-mono text-sm font-medium tracking-wide text-charcoal transition-colors hover:border-gold-500 hover:text-gold-700">
 <svg class="h-4 w-4 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
 <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
 </svg>
 <span>{founder.phone}</span>
 </a>
 <span class="text-sm text-ash">Direct line — no voicemail loop.</span>
 </div>
 </div>
 </div>
 </article>

 <!-- Production partners photo strip -->
 <div class="mt-16 border border-hairline bg-panel p-2">
 <Image
 src={workwearFlatlay}
 alt="Branded workwear and apparel produced in the Bighorn Threads shop"
 loading="lazy"
 class="h-[280px] w-full object-cover sm:h-[320px]"
 />
 </div>
 </div>
 </section>

 <!-- Location — concrete -->
 <section class="bg-concrete py-24 sm:py-32">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 lg:items-center">
 <div>
 <p class="kicker mb-3">Based in Las Vegas</p>
 <h2 class="mb-6 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl lg:text-5xl">
 Vegas roots. <span class="text-gold-600">Nationwide reach.</span>
 </h2>
 <p class="mb-6 text-lg leading-relaxed text-ash">
 We produce locally in Las Vegas — fast delivery to any Vegas office or job trailer, and a local team you can meet for coffee to walk through artwork. For teams outside the valley, we ship direct nationwide.
 </p>
 <p class="mb-8 text-lg leading-relaxed text-ash">
 We regularly deliver to job sites all over the Vegas metro — from Strip high-rises to Henderson masterplans to out-of-town projects in Pahrump and Boulder City. If your crew's working it, we're probably already shipping there.
 </p>

 <div class="mb-8 flex items-start gap-4 border border-hairline bg-panel p-6">
 <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center bg-gold-500/15 text-gold-700">
 <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
 <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
