---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SmsConsentFields from '@/components/SmsConsentFields.astro'

const title = 'Get a Quote | Bighorn Threads — Custom Apparel & Promo, Las Vegas'
const description =
  'Get a quote on custom screen printing, embroidery, company stores, and promo products. Las Vegas based, serving crews and brands nationwide. Tell us what you need — a real human replies.'

const whatWeDo = [
  {
    title: 'Screen Printing',
    desc: 'Bold, durable prints for tees, hoodies, and workwear. Built to survive job sites, wash after wash.',
  },
  {
    title: 'Embroidery',
    desc: 'Stitched logos on polos, caps, jackets, and softshells. Clean, premium, and reorder-ready.',
  },
  {
    title: 'Company Stores',
    desc: 'A branded online store your team orders from direct. Your logo on file, sizes handled by them, not you.',
  },
  {
    title: 'Promo Products',
    desc: 'Drinkware, bags, hard hats, and giveaways that put your brand in people’s hands and keep it there.',
  },
]

const whyUs = [
  {
    title: 'A Real Human Replies',
    desc: 'No chatbot, no phone tree. You talk to the shop. We read your request, flag the gaps, and answer straight.',
  },
  {
    title: 'Built for Every Team',
    desc: 'We outfit teams of every kind — Las Vegas based, shipping to crews, offices, and brands across the country.',
  },
  {
    title: 'Free Digital Mockups',
    desc: 'You see exactly what you’re getting before a press ever turns on. Approve artwork, colors, and placement in writing.',
  },
  {
    title: 'No Mystery Line Items',
    desc: 'Itemized pricing — garments, decoration, artwork, and shipping spelled out. If you want options, we give you options.',
  },
]

const services = [
  'Screen Printing',
  'Embroidery',
  'Company Store',
  'Promo Products',
  'Full Crew Outfit',
  'Not sure — help me figure it out',
]

const decorationMethods = [
  'Screen Printing',
  'Embroidery',
  'DTF Transfers',
  'Heat Transfer / Vinyl',
  'Patches',
  'Not sure — recommend one',
]

const timelines = [
  'ASAP — I need it yesterday',
  'Within 1 week',
  'Within 2 weeks',
  '2 to 4 weeks out',
  '1 month+',
  'Just gathering quotes',
]

const steps = [
  { n: '01', title: 'We review your needs', time: 'Quick reply', body: 'A real human on our team — not a chatbot — reads your request, flags any gaps, and pulls pricing on the specific blanks and decoration method that fit your job.' },
  { n: '02', title: 'You get a quote', time: 'Itemized', body: 'Pricing with garment choices, decoration cost, artwork, turnaround, and shipping. No mystery line items. If you want options, we give you options.' },
  { n: '03', title: 'We finalize artwork', time: 'Free mockups', body: 'Our art team cleans up your logo, builds digital mockups, and sends proofs for written approval. Need vectorization? Flat fee, no surprise invoice.' },
  { n: '04', title: 'Production starts', time: 'You get tracking', body: 'Screens burned, needles threaded, presses running. You get production updates and a delivery ETA. Finished goods ship or deliver inside the Vegas Valley.' },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Get a Quote', item: 'https://bighornthreads.com/get-a-quote/' },
  ],
}

const inputClass =
  'mt-2 block w-full min-h-[44px] rounded border border-hairline bg-panel px-4 py-3 text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25'
---

<BaseLayout title={title} description={description} canonical="https://bighornthreads.com/get-a-quote/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- ════ QUOTE FORM — concrete ════ -->
  <section id="quote-form" class="scroll-mt-20 bg-concrete pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 max-w-3xl">
        <p class="kicker mb-3">Get a Quote</p>
        <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl lg:text-6xl">
          Tell us what you need. <span class="text-gold-600">We'll handle the rest.</span>
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ash">
          Custom apparel, embroidery, company stores, and promo — quoted by a real human. Las Vegas
          based, serving crews and brands nationwide. No pushy sales calls, no BS — just straight answers.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-5 lg:gap-10">
        <!-- FORM -->
        <div class="lg:col-span-3">
          <form id="quoteForm" action="/api/contact" method="POST" class="relative border border-hairline bg-paper p-6 sm:p-8 lg:p-10" novalidate>
            <div class="absolute -left-[9999px]" aria-hidden="true">
              <label for="bh_hp_field">Leave blank</label>
              <input type="text" name="bh_hp_field" id="bh_hp_field" tabindex="-1" autocomplete="off" />
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-semibold text-charcoal">Name <span class="text-gold-600">*</span></label>
                <input type="text" name="name" id="name" required autocomplete="name" class={inputClass} placeholder="Jordan Reyes" />
              </div>
              <div>
                <label for="company" class="block text-sm font-semibold text-charcoal">Company <span class="text-gold-600">*</span></label>
                <input type="text" name="company" id="company" required autocomplete="organization" class={inputClass} placeholder="Reyes Concrete & Grading" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-charcoal">Email <span class="text-gold-600">*</span></label>
                <input type="email" name="email" id="email" required autocomplete="email" class={inputClass} placeholder="jordan@reyesgrading.com" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-charcoal">Phone</label>
                <input type="tel" name="phone" id="phone" autocomplete="tel" class={inputClass} placeholder="(702) 555-0187" />
              </div>
              <div class="sm:col-span-2">
                <label for="service" class="block text-sm font-semibold text-charcoal">What do you need?</label>
                <select name="service" id="service" class={inputClass}>
                  <option value="">Pick one.</option>
                  {services.map((s) => <option value={s}>{s}</option>)}
                </select>
              </div>
              <div>
                <label for="garments" class="block text-sm font-semibold text-charcoal">Garments / items</label>
                <input type="text" name="garments" id="garments" class={inputClass} placeholder="e.g. tees, hoodies, hats, hi-vis" />
              </div>
              <div>
                <label for="decorationMethod" class="block text-sm font-semibold text-charcoal">Decoration method</label>
                <select name="decorationMethod" id="decorationMethod" class={inputClass}>
                  <option value="">Pick one (or let us recommend).</option>
                  {decorationMethods.map((d) => <option value={d}>{d}</option>)}
                </select>
              </div>
              <div>
                <label for="quantity" class="block text-sm font-semibold text-charcoal">Quantity estimate</label>
                <input type="text" name="quantity" id="quantity" inputmode="numeric" class={`${inputClass} font-mono`} placeholder="e.g. 48 shirts + 24 hats" />
              </div>
              <div>
                <label for="timeline" class="block text-sm font-semibold text-charcoal">Deadline / timeline</label>
                <select name="timeline" id="timeline" class={inputClass}>
                  <option value="">When do you need it?</option>
                  {timelines.map((t) => <option value={t}>{t}</option>)}
                </select>
              </div>
              <div class="sm:col-span-2">
                <label for="message" class="block text-sm font-semibold text-charcoal">Details</label>
                <textarea name="message" id="message" rows="5" class={inputClass} placeholder="Tell us about your crew, the garments you want, logo placement, deadlines, anything relevant."></textarea>
              </div>
            </div>

            <SmsConsentFields />

            <div class="cf-turnstile mt-8" data-sitekey="0x4AAAAAADW_K97ZyhlAHC4I" data-theme="light"></div>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-ash">A real human replies fast — usually same business day.</p>
              <button type="submit" class="btn-primary justify-center text-base disabled:opacity-60">Send My Request</button>
            </div>

            <div id="formStatus" role="status" aria-live="polite" aria-atomic="true" class="mt-6 text-sm"></div>
          </form>
        </div>

        <!-- WHAT WE DO -->
        <aside class="space-y-5 lg:col-span-2">
          <div class="border border-hairline bg-panel p-7">
            <div class="kicker">What We Do</div>
            <p class="mt-2 text-sm leading-relaxed text-ash">
              One shop for everything your brand wears and hands out. Tell us what you need and we'll point
              you at the right method.
            </p>
            <ul class="mt-5 space-y-4">
              {whatWeDo.map((item) => (
                <li>
                  <h3 class="font-heading text-base font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-ash">{item.desc}</p>
                </li>
              ))}
            </ul>
          </div>

          <a href="tel:+17029048923" class="group block border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center bg-gold-500/15 text-gold-700" aria-hidden="true">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.5a1 1 0 01-.5 1.21l-1.58.79a11 11 0 005.6 5.6l.79-1.58a1 1 0 011.21-.5l4.5 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.82 21 3 14.18 3 6V5z" /></svg>
              </div>
              <div class="min-w-0">
                <div class="kicker">Prefer to Call?</div>
                <div class="mt-1 font-mono text-xl font-bold text-charcoal sm:text-2xl">702.904.8923</div>
                <p class="mt-1 text-sm text-ash">Ring the shop. A human answers.</p>
              </div>
            </div>
          </a>
        </aside>
      </div>
    </div>
  </section>

  <!-- ════ WHY US — paper ════ -->
  <section id="why-us" class="scroll-mt-20 border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="kicker mb-3">Why Bighorn</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Why crews send us <span class="text-gold-600">the order.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          We keep it simple: real answers, work built to last, and a quote you can actually read.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {whyUs.map((item) => (
          <div class="border border-hairline bg-panel p-7">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ GET PRICING / PROCESS — concrete ════ -->
  <section id="get-pricing" class="scroll-mt-20 bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="kicker mb-3">Get Pricing</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          From request to <span class="text-gold-600">finished gear.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          From the second you hit send, here is exactly what we do. No mystery. No weeks of radio silence.
        </p>
      </div>

      <ol class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {steps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-500">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.time}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.body}</p>
          </li>
        ))}
      </ol>

      <div class="mt-10">
        <a href="#quote-form" class="btn-primary text-base">Start My Quote</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('quoteForm')
      const status = document.getElementById('formStatus')
      if (!form || !status) return

      const setStatus = (msg, tone) => {
        status.textContent = msg
        status.className =
          'mt-6 text-sm ' +
          (tone === 'error' ? 'text-red-600' : tone === 'success' ? 'text-gold-700' : 'text-ash')
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault()

        const hp = form.querySelector('input[name="bh_hp_field"]')
        if (hp && hp.value) {
          setStatus('Thanks — we got it.', 'success')
          form.reset()
          return
        }

        const required = ['name', 'company', 'email']
        for (const field of required) {
          const el = form.elements.namedItem(field)
          if (!el || !el.value.trim()) {
            setStatus('Please fill in your name, company, and email so we can reply.', 'error')
            if (el && typeof el.focus === 'function') el.focus()
            return
          }
        }

        const email = form.elements.namedItem('email')
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
          setStatus('That email does not look right — mind double-checking?', 'error')
          email.focus()
          return
        }

        setStatus('Sending your request.', 'info')
        const submitBtn = form.querySelector('button[type="submit"]')
        if (submitBtn) submitBtn.disabled = true

        try {
          const fd = new FormData(form)
          fd.append('consentUrl', window.location.href)

          // /api/contact reads `message` but not `garments`/`decorationMethod`,
          // so fold those into the message text so nothing is dropped on the way to GHL.
          const garments = (fd.get('garments') || '').toString().trim()
          const decoration = (fd.get('decorationMethod') || '').toString().trim()
          const extras = []
          if (garments) extras.push('Garments / items: ' + garments)
          if (decoration) extras.push('Decoration method: ' + decoration)
          if (extras.length) {
            const existing = (fd.get('message') || '').toString().trim()
            fd.set('message', [existing, extras.join('\n')].filter(Boolean).join('\n\n'))
          }
          const res = await fetch(form.action, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: fd,
          })
          if (res.ok) {
            if (typeof gtag === 'function') {
              gtag('event', 'generate_lead', { form: 'contact_quote', page_path: window.location.pathname })
            }
            setStatus('Got it. A real human will reply soon with a full quote.', 'success')
            form.reset()
          } else {
            throw new Error('Request failed')
          }
        } catch (err) {
          setStatus('Something broke on our end. Call us at 702.904.8923 or email info@bighornthreads.com and we will handle it.', 'error')
        } finally {
          if (submitBtn) submitBtn.disabled = false
        }
      })
    })()
  </script>
</BaseLayout>
