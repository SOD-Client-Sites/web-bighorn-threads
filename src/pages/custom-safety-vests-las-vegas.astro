---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Safety Vests in Las Vegas | ANSI 107 Class 2 & Class 3 Branded Hi-Vis — Bighorn Threads',
 description:
 'Custom hi-vis safety vests for Las Vegas crews — ANSI/ISEA 107 Class 2 and Class 3, branded within the 72 sq inch decoration limit so the certification stays valid. ML Kishigo, PIP, Radians, Pyramex. Get a quote.',
 hero: '/images/generated/service-screen-printing.jpg',
 url: 'https://bighornthreads.com/custom-safety-vests-las-vegas/',
}

const stack = [
 { label: 'The vest', body: 'ANSI/ISEA 107-certified hi-vis vests from ML Kishigo, PIP, Radians, and Pyramex. Class 2 for general construction and surveying. Class 3 for highway and night work.' },
 { label: 'The branding', body: 'Embroidered or screen-printed company logo on the chest and back yoke, within the 72 sq inch non-retroreflective decoration limit. Certification stays valid.' },
 { label: 'Color options', body: 'Fluorescent yellow-green (default — highest contrast against most backgrounds) and fluorescent orange (utility, oil/gas, hunting-adjacent visibility programs). Both Class 2 and 3 available in each.' },
 { label: 'Sizing', body: 'S–5XL on most blanks. Mesh and solid fabric options. Multi-pocket "surveyor" cuts for trades that carry tools, badges, or radios.' },
]

const classes = [
 { row: 'Class 2', meaning: '775 sq in fluorescent base + retroreflective tape', use: 'General construction, surveying, school crossing, parking, daytime traffic-adjacent work' },
 { row: 'Class 3', meaning: '1,240 sq in fluorescent base + sleeves required', use: 'Highway work, night-shift, low-visibility conditions, traffic-exposed roles' },
 { row: 'Class E', meaning: 'Pants/shorts only — pairs with Class 2 or 3 top', use: 'Worn over the vest for full ANSI 107 compliance on highway projects' },
]

const placements = [
 { name: 'Left chest logo', detail: 'Standard 3–3.5" wide. Within the published placement zone on every Class 2 and 3 vest.' },
 { name: 'Right chest name/title', detail: 'First name, last initial, and title (Foreman, Super, Lead). Standard for crew identification.' },
 { name: 'Back yoke logo', detail: 'Above the upper retroreflective tape. Sized to stay clear of the tape lines — usually 6–8" wide.' },
 { name: 'Back lower panel', detail: 'Below the lowest reflective stripe. For project IDs, gate badges, or "TRAINEE" / "SAFETY" callouts.' },
]

const faqs = [
 { q: 'Can you put a logo on an ANSI 107 safety vest?', a: 'Yes — within published placement limits. ANSI/ISEA 107 caps non-retroreflective decoration on a Class 2 vest at 72 square inches total across all placements, and the decoration cannot cover or obstruct any of the retroreflective tape required for the certification. Embroidered and screen-printed logos are both compliant if they fit within the area limit.' },
 { q: 'What\'s the size limit for a logo on a hi-vis vest?', a: 'ANSI/ISEA 107 caps non-retroreflective decoration at 72 square inches total on a Class 2 garment. Most company logos use roughly 8-12 square inches at 3-3.5 inches wide on the chest, well within the limit. Adding a back logo can push closer to the cap on larger vests.' },
 { q: 'Can decoration affect ANSI compliance on a safety vest?', a: 'Yes if it\'s done wrong. Decoration that covers any part of the retroreflective tape voids the certification immediately. Exceeding the 72 sq inch decoration limit also voids it. Working within published manufacturer placement guides keeps the certification intact.' },
 { q: 'Class 2 vs Class 3 — which one does my crew need?', a: 'Class 2 is the standard for general construction, surveying, school zones, and daytime traffic-adjacent work. Class 3 is required for highway projects, night-shift work, and low-visibility conditions. Many state DOTs require Class 3 for any worker within a defined distance of moving traffic.' },
 { q: 'Embroidery or screen print on a hi-vis vest?', a: 'Embroidery has an advantage on vests because it doesn\'t add ink that could be misread as retroreflective material under headlights. Screen printing is fine for higher-volume runs and large back logos. Both are compliant within the 72 sq inch decoration limit.' },
 { q: 'Can you supply hi-vis vests with company logo and worker name?', a: 'Yes. Standard layout: company logo on the left chest at 3-3.5" wide, worker name (first + last initial) on the right chest, large back logo above the retroreflective tape line. All within the published placement zones.' },
 { q: 'Where can I get ANSI 107-compliant custom safety vests in Las Vegas?', a: 'Bighorn Threads supplies and decorates ANSI 107 Class 2 and Class 3 safety vests for Vegas contractors, road crews, and night-work operations. ML Kishigo, PIP, Radians, and Pyramex blanks in stock S-5XL. Decoration kept within ANSI placement and area limits. Send your roster size and program spec for a quote.' },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Custom Safety Vests Las Vegas', item: page.url },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Safety Vests in Las Vegas',
 serviceType: 'ANSI 107 Class 2 and Class 3 hi-vis safety vests with compliant decoration',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
