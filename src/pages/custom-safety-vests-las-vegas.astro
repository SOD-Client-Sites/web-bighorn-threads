 <h3 class="mb-3 font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{s.label}</h3>
 <p class="text-sm leading-relaxed text-ash">{s.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Class table -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-10 max-w-2xl">
 <p class="kicker mb-3">ANSI/ISEA 107</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Class 2, Class 3, Class E — what to spec.</h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 The class determines fluorescent base area, retroreflective tape requirements, and sleeve coverage. Project plan or DOT spec drives which one you need.
 </p>
 </div>

 <div class="overflow-hidden border border-hairline bg-panel">
 <table class="w-full">
 <thead class="bg-concrete">
 <tr class="border-b border-hairline">
 <th class="px-6 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-gold-600">Class</th>
 <th class="px-6 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-gold-600">Requires</th>
 <th class="hidden px-6 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-gold-600 lg:table-cell">Typical Use</th>
 </tr>
 </thead>
