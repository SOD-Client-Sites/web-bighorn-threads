---
import BaseLayout from '@/layouts/BaseLayout.astro'

const problems = [
  {
    title: 'Department uniforms, no system',
    desc: 'Public works, parks, water, transit — every department needs its own uniforms, and there is no single place to order them.',
  },
  {
    title: 'Hi-vis and safety compliance',
    desc: 'Field crews need ANSI hi-vis and safety apparel that meets spec. Guessing on classes and sizes slows the whole crew down.',
  },
  {
    title: 'Everyone orders separately',
    desc: 'Each department emails a different vendor, picks different garments, and the agency loses one consistent identity.',
  },
  {
    title: 'Procurement and budget control',
    desc: 'Without approved items and spend limits, orders drift off-spec and budgets are hard to track across departments.',
  },
  {
    title: 'Inconsistent identity across the workforce',
    desc: 'A city or county is one brand to the public. Mismatched logos, colors, and gear make a single agency look like ten.',
  },
]

const storeSteps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We build your free branded store',
    desc: 'Your agency seal or logo on file. Your approved garments, your colors, your departments. Free store setup — first digitizing is on us.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Staff order their own sizes',
    desc: 'Each department and employee logs in, picks the right size, and submits. No spreadsheets, no size-guessing, no email chains.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships direct, budget controlled',
    desc: 'Gear ships direct to the yard, office, or employee. You set approved items and spend by department. The store can hold ANSI hi-vis and safety gear for public-works crews.',
  },
]

const storeItems = [
  {
    title: 'Department uniforms & polos',
    desc: 'Embroidered polos, button-ups, and service shirts that keep parks, water, transit, and admin staff on one consistent standard.',
  },
  {
    title: 'ANSI hi-vis safety apparel',
    desc: 'Hi-vis tees, vests, and long sleeves for field crews — held in your store so the right class is one click, not a guess.',
  },
  {
    title: 'Embroidered outerwear',
    desc: 'Branded softshells, jackets, and beanies for crews working through every season, logo placement saved on file.',
  },
  {
    title: 'Branded hats & accessories',
    desc: 'Caps, beanies, and accessories that carry the agency mark across every department and every shift.',
  },
  {
    title: 'Public-works field gear',
    desc: 'Durable workwear built for the field — sized, decorated, and ready to reorder without starting over each time.',
  },
]

const faqs = [
  {
    q: 'What is an agency company store?',
    a: 'A company store is a private online store branded for your agency. It holds your approved uniforms, hi-vis gear, and accessories with your logo on file, so every department and employee orders the right items in their own size from one place.',
  },
  {
    q: 'Can multiple departments order from one store?',
    a: 'Yes. One store can serve public works, parks, water, transit, and admin together. Each department orders its own approved items and sizes, and the agency keeps one consistent identity across the workforce.',
  },
  {
    q: 'Can it handle hi-vis and ANSI safety apparel?',
    a: 'Yes. The store can hold ANSI hi-vis and safety apparel for public-works and field crews alongside your standard uniforms, so the right safety class is built into what staff can order.',
  },
  {
    q: 'Can we control approved items and budget by department?',
    a: 'Yes. You decide which items each department can order and can set spend limits by department, so orders stay on-spec and on budget without manual approvals on every request.',
  },
  {
    q: 'How do reorders work?',
    a: 'Your logo, colors, decoration, and placement are saved on file. New hires and replacements order their own sizes from the store and gear ships direct — no re-sending artwork or starting the order from scratch.',
  },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
    { '@type': 'ListItem', position: 3, name: 'Government', item: 'https://bighornthreads.com/industries/government/' },
  ],
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
  title="Uniforms & Company Stores for Cities, Counties & Public Agencies"
  description="Branded uniforms, ANSI hi-vis safety apparel, and company stores for cities, counties, state agencies, public works, utilities, and transit. One store, multiple departments, budget controlled."
  canonical="https://bighornthreads.com/industries/government/"
>
  <!-- ════ HERO — concrete ════ -->
  <section class="bg-concrete pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-600">Home</a>
        <span class="px-2 text-ash/60">/</span>
        <a href="/industries/" class="hover:text-gold-600">Industries</a>
        <span class="px-2 text-ash/60">/</span>
        <span class="text-gold-600">Government</span>
      </nav>

      <div class="max-w-3xl">
        <p class="kicker mb-5 flex items-center gap-2.5">
          <span class="h-px w-8 bg-gold-500"></span>
          For Cities, Counties &amp; Public Agencies
        </p>
        <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
          Uniforms, branded gear &amp; company stores for <span class="text-gold-600">public-sector teams.</span>
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ash sm:text-xl">
          Department uniforms, ANSI hi-vis safety apparel, and a private ordering store for cities,
          counties, state agencies, public works, utilities, and transit. One store, every department,
          budget controlled — your logo on file, staff order their own sizes, gear ships direct.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="/get-started/government/" class="btn-primary text-base">
            Build my company store plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-charcoal transition-colors hover:text-gold-600">
            <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ THE PROBLEM — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">The Problem</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Outfitting an agency is harder than <span class="text-gold-600">it should be.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          A public agency runs many departments, many crews, and one public identity. Without a system,
          uniforms drift off-spec, safety gear gets guessed at, and the budget is hard to see.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {problems.map((item) => (
          <div class="border border-hairline bg-panel p-6">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ HOW IT WORKS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">Company Stores</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          How a company store works <span class="text-gold-600">for an agency.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          A real ordering portal your departments use and your ops team controls. It can hold ANSI
          hi-vis and safety gear for public-works crews right next to your standard uniforms.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {storeSteps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ════ WHAT GOES IN THE STORE — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">What Goes In The Store</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Everything your departments <span class="text-gold-600">actually order.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Stock your store with the gear each department needs — uniforms, safety apparel, outerwear,
          and accessories, all decorated with your agency mark and saved for reorder.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {storeItems.map((item) => (
          <div class="border border-hairline bg-panel p-6">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ FAQ — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <p class="kicker mb-3">FAQ</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Public-sector company stores, <span class="text-gold-600">answered.</span>
        </h2>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CTA BAND — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start gap-6 border border-hairline bg-charcoal p-8 sm:flex-row sm:items-center sm:justify-between sm:p-10">
        <div class="max-w-xl">
          <h2 class="font-heading text-2xl font-bold uppercase tracking-tight text-concrete sm:text-3xl">
            Get a company store plan for your agency.
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-navy-200">
            One store for every department. Your logo on file, staff order their own sizes, hi-vis and
            uniforms in one place, budget controlled. Free store setup.
          </p>
        </div>
        <a href="/get-started/government/" class="btn-primary shrink-0 text-base">
          Build my company store plan
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</BaseLayout>
