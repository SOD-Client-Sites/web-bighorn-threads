const faqs = [
 {
 q: 'Can you embroider on NFPA 2112 FR coveralls without voiding the rating?',
 a: 'Yes — we use FR-compatible thread (Nomex or aramid blend) and follow Bulwark and Carhartt FR placement guidelines. The NFPA 2112 cert stays valid through the working life of the garment as long as the decoration meets the manufacturer spec, which we verify before every FR run.',
