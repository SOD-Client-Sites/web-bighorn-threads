---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Landscaping Crew Apparel and Branded Workwear | Las Vegas',
  description:
    'UPF long-sleeves, branded crew tees, and embroidered service polos for Las Vegas landscaping companies. Built for 5 AM Nevada heat-law starts and 110° afternoons. 24-hour quotes.',
  h1Pre: 'Landscaping',
  hero: '/images/generated/kit-landscaping.jpg',
}

const conditions = [
  { num: '5 AM', label: 'Nevada start time', body: 'NV OSHA heat-law adjustments push commercial maintenance crews to pre-dawn starts in summer. Branded hoodies and lightweight long-sleeves cover the cool first hour, then breathe through the heat.' },
  { num: '110°+', label: 'Afternoon ambient', body: 'Vegas summer hits 110° in the shade. Cotton tees soak through and stay wet. We stock UPF poly blends and moisture-wicking long-sleeves crews actually keep on past lunch.' },
  { num: '8 hrs', label: 'UV exposure', body: 'A landscaper averages 8 hours of direct sun a day. UPF 50+ branded long-sleeves protect skin and put your logo on every property you touch.' },
]

const gear = [
  { name: 'UPF 50+ branded long-sleeves', detail: 'Sun-blocking · poly blend · embroidered chest + sleeve', img: '/images/generated/kit-landscaping.jpg' },
  { name: 'Crew tees (poly-cotton)', detail: 'Wicking · screen-printed back · stocked S–4XL in 6 colors', img: '/images/generated/service-screen-printing.jpg' },
  { name: 'Branded service polos', detail: 'For account managers + design-build leads · embroidered logo', img: '/images/generated/service-embroidery.jpg' },
  { name: 'Hi-vis vests + hats', detail: 'For roadside maintenance + commercial property work · ANSI Class 2', img: '/images/generated/service-company-stores.jpg' },
]

const useCases = [
  'Maintenance crews in branded long-sleeves with company logo on the back',
  'Design-build / install crews in heavier branded tees with safety vests over',
  'Account managers and estimators in embroidered service polos for client walk-throughs',
  'Pre-dawn winter starts in branded hoodies and quarter-zips for cool desert mornings',
  'Spray techs and applicator-licensed crew in differentiated colorway for compliance visibility',
  'Branded swag for HOA presentations, property-manager pitches, and home shows',
]

const faqs = [
  {
    q: 'What\'s the best fabric for landscapers working through Vegas summer?',
    a: 'Polyester or poly-cotton blends with moisture-wicking — never 100% cotton. Cotton soaks through, stays wet, and weighs the crew down by lunch. We stock 100% poly long-sleeves with UPF 50+ that protect from sun without trapping heat.',
  },
  {
    q: 'Can you do residential vs commercial branding split for the same company?',
    a: 'Yes. Common setup: residential maintenance crews in branded tees (lower cost, higher rotation), commercial property crews in embroidered long-sleeves (higher visibility, premium look). Same logo, different garment program.',
  },
  {
    q: 'How many shirts do I need per crew member per season?',
    a: 'Rule of thumb: 5 tees per maintenance crew member for the summer rotation, 2-3 long-sleeves, 1 hoodie for winter. Account managers usually get 5 polos. Most companies do an annual order plus mid-season top-up.',
  },
  {
    q: 'Do you stock hi-vis for crews working near streets or commercial properties?',
    a: 'Yes — ANSI Class 2 vests, t-shirts, and long-sleeve hi-vis from ML Kishigo and Pioneer. Stocked in lime and orange S–4XL. Branded with screen-printed back logo within ANSI placement limits.',
  },
  {
    q: 'Can you set up a company store so foremen can order direct?',
    a: 'Yes. Particularly useful for landscaping companies running multiple crews — each foreman or office manager logs in, orders against a budget, and we ship direct. No closet, no spreadsheet, no missing sizes.',
  },
  {
    q: 'How fast can you turn around a 30-shirt order for a new crew starting Monday?',
    a: 'Standard rush is 72 hours when files are on hand. New artwork adds a day for digitizing. Call before 10am Tuesday and Friday delivery is realistic for a 30-piece run.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
    { '@type': 'ListItem', position: 3, name: 'Landscaping', item: 'https://bighornthreads.com/industries/landscaping-las-vegas/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear for Landscaping Crews',
  serviceType: 'Sun-protective branded apparel and crew uniforms',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: [
    { '@type': 'City', name: 'Las Vegas' },
    { '@type': 'City', name: 'Henderson' },
    { '@type': 'City', name: 'North Las Vegas' },
  ],
  audience: { '@type': 'BusinessAudience', audienceType: 'Landscaping Contractors' },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/industries/landscaping-las-vegas/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/industries/" class="hover:text-gold-400">Industries</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Landscaping</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Branded Crew Gear Built for <span class="text-gold-500">5 AM Starts and 110° Afternoons.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        UPF long-sleeves your crew will keep on past noon. Wicking tees that don't soak through. Polos sharp enough for HOA walk-throughs. We outfit Vegas landscaping companies from 4-truck operations to commercial property crews.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Conditions -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Vegas Conditions</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Why generic crew shirts fail in the Mojave.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          A landscaper in Vegas works through summer conditions a Pacific Northwest crew never sees. Pre-dawn starts, mid-day exposure, and zero shade between properties. We pick gear that holds up.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {conditions.map((c) => (
          <div class="rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="mb-3 flex items-baseline gap-3">
              <span class="font-heading text-4xl font-bold text-gold-500">{c.num}</span>
              <span class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-gray-300">{c.label}</span>
            </div>
            <p class="text-base leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gear -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Gear</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we make for landscaping crews.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Field-tested combinations for Vegas, Henderson, Summerlin, and Boulder City landscape companies. Mix and match — most operations run two or three of these year-round.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {gear.map((g) => (
          <div class="overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
              <img src={g.img} alt={g.name} class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="mb-2 font-heading text-lg font-bold tracking-tight text-white">{g.name}</h3>
              <p class="text-sm leading-relaxed text-gray-400">{g.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Typical Orders</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Configurations we run every season for landscapers.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Maintenance crews tend to standardize on tees and long-sleeves. Design-build operations split their gear by role — installers in heavyweight, account managers in polos. Spray techs usually get a different colorway for compliance visibility.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">All Services →</a>
            <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Company Stores →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {useCases.map((u, i) => (
            <li class="flex items-start gap-4 rounded-xl border border-navy-700/30 bg-navy-900/30 p-4 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-base leading-relaxed text-gray-200">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Deep dive -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Buyer's Guide</span>
      <h2 class="mb-8 font-heading text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        Branded workwear for Las Vegas landscaping and grounds-maintenance crews.
      </h2>

      <div class="space-y-5 text-lg leading-relaxed text-navy-200">
        <p>
          Landscaping in Las Vegas is harder on workwear than most clients realize — the combination of sustained outdoor sun exposure, abrasive desert vegetation, irrigation moisture, and chemical exposure (fertilizers, herbicides, pesticides) ages standard apparel fast. Bighorn Threads outfits Las Vegas landscaping companies, HOA grounds-maintenance crews, golf course operations, irrigation specialists, and tree service teams with branded workwear that reads as "professional service business" while standing up to the work. The right baseline spec balances heat tolerance, sun protection, durability, and the brand-impression value of having a clean, identifying uniform on every crew member.
        </p>
        <p>
          The hottest-running landscaping crews are mowing and irrigation teams that work direct-sun through the entire day. For these roles, lightweight UPF performance long-sleeve shirts in light colorways are the right spec — same logic as roofing and solar. The Bayside Performance Long-Sleeve and Carhartt Force Long-Sleeve in light gray, khaki, or sand colors give crews sustained UV protection without the heat trap of a dark cotton tee. Embroidered logos in your brand color keep the visual identity intact while the base shirt is purpose-built for desert conditions.
        </p>
        <p>
          For client-facing roles — supervisors, account managers, design consultants — the Vegas standard is a moisture-wicking polo with embroidered logo and (optionally) employee name. Port Authority K540 Silk Touch Performance Polo is the bestseller for landscaping companies because it looks sharp at a client meeting, holds up to a quick site walkthrough afterward, and breathes well enough that the supervisor isn't sweating through it on a 95° afternoon estimate.
        </p>
        <p>
          Pants and shorts split by role. Mowing and grounds crews wear lightweight cargos or work shorts (Carhartt B11 Loose Fit work pants, Carhartt B144 Rugged Flex Rigby Cargo Short) with embroidered logos on the back pocket. Irrigation techs need pants with reinforced knees for digging, valve work, and sprinkler repair — the Carhartt B324 Carpenter pant with double-knee reinforcement is the most-ordered SKU. Tree service crews working with chainsaws need cut-resistant chaps over their base pants, supplied separately as PPE.
        </p>
        <p>
          Caps and hats are the cheapest, highest-visibility piece of the program. Wide-brim sun hats (Carhartt CT103847 or equivalent) for mowing crews give better UV coverage than baseball caps; Richardson 112 trucker hats with embroidered logos work for everyone else. Hi-vis vests are a sitewide requirement on commercial landscape projects with active vehicle traffic — we supply ANSI 107 Class 2 mesh vests and decorate them with embroidered logos that preserve the retroreflective tape coverage.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Questions landscaping crews ask us.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/industries/roofing-solar-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Roofing &amp; Solar</h3>
          <p class="mt-2 text-sm text-gray-400">Sun-protective hi-vis for crews working full sun all day.</p>
        </a>
        <a href="/industries/general-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">General Contractors</h3>
          <p class="mt-2 text-sm text-gray-400">Crew uniforms, sub branding, and onboarding kits for Vegas GCs.</p>
        </a>
        <a href="/blog/screen-printing-vs-embroidery-construction/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Screen Print vs Embroidery</h3>
          <p class="mt-2 text-sm text-gray-400">Which decoration method holds up on outdoor crew gear.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Outfit your crew for the desert, not the catalog.</h2>
      <p class="mb-8 text-lg text-gray-300">Quote in 24 hours. Stocked tees and long-sleeves ship same week.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
