---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Landscaping Crew Apparel and Branded Workwear | Las Vegas',
 description:
 'UPF long-sleeves, branded crew tees, and embroidered service polos for Las Vegas landscaping companies. Built for 5 AM Nevada heat-law starts and 110° afternoons.',
 h1Pre: 'Landscaping',
 hero: '/images/generated/kit-landscaping.jpg',
}

const conditions = [
 { num: '5 AM', label: 'Nevada start time', body: '<a href="https://www.osha.gov/heat-exposure" rel="noopener" class="text-gold-700 hover:underline">OSHA heat-stress guidance</a> pushes commercial maintenance crews to pre-dawn starts in summer. Branded hoodies and lightweight long-sleeves cover the cool first hour, then breathe through the heat.' },
 { num: '110°+', label: 'Afternoon ambient', body: 'Vegas summer hits 110° in the shade. Cotton tees soak through and stay wet. We stock UPF poly blends and moisture-wicking long-sleeves crews actually keep on past lunch.' },
 { num: '8 hrs', label: 'UV exposure', body: 'A landscaper averages 8 hours of direct sun a day. UPF 50+ branded long-sleeves protect skin and put your logo on every property you touch. (Reference: <a href="https://www.cdc.gov/niosh/topics/heatstress/" rel="noopener" class="text-gold-700 hover:underline">NIOSH heat stress</a>.)' },
]

const gear = [
 { name: 'UPF 50+ branded long-sleeves', detail: 'Sun-blocking · poly blend · embroidered chest + sleeve', img: '/images/generated/kit-landscaping.jpg' },
 { name: 'Crew tees (poly-cotton)', detail: 'Wicking · screen-printed back · stocked S–4XL in 6 colors', img: '/images/generated/service-screen-printing.jpg' },
 { name: 'Branded service polos', detail: 'For account managers + design-build leads · embroidered logo', img: '/images/generated/service-embroidery.jpg' },
 { name: 'Hi-vis vests + hats', detail: 'For roadside maintenance + commercial property work · ANSI Class 2', img: '/images/generated/service-company-stores.jpg' },
]

const useCases = [
 'Maintenance crews in branded long-sleeves with company logo on the back',
 'Design-build / install crews in heavier branded tees with safety vests over',
 'Account managers and estimators in embroidered service polos for client walk-throughs',
 'Pre-dawn winter starts in branded hoodies and quarter-zips for cool desert mornings',
 'Spray techs and applicator-licensed crew in differentiated colorway for compliance visibility',
 'Branded swag for HOA presentations, property-manager pitches, and home shows',
]

const faqs = [
 {
 q: 'What\'s the best fabric for landscapers working through Vegas summer?',
 a: 'Polyester or poly-cotton blends with moisture-wicking — never 100% cotton. Cotton soaks through, stays wet, and weighs the crew down by lunch. We stock 100% poly long-sleeves with UPF 50+ that protect from sun without trapping heat.',
 },
 {
 q: 'Can you do residential vs commercial branding split for the same company?',
 a: 'Yes. Common setup: residential maintenance crews in branded tees (lower cost, higher rotation), commercial property crews in embroidered long-sleeves (higher visibility, premium look). Same logo, different garment program.',
 },
 {
 q: 'How many shirts do I need per crew member per season?',
 a: 'Rule of thumb: 5 tees per maintenance crew member for the summer rotation, 2-3 long-sleeves, 1 hoodie for winter. Account managers usually get 5 polos. Most companies do an annual order plus mid-season top-up.',
 },
 {
 q: 'Do you stock hi-vis for crews working near streets or commercial properties?',
 a: 'Yes — ANSI Class 2 vests, t-shirts, and long-sleeve hi-vis from ML Kishigo and Pioneer. Stocked in lime and orange S–4XL. Branded with screen-printed back logo within ANSI placement limits.',
 },
 {
 q: 'Can you set up a company store so foremen can order direct?',
 a: 'Yes. Particularly useful for landscaping companies running multiple crews — each foreman or office manager logs in, orders against a budget, and we ship direct. No closet, no spreadsheet, no missing sizes.',
 },
 {
 q: 'How fast can you turn around a 30-shirt order for a new crew starting Monday?',
 a: 'Rush options are available. New artwork adds a small amount of prep time. Standard runs are quoted up front with a clear timeline.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
 { '@type': 'ListItem', position: 3, name: 'Landscaping', item: 'https://bighornthreads.com/industries/landscaping-las-vegas/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear for Landscaping Crews',
 serviceType: 'Sun-protective branded apparel and crew uniforms',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 ],
 audience: { '@type': 'BusinessAudience', audienceType: 'Landscaping Contractors' },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/industries/landscaping-las-vegas/"
