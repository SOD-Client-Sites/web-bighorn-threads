---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Custom Workwear for Data Center Contractors in Las Vegas',
  description:
    'FR shirts, hi-vis, and mission-critical uniforms for Las Vegas data center construction. NFPA 70E arc-rated apparel for high-voltage electrical work, NDA-friendly branding options, and tour-ready polos for commissioning.',
  h1Pre: 'Data Center Contractors',
  hero: '/images/generated/kit-electrical.jpg',
}

const compliance = [
  {
    code: 'NFPA 70E',
    title: 'Arc-rated apparel for switchgear and medium-voltage work',
    body: 'Bulwark, Carhartt FR, and FRC shirts in CAT 1 and CAT 2 ratings for the high-voltage phase of data center buildouts. We embroider on FR garments with FR-compatible thread that preserves the certification.',
  },
  {
    code: 'NFPA 2112',
    title: 'Flash-fire rated garments for energized work',
    body: '2112-compliant shirts and coveralls for electricians working on energized gear during commissioning. Matched to your prime\'s safety spec, with spec sheets kept on file for reorders.',
  },
  {
    code: 'ANSI/ISEA 107 Class 2 + 3',
    title: 'Hi-vis for the civil and steel phases',
    body: 'Class 2 and Class 3 vests, shirts, and jackets for the heavy-civil, steel, and enclosure phases. Logo placement follows the ANSI square-inch limits so your branding never breaks compliance.',
  },
]

const gear = [
  { name: 'FR work shirts — CAT 1 / CAT 2', detail: 'Bulwark and Carhartt FR · button-down or henley · embroidered chest + sleeve', img: '/images/generated/kit-electrical.jpg' },
  { name: 'Hi-vis Class 2 + Class 3', detail: 'Lime or orange · ANSI 107-compliant placement · reflective striping', img: '/images/generated/service-screen-printing.jpg' },
  { name: 'Commissioning polos', detail: 'Port Authority K500 · embroidered chest · tour-ready for client walkthroughs', img: '/images/generated/service-embroidery.jpg' },
  { name: 'Hard hat + decal customization', detail: 'Vinyl cut · OSHA-compliant placement · bulk pricing available', img: '/images/generated/kit-office-sales.jpg' },
]

const useCases = [
  'Multi-trade GC crews on new build — electrical, mechanical, controls, fiber',
  'High-voltage electricians on FR rotation (medium-voltage phase)',
  'Commissioning teams transitioning from hi-vis to clean polos at turnover',
  'NDA-controlled orders with job-site-only branding (no public company marks)',
  '24/7 ops crews for colo tenants running day/night shift uniforms',
  'Visitor / vendor badged polos for controlled-access facility tours',
  'Foreman and superintendent differentiation across dozens of subs',
  'Runs across Vegas hyperscaler and colo campuses',
]

const faqs = [
  {
    q: 'Can you meet NFPA 70E CAT 2 for medium-voltage electrical work on data center builds?',
    a: 'Yes — Bulwark and Carhartt FR shirts rated at 8 cal/cm² (CAT 2) with FR-compatible aramid thread. We verify the garment-specific decoration spec with the manufacturer before every run. The certification stays valid through decoration.',
  },
  {
    q: 'Some of our data center clients have NDAs — can we order without showing the end-client\'s name?',
    a: 'All the time. We can run shirts with only your company logo, or with a project code instead of a client name, or completely blank for controlled distribution. Every order stays in our system under your account, not the end client\'s.',
  },
  {
    q: 'What\'s the difference between construction-phase uniforms and operations uniforms for a data center?',
    a: 'Construction phase is hi-vis Class 2/3 plus FR shirts for electrical. Commissioning shifts to clean embroidered polos that read well on a client walkthrough. Ops phase is typically 24/7 shift uniforms — branded polos or work shirts with name + shift color coding. We run all three.',
  },
  {
    q: 'Do you handle ESD-safe or cleanroom-adjacent apparel?',
    a: 'We don\'t stock cleanroom garments — those are a specialized category from cleanroom suppliers. For ESD-control work outside the white space (electrical rooms, telecom closets), standard FR garments work. Ask and we\'ll tell you if a job needs something we don\'t cover.',
  },
  {
    q: 'Our GC runs multiple data center projects at once. Can you standardize uniforms across job sites?',
    a: 'That\'s exactly the company store use case. Every crew member logs in, sees only the approved gear for their role and trade, and orders direct. Foreman can order for their crew. Reorders match the original run every time. One account, multiple sites, consistent branding.',
  },
  {
    q: 'We\'ve got a commissioning deadline. What\'s your rush turnaround on embroidered polos?',
    a: 'Rush options are available — call us with your deadline and we\'ll tell you straight whether it\'s realistic and what it costs.',
  },
  {
    q: 'Can you brand hard hats and decals to OSHA placement rules?',
    a: 'Vinyl decals in any size up to the manufacturer\'s placement limits. We don\'t drill, heat-transfer, or alter the shell. Stickers only — the only OSHA-compliant method. Bulk pricing available.',
  },
  {
    q: 'Do you work with the GCs building the major Vegas data center campuses?',
    a: 'Yes — we outfit crews on data center projects across Las Vegas, Henderson, and Summerlin. We won\'t name clients publicly for NDA reasons, but call us and we\'ll walk you through how we handle projects similar to yours.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
    { '@type': 'ListItem', position: 3, name: 'Data Center Contractors', item: 'https://bighornthreads.com/industries/data-center-contractors-las-vegas/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear for Data Center Contractors',
  serviceType: 'Branded apparel and FR-compliant uniforms for data center construction and operations',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: [
    { '@type': 'City', name: 'Las Vegas' },
    { '@type': 'City', name: 'Henderson' },
    { '@type': 'City', name: 'North Las Vegas' },
    { '@type': 'City', name: 'Summerlin' },
  ],
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Data Center Contractors and Mission-Critical Builders',
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/industries/data-center-contractors-las-vegas/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/industries/" class="hover:text-gold-400">Industries</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Data Center Contractors</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre} · Las Vegas #1 Growth Sector</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Mission-Critical Uniforms for <span class="text-gold-500">Vegas Data Center Builds.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        NFPA 70E-rated shirts for the electrical phase. Hi-vis Class 2 + 3 for civil and steel. Tour-ready polos for commissioning. NDA-friendly branding when the end client stays off the shirt.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Vegas DC context -->
  <section class="border-b border-navy-800 bg-navy-900/20 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Vegas Market Context</span>
      <h2 class="mb-6 font-heading text-3xl font-bold tracking-tight sm:text-4xl">The data center wave is here.</h2>
      <p class="mb-5 text-lg leading-relaxed text-gray-300">
        Las Vegas and the surrounding valley have become one of the largest hyperscale and colocation hubs in the U.S. Between the major hyperscaler campuses and the colo build-outs across Henderson and Summerlin coming online, the data center construction pipeline dwarfs anything Vegas has seen outside the Strip.
      </p>
      <p class="mb-5 text-lg leading-relaxed text-gray-300">
        Data center contractors operate under a specific mix: very high voltage (arc-flash country), heavy civil + steel, mission-critical mechanical, telecom/fiber, and building controls — all under aggressive commissioning timelines with NDAs layered on top. The apparel needs across those phases don't match a standard commercial GC's needs.
      </p>
      <p class="text-lg leading-relaxed text-gray-300">
        We outfit Vegas data center crews across prime contractors and colo tenants. We know the FR rotations, the commissioning-week polo runs, the "no end-client logo on the shirt" NDA pattern, and the hard hat decal rules. You won't need to explain the job to us.
      </p>
    </div>
  </section>

  <!-- Compliance hero strip -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Compliance &amp; Spec</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">We speak your safety officer's language.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Every data center build operates under a safety spec from the prime, the client, and sometimes both. We carry the brands, ratings, and certifications they want on file — and we keep spec sheets so reorders match exactly.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {compliance.map((c) => (
          <div class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <span class="mb-4 inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{c.code}</span>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white">{c.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What we make -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Gear</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we run for data center builds.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          The sequence we see most often: hi-vis on civil, FR through electrical and commissioning, embroidered polos for client walk-throughs, branded ops gear once the building turns over.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {gear.map((g) => (
          <div class="overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
