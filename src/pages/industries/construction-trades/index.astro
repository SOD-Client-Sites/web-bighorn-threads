---
import BaseLayout from '@/layouts/BaseLayout.astro'

const trades = [
 {
 name: 'General Contractors',
 href: '/industries/general-contractors-las-vegas/',
 desc: 'Embroidered polos, hi-vis tees, branded hard hats, and crew uniforms — from the foreman to the newest hire.',
 },
 {
 name: 'Electrical Contractors',
 href: '/industries/electrical-contractors-las-vegas/',
 desc: 'NFPA 70E FR-rated shirts, arc-flash workwear, and embroidered service uniforms decorated to spec.',
 },
 {
 name: 'Plumbing & HVAC',
 href: '/industries/plumbing-hvac-las-vegas/',
 desc: 'Embroidered service polos, branded work jackets, and name-taped shirts your service techs wear every day.',
 },
 {
 name: 'Concrete & Masonry',
 href: '/industries/concrete-masonry-las-vegas/',
 desc: 'ANSI hi-vis tees and long sleeves, heavy-duty work jackets, and branded hard hats built for the pour.',
 },
 {
 name: 'Steel & Ironworkers',
 href: '/industries/steel-iron-workers-las-vegas/',
 desc: 'FR-rated long-sleeve shirts, arc-rated hoodies, welding gloves, and chin-strap hard hats.',
 },
 {
 name: 'Data Center & Mission-Critical',
 href: '/industries/data-center-contractors-las-vegas/',
 desc: 'NFPA 70E FR button-ups, embroidered softshells, and fine-dust-ready gear for mission-critical builds.',
 },
 {
 name: 'Roofing & Solar',
 href: '/industries/roofing-solar-las-vegas/',
 desc: 'Hi-vis branded gear, sun-ready workwear, custom hard hats, and crew tees that hold up on the roof.',
 },
 {
 name: 'Landscaping',
 href: '/industries/landscaping-las-vegas/',
 desc: 'Sun-protection hats, branded tees and tanks, and crew uniforms built for long days outdoors.',
 },
 {
 name: 'Oil, Gas & Mechanical',
 href: '/industries/oil-gas-mechanical-las-vegas/',
 desc: 'FR-rated workwear, embroidered jackets, and branded gear for mechanical and energy crews.',
 },
]

const storeSteps = [
 {
 n: '01',
 meta: 'Setup',
 title: 'We Build Your Branded Store',
 desc: 'Your logo, your colors, your approved garments — set up as a real online store for your crew. Hi-vis and FR options held to spec, logo on file.',
 },
 {
 n: '02',
 meta: 'Ongoing',
 title: 'Your Crew Orders Their Own Sizes',
 desc: 'Each crew member logs in, picks the gear you approved in their own size, and submits the order. No size-guessing, no email chains, no inventory closet.',
 },
 {
 n: '03',
 meta: 'Ongoing',
 title: 'Gear Ships Where It Needs To Go',
 desc: 'Direct to the job site, the trailer, the office, or each employee’s home — your call. Reorders match the originals because your specs are saved.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
 { '@type': 'ListItem', position: 3, name: 'Construction & Trades', item: 'https://bighornthreads.com/industries/construction-trades/' },
 ],
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
 title="Uniforms & Company Stores for Construction & The Trades"
 description="Branded uniforms, hi-vis and FR workwear, and company stores for trade crews — general contractors, electrical, plumbing, HVAC, roofing, concrete, steel, and more. Logo on file, reorders that match."
>
 <!-- ════ HERO — concrete ════ -->
 <section class="bg-concrete">
 <div class="mx-auto max-w-7xl px-4 pb-16 pt-20 sm:px-6 sm:pt-24 lg:px-8 lg:pb-24 lg:pt-14">
 <div class="max-w-3xl">
 <p class="kicker mb-5 flex items-center gap-2.5">
 <span class="h-px w-8 bg-gold-500"></span>
 For Construction &amp; The Trades
 </p>
 <h1 class="font-heading text-5xl font-extrabold uppercase leading-[0.92] tracking-tight text-charcoal sm:text-6xl lg:text-[5rem]">
 Uniforms &amp; company stores for
 <span class="text-gold-600"> trade crews.</span>
 </h1>
 <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ash sm:text-xl">
 Hi-vis, FR workwear, embroidered uniforms, and branded company stores for the
 crews that build. General contractors, electricians, plumbers and HVAC, roofers,
 concrete and masonry, steel and ironworkers — outfitted to spec, easy to reorder,
 consistent every time.
 </p>
 <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
 <a href="/contact/" class="btn-primary text-base">
 Get a Free Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-charcoal transition-colors hover:text-gold-600">
 <svg class="h-4 w-4 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
 702.904.8923
 </a>
 </div>
 </div>
 </div>
 </section>

 <!-- ════ TRADES WE OUTFIT — paper ════ -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Trades We Outfit</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 One partner for <span class="text-gold-600">every trade on the job.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 We specialize in construction and the trades — we know the garments, the compliance,
 and the reorder patterns of each crew. Pick your trade for the gear, specs, and
 details that fit the work.
 </p>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
 {trades.map((trade) => (
 <a href={trade.href} class="group flex flex-col border border-hairline bg-panel p-6 transition-colors duration-200 hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">{trade.name}</h3>
 <p class="mt-2 flex-1 text-sm leading-relaxed text-ash">{trade.desc}</p>
 <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs font-medium uppercase tracking-wider text-gold-600 transition-all group-hover:gap-2.5">
 See the gear
 <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </span>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- ════ HOW A COMPANY STORE WORKS — concrete ════ -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-3xl">
 <p class="kicker mb-3">Company Stores</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 How a company store <span class="text-gold-600">works for a crew.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Stop chasing uniform orders. A branded store puts the right gear in front of your
 crew, holds your specs on file, and ships it where it needs to go.
 </p>
 </div>

 <ol class="grid gap-5 md:grid-cols-3">
 {storeSteps.map((step) => (
 <li class="border border-hairline bg-panel p-7">
 <div class="mb-5 flex items-baseline justify-between">
 <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
 <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
 </div>
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
 <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
 </li>
 ))}
 </ol>
 </div>
 </section>

 <!-- ════ COMPLIANCE NOTE — paper ════ -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
 <div>
 <p class="kicker mb-3">Compliance Held to Spec</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 Hi-vis and FR, <span class="text-gold-600">decorated right.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Safety gear only protects the crew if it stays compliant. We decorate to the
 standard — ANSI/ISEA 107 hi-vis with placement that respects the limits, and
 NFPA 70E flame-resistant garments embroidered with FR-compatible methods that
 preserve the rating.
 </p>
 <a href="/safety-compliance/" class="btn-secondary mt-8 text-sm">
 See safety &amp; compliance
 <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 </div>

 <div class="divide-y divide-hairline border-y border-hairline">
 <div class="flex gap-4 py-5">
 <span class="spec mt-0.5 shrink-0 border border-hairline px-2 py-1 text-ash">ANSI 107</span>
 <div>
 <h3 class="font-heading text-base font-bold uppercase tracking-tight text-charcoal">Hi-Vis That Stays Compliant</h3>
 <p class="mt-1 text-sm leading-relaxed text-ash">Class 2 and 3 hi-vis with reflective striping per ANSI/ISEA 107. Logo placement follows the limits so branding never breaks compliance.</p>
 </div>
 </div>
 <div class="flex gap-4 py-5">
 <span class="spec mt-0.5 shrink-0 border border-hairline px-2 py-1 text-ash">NFPA 70E</span>
 <div>
 <h3 class="font-heading text-base font-bold uppercase tracking-tight text-charcoal">FR Without Voiding the Rating</h3>
 <p class="mt-1 text-sm leading-relaxed text-ash">Flame-resistant shirts embroidered with FR-compatible thread and placement that preserves the certification, verified before every run.</p>
 </div>
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- ════ CTA BAND — concrete ════ -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="flex flex-col items-start gap-6 border border-hairline bg-charcoal p-8 sm:flex-row sm:items-center sm:justify-between sm:p-12">
 <div class="max-w-2xl">
 <h2 class="font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-4xl">
 Ready to outfit <span class="text-gold-400">your crew?</span>
 </h2>
 <p class="mt-3 text-base leading-relaxed text-navy-200">
 Get a quote, see real mockups, and talk to a human who knows the trades. Or walk
 through a live company store before you commit.
 </p>
 </div>
 <div class="flex shrink-0 flex-col gap-3 sm:flex-row sm:items-center">
 <a href="/contact/" class="btn-primary text-base">
 Get a Free Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 <a href="/demo/" class="inline-flex items-center gap-2 border border-gold-500 px-6 py-3.5 font-mono text-sm font-medium tracking-wide text-gold-400 transition-colors hover:bg-gold-500 hover:text-charcoal">
 See a demo store
 <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 </div>
 </div>
 </div>
 </section>

 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</BaseLayout>
