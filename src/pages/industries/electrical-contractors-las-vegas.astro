const compliance = [
 {
 code: 'NFPA 70E',
 title: 'Arc-rated apparel for the field',
 body: '<a href="https://www.bulwarkprotection.com/" rel="noopener" class="text-gold-700 hover:underline">Bulwark</a>, <a href="https://www.carhartt.com/category/mens/fr-flame-resistant-clothing.html" rel="noopener" class="text-gold-700 hover:underline">Carhartt FR</a>, and FRC shirts in CAT 1 and CAT 2 ratings — see <a href="https://www.nfpa.org/codes-and-standards/all-codes-and-standards/list-of-codes-and-standards/detail?code=70E" rel="noopener" class="text-gold-700 hover:underline">NFPA 70E standard</a>. We embroider on FR garments using FR-compatible thread and placement techniques that preserve the certification.',
 },
 {
 code: 'ANSI/ISEA 107 Class 2',
 title: 'Hi-vis for service crews and roadside work',
 body: 'Class 2 vests, t-shirts, and long-sleeve hi-vis with reflective striping per <a href="https://safetyequipment.org/standards/ansi-isea-107/" rel="noopener" class="text-gold-700 hover:underline">ANSI/ISEA 107</a>. Logo placement follows the 72-square-inch limit so your branding never breaks compliance.',
 },
 {
 code: 'OSHA 1910.269',
 title: 'PPE that meets the spec sheet',
 body: 'We carry the gear your safety manager already knows per <a href="https://www.osha.gov/laws-regs/regulations/standardnumber/1910/1910.269" rel="noopener" class="text-gold-700 hover:underline">OSHA 1910.269</a> — PIP, ML Kishigo, Bulwark, Wrangler Riggs. Every spec sheet on file. Reorders match the original lot every time.',
 },
]

const gear = [
 { name: 'FR work shirts', detail: 'CAT 1 / CAT 2 rated · button-down or polo · embroidered chest', img: '/images/generated/kit-electrical.jpg' },
 { name: 'Hi-vis Class 2 t-shirts', detail: 'Lime or orange · screen-printed back · ANSI-compliant placement', img: '/images/generated/service-screen-printing.jpg' },
 { name: 'Branded service polos', detail: 'Port Authority K500 · embroidered chest + sleeve · 8 stocked colors', img: '/images/generated/service-embroidery.jpg' },
 { name: 'Hard hat stickers + decals', detail: 'Vinyl cut · OSHA-compliant placement · bulk pricing available', img: '/images/generated/kit-office-sales.jpg' },
]

const useCases = [
 'Service truck crew uniforms with embroidered name + company logo',
 'New-hire onboarding kits (5 shirts, hat, hoodie, FR layer)',
 'Apprentice gear allowances tied to hour milestones',
 'Foreman and supervisor differentiation (color, embroidery vs print)',
 'Trade show + IBEW event apparel for Las Vegas locals',
 'Branded swag for journeyman recruiting drives',
]

const faqs = [
 {
 q: 'Can you embroider on FR shirts without voiding the NFPA 70E rating?',
 a: 'Yes — we use FR-compatible thread (Nomex or aramid blend) and follow garment-specific placement rules. The certification stays valid as long as the decoration meets the manufacturer\'s spec, which we verify before every FR run.',
 },
 {
 q: 'What\'s the minimum order for hi-vis Class 2 shirts?',
 a: '24 pieces for screen printing, 12 for embroidery. We stock ANSI 107 Class 2 in lime and orange in adult sizes S–4XL, ready for fast production.',
 },
 {
 q: 'Do you do rush orders for service trucks getting wrapped or new fleets?',
 a: 'Standard Rush options available. We\'ve hit rushs for repeat clients with files already on hand. Call early and we will get a quote back to you.',
 },
 {
 q: 'What brands do you stock for electrical contractors specifically?',
 a: 'Bulwark FR, Carhartt FR, Wrangler Riggs, Port Authority, ML Kishigo, PIP, Pioneer. We\'ll match whatever\'s on your existing safety spec sheet.',
 },
 {
 q: 'Can you set up a company store so my apprentices can order their own gear?',
 a: 'Yes. Each employee logs in, sees only the gear you\'ve approved (with allowances if you set them), and orders direct. We print and ship — no inventory on your end. Read more on company stores.',
 },
 {
 q: 'Do you handle hard hat customization to OSHA standards?',
 a: 'Yes — vinyl decals in any size up to manufacturer placement limits. We don\'t alter the shell, drill, or apply heat. Stickers only. Bulk discounts available.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
 { '@type': 'ListItem', position: 3, name: 'Electrical Contractors', item: 'https://bighornthreads.com/industries/electrical-contractors-las-vegas/' },
