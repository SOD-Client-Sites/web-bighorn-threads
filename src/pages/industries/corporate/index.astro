---
import BaseLayout from '@/layouts/BaseLayout.astro'

const problems = [
  {
    title: 'Chasing Sizes by Email.',
    desc: 'Someone in ops spends days collecting shirt sizes in a spreadsheet. New hire starts, the cycle repeats. It never ends.',
  },
  {
    title: 'Swag Nobody Wears.',
    desc: 'Cheap blanks ordered in bulk sit in a closet. Wrong sizes, wrong styles. Your brand on gear people quietly throw out.',
  },
  {
    title: 'Brand Drift Across Vendors.',
    desc: 'Marketing buys polos one place, HR buys onboarding kits another. Logos drift, colors drift. Your brand looks inconsistent.',
  },
  {
    title: 'New-Hire Kits Done by Hand.',
    desc: 'Every start date means a manual order, a guess at sizes, and a scramble to get gear there in time. It does not scale.',
  },
]

const storeSteps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We Build Your Store — Free',
    desc: 'Your logo, your colors, your approved products, your budget rules. We set up your branded company store. Logo stays on file so every reorder matches.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Your People Order Their Own Sizes',
    desc: 'Each person logs in, picks their own size, and submits. No spreadsheets, no size-guessing, no email chains for you to manage.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships Direct — You Control Budget',
    desc: 'Gear ships to the office or each person’s home. You cap spend per person, see every order in one place, and reorder in a click.',
  },
]

const offerings = [
  {
    title: 'Embroidered Polos & Softshells',
    desc: 'Embroidered polos, button-ups, quarter-zips, and softshell jackets. Your logo digitized once and held on file for consistent reorders.',
    tag: 'Apparel',
  },
  {
    title: 'Premium Brands',
    desc: 'Recognized brands your team actually wants to wear — Port Authority, premium outerwear, YETI drinkware, and more. Branded, not bargain-bin.',
    tag: 'Premium',
  },
  {
    title: 'New-Hire Onboarding Kits',
    desc: 'A branded welcome kit ready to ship the day someone starts. Polo, drinkware, the essentials — sized by the new hire, not guessed by you.',
    tag: 'Onboarding',
  },
  {
    title: 'Event & Trade-Show Apparel',
    desc: 'Matching gear for conferences, booths, and company events. Order what you need, ship to the venue or to each attendee.',
    tag: 'Events',
  },
  {
    title: 'Client Gifts',
    desc: 'Branded gifts that get used, not tossed. Drinkware, bags, and premium pieces that keep your brand in front of the people who matter.',
    tag: 'Gifts',
  },
]

const faqs = [
  {
    q: 'What is a company store?',
    a: 'A company store is your own branded online store. We stock it with your approved gear and your logo. Your people order their own sizes, and it ships direct — no spreadsheets, no closet inventory, no size-guessing on your end.',
  },
  {
    q: 'Do we need a minimum number of people to start?',
    a: 'No. We build your store for teams of every size. Small office or large company, the store works the same way — your people order what they need, when they need it.',
  },
  {
    q: 'Can remote employees order gear to their home?',
    a: 'Yes. Each person picks their own size and ships to their home address. Remote teams, multiple locations, and field staff all order the same way.',
  },
  {
    q: 'Can we cap how much each person spends?',
    a: 'Yes. You set a budget per person — a gift-card balance or a spend limit. People order within it, and you see every order in one place. You control the budget, not a phone chain.',
  },
  {
    q: 'How do reorders and onboarding kits work?',
    a: 'Your logo, colors, and approved products stay on file. Reorder in a click. For onboarding, a branded welcome kit ships the day a new hire starts — sized by them, not guessed by you.',
  },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
    { '@type': 'ListItem', position: 3, name: 'Corporate', item: 'https://bighornthreads.com/industries/corporate/' },
  ],
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
  title="Branded Apparel & Company Stores for Corporate & Office Teams"
  description="Branded gear and a free company store for corporate, office, and professional teams — tech, finance, energy, professional services. Your people order their own sizes. Ships direct. You control the budget."
  canonical="https://bighornthreads.com/industries/corporate/"
>
  <!-- ════ HERO — concrete (no photographic band) ════ -->
  <section class="bg-concrete pt-16 pb-20 sm:pt-16 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-600">Home</a>
        <span class="px-2 text-ash/60">/</span>
        <a href="/industries/" class="hover:text-gold-600">Industries</a>
        <span class="px-2 text-ash/60">/</span>
        <span class="text-gold-600">Corporate</span>
      </nav>

      <div class="max-w-3xl">
        <p class="kicker mb-5 flex items-center gap-2.5">
          <span class="h-px w-8 bg-gold-500"></span>
          For Corporate &amp; Office Teams
        </p>
        <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
          Branded gear &amp; company stores for
          <span class="text-gold-600"> company teams.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ash sm:text-xl">
          Stop chasing sizes by email. We build your branded company store, your people order their
          own gear, and it ships direct. For tech, finance, energy, and professional services teams.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="/get-started/corporate/" class="btn-primary text-base">
            Build my company store plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-charcoal transition-colors hover:text-gold-600">
            <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ THE PROBLEM — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">The Problem</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Branded gear shouldn’t be <span class="text-gold-600">an ops headache.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          If you run office or people ops, you know the drill. Branded apparel turns into a spreadsheet
          you maintain by hand. It eats your time and your brand pays for it.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {problems.map((item) => (
          <div class="border border-hairline bg-panel p-7">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ HOW A COMPANY STORE WORKS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          How a company store works <span class="text-gold-600">for your team.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Your logo on file, consistent reorders, and a store your people run themselves. You set the
          budget. We handle the rest.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {storeSteps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-8">
        <a href="/get-started/corporate/" class="btn-secondary text-sm">
          Build my company store plan
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ WHAT YOU CAN PUT IN THE STORE — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">What You Stock</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          What you can put in <span class="text-gold-600">your store.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Pick the gear that fits your team and your brand. Stock as much or as little as you want —
          add and swap products any time.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {offerings.map((item) => (
          <div class="flex flex-col border border-hairline bg-panel p-6">
            <span class="spec mb-3 inline-block self-start border border-hairline px-2 py-1 text-ash">{item.tag}</span>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ FAQ — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <p class="kicker mb-3">FAQ</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Company stores, <span class="text-gold-600">answered.</span>
        </h2>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CTA BAND — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start gap-6 border border-hairline bg-charcoal p-8 sm:flex-row sm:items-center sm:justify-between sm:p-12">
        <div class="max-w-xl">
          <p class="kicker mb-3">Get Started</p>
          <h2 class="font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-4xl">
            Ready to give your team <span class="text-gold-400">a real company store?</span>
          </h2>
          <p class="mt-4 text-base leading-relaxed text-navy-200">
            Free store setup. Your people order their own sizes. A real person follows up. Tell us about
            your team and we’ll build your plan.
          </p>
        </div>
        <a href="/get-started/corporate/" class="btn-primary shrink-0 text-base">
          Build my company store plan
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
