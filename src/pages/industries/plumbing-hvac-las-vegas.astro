 <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-600">{String(i + 1).padStart(2, '0')}</span>
 <span class="text-base leading-relaxed text-charcoal">{u}</span>
 </li>
 ))}
 </ul>
