---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Plumbing and HVAC Service Uniforms | Las Vegas',
  description:
    'Embroidered service tech uniforms, branded polos, and customer-facing apparel for Las Vegas plumbing and HVAC contractors. Name + title embroidery, name patches, and 24-hour quotes.',
  h1Pre: 'Plumbing & HVAC',
  hero: '/images/generated/kit-plumbing-hvac.jpg',
}

const compliance = [
  {
    code: 'Customer Trust',
    title: 'A uniformed tech closes more service calls',
    body: 'When the homeowner opens the door, the embroidered logo, name, and title do half the trust-building before the tech says a word. Branded uniforms are the cheapest sales tool you have.',
  },
  {
    code: 'NV State Contractor Board',
    title: 'License-visible branding done right',
    body: 'License number on the truck, on the shirt, on the invoice — Nevada customers expect to see it. We lay out chest embroidery so license, company, and tech name all read clean from 6 feet.',
  },
  {
    code: 'OSHA / NIOSH Heat Stress',
    title: 'Service tech apparel for 115° attic work',
    body: 'HVAC techs work in 130°+ attics in July. We stock moisture-wicking poly polos and lightweight long-sleeves so techs stay covered without overheating between calls.',
  },
]

const gear = [
  { name: 'Embroidered service polos', detail: 'Port Authority K500 · name + title + logo · 8 stocked colors', img: '/images/generated/service-embroidery.jpg' },
  { name: 'Mechanic-style work shirts', detail: 'Red Kap or Dickies · button-down · stitched name patch + chest logo', img: '/images/generated/kit-plumbing-hvac.jpg' },
  { name: 'Branded service tees', detail: 'Carhartt K87 or poly blend · printed back · for ride-along + warehouse', img: '/images/generated/service-screen-printing.jpg' },
  { name: 'Tech name patches + tags', detail: 'Sewn-on or velcro · interchangeable for new hires · matches uniform colorway', img: '/images/generated/service-company-stores.jpg' },
]

const useCases = [
  'Residential service techs in embroidered polos with name + title (lead tech, journeyman, apprentice)',
  'Commercial mechanical crews in heavier work shirts with company name patch',
  'Install crews in branded tees and hi-vis when working new construction sites',
  'Dispatcher and office staff in lighter-weight branded polos for the front counter',
  'Apprentice / helper differentiation by polo color or sleeve embroidery',
  'Branded swag for trade shows, AGC events, and home shows around the valley',
]

const faqs = [
  {
    q: 'Can you do name embroidery on every shirt and still hit a 24-hour quote?',
    a: 'Yes. Once we have your logo and tech roster on file, name embroidery adds about a day to the standard run — not a week. We stitch each name to order; the per-shirt cost is fixed regardless of name length.',
  },
  {
    q: 'What\'s better for service techs — embroidered polos or mechanic-style work shirts?',
    a: 'Polos for residential service (cleaner customer-facing look). Mechanic shirts for commercial mechanical or anyone crawling in attics and under cabinets all day — they wear the abuse better and the name patches are interchangeable.',
  },
  {
    q: 'Do you stock moisture-wicking polos for Vegas summer?',
    a: 'Yes. Port Authority K500 and Sport-Tek ST650 in 100% poly micro-mesh, both stocked S–4XL. Cotton blend polos look nicer at week one but they\'re soaked through by 11am in July.',
  },
  {
    q: 'How do you handle name changes when a tech leaves or a new one starts?',
    a: 'Name patches are velcro-swappable on the work-shirt program. For embroidered polos, we stitch new ones as needed — you keep the old shirts as ride-along or shop gear, or we re-stitch over for a small charge.',
  },
  {
    q: 'Can you put our license number and 24-hour service line on every shirt?',
    a: 'Yes. We typically run license number on the sleeve and the service number on the back collar or hem tag. Keeps the chest clean for the logo + name and the customer still sees the contact info.',
  },
  {
    q: 'Do you set up company stores for plumbing and HVAC shops?',
    a: 'Yes. Particularly useful for mid-size shops (15+ techs) where you want each tech to log in, see only their approved kit, and order with their allowance. We print, embroider, ship — no closet inventory on your end.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
    { '@type': 'ListItem', position: 3, name: 'Plumbing & HVAC', item: 'https://bighornthreads.com/industries/plumbing-hvac-las-vegas/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear for Plumbing and HVAC Contractors',
  serviceType: 'Branded service uniforms and embroidered apparel',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: [
    { '@type': 'City', name: 'Las Vegas' },
    { '@type': 'City', name: 'Henderson' },
    { '@type': 'City', name: 'North Las Vegas' },
  ],
  audience: { '@type': 'BusinessAudience', audienceType: 'Plumbing and HVAC Contractors' },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/industries/plumbing-hvac-las-vegas/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/industries/" class="hover:text-gold-400">Industries</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Plumbing &amp; HVAC</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Service Tech Uniforms That Close <span class="text-gold-500">Calls Before You Knock.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        Embroidered polos with name and title. Mechanic shirts with swappable name patches. License-visible layouts that look sharp on the doorstep. We outfit Vegas plumbing and HVAC shops from 3-truck operations to 50-tech fleets.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Compliance / trust strip -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Why It Matters</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Your tech's shirt sells the call.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Service trades live or die on customer trust at the front door. A clean uniform with name, title, and license closes the gap between "guy in a t-shirt" and "professional you'd let into your house."
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {compliance.map((c) => (
          <div class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <span class="mb-4 inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{c.code}</span>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white">{c.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What we make -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Gear</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we make for plumbing and HVAC shops.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Most shops end up running a polo program for residential service and a work-shirt program for install crews and shop techs. We stock both and keep the spec on file so reorders match every time.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {gear.map((g) => (
          <div class="overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
              <img src={g.img} alt={g.name} class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="mb-2 font-heading text-lg font-bold tracking-tight text-white">{g.name}</h3>
              <p class="text-sm leading-relaxed text-gray-400">{g.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Typical Orders</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we run every week for service shops.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            From two-truck plumbers to 40-tech HVAC operations. Once you cross 15 techs, a company store usually pays for itself in saved sizing-spreadsheet hours.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">All Services →</a>
            <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Company Stores →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {useCases.map((u, i) => (
            <li class="flex items-start gap-4 rounded-xl border border-navy-700/30 bg-navy-900/30 p-4 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-base leading-relaxed text-gray-200">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Questions plumbing and HVAC shops ask us.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/industries/electrical-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Electrical Contractors</h3>
          <p class="mt-2 text-sm text-gray-400">FR shirts, hi-vis, and code-compliant decoration for service crews.</p>
        </a>
        <a href="/industries/general-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">General Contractors</h3>
          <p class="mt-2 text-sm text-gray-400">Crew uniforms, sub branding, and onboarding kits for Vegas GCs.</p>
        </a>
        <a href="/blog/screen-printing-vs-embroidery-construction/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Screen Print vs Embroidery</h3>
          <p class="mt-2 text-sm text-gray-400">Which method holds up on service-tech apparel.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Quote in 24 hours. Stocked polos ship same week.</h2>
      <p class="mb-8 text-lg text-gray-300">Talk to a real human who knows service-tech apparel.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
