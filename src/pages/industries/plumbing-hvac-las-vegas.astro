 <!-- Related — concrete -->
 <section class="bg-concrete py-16">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-6">Related</p>
 <div class="grid gap-5 md:grid-cols-3">
 <a href="/industries/electrical-contractors-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Electrical Contractors</h3>
