---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Plumbing and HVAC Service Uniforms | Las Vegas',
 description:
 'Embroidered service tech uniforms, branded polos, and customer-facing apparel for Las Vegas plumbing and HVAC contractors. Name + title embroidery, name patches, and quotes turned around quickly.',
 h1Pre: 'Plumbing & HVAC',
 hero: '/images/generated/kit-plumbing-hvac.jpg',
}

const compliance = [
 {
 code: 'Customer Trust',
 title: 'A uniformed tech closes more service calls',
 body: 'When the homeowner opens the door, the embroidered logo, name, and title do half the trust-building before the tech says a word. Branded uniforms are the cheapest sales tool you have.',
 },
 {
 code: 'NV State Contractor Board',
 title: 'License-visible branding done right',
 body: 'License number on the truck, on the shirt, on the invoice — Nevada customers expect to see it. We lay out chest embroidery so license, company, and tech name all read clean from 6 feet. (See <a href="https://nscb.nv.gov/" rel="noopener" class="text-gold-700 hover:underline">NSCB licensing rules</a>.)',
 },
 {
 code: 'OSHA / NIOSH Heat Stress',
 title: 'Service tech apparel for 115° attic work',
 body: 'HVAC techs work in 130°+ attics in July. We stock moisture-wicking poly polos and lightweight long-sleeves so techs stay covered without overheating between calls. (Reference: <a href="https://www.osha.gov/heat-exposure" rel="noopener" class="text-gold-700 hover:underline">OSHA heat exposure guidance</a> and <a href="https://www.cdc.gov/niosh/topics/heatstress/" rel="noopener" class="text-gold-700 hover:underline">NIOSH heat stress</a>.)',
 },
]

const gear = [
 { name: 'Embroidered service polos', detail: 'Port Authority K500 · name + title + logo · 8 stocked colors', img: '/images/generated/service-embroidery.jpg' },
 { name: 'Mechanic-style work shirts', detail: 'Red Kap or Dickies · button-down · stitched name patch + chest logo', img: '/images/generated/kit-plumbing-hvac.jpg' },
 { name: 'Branded service tees', detail: 'Carhartt K87 or poly blend · printed back · for ride-along + warehouse', img: '/images/generated/service-screen-printing.jpg' },
 { name: 'Tech name patches + tags', detail: 'Sewn-on or velcro · interchangeable for new hires · matches uniform colorway', img: '/images/generated/service-company-stores.jpg' },
]

const useCases = [
 'Residential service techs in embroidered polos with name + title (lead tech, journeyman, apprentice)',
 'Commercial mechanical crews in heavier work shirts with company name patch',
 'Install crews in branded tees and hi-vis when working new construction sites',
 'Dispatcher and office staff in lighter-weight branded polos for the front counter',
 'Apprentice / helper differentiation by polo color or sleeve embroidery',
 'Branded swag for trade shows, AGC events, and home shows around the valley',
]

const faqs = [
 {
 q: 'Can you do name embroidery on every shirt and still do it without slowing the order down?',
 a: 'Yes. Once we have your logo and tech roster on file, name embroidery adds about a day to the standard run — not a week. We stitch each name to order; the per-shirt cost is fixed regardless of name length.',
 },
 {
 q: 'What\'s better for service techs — embroidered polos or mechanic-style work shirts?',
 a: 'Polos for residential service (cleaner customer-facing look). Mechanic shirts for commercial mechanical or anyone crawling in attics and under cabinets all day — they wear the abuse better and the name patches are interchangeable.',
 },
 {
 q: 'Do you stock moisture-wicking polos for Vegas summer?',
 a: 'Yes. Port Authority K500 and Sport-Tek ST650 in 100% poly micro-mesh, both stocked S–4XL. Cotton blend polos look nicer at week one but they\'re soaked through by 11am in July.',
 },
 {
 q: 'How do you handle name changes when a tech leaves or a new one starts?',
 a: 'Name patches are velcro-swappable on the work-shirt program. For embroidered polos, we stitch new ones as needed — you keep the old shirts as ride-along or shop gear, or we re-stitch over for a small charge.',
 },
 {
 q: 'Can you put our license number and service line on every shirt?',
 a: 'Yes. We typically run license number on the sleeve and the service number on the back collar or hem tag. Keeps the chest clean for the logo + name and the customer still sees the contact info.',
 },
 {
 q: 'Do you set up company stores for plumbing and HVAC shops?',
 a: 'Yes. Particularly useful for mid-size shops (15+ techs) where you want each tech to log in, see only their approved kit, and order with their allowance. We print, embroider, ship — no closet inventory on your end.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
 { '@type': 'ListItem', position: 3, name: 'Plumbing & HVAC', item: 'https://bighornthreads.com/industries/plumbing-hvac-las-vegas/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear for Plumbing and HVAC Contractors',
 serviceType: 'Branded service uniforms and embroidered apparel',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 ],
 audience: { '@type': 'BusinessAudience', audienceType: 'Plumbing and HVAC Contractors' },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/industries/plumbing-hvac-las-vegas/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover object-center" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-950 via-navy-950/85 to-navy-950/40"></div>

 <div class="mx-auto max-w-7xl px-4 pb-16 pt-32 sm:px-6 sm:pt-40 lg:px-8 lg:pb-24 lg:pt-44">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
