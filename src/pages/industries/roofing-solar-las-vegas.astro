---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Roofing and Solar Crew Apparel | Las Vegas',
  description:
    'Sun-protective hi-vis shirts, branded hoodies for early starts, and embroidered service polos for Las Vegas roofing and solar installation crews. Built for 110° rooftops.',
  h1Pre: 'Roofing & Solar',
  hero: '/images/generated/kit-roofing.jpg',
}

const conditions = [
  { num: '110°+', label: 'Rooftop ambient', body: 'Vegas summer rooftops hit 130°F surface temps. Cotton kills. We stock moisture-wicking poly blends and sun-protective long-sleeve hi-vis that crews actually keep on.' },
  { num: '5 AM', label: 'Start time', body: 'Nevada\'s heat law allows 5 AM construction starts in summer. That means branded hoodies and warm layers for the first hour of the shift, then breathable swap-outs.' },
  { num: '8 hrs', label: 'UV exposure', body: 'A roofer averages 8 hours of UPF-relevant sun exposure per shift. UPF 50+ long-sleeves protect more than they cost in heat retention.' },
]

const gear = [
  { name: 'UPF 50+ long-sleeve hi-vis', detail: 'Sun-blocking · ANSI Class 2 · embroidered chest', img: '/images/generated/kit-roofing.jpg' },
  { name: 'Hi-vis tees (poly blend)', detail: 'Wicking · Class 2 · screen-printed back', img: '/images/generated/service-screen-printing.jpg' },
  { name: 'Branded crew hoodies', detail: 'Heavyweight · for 5 AM starts · embroidered or printed', img: '/images/generated/service-embroidery.jpg' },
  { name: 'Solar installer service polos', detail: 'Customer-facing roles · Port Authority · embroidered', img: '/images/generated/service-company-stores.jpg' },
]

const useCases = [
  'Solar install crews with customer-facing branding (homeowner sees the company)',
  'Roof tear-off crews where hi-vis is non-negotiable on residential streets',
  'Service / repair techs in branded service polos with name embroidery',
  'Sales reps doing site walks in lighter branded button-downs',
  'Office staff and project managers in matched but lighter-weight gear',
  'Trade-show + industry event apparel for SEIA and NABCEP events',
]

const faqs = [
  {
    q: 'What\'s the best fabric for Vegas rooftop work in summer?',
    a: 'Polyester or poly-cotton blends with moisture-wicking — never 100% cotton. We stock 100% polyester hi-vis from ML Kishigo and Pioneer that breathes well at 100°+ ambient. UPF 50+ long-sleeve options block sun without trapping heat.',
  },
  {
    q: 'Can you do solar-installer-specific branding (NABCEP cert, manufacturer partner badges)?',
    a: 'Yes — embroidered NABCEP, Tesla, Enphase, and SunPower cert badges go on chest or sleeve. Multi-cert installers usually run them stacked or as a single embroidered patch.',
  },
  {
    q: 'How fast can you turn around 50 hi-vis shirts for a new crew starting Monday?',
    a: 'Standard rush is 72 hours when files are on hand. New artwork adds a day. Call before 10am Tuesday and Friday delivery is realistic.',
  },
  {
    q: 'Do you stock hi-vis in non-standard sizes (XS for smaller crews, 5XL+)?',
    a: 'Yes — adult S–4XL in stock, 5XL on a 1-week lead time. Youth sizes for apprentice ride-along programs by request.',
  },
  {
    q: 'Can roofing crews use a company store like GCs do?',
    a: 'Yes. Particularly useful when you have multiple crews and varying gear preferences. Each employee gets an allowance, picks their sizes, and gear ships direct. No shop closet inventory.',
  },
  {
    q: 'Do you handle Tyvek or coverall branding for tear-off crews?',
    a: 'We can screen-print on Tyvek single-use coveralls in bulk (cases of 25+). For reusable FR coveralls, we embroider chest patches that don\'t void the rating.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
    { '@type': 'ListItem', position: 3, name: 'Roofing & Solar', item: 'https://bighornthreads.com/industries/roofing-solar-las-vegas/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear for Roofing and Solar Crews',
  serviceType: 'Sun-protective branded apparel',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: [
    { '@type': 'City', name: 'Las Vegas' },
    { '@type': 'City', name: 'Henderson' },
    { '@type': 'City', name: 'North Las Vegas' },
  ],
  audience: { '@type': 'BusinessAudience', audienceType: 'Roofing and Solar Contractors' },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/industries/roofing-solar-las-vegas/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/industries/" class="hover:text-gold-400">Industries</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Roofing &amp; Solar</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Sun-Protective Hi-Vis and Crew Gear <span class="text-gold-500">Built for 110° Vegas Rooftops.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        UPF long-sleeves that crews actually keep on. Hi-vis poly blends that wick instead of trap. Branded hoodies for 5 AM starts. We outfit roofers and solar installers across Vegas, Henderson, and North Las Vegas.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Conditions -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Vegas Conditions</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Why standard hi-vis fails on Vegas rooftops.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Most workwear rated for "construction" was specced in 75° conditions. Pull on a cotton hi-vis at 11am in July and you're peeling it off by noon. We pick gear that holds up.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {conditions.map((c) => (
          <div class="rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="mb-3 flex items-baseline gap-3">
              <span class="font-heading text-4xl font-bold text-gold-500">{c.num}</span>
              <span class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-gray-300">{c.label}</span>
            </div>
            <p class="text-base leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gear -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Gear</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we make for roofing and solar crews.</h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {gear.map((g) => (
          <div class="overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
              <img src={g.img} alt={g.name} class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="mb-2 font-heading text-lg font-bold tracking-tight text-white">{g.name}</h3>
              <p class="text-sm leading-relaxed text-gray-400">{g.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Typical Orders</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Crew configurations we run every week.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Solar installers usually need split kits — customer-facing techs in branded polos, install crews in hi-vis. Roofers tend to standardize across the crew but split office vs field by garment weight.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">All Services →</a>
            <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Company Stores →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {useCases.map((u, i) => (
            <li class="flex items-start gap-4 rounded-xl border border-navy-700/30 bg-navy-900/30 p-4 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-base leading-relaxed text-gray-200">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Questions roofing and solar crews ask us.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/industries/electrical-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Electrical Contractors</h3>
          <p class="mt-2 text-sm text-gray-400">FR shirts, hi-vis, and code-compliant decoration.</p>
        </a>
        <a href="/industries/general-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">General Contractors</h3>
          <p class="mt-2 text-sm text-gray-400">Crew uniforms, sub branding, and rapid onboarding.</p>
        </a>
        <a href="/blog/screen-printing-vs-embroidery-construction/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Screen Print vs Embroidery</h3>
          <p class="mt-2 text-sm text-gray-400">Which decoration method holds up on a Vegas job site.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Outfit your crew for the rooftop, not the office.</h2>
      <p class="mb-8 text-lg text-gray-300">Quote in 24 hours. Stocked hi-vis ships same week.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
