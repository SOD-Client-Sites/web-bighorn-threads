---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Roofing and Solar Crew Apparel | Las Vegas',
 description:
 'Sun-protective hi-vis shirts, branded hoodies for early starts, and embroidered service polos for Las Vegas roofing and solar installation crews. Built for 110° rooftops.',
 h1Pre: 'Roofing & Solar',
 hero: '/images/generated/kit-roofing.jpg',
}

const conditions = [
 { num: '110°+', label: 'Rooftop ambient', body: 'Vegas summer rooftops hit 130°F surface temps. Cotton kills. We stock moisture-wicking poly blends and sun-protective long-sleeve hi-vis that crews actually keep on. (See <a href="https://www.osha.gov/heat-exposure" rel="noopener" class="text-gold-700 hover:underline">OSHA heat exposure guidance</a>.)' },
 { num: '5 AM', label: 'Start time', body: 'Nevada\'s heat-stress rules push commercial construction crews to pre-dawn starts in summer. That means branded hoodies and warm layers for the first hour of the shift, then breathable swap-outs.' },
 { num: '8 hrs', label: 'UV exposure', body: 'A roofer averages 8 hours of UPF-relevant sun exposure per shift. UPF 50+ long-sleeves protect more than they cost in heat retention. (Reference: <a href="https://www.cdc.gov/niosh/topics/heatstress/" rel="noopener" class="text-gold-700 hover:underline">NIOSH heat stress</a>.)' },
]

const gear = [
 { name: 'UPF 50+ long-sleeve hi-vis', detail: 'Sun-blocking · ANSI Class 2 · embroidered chest', img: '/images/generated/kit-roofing.jpg' },
 { name: 'Hi-vis tees (poly blend)', detail: 'Wicking · Class 2 · screen-printed back', img: '/images/generated/service-screen-printing.jpg' },
 { name: 'Branded crew hoodies', detail: 'Heavyweight · for 5 AM starts · embroidered or printed', img: '/images/generated/service-embroidery.jpg' },
 { name: 'Solar installer service polos', detail: 'Customer-facing roles · Port Authority · embroidered', img: '/images/generated/service-company-stores.jpg' },
]

const useCases = [
 'Solar install crews with customer-facing branding (homeowner sees the company)',
 'Roof tear-off crews where hi-vis is non-negotiable on residential streets',
 'Service / repair techs in branded service polos with name embroidery',
 'Sales reps doing site walks in lighter branded button-downs',
 'Office staff and project managers in matched but lighter-weight gear',
 'Trade-show + industry event apparel for SEIA and NABCEP events',
]

const faqs = [
 {
 q: 'What\'s the best fabric for Vegas rooftop work in summer?',
 a: 'Polyester or poly-cotton blends with moisture-wicking — never 100% cotton. We stock 100% polyester hi-vis from ML Kishigo and Pioneer that breathes well at 100°+ ambient. UPF 50+ long-sleeve options block sun without trapping heat.',
 },
 {
 q: 'Can you do solar-installer-specific branding (NABCEP cert, manufacturer partner badges)?',
 a: 'Yes — embroidered NABCEP, Tesla, Enphase, and SunPower cert badges go on chest or sleeve. Multi-cert installers usually run them stacked or as a single embroidered patch.',
 },
 {
 q: 'How fast can you turn around 50 hi-vis shirts for a new crew starting Monday?',
 a: 'Rush options are available. New artwork adds a small amount of prep time for digitizing or screen burn. Call us with the deadline and we\'ll tell you straight whether it works and what any rush surcharge would be.',
 },
 {
 q: 'Do you stock hi-vis in non-standard sizes (XS for smaller crews, 5XL+)?',
 a: 'Yes — adult S–4XL in stock; 5XL is a special-order item we can quote for you. Youth sizes for apprentice ride-along programs by request.',
 },
 {
 q: 'Can roofing crews use a company store like GCs do?',
 a: 'Yes. Particularly useful when you have multiple crews and varying gear preferences. Each employee gets an allowance, picks their sizes, and gear ships direct. No shop closet inventory.',
 },
 {
 q: 'Do you handle Tyvek or coverall branding for tear-off crews?',
 a: 'We can screen-print on Tyvek single-use coveralls in bulk (cases of 25+). For reusable FR coveralls, we embroider chest patches that don\'t void the rating.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://bighornthreads.com/industries/' },
 { '@type': 'ListItem', position: 3, name: 'Roofing & Solar', item: 'https://bighornthreads.com/industries/roofing-solar-las-vegas/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear for Roofing and Solar Crews',
 serviceType: 'Sun-protective branded apparel',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 ],
 audience: { '@type': 'BusinessAudience', audienceType: 'Roofing and Solar Contractors' },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
