---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Embroidery in Las Vegas',
 description:
 'Custom embroidery in Las Vegas for polos, hats, jackets, and uniforms. on first run, FR-safe stitching, thread-color matching, 12-piece minimum.',
 hero: '/images/generated/service-embroidery.jpg',
}

const process = [
 { step: '01', title: 'Quote + digitizing', body: 'Send your logo. We digitize it for embroidery — converting the artwork into a stitch file. First-time digitizing is free with order.' },
 { step: '02', title: 'Sew-out + approval', body: 'We do a test sew on a similar fabric to verify thread density, color, and detail. You approve before production starts.' },
 { step: '03', title: 'Production run', body: '12-head and 6-head machines depending on count. Inline color matching ensures consistency from piece to piece.' },
 { step: '04', title: 'Trim, fold, deliver', body: 'Backing trimmed, threads cleaned, pieces folded and sorted by size. Local delivery, pickup, or split-ship to employees.' },
]

const placements = [
 { name: 'Left chest', detail: 'The standard. ~3.5" wide. Fits 95% of polo and shirt programs.' },
 { name: 'Right chest', detail: 'Mirror to LC, often used for name embroidery alongside left-chest logo.' },
 { name: 'Sleeve', detail: 'Cap sleeve or full sleeve. Good for cert badges or secondary brand marks.' },
 { name: 'Back yoke / center back', detail: 'For larger logos on jackets, hoodies, and outerwear.' },
 { name: 'Hat front', detail: 'Standard 2.5" tall × 4.5" wide. Curved or flat bill.' },
 { name: 'Hat side / back', detail: 'Smaller secondary marks on cap side panels or rear strap area.' },
]

const stitchTypes = [
 { count: 'Up to 7,000 stitches', label: 'Standard logo', notes: 'Most company logos fall in this range. Quick run, cleanest look.' },
 { count: '7,000 – 12,000 stitches', label: 'Detailed logo', notes: 'Logos with multiple colors, fine type, or complex shapes. Slight upcharge.' },
 { count: '12,000+ stitches', label: 'Heavy / large designs', notes: 'Big back logos, dense fills. Custom quote.' },
]

const faqs = [
 {
 q: 'What\'s the minimum order for embroidery?',
 a: '12 pieces. Below 12, we still produce but charge a small per-piece premium. Most ongoing accounts run 24+ at a time for the cost-per-piece break.',
 },
 {
 q: 'How much does digitizing cost?',
 a: 'Free on the first order with us. After that, it\'s on file forever — every reorder uses the same stitch file with no setup. If your logo changes, we re-digitize at the standard rate (a flat fee depending on complexity).',
 },
 {
 q: 'Can you embroider on FR (flame-resistant) shirts without voiding the rating?',
 a: 'Yes — using FR-compatible thread (Nomex or aramid blend) and following the garment manufacturer\'s placement rules. We verify the spec before each FR run. See our electrical contractors page for more on FR.',
 },
 {
 q: 'How long does an embroidery order take?',
 a: 'It depends on quantity, garment availability, and whether the artwork is already digitized. Repeat orders with files on hand move quickly. New artwork adds prep time for digitizing. Tell us your deadline and we\'ll quote a real date.',
 },
 {
 q: 'What thread colors can you match?',
 a: 'We carry the full Madeira and Robison-Anton thread libraries — over 400 colors between them. Pantone matching to within ~2 shades on most colors. Brand colors get locked on file once approved.',
 },
 {
 q: 'Do you do name embroidery for service uniforms?',
 a: 'Yes. Name + title runs about additional. Common for HVAC, plumbing, electrical service techs. We can store name lists per crew and reorder by employee — useful for high-turnover roles.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://bighornthreads.com/services/' },
 { '@type': 'ListItem', position: 3, name: 'Embroidery', item: 'https://bighornthreads.com/services/embroidery-las-vegas/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Embroidery in Las Vegas',
 serviceType: 'Embroidery on apparel and headwear',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 ],
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
