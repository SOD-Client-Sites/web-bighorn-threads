---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Custom Screen Printing in Las Vegas',
  description:
    'Custom screen printing in Las Vegas for construction crews, contractors, and trades. Plastisol and water-based ink, Pantone matching, no setup fee over 25 pieces, rush options.',
  hero: '/images/generated/service-screen-printing.jpg',
}

const process = [
  { step: '01', title: 'Quote + artwork', body: 'Send your logo + counts. We send back a Fast quote with mockup, garment recommendations, and any artwork notes (color separations, ink choices).' },
  { step: '02', title: 'Approval + screen burn', body: 'Once you approve, we separate colors, burn the screens, and lock in Pantone-matched inks. New artwork adds a day for screen prep.' },
  { step: '03', title: 'Production + cure', body: 'Manual or auto press depending on count. Cure tunnel locks the ink. Inline QC pulls anything off-register or off-color before fold.' },
  { step: '04', title: 'Fold, pack, deliver', body: 'Folded, polybagged if requested, sorted by size. Local Vegas pickup or we deliver to your office, jobsite, or split-ship to employees.' },
]

const inkTypes = [
  { name: 'Plastisol', best: 'Bold, punchy graphics on cotton or blended tees. Most jobs.', notes: 'Sits on top of the fabric. Bright, opaque, durable through rough use.' },
  { name: 'Water-based', best: 'Soft hand-feel, vintage / faded look, super-soft tees.', notes: 'Sinks into the fabric. Slightly less opaque on dark garments. Premium feel.' },
  { name: 'Discharge', best: 'Dark cotton tees where you want zero ink feel.', notes: 'Removes the dye and replaces it with new color. Cotton only. Soft as untreated.' },
  { name: 'Athletic / nylon-safe', best: 'Performance polyester, nylon, hi-vis, and FR garments.', notes: 'Specialty inks that bond to synthetics without bleeding or cracking.' },
]

const garments = ['T-shirts (cotton + blends)', 'Long-sleeve tees', 'Hoodies + crewnecks', 'Hi-vis polyester', 'FR shirts (with FR-safe inks)', 'Tote bags + canvas', 'Workwear (Carhartt, Dickies)', 'Polos (smaller print areas)']

const minimums = [
  { count: '24 pieces', best: 'Standard minimum for screen printing. Setup fees apply under 25.' },
  { count: '50 pieces', best: 'Sweet spot for cost-per-piece on most single-color prints.' },
  { count: 'larger orders', best: 'Multi-color, multi-location, or complex jobs make economic sense.' },
  { count: '500+ pieces', best: 'Auto-press production. Lowest per-piece cost. Rush still possible.' },
]

const faqs = [
  {
    q: 'What\'s the minimum order for screen printing?',
    a: '24 pieces. Under 25 pieces incurs a setup fee per color per location. Most contractors order 50+ to keep cost per piece low.',
  },
  {
    q: 'How fast can you turn around a rush order?',
    a: 'Rush options available. Call early in the day for fast quote turnaround. We don\'t panic-charge for rush — most are at standard rates if your timeline allows real production hours.',
  },
  {
    q: 'Can you Pantone-match exact brand colors?',
    a: 'Yes. We mix Pantone-matched inks in-house. Once your color is dialed in on the first run, it\'s locked on file for every reorder. Pantone Coated, Uncoated, and Process — all supported.',
  },
  {
    q: 'Do you screen print on FR (flame-resistant) shirts?',
    a: 'Yes — using FR-compatible inks specifically rated to preserve the NFPA 70E or NFPA 2112 certification. We verify garment-by-garment before each run.',
  },
  {
    q: 'How many colors can you print in one job?',
    a: 'Up to 8 colors on the manual press, 12 on the auto. Most contractor logos run in 1–3 colors. Photographic / full-color jobs are usually better suited to DTG or DTF — we\'ll tell you which method fits before you commit.',
  },
  {
    q: 'Will the print last?',
    a: 'Plastisol holds up through extensive industrial washes when properly cured. Water-based fades earlier (intentionally, for the soft look). Discharge lasts the life of the garment. We pick the right method for how the gear will be used.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://bighornthreads.com/services/' },
    { '@type': 'ListItem', position: 3, name: 'Screen Printing', item: 'https://bighornthreads.com/services/screen-printing-las-vegas/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Screen Printing in Las Vegas',
  serviceType: 'Screen printing on apparel',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: [
    { '@type': 'City', name: 'Las Vegas' },
    { '@type': 'City', name: 'Henderson' },
    { '@type': 'City', name: 'North Las Vegas' },
  ],
  offers: { '@type': 'Offer', priceCurrency: 'USD', priceSpecification: { '@type': 'PriceSpecification', minPrice: 8 } },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/services/screen-printing-las-vegas/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/services/" class="hover:text-gold-400">Services</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Screen Printing</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Service</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Custom Screen Printing <span class="text-gold-500">for Vegas Crews and Contractors.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        Plastisol, water-based, and FR-safe inks. Pantone-matched. No setup fee over 25 pieces. Standard 7-day production, rush options, fast quote turnaround.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/services/embroidery-las-vegas/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          Compare to Embroidery
        </a>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">How It Works</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">From quote to delivery in 7 days.</h2>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {process.map((p) => (
          <div class="rounded-2xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/30 hover:bg-navy-900/60">
            <span class="mb-4 block font-mono text-xs font-bold tracking-wider text-gold-500">{p.step}</span>
            <h3 class="mb-3 font-heading text-lg font-bold leading-tight tracking-tight text-white">{p.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ink types -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Ink Selection</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Four ink families. We pick the one that fits the job.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Most shops only run one. We carry plastisol, water-based, discharge, and athletic — and we choose based on garment, conditions, and how you want it to feel.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {inkTypes.map((ink) => (
          <div class="rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <h3 class="mb-2 font-heading text-xl font-bold tracking-tight text-white">{ink.name}</h3>
            <p class="mb-3 text-sm leading-relaxed text-gold-400">Best for: {ink.best}</p>
            <p class="text-sm leading-relaxed text-gray-300">{ink.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Garments + Minimums -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Garments</span>
          <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we print on.</h2>
          <p class="mb-6 text-lg leading-relaxed text-gray-300">
            Cotton through synthetics. Decorate-able workwear. We carry the brands trades actually wear — Carhartt, Dickies, Bulwark, Port Authority, ML Kishigo.
          </p>
          <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {garments.map((g) => (
              <li class="flex items-start gap-2 text-sm text-gray-200">
                <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
                {g}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Minimums &amp; Pricing</span>
          <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Built around real order sizes.</h2>
          <div class="space-y-3">
            {minimums.map((m) => (
              <div class="rounded-xl border border-navy-700/40 bg-navy-900/40 p-4">
                <span class="mb-1 block font-mono text-sm font-bold text-gold-500">{m.count}</span>
                <p class="text-sm text-gray-300">{m.best}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Deep dive -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Buyer's Guide</span>
      <h2 class="mb-8 font-heading text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        Custom screen printing for Las Vegas trades, crews, and brand programs.
      </h2>

      <div class="space-y-5 text-lg leading-relaxed text-navy-200">
        <p>
          Screen printing is the most cost-effective decoration method for high-volume orders — t-shirts, hoodies, sweatshirts, and any garment where the design is going on flat fabric in 1-6 ink colors. Bighorn Threads runs automatic screen-printing presses from our Las Vegas production shop, printing for construction crews, sports teams, schools, trade shows, fundraising events, and brand merchandise programs. Minimum order is 24 pieces per design — under that we switch you to DTF transfers, which carry no minimum and no setup fee. Above 24 pieces, screen printing is almost always the cheaper option per shirt, and the durability is unmatched: a properly cured plastisol print survives extensive industrial wash cycles without cracking, fading, or peeling.
        </p>
        <p>
          The right ink type depends on the garment and the look you want. Plastisol — the standard workhorse — is a thick, opaque ink that sits on top of the fabric. It produces vivid colors, blocks underlying fabric color, and survives every wash cycle. Water-based inks soak into the fabric instead of sitting on top, producing a softer hand and a more vintage look — preferred for fashion-forward apparel and softer-feel brand merch but less durable on heavy work shirts. Discharge inks (a specialty water-based variant) actually remove dye from dark cotton and replace it with the print color, leaving zero hand. We carry all three and we'll recommend by use case, not by what's easiest to set up.
        </p>
        <p>
          Setup is where most catalog screen printers add cost. Every color in your design requires a separate screen burned at the shop. We keep setup fees transparent and quote them up front — no surprise screen charges added at invoice. For multi-color designs we batch the screens efficiently, and for repeat orders we save the screens so reorders skip the setup time entirely.
        </p>
        <p>
          For Las Vegas construction trades, the most-printed item is the heavyweight cotton work tee — Carhartt K87, Bayside 5100, Hanes Beefy-T — in heavyweight 6.75 oz cotton with a left-chest or full-front print. Hi-vis tees and safety apparel can be screen-printed but the print area is restricted by ANSI 107 retroreflective tape coverage rules; we follow the published decoration guides on every hi-vis order so the certification stays intact. FR-rated garments cannot be screen-printed with standard plastisol — the ink melts in arc events. For FR, we use FR-safe inks on the rare order that requires print decoration, but embroidery with Nomex thread is the standard FR decoration spec.
        </p>
        <p>
          Turnaround is fast from artwork approval on standard orders. Rush orders are available most weeks when blank inventory cooperates — we keep the high-volume garments (Carhartt K87, Bayside 5100, Gildan G500, Port & Company PC54) in stock locally so rush orders for trade shows, ribbon cuttings, and last-minute new-hire onboardings are realistic. Free delivery inside the Las Vegas Valley on qualifying orders.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Screen printing questions, answered.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/services/embroidery-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Embroidery</h3>
          <p class="mt-2 text-sm text-gray-400">When you want stitched logos for polos, hats, and outerwear.</p>
        </a>
        <a href="/services/rush-orders-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Rush Orders</h3>
          <p class="mt-2 text-sm text-gray-400">rush turnaround on most jobs. 48 for repeat clients.</p>
        </a>
        <a href="/blog/screen-printing-vs-embroidery-construction/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Screen Print vs Embroidery</h3>
          <p class="mt-2 text-sm text-gray-400">Which is right for construction gear?</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Send your logo. We'll send a Fast quote.</h2>
      <p class="mb-8 text-lg text-gray-300">No setup fee over 25 pieces. Pantone-matched. Built to last.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
