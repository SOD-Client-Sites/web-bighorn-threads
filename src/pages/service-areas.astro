---
import BaseLayout from '@/layouts/BaseLayout.astro'

const areas = [
  {
    href: '/service-areas/henderson-nv/',
    name: 'Henderson, NV',
    blurb:
      'Master-planned community build-out, south-valley service trades, and Henderson Hospital commercial work. Free delivery to Eastgate, Gibson, and Stephanie corridor.',
  },
  {
    href: '/service-areas/north-las-vegas/',
    name: 'North Las Vegas',
    blurb:
      'Apex Industrial Park, Aliante build-out, and the north-valley GC ecosystem. Heavy industrial and distribution crews running long days in hot conditions.',
  },
  {
    href: '/service-areas/summerlin/',
    name: 'Summerlin',
    blurb:
      'West-side residential and mixed-use commercial. Downtown Summerlin, Red Rock, and The Ridges. Clean-presentation crews for visible work.',
  },
  {
    href: '/service-areas/spring-valley/',
    name: 'Spring Valley',
    blurb:
      'Mid-valley service trades and smaller commercial fit-out. HVAC, plumbing, and electrical shops running daily calls across the west side.',
  },
  {
    href: '/service-areas/boulder-city/',
    name: 'Boulder City',
    blurb:
      'Hoover Dam, Eldorado Valley solar fields, and Railroad Pass industrial. Solar EPCs, utility crews, and the hardest working desert in Nevada.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
  ],
}
---

<BaseLayout
  title="Service Areas — Las Vegas Valley Workwear & Branded Apparel"
  description="Bighorn Threads serves construction and service trades across the Las Vegas valley — Henderson, North Las Vegas, Summerlin, Spring Valley, and Boulder City. Free local delivery, 24-hour quotes."
  canonical="https://bighornthreads.com/service-areas/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/40 bg-navy-900/50 pt-28 pb-16 sm:pt-32 sm:pb-20">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-gray-900"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_30%,_rgba(193,155,61,0.12),_transparent)]"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-5 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Service Areas</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Las Vegas Valley · Southern Nevada</span>
      <h1 class="mb-5 font-heading text-4xl font-bold leading-[1.05] tracking-tight text-white sm:text-5xl lg:text-6xl">
        Where We <span class="text-gold-500">Deliver Gear</span>
      </h1>
      <p class="max-w-3xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        We serve construction and service trades across the Las Vegas valley. Free local delivery on commercial addresses, 24-hour quote turnaround, and crews on the ground who know the job sites.
      </p>
    </div>
  </section>

  <!-- Areas grid -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {areas.map((a) => (
          <a href={a.href} class="group flex flex-col rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/50 hover:bg-navy-900/60">
            <span class="mb-2 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-gold-500">Las Vegas Valley</span>
            <h2 class="mb-3 font-heading text-xl font-bold tracking-tight text-white group-hover:text-gold-400">{a.name}</h2>
            <p class="mb-5 flex-1 text-sm leading-relaxed text-gray-300">{a.blurb}</p>
            <span class="inline-flex items-center gap-1.5 font-mono text-[11px] font-bold uppercase tracking-wider text-gold-500 group-hover:text-gold-400">
              View details
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="mt-12 rounded-xl border border-gold-500/30 bg-gradient-to-br from-navy-900 to-navy-950 p-8 text-center sm:p-10">
        <h2 class="mb-3 font-heading text-2xl font-bold tracking-tight text-white sm:text-3xl">Outside these areas?</h2>
        <p class="mx-auto mb-6 max-w-2xl text-base leading-relaxed text-gray-300">
          We still ship statewide and beyond. Call us and we'll work out logistics — rush jobs, larger rollouts, and multi-location crews are what we do.
        </p>
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
          <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 hover:bg-gold-400">Call 725.235.6196</a>
          <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-7 py-3 font-mono text-base font-medium text-white hover:border-gold-500 hover:text-gold-500">Send us a note</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
