---
import BaseLayout from '@/layouts/BaseLayout.astro'

const areas = [
 {
 href: '/service-areas/henderson-nv/',
 name: 'Henderson, NV',
 blurb:
 'Master-planned community build-out, south-valley service trades, and Henderson Hospital commercial work. Local delivery available across the Eastgate, Gibson, and Stephanie corridor.',
 },
 {
 href: '/service-areas/north-las-vegas/',
 name: 'North Las Vegas',
 blurb:
 'Apex Industrial Park, Aliante build-out, and the north-valley GC ecosystem. Heavy industrial and distribution crews running long days in hot conditions.',
 },
 {
 href: '/service-areas/summerlin/',
 name: 'Summerlin',
 blurb:
 'West-side residential and mixed-use commercial. Downtown Summerlin, Red Rock, and The Ridges. Clean-presentation crews for visible work.',
 },
 {
 href: '/service-areas/spring-valley/',
 name: 'Spring Valley',
 blurb:
 'Mid-valley service trades and smaller commercial fit-out. HVAC, plumbing, and electrical shops running daily calls across the west side.',
 },
 {
 href: '/service-areas/boulder-city/',
 name: 'Boulder City',
 blurb:
 'Hoover Dam, Eldorado Valley solar fields, and Railroad Pass industrial. Solar EPCs, utility crews, and the hardest working desert in Nevada.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
 ],
}
---

<BaseLayout
 title="Service Areas — Las Vegas Valley Workwear & Branded Apparel"
 description="Bighorn Threads serves construction and service trades across the Las Vegas valley — Henderson, North Las Vegas, Summerlin, Spring Valley, and Boulder City. Local delivery."
 canonical="https://bighornthreads.com/service-areas/"
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/crew-vegas.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-6xl px-4 pb-16 pt-14 sm:px-6 sm:pb-20 sm:pt-16 lg:px-8">
 <nav class="mb-5 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Service Areas</span>
 </nav>

 <p class="kicker mb-3">Las Vegas Valley · Southern Nevada</p>
 <h1 class="mb-5 font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Where We <span class="text-gold-400">Deliver Gear</span>
 </h1>
 <p class="max-w-3xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 We serve construction and service trades across the Las Vegas valley, with crews on the ground who know the job sites.
 </p>
 </div>
 </section>

 <!-- Areas grid — concrete -->
 <section class="bg-concrete py-16 sm:py-20">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
 {areas.map((a) => (
 <a href={a.href} class="group flex flex-col border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <span class="spec mb-2 text-gold-600">Las Vegas Valley</span>
 <h2 class="mb-3 font-heading text-xl font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">{a.name}</h2>
 <p class="mb-5 flex-1 text-sm leading-relaxed text-ash">{a.blurb}</p>
 <span class="inline-flex items-center gap-1.5 font-mono text-[11px] font-bold uppercase tracking-wider text-gold-600">
 View details
 <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </span>
 </a>
 ))}
 </div>

 <div class="mt-12 border-l-4 border-gold-500 bg-panel">
 <div class="border border-l-0 border-hairline p-8 text-center sm:p-10">
 <h2 class="mb-3 font-heading text-2xl font-extrabold uppercase tracking-tight text-charcoal sm:text-3xl">Outside these areas?</h2>
 <p class="mx-auto mb-6 max-w-2xl text-base leading-relaxed text-ash">
 We still ship statewide and beyond. Call us and we'll work out logistics — rush jobs, larger rollouts, and multi-location crews are what we do.
 </p>
 <div class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
 <a href="tel:+17029048923" class="btn-primary text-base">Call 702.904.8923</a>
 <a href="/contact/" class="btn-secondary text-base">Send us a note</a>
 </div>
 </div>
 </div>
 </div>
 </section>
</BaseLayout>
