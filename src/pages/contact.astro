  <!-- ============================================================ -->
  <!-- FORM VALIDATION + SUBMIT (progressive enhancement) =========== -->
  <!-- ============================================================ -->
  <script is:inline>
    (function () {
      const form = document.getElementById('quoteForm')
      const status = document.getElementById('formStatus')
      if (!form || !status) return

      const setStatus = (msg, tone) => {
        status.textContent = msg
        status.className =
          'mt-6 text-sm ' +
          (tone === 'error'
            ? 'text-red-400'
            : tone === 'success'
              ? 'text-gold-400'
              : 'text-gray-400')
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault()

        // Honeypot — silently drop bots
        const hp = form.querySelector('input[name="website"]')
        if (hp && hp.value) {
          setStatus('Thanks — we got it.', 'success')
          form.reset()
          return
        }

        // Basic required validation
        const required = ['name', 'company', 'email']
        for (const field of required) {
          const el = form.elements.namedItem(field)
          if (!el || !el.value.trim()) {
            setStatus(
              'Please fill in your name, company, and email so we can reply.',
              'error'
            )
            if (el && typeof el.focus === 'function') el.focus()
            return
          }
        }

        const email = form.elements.namedItem('email')
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
          setStatus('That email does not look right — mind double-checking?', 'error')
          email.focus()
          return
        }

        setStatus('Sending your request...', 'info')
        const submitBtn = form.querySelector('button[type="submit"]')
        if (submitBtn) submitBtn.disabled = true

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          })
          if (res.ok) {
            setStatus(
              'Got it. A real human will reply within 2 business hours with a full quote inside 24.',
              'success'
            )
            form.reset()
          } else {
            throw new Error('Request failed')
          }
        } catch (err) {
          setStatus(
            'Something broke on our end. Call us at 725.235.6196 or email info@bighornthreads.com and we will handle it.',
            'error'
          )
        } finally {
          if (submitBtn) submitBtn.disabled = false
        }
      })
    })()
  </script>
