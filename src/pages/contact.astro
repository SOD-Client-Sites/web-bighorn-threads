---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SmsConsentFields from '@/components/SmsConsentFields.astro'

const title = 'Contact Bighorn Threads | Branded Apparel & Company Stores'
const description =
  'Get in touch with Bighorn Threads. Call the shop or send a message — screen printing, embroidery, company stores, and promo products for teams across Las Vegas and nationwide.'

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Bighorn Threads',
  description:
    'Call or message Bighorn Threads for screen printing, embroidery, company stores, or promo products in Las Vegas.',
  url: 'https://bighornthreads.com/contact',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: 'Bighorn Threads',
    telephone: '+1-702-904-8923',
    email: 'info@bighornthreads.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '9205 W. Russell Rd Ste 305',
      addressLocality: 'Las Vegas',
      addressRegion: 'NV',
      postalCode: '89149',
      addressCountry: 'US',
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '08:00',
        closes: '17:00',
      },
    ],
  },
}

const inputClass =
  'mt-2 block w-full min-h-[44px] rounded border border-hairline bg-panel px-4 py-3 text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25'
---

<BaseLayout title={title} description={description}>
  <!-- ════ CONTACT — concrete ════ -->
  <section id="contact" class="scroll-mt-20 bg-concrete pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 max-w-3xl">
        <p class="kicker mb-3">Contact Us</p>
        <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl lg:text-6xl">
          Get in touch. <span class="text-gold-600">A human answers.</span>
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ash">
          Call the shop or send a quick message. No phone tree, no chatbot — just a real Las Vegas
          shop that prints and stitches for the trades that build this town.
        </p>
      </div>

      <!-- Prominent call CTA -->
      <a href="tel:+17029048923" class="group mb-10 block border border-hairline bg-charcoal p-7 transition-colors hover:border-gold-500 sm:p-9">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-start gap-4">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center bg-gold-500 text-charcoal" aria-hidden="true">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.5a1 1 0 01-.5 1.21l-1.58.79a11 11 0 005.6 5.6l.79-1.58a1 1 0 011.21-.5l4.5 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.82 21 3 14.18 3 6V5z" /></svg>
            </div>
            <div class="min-w-0">
              <div class="font-mono text-xs uppercase tracking-[0.16em] text-gold-400">Call the Shop</div>
              <div class="mt-1 font-mono text-2xl font-bold text-concrete sm:text-3xl">702.904.8923</div>
              <p class="mt-1 text-sm text-navy-200">Fastest way to reach us — a real human picks up.</p>
            </div>
          </div>
          <span class="btn-primary shrink-0 justify-center text-base">Call Now</span>
        </div>
      </a>

      <div class="grid gap-8 lg:grid-cols-5 lg:gap-10">
        <!-- BASIC CONTACT FORM -->
        <div class="lg:col-span-3">
          <form id="contactForm" action="/api/contact" method="POST" class="relative border border-hairline bg-paper p-6 sm:p-8 lg:p-10" novalidate>
            <div class="absolute -left-[9999px]" aria-hidden="true">
              <label for="bh_hp_field">Leave blank</label>
              <input type="text" name="bh_hp_field" id="bh_hp_field" tabindex="-1" autocomplete="off" />
            </div>
            <input type="hidden" name="company" value="Contact form (not provided)" />

            <p class="mb-6 font-mono text-xs uppercase tracking-[0.16em] text-gold-700">Send a Message</p>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-semibold text-charcoal">Name <span class="text-gold-600">*</span></label>
                <input type="text" name="name" id="name" required autocomplete="name" class={inputClass} placeholder="Jordan Reyes" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-charcoal">Email <span class="text-gold-600">*</span></label>
                <input type="email" name="email" id="email" required autocomplete="email" class={inputClass} placeholder="jordan@reyesgrading.com" />
              </div>
              <div class="sm:col-span-2">
                <label for="phone" class="block text-sm font-semibold text-charcoal">Phone</label>
                <input type="tel" name="phone" id="phone" autocomplete="tel" class={inputClass} placeholder="(702) 555-0187" />
              </div>
              <div class="sm:col-span-2">
                <label for="message" class="block text-sm font-semibold text-charcoal">Message</label>
                <textarea name="message" id="message" rows="6" class={inputClass} placeholder="What can we help you with?"></textarea>
              </div>
            </div>

            <SmsConsentFields />

            <div class="cf-turnstile mt-8" data-sitekey="0x4AAAAAADW_K97ZyhlAHC4I" data-theme="light"></div>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-ash">A real human replies fast — usually same business day.</p>
              <button type="submit" class="btn-primary justify-center text-base disabled:opacity-60">Send Message</button>
            </div>

            <p class="mt-5 text-sm text-ash">
              Ready to price a job? <a href="/get-a-quote/" class="text-gold-700 underline underline-offset-2 hover:text-gold-600">Get a quote</a> instead.
            </p>

            <div id="formStatus" role="status" aria-live="polite" aria-atomic="true" class="mt-6 text-sm"></div>
          </form>
        </div>

        <!-- CONTACT INFO -->
        <aside class="space-y-5 lg:col-span-2">
          <a href="mailto:info@bighornthreads.com" class="group block border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center bg-gold-500/15 text-gold-700" aria-hidden="true">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div class="min-w-0">
                <div class="kicker">Email Us</div>
                <div class="mt-1 break-all text-lg font-semibold text-charcoal">info@bighornthreads.com</div>
                <p class="mt-1 text-sm text-ash">Attach your logo — we'll take it from there.</p>
              </div>
            </div>
          </a>

          <div class="overflow-hidden border border-hairline bg-panel">
            <div aria-hidden="true" class="relative h-44 w-full overflow-hidden">
              <img src="/images/generated/cta-bluehour.jpg" alt="" width="1920" height="480" loading="lazy" decoding="async" class="absolute inset-0 h-full w-full object-cover" />
              <div class="absolute inset-0 bg-navy-950/55"></div>
              <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-center">
                <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center bg-gold-500 text-charcoal">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                <div class="font-mono text-xs uppercase tracking-[0.2em] text-gold-300">Las Vegas · Nevada</div>
              </div>
            </div>
            <div class="p-7">
              <div class="kicker">Find Us</div>
              <div class="mt-1 font-heading text-lg font-bold uppercase tracking-tight text-charcoal">9205 W. Russell Rd Ste 305</div>
              <p class="mt-1 text-sm text-ash">Las Vegas, NV 89149 — production shop serving crews across the Valley, Henderson, North Las Vegas, and beyond.</p>
            </div>
          </div>

          <div class="border border-hairline bg-panel p-7">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center bg-gold-500/15 text-gold-700" aria-hidden="true">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div class="min-w-0">
                <div class="kicker">Hours</div>
                <dl class="mt-2 space-y-1 text-sm">
                  <div class="flex justify-between gap-4"><dt class="text-ash">Mon – Fri</dt><dd class="font-mono text-charcoal">8:00 AM – 5:00 PM</dd></div>
                  <div class="flex justify-between gap-4"><dt class="text-ash">Saturday</dt><dd class="font-mono text-ash">By appointment</dd></div>
                  <div class="flex justify-between gap-4"><dt class="text-ash">Sunday</dt><dd class="font-mono text-ash">Closed</dd></div>
                </dl>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <script is:inline>
    (function () {
      const form = document.getElementById('contactForm')
      const status = document.getElementById('formStatus')
      if (!form || !status) return

      const setStatus = (msg, tone) => {
        status.textContent = msg
        status.className =
          'mt-6 text-sm ' +
          (tone === 'error' ? 'text-red-600' : tone === 'success' ? 'text-gold-700' : 'text-ash')
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault()

        const hp = form.querySelector('input[name="bh_hp_field"]')
        if (hp && hp.value) {
          setStatus('Thanks — we got it.', 'success')
          form.reset()
          return
        }

        const required = ['name', 'email']
        for (const field of required) {
          const el = form.elements.namedItem(field)
          if (!el || !el.value.trim()) {
            setStatus('Please fill in your name and email so we can reply.', 'error')
            if (el && typeof el.focus === 'function') el.focus()
            return
          }
        }

        const email = form.elements.namedItem('email')
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
          setStatus('That email does not look right — mind double-checking?', 'error')
          email.focus()
          return
        }

        setStatus('Sending your message.', 'info')
        const submitBtn = form.querySelector('button[type="submit"]')
        if (submitBtn) submitBtn.disabled = true

        try {
          const fd = new FormData(form)
          fd.append('consentUrl', window.location.href)
          const res = await fetch(form.action, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: fd,
          })
          if (res.ok) {
            if (typeof gtag === 'function') {
              gtag('event', 'generate_lead', { form: 'contact_message', page_path: window.location.pathname })
            }
            setStatus('Got it. A real human will get back to you soon.', 'success')
            form.reset()
          } else {
            throw new Error('Request failed')
          }
        } catch (err) {
          setStatus('Something broke on our end. Call us at 702.904.8923 or email info@bighornthreads.com and we will handle it.', 'error')
        } finally {
          if (submitBtn) submitBtn.disabled = false
        }
      })
    })()
  </script>
</BaseLayout>
