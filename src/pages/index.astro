---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Bighorn Threads | Las Vegas Branded Apparel for Construction & Trades"
  description="Branded apparel, screen printing, embroidery, and company stores for Las Vegas construction companies and trades. 15+ years outfitting the crews that build Vegas."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,_rgba(232,160,25,0.15),_transparent)]" />
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');" />

    <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <!-- Badge -->
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-4 py-1.5">
            <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse" />
            <span class="text-sm font-medium text-amber-500">Las Vegas, Nevada</span>
          </div>

          <h1 class="mb-6 text-4xl font-bold leading-[1.08] tracking-tight sm:text-5xl lg:text-6xl xl:text-7xl">
            Your Crew.
            <span class="bg-gradient-to-r from-amber-500 to-amber-400 bg-clip-text text-transparent"> Your Brand.</span>
            <br />
            Built Tough.
          </h1>

          <p class="mb-8 max-w-xl text-lg leading-relaxed text-navy-300 sm:text-xl">
            Branded apparel and promotional products for the companies that build Las Vegas. 15+ years of outfitting crews that mean business.
          </p>

          <div class="flex flex-col gap-4 sm:flex-row">
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-amber-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-amber-400 hover:shadow-xl hover:shadow-amber-500/20 hover:-translate-y-0.5"
            >
              Get a Free Quote
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="tel:+17252356196"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-navy-600 px-6 py-3.5 text-base font-medium text-white transition-all hover:border-navy-500 hover:bg-navy-800/50"
            >
              <svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="font-mono">725.235.6196</span>
            </a>
          </div>

          <!-- Stats Row -->
          <div class="mt-12 flex gap-8 border-t border-navy-700/50 pt-8">
            <div>
              <span class="block font-mono text-3xl font-bold text-amber-500">15+</span>
              <span class="text-sm text-navy-400">Years Experience</span>
            </div>
            <div>
              <span class="block font-mono text-3xl font-bold text-amber-500">100+</span>
              <span class="text-sm text-navy-400">Contractor Clients</span>
            </div>
            <div>
              <span class="block font-mono text-3xl font-bold text-amber-500">50K+</span>
              <span class="text-sm text-navy-400">Items Yearly</span>
            </div>
          </div>
        </div>

        <!-- Hero Visual -->
        <div class="relative hidden lg:block">
          <div class="absolute -inset-4 rounded-2xl bg-gradient-to-br from-amber-500/20 to-transparent blur-3xl" />
          <div class="relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8">
            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-4">
                <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-navy-700 to-navy-800 p-6 flex items-end">
                  <div>
                    <span class="block text-xs font-bold uppercase tracking-wider text-amber-500">Screen Printing</span>
                    <span class="block text-sm text-navy-300">Bold prints that survive the job site</span>
                  </div>
                </div>
                <div class="aspect-square rounded-xl bg-gradient-to-br from-amber-500/20 to-amber-600/10 border border-amber-500/20 p-6 flex items-center justify-center">
                  <div class="text-center">
                    <span class="block font-heading text-4xl font-bold text-amber-500">BT</span>
                    <span class="block mt-1 text-xs font-bold uppercase tracking-widest text-amber-400/60">EST. 2010</span>
                  </div>
                </div>
              </div>
              <div class="space-y-4 pt-8">
                <div class="aspect-square rounded-xl bg-gradient-to-br from-navy-700 to-navy-800 p-6 flex items-end">
                  <div>
                    <span class="block text-xs font-bold uppercase tracking-wider text-amber-500">Embroidery</span>
                    <span class="block text-sm text-navy-300">Professional logo work</span>
                  </div>
                </div>
                <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-navy-700 to-navy-800 p-6 flex items-end">
                  <div>
                    <span class="block text-xs font-bold uppercase tracking-wider text-amber-500">Company Stores</span>
                    <span class="block text-sm text-navy-300">Your crew orders online</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom edge gradient -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-500/30 to-transparent" />
  </section>

  <!-- Services -->
  <section class="relative py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-amber-500">What We Do</span>
        <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
          Everything Your Crew Needs. <span class="text-navy-400">Under One Roof.</span>
        </h2>
        <p class="text-lg text-navy-300">
          From a single embroidered hat to outfitting your entire operation — we handle it all with in-house production and fast turnaround.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <!-- Screen Printing -->
        <a href="/services#screen-printing" class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8 transition-all hover:border-amber-500/30 hover:bg-navy-800/50">
          <div class="absolute top-0 right-0 h-32 w-32 bg-gradient-to-bl from-amber-500/5 to-transparent" />
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10">
            <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-8.25 0h.008v.008H10.5V12z" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-white group-hover:text-amber-500 transition-colors">Screen Printing</h3>
          <p class="mb-4 text-sm text-navy-300">Bold, durable prints that survive the job site. In-house production, multi-color, fast turnaround.</p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-amber-500 opacity-0 transition-opacity group-hover:opacity-100">
            Learn more <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </a>

        <!-- Embroidery -->
        <a href="/services#embroidery" class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8 transition-all hover:border-amber-500/30 hover:bg-navy-800/50">
          <div class="absolute top-0 right-0 h-32 w-32 bg-gradient-to-bl from-amber-500/5 to-transparent" />
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10">
            <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-white group-hover:text-amber-500 transition-colors">Embroidery</h3>
          <p class="mb-4 text-sm text-navy-300">Professional logo embroidery on polos, jackets, hats, and bags. Free digitizing on your first order.</p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-amber-500 opacity-0 transition-opacity group-hover:opacity-100">
            Learn more <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </a>

        <!-- Branded Apparel -->
        <a href="/services#branded-apparel" class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8 transition-all hover:border-amber-500/30 hover:bg-navy-800/50">
          <div class="absolute top-0 right-0 h-32 w-32 bg-gradient-to-bl from-amber-500/5 to-transparent" />
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10">
            <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-white group-hover:text-amber-500 transition-colors">Branded Apparel</h3>
          <p class="mb-4 text-sm text-navy-300">T-shirts, polos, hoodies, hi-vis, hard hats — everything your crew needs to look professional.</p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-amber-500 opacity-0 transition-opacity group-hover:opacity-100">
            Learn more <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </a>

        <!-- Company Stores -->
        <a href="/company-stores" class="group relative overflow-hidden rounded-2xl border border-amber-500/20 bg-gradient-to-br from-amber-500/10 to-navy-800/30 p-8 transition-all hover:border-amber-500/40 hover:from-amber-500/15 md:col-span-2 lg:col-span-2">
          <div class="absolute top-0 right-0 h-40 w-40 bg-gradient-to-bl from-amber-500/10 to-transparent" />
          <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
            <div class="flex-1">
              <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-amber-500/20 px-3 py-1 text-xs font-bold uppercase tracking-wider text-amber-500">
                Most Popular
              </div>
              <h3 class="mb-2 text-xl font-bold text-white group-hover:text-amber-500 transition-colors">Company Stores</h3>
              <p class="text-sm text-navy-300">Give your team their own branded online store. They order what they need, we print and ship. Zero inventory for you.</p>
            </div>
            <div class="flex-shrink-0">
              <span class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-5 py-3 text-sm font-bold text-navy-950 transition-all group-hover:bg-amber-400 group-hover:shadow-lg group-hover:shadow-amber-500/20">
                Learn More
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Promotional Products -->
        <a href="/services#promotional-products" class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8 transition-all hover:border-amber-500/30 hover:bg-navy-800/50">
          <div class="absolute top-0 right-0 h-32 w-32 bg-gradient-to-bl from-amber-500/5 to-transparent" />
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10">
            <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-white group-hover:text-amber-500 transition-colors">Promotional Products</h3>
          <p class="mb-4 text-sm text-navy-300">Branded swag that gets used, not tossed. Drinkware, bags, safety gear, tech accessories.</p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-amber-500 opacity-0 transition-opacity group-hover:opacity-100">
            Learn more <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="relative border-y border-navy-700/30 bg-navy-900/50 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 text-center">
        <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-amber-500">Who We Serve</span>
        <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
          Built for the Trades
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-navy-300">
          We specialize in the companies that build, fix, and power Las Vegas. If your crew shows up to a job site, we outfit them.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { name: 'General Contractors', icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 7.5h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z', primary: true },
          { name: 'Electrical', icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z' },
          { name: 'Plumbing & HVAC', icon: 'M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m3.586 3.586a2.123 2.123 0 01-3-3m3 3l-3-3m0 0l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m8.586-3.586a2.123 2.123 0 013 3m-3-3l3 3' },
          { name: 'Roofing & Solar', icon: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z' },
          { name: 'Landscaping', icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25' },
          { name: 'Concrete & Masonry', icon: 'M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125' },
        ].map((industry) => (
          <a href={`/industries#${industry.name.toLowerCase().replace(/\s*&\s*/g, '-').replace(/\s+/g, '-')}`}
            class:list={[
              'group flex items-center gap-4 rounded-xl border p-5 transition-all hover:border-amber-500/30 hover:bg-navy-800/50',
              industry.primary ? 'border-amber-500/20 bg-amber-500/5' : 'border-navy-700/50 bg-navy-800/20',
            ]}
          >
            <div class:list={[
              'flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg',
              industry.primary ? 'bg-amber-500/20' : 'bg-navy-700/50',
            ]}>
              <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={industry.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-white group-hover:text-amber-500 transition-colors">{industry.name}</h3>
              {industry.primary && <span class="text-xs font-medium text-amber-500/70">Our Specialty</span>}
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/industries" class="inline-flex items-center gap-2 text-sm font-medium text-amber-500 transition-colors hover:text-amber-400">
          View all industries we serve
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Bighorn -->
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-amber-500">Why Bighorn Threads</span>
          <h2 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">
            Not Another Online Catalog. <span class="text-navy-400">We're Down the Street.</span>
          </h2>
          <p class="mb-8 text-lg text-navy-300">
            We show up to your office, your job site, your networking event. When you call, a real person picks up — someone who knows your account and your crew.
          </p>
          <div class="space-y-6">
            {[
              { title: '15+ Years in the Game', desc: 'We know the promo industry inside and out. No learning curves, no guesswork.' },
              { title: 'Construction is Our World', desc: 'We outfit the crews that build Las Vegas. We know what works on a job site.' },
              { title: 'Fast Turnaround', desc: 'In-house production means your order doesn\'t sit in a queue across the country.' },
