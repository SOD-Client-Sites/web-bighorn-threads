---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Image, Picture } from 'astro:assets'
import logoColor from '@/assets/logos/bighorn-logo-color.png'
import logoBw from '@/assets/logos/bighorn-logo-bw.png'
import foremanPhoto from '@/assets/generated/foreman-closeup.jpg'

const faqs = [
  {
    q: "What's the minimum order?",
    a: '24 pieces for screen printing, 12 for embroidery. No setup fee on orders over 25.',
  },
  {
    q: 'How fast can you turn around a rush job?',
    a: "We've hit 72-hour rush on 200-piece hi-vis orders. Call before 10am and we can usually commit same-day.",
  },
  {
    q: 'Do you handle hi-vis and FR compliance?',
    a: 'Yes. ANSI/ISEA 107 Class 2 and 3 hi-vis apparel and NFPA 70E flame-resistant shirts, both printed and embroidered to spec.',
  },
  {
    q: 'Can you match our existing logo colors?',
    a: 'Pantone-matched inks for screen print, thread matching for embroidery. Your colors locked on file after the first order.',
  },
  {
    q: 'What\u2019s a company store and do we need one?',
    a: 'If you onboard new hires regularly, run multiple crews, or reorder the same gear every quarter \u2014 yes. It replaces email chains, size-guessing, and inventory closets.',
  },
  {
    q: 'Do we have to commit to a subscription?',
    a: "No. First order is no-commitment retail pricing. Program pricing and portals are optional once you're ready.",
  },
  {
    q: "Can you ship to job sites or employees' homes?",
    a: 'Both. Your call per order \u2014 office, job trailer, or individual employee addresses.',
  },
  {
    q: 'How do you handle reorders?',
    a: 'Screens, digitized files, thread colors, and placement specs are all saved. Reorder with one email or one portal click.',
  },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<BaseLayout
  title="Las Vegas Branded Apparel for Construction & Trades"
  description="Branded apparel, screen printing, embroidery, and company stores for Las Vegas construction companies and trades. 15+ years outfitting the crews that build Vegas."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Dark gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-gray-900" />
    <!-- Radial gold glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_40%,_rgba(193,155,61,0.06),_transparent)]" />
    <!-- Ghost ram watermark (contained inside section) -->
    <Image
      src={logoBw}
      alt=""
      aria-hidden="true"
      width={700}
      format="webp"
      quality={60}
      class="pointer-events-none absolute left-1/2 top-1/2 w-[85%] max-w-[900px] -translate-x-1/2 -translate-y-1/2 opacity-[0.06] invert"
      loading="lazy"
      decoding="async"
    />

    <div class="relative mx-auto max-w-7xl px-4 pt-32 pb-16 sm:px-6 sm:pt-36 lg:px-8 lg:pt-40 lg:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <!-- Badge -->
          <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-gold-500/20 bg-gold-500/5 px-5 py-2">
            <span class="h-2 w-2 rounded-full bg-gold-500 animate-pulse" />
            <span class="text-sm font-medium text-gold-500">Outfitting Las Vegas Construction Since 2010</span>
          </div>

          <h1 class="mb-6 font-heading text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl lg:text-7xl">
            Uniforms and Company Stores
            <span class="block bg-gradient-to-r from-gold-500 to-gold-300 bg-clip-text text-transparent">for the Crews That Build Vegas.</span>
          </h1>

          <p class="mb-10 max-w-xl text-xl leading-relaxed text-gray-400 sm:text-2xl">
            Branded workwear, embroidery, and reorder portals for general contractors, electricians, roofers, plumbers, and HVAC teams. Built for the jobsite. Easy to reorder. Consistent every time.
          </p>

          <div class="flex flex-col gap-4 sm:flex-row">
            <a
              href="/contact/"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-lg font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5"
            >
              Get a Free Quote
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="tel:+17252356196"
              class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-gold-500/30 px-8 py-4 text-lg font-medium text-white transition-all hover:border-gold-500/70 hover:bg-navy-800/50"
            >
              <svg class="h-5 w-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="font-mono">725.235.6196</span>
            </a>
          </div>
        </div>

        <!-- Logo Feature -->
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative">
            <div class="absolute inset-0 rounded-full bg-gold-500/10 blur-3xl scale-150" />
            <Picture
              src={logoColor}
              alt="Bighorn Threads ram logo"
              widths={[384, 478, 640, 768]}
              sizes="(min-width: 1024px) 384px, 0px"
              formats={['avif', 'webp']}
              fallbackFormat="png"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="relative h-96 w-auto drop-shadow-2xl"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom stats bar (normal flow, no overlap) -->
    <div class="relative border-t border-gray-700/30 bg-navy-950/80 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-6 px-4 py-5 sm:px-6 lg:px-8">
        <div class="flex items-center gap-8">
          <div>
            <span class="block font-mono text-2xl font-bold text-gold-500">15+</span>
            <span class="text-xs font-medium uppercase tracking-wider text-gray-500">Years</span>
          </div>
          <div class="h-8 w-px bg-gray-700/50" />
          <div>
            <span class="block font-mono text-2xl font-bold text-gold-500">100+</span>
            <span class="text-xs font-medium uppercase tracking-wider text-gray-500">Contractors</span>
          </div>
          <div class="h-8 w-px bg-gray-700/50" />
          <div>
            <span class="block font-mono text-2xl font-bold text-gold-500">50K+</span>
            <span class="text-xs font-medium uppercase tracking-wider text-gray-500">Items/Year</span>
          </div>
        </div>
        <div class="hidden items-center gap-2 text-sm text-gray-500 sm:flex">
          <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Las Vegas, Nevada
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted By Strip -->
  <section class="border-y border-gray-700/20 bg-navy-900/60 py-5">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
        Outfitting Las Vegas general contractors, electrical, plumbing, HVAC, roofing, and landscaping crews
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="relative py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">What We Do</span>
        <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
          One Partner. Every Piece of Gear. <span class="text-gray-500">Every Reorder.</span>
        </h2>
        <p class="text-lg text-gray-400">
          From first crew order to full company store — screen printing, embroidery, hi-vis, PPE-compatible gear, and branded workwear for Las Vegas trades. Your files, your screens, your color standards — held on our end so every reorder matches.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: 'Screen Printing',
            desc: 'Prints that hold up to sun, sweat, concrete, and 100 washes. Multi-color, hi-vis-compatible inks, 24-piece minimum. Screens held on file so reorders match.',
            icon: 'M8 4L5 5.5 3 9l2.5 1.5V20h13V10.5L21 9l-2-3.5-3-1.5a4 4 0 01-8 0z M9.5 13h5 M9.5 16h5',
            href: '/services#screen-printing',
          },
          {
            title: 'Embroidery',
            desc: 'Embroidered polos, jackets, beanies, and FR-rated shirts. Digitized logo held on file — Pantone-matched thread, same placement, every reorder. First digitizing is on us.',
            icon: 'M12 3a9 9 0 109 9 9 9 0 00-9-9z M9 10l2 2 M11 10l-2 2 M13 14l2 2 M15 14l-2 2',
            href: '/services#embroidery',
          },
          {
            title: 'Branded Apparel',
            desc: 'Role-based kits for crew, supervisor, and office staff. Hi-vis tees and vests (ANSI/ISEA 107), FR shirts (NFPA 70E), embroidered polos, softshells, and branded hard hats.',
            icon: 'M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z',
            href: '/services#branded-apparel',
          },
        ].map((service) => (
          <a href={service.href} class="group relative overflow-hidden rounded-2xl border border-gray-700/40 bg-navy-800/20 p-8 transition-all duration-300 hover:border-gold-500/40 hover:bg-navy-800/40 hover:shadow-xl hover:shadow-gold-500/5 hover:-translate-y-1">
            <div class="absolute top-0 right-0 h-40 w-40 bg-gradient-to-bl from-gold-500/5 to-transparent transition-opacity group-hover:opacity-100 opacity-0" />
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10 transition-colors group-hover:bg-gold-500/20">
              <svg class="h-7 w-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-bold text-white transition-colors group-hover:text-gold-500">{service.title}</h3>
            <p class="mb-5 text-sm leading-relaxed text-gray-400">{service.desc}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold-500 transition-all group-hover:gap-2.5">
              Learn more
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </a>
        ))}

        <!-- Company Stores — Featured -->
        <a href="/company-stores/" class="group relative overflow-hidden rounded-2xl border-2 border-gold-500/30 bg-gradient-to-br from-gold-500/10 via-navy-800/30 to-navy-900/50 p-8 transition-all duration-300 hover:border-gold-500/50 hover:shadow-xl hover:shadow-gold-500/10 hover:-translate-y-1 md:col-span-2 lg:col-span-2">
          <div class="absolute top-0 right-0 h-48 w-48 bg-gradient-to-bl from-gold-500/10 to-transparent" />
          <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
            <div class="flex-1">
              <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-gold-500/20 px-3 py-1 text-xs font-bold uppercase tracking-wider text-gold-500">
                Most Popular Service
              </div>
              <h3 class="mb-3 text-2xl font-bold text-white transition-colors group-hover:text-gold-500">Company Stores</h3>
              <p class="max-w-lg text-gray-400">Your branded portal. Your approved products. Your crew logs in, picks their size, you set the budget or gift-card allowance — we produce and ship to the job trailer, office, or employee's door. Zero inventory. Zero admin. Onboarding-ready for every new hire.</p>
            </div>
            <div class="flex-shrink-0">
              <span class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all group-hover:bg-gold-400 group-hover:shadow-lg group-hover:shadow-gold-500/25">
                Learn More
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Promotional Products -->
        <a href="/services#promotional-products" class="group relative overflow-hidden rounded-2xl border border-gray-700/40 bg-navy-800/20 p-8 transition-all duration-300 hover:border-gold-500/40 hover:bg-navy-800/40 hover:shadow-xl hover:shadow-gold-500/5 hover:-translate-y-1">
          <div class="absolute top-0 right-0 h-40 w-40 bg-gradient-to-bl from-gold-500/5 to-transparent transition-opacity group-hover:opacity-100 opacity-0" />
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10 transition-colors group-hover:bg-gold-500/20">
            <svg class="h-7 w-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="mb-3 text-xl font-bold text-white transition-colors group-hover:text-gold-500">Promotional Products</h3>
          <p class="mb-5 text-sm leading-relaxed text-gray-400">Branded swag for trade shows, golf tournaments, and client gifts. Drinkware, bags, safety gear, tech.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold-500 transition-all group-hover:gap-2.5">
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- How Company Stores Work -->
  <section class="relative border-y border-gray-700/20 bg-navy-900/40 py-24 sm:py-32">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,_rgba(193,155,61,0.06),_transparent)]" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 max-w-3xl">
        <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Company Stores</span>
        <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl font-heading">
          How a Bighorn Company Store <span class="text-gold-500">Actually Works.</span>
        </h2>
        <p class="text-lg text-gray-400">
          Most "company stores" are glorified PDF catalogs. Ours is a real portal your crew uses and your ops team controls.
        </p>
      </div>

      <ol class="grid gap-6 md:grid-cols-3">
        {[
          { n: '01', title: 'We Build Your Portal', meta: 'Week 1', desc: 'Your logo. Your colors. Your approved garments. Your price rules. Free setup on your first portal.' },
          { n: '02', title: 'Your Crew Orders', meta: 'Ongoing', desc: 'New hires get a login and a gift-card balance. They pick sizes, submit orders, and we print and ship. You see every order in one dashboard.' },
          { n: '03', title: 'You Never Touch Inventory', meta: 'Ongoing', desc: 'No stockroom, no size guessing, no reorder headaches. Gear ships direct to office, job trailer, or employee\u2019s home — your call per order.' },
        ].map((step) => (
          <li class="group relative rounded-2xl border border-gray-700/40 bg-navy-800/20 p-8 transition-all duration-300 hover:border-gold-500/40 hover:bg-navy-800/40">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-mono text-4xl font-bold text-gold-500">{step.n}</span>
              <span class="rounded-full border border-gold-500/20 bg-gold-500/5 px-3 py-1 text-xs font-bold uppercase tracking-wider text-gold-500">{step.meta}</span>
            </div>
            <h3 class="mb-3 text-xl font-bold text-white">{step.title}</h3>
            <p class="text-sm leading-relaxed text-gray-400">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-10 text-center">
        <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border-2 border-gold-500/40 px-6 py-3.5 text-base font-bold text-white transition-all hover:border-gold-500 hover:bg-gold-500/10">
          See a live demo portal
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Industries — Construction First -->
  <section class="relative border-y border-gray-700/20 bg-navy-900/50 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 text-center">
        <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Industries We Serve</span>
        <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
          Built for the Companies That <span class="text-gold-500">Build Vegas</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-400">
          We specialize in construction and trades. If your crew shows up to a job site, we make sure they look like they belong to something.
        </p>
      </div>

      <!-- Featured: Construction -->
      <div class="mb-8 overflow-hidden rounded-2xl border-2 border-gold-500/30 bg-gradient-to-r from-gold-500/10 via-navy-800/40 to-navy-800/20 p-8 sm:p-10">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center">
          <div class="flex-1">
            <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-gold-500/20 px-3 py-1 text-xs font-bold uppercase tracking-wider text-gold-500">
              Our Specialty
            </div>
            <h3 class="mb-3 text-2xl font-bold sm:text-3xl">General Contractors & Construction</h3>
            <p class="mb-4 text-gray-400">
              Your crew is your brand on every job site. We outfit general contractors with branded hard hats, hi-vis tees, polos for the office, and company stores so every crew member — from the foreman to the newest hire — looks professional.
            </p>
            <div class="flex flex-wrap gap-2">
              {['Hi-vis safety wear', 'Branded hard hats', 'Company stores', 'Crew uniforms', 'Client gifts'].map((tag) => (
                <span class="rounded-full border border-gold-500/20 bg-gold-500/5 px-3 py-1 text-xs font-medium text-gold-400">{tag}</span>
              ))}
            </div>
          </div>
          <div class="flex-shrink-0">
            <a href="/contact/" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-6 py-3.5 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
              Get a Quote
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Other Industries Grid -->
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { name: 'Electrical Contractors', desc: 'Embroidered polos, branded beanies, safety promo items', icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z' },
          { name: 'Plumbing & HVAC', desc: 'Moisture-wicking work shirts, embroidered jackets, leave-behinds', icon: 'M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m3.586 3.586a2.123 2.123 0 01-3-3m3 3l-3-3m0 0l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m8.586-3.586a2.123 2.123 0 013 3m-3-3l3 3' },
          { name: 'Roofing & Solar', desc: 'Hi-vis branded gear, custom hard hats, trade show giveaways', icon: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z' },
