---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Image, Picture } from 'astro:assets'
import heroPhoto from '@/assets/generated/crew-vegas.jpg'
import foremanPhoto from '@/assets/generated/foreman-closeup.jpg'

const faqs = [
 {
 q: "What's the minimum order?",
 a: '24 pieces for screen printing, 12 for embroidery. Setup fees waived on qualifying orders — ask when you quote.',
 },
 {
 q: 'How fast can you turn around a rush job?',
 a: "Rush options are available — call us with your deadline and we'll tell you straight if we can hit it.",
 },
 {
 q: 'Do you handle hi-vis and FR compliance?',
 a: 'Yes. ANSI/ISEA 107 Class 2 and 3 hi-vis apparel and NFPA 70E flame-resistant shirts, both printed and embroidered to spec.',
 },
 {
 q: 'Can you match our existing logo colors?',
 a: 'Pantone-matched inks for screen print, thread matching for embroidery. Your colors locked on file after the first order.',
 },
 {
 q: 'What’s a company store and do we need one?',
 a: 'If you onboard new hires regularly, run multiple crews, or reorder the same gear every quarter — yes. It replaces email chains, size-guessing, and inventory closets.',
 },
 {
 q: 'Do we have to commit to a subscription?',
 a: "No. First order is no-commitment retail pricing. Program pricing and portals are optional once you're ready.",
 },
 {
 q: "Can you ship to job sites or employees' homes?",
 a: 'Both. Your call per order — office, job trailer, or individual employee addresses.',
 },
 {
 q: 'How do you handle reorders?',
 a: 'Screens, digitized files, thread colors, and placement specs are all saved. Reorder with one email or one portal click.',
 },
]

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}

const services = [
 {
 title: 'Screen Printing',
 desc: 'Prints that hold up to sun, sweat, and concrete. Multi-color, hi-vis-compatible inks, 24-piece minimum. Screens held on file so reorders match.',
 img: '/images/generated/service-screen-printing.jpg',
 href: '/services/screen-printing-las-vegas/',
 tag: 'Decoration',
 },
 {
 title: 'Embroidery',
 desc: 'Embroidered polos, jackets, beanies, and FR-rated shirts. Digitized logo held on file — Pantone-matched thread, same placement, every reorder. First digitizing is on us.',
 img: '/images/generated/service-embroidery.jpg',
 href: '/services/embroidery-las-vegas/',
 tag: 'Decoration',
 },
 {
 title: 'Branded Apparel',
 desc: 'Role-based kits for crew, supervisor, and office staff. Hi-vis tees and vests (ANSI/ISEA 107), FR shirts (NFPA 70E), embroidered polos, softshells, and branded hard hats.',
 img: '/images/generated/service-branded-apparel.jpg',
 href: '/services#branded-apparel',
 tag: 'Apparel',
 },
 {
 title: 'Promotional Products',
 desc: 'Branded swag for trade shows, golf tournaments, and client gifts. Drinkware, bags, safety gear, tech.',
 img: '/images/generated/product-stack.jpg',
 href: '/promo-products-las-vegas/',
 tag: 'Promo',
 },
]

const trades = [
 {
 name: 'General Contractors',
 href: '/industries/general-contractors-las-vegas/',
 img: '/images/generated/kit-gc.jpg',
 alt: 'Flat-lay of general contractor gear — embroidered polo, hi-vis tee, branded hard hat, work gloves',
 items: ['Embroidered polos & button-ups', 'ANSI Class 2 hi-vis tees & vests', 'Branded hard hats & beanies', 'Carhartt-style work jackets'],
 },
 {
 name: 'Electrical Contractors',
 href: '/industries/electrical-contractors-las-vegas/',
 img: '/images/generated/kit-electrical.jpg',
 alt: 'Electrician gear — FR-rated button-up, embroidered softshell jacket, beanie, insulated gloves',
 items: ['NFPA 70E FR-rated shirts', 'Arc-flash compliant workwear', 'Embroidered softshells & beanies', 'Data center / MEP sub uniforms'],
 },
 {
 name: 'Mechanical & HVAC',
 href: '/industries/plumbing-hvac-las-vegas/',
 img: '/images/generated/kit-plumbing-hvac.jpg',
 alt: 'Mechanical and HVAC service gear — navy service polo, branded work jacket, ball cap, utility belt',
 items: ['Embroidered service polos', 'Branded work jackets', 'Data center cooling tech uniforms', 'Name-taped service shirts'],
 },
 {
 name: 'Concrete & Masonry',
 href: '/industries/concrete-masonry-las-vegas/',
 img: '/images/generated/kit-concrete.jpg',
 alt: 'Concrete and masonry crew gear — hi-vis tee, work jacket, white hard hat, trowel, gloves',
 items: ['ANSI hi-vis tees & long sleeves', 'Heavy-duty embroidered work jackets', 'Branded white hard hats', 'Knee pads, gloves, and crew tees'],
 },
 {
 name: 'Steel & Ironworkers',
 href: '/industries/steel-iron-workers-las-vegas/',
 img: '/images/generated/kit-steel.jpg',
 alt: 'Ironworker and structural steel gear — FR long-sleeve, welding gloves, hard hat, spud wrench',
 items: ['FR-rated long-sleeve work shirts', 'Branded hard hats with chin straps', 'Heavy leather welding gloves', 'Arc-rated hoodies & softshells'],
 },
 {
 name: 'Data Center & Mission-Critical',
 href: '/industries/data-center-contractors-las-vegas/',
 img: '/images/generated/kit-datacenter.jpg',
 alt: 'Data center contractor gear — FR button-up, embroidered softshell, hard hat, network tools',
 items: ['NFPA 70E FR-rated button-ups', 'Embroidered softshell jackets', 'Chin-strap hard hats', 'Arc-rated gloves & fine-dust gear'],
 badge: 'Vegas #1 growth sector',
 },
]

const industries = [
 { name: 'Electrical Contractors', desc: 'Embroidered polos, branded beanies, safety promo items' },
 { name: 'Plumbing & HVAC', desc: 'Moisture-wicking work shirts, embroidered jackets, leave-behinds' },
 { name: 'Roofing & Solar', desc: 'Hi-vis branded gear, custom hard hats, trade show giveaways' },
 { name: 'Landscaping', desc: 'Sun protection hats, branded tees & tanks, crew uniforms' },
 { name: 'Concrete & Masonry', desc: 'Durable workwear, branded safety vests, company polos' },
 { name: 'Steel & Iron Workers', desc: 'FR-rated branded apparel, embroidered jackets, hard hat stickers' },
]

const whyPoints = [
 { title: 'Trades-Only. Not Generalists.', desc: "We don't do wedding swag or fashion drops. We outfit the trades — construction, electrical, plumbing, HVAC, roofing, landscaping — and we know the garments, compliance, and reorder patterns of each." },
 { title: 'Your Deadline Was Yesterday.', desc: "Quick quotes, quick mockups, rush options when you need them. Tell us your deadline and we'll tell you straight if we can hit it." },
 { title: 'Reorders Without the Phone Tag.', desc: 'Your company store holds your logo, your colors, your approved products. New hires get a gift-card allowance, pick their sizes, and gear ships direct.' },
 { title: 'Vegas Local. Vegas Production.', desc: 'Our production partners are in Vegas. When a blank supplier jacks prices mid-quarter, we know before you do — and we hedge with annual-lock pricing.' },
]

const process = [
 { n: '01', meta: 'Quote', title: 'Scope the Job', desc: 'Tell us crew size, gear types, deadline, and any compliance requirements (ANSI, FR, Pantone match). We quote quickly.' },
 { n: '02', meta: 'Proofs', title: 'Free Mockups', desc: 'We send digital proofs showing exactly where your logo sits, thread colors for embroidery, and ink placement for screen print.' },
 { n: '03', meta: 'Production', title: 'Local Production', desc: 'Printed and embroidered through our Las Vegas production partners. Every piece quality-checked — the same standard on the first order and every reorder.' },
 { n: '04', meta: 'Delivery', title: 'Direct Delivery', desc: 'Shipped to your office, job trailer, or each employee’s home — your call at checkout. Rush timeline? We run the schedule tighter.' },
]

const storeSteps = [
 { n: '01', meta: 'Setup', title: 'We Build Your Portal', desc: 'Your logo. Your colors. Your approved garments. Your price rules. Free setup on your first portal.' },
 { n: '02', meta: 'Ongoing', title: 'Your Crew Orders', desc: 'New hires get a login and a gift-card balance. They pick sizes, submit orders, and we print and ship. You see every order in one dashboard.' },
 { n: '03', meta: 'Ongoing', title: 'You Never Touch Inventory', desc: 'No stockroom, no size guessing, no reorder headaches. Gear ships direct to office, job trailer, or employee’s home.' },
]

const blogLinks = [
 { href: '/blog/what-is-embroidery-buyers-guide/', label: 'What is embroidery — buyer’s guide' },
 { href: '/blog/what-is-screen-printing/', label: 'What is screen printing — primer' },
 { href: '/blog/nfpa-70e-fr-shirts-vegas-electricians/', label: 'NFPA 70E FR shirts for Vegas electricians' },
 { href: '/blog/nevada-osha-heat-rules-2026-workwear/', label: 'Nevada OSHA heat rules — 2026 workwear' },
 { href: '/blog/hvac-uniforms-service-tech-apparel/', label: 'HVAC uniforms — service tech apparel' },
 { href: '/blog/how-to-outfit-a-construction-crew-vegas/', label: 'How to outfit a construction crew in Vegas' },
]

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
 title="Company Stores & Branded Apparel — Built in Las Vegas, Shipped Nationwide"
 description="Custom company stores, screen printing, embroidery, uniforms, and FR & hi-vis workwear for teams across construction, corporate, education, healthcare, and government. Vegas roots, nationwide shipping."
>
 <!-- ════ HERO — full-bleed photographic dark band ════ -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <Image
 src={heroPhoto}
 alt="Construction crew in branded hi-vis workwear on a Las Vegas job site"
 widths={[768, 1280, 1920]}
 sizes="100vw"
 formats={['avif', 'webp']}
 fallbackFormat="jpg"
 loading="eager"
 fetchpriority="high"
 decoding="async"
 class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
 />
 <!-- Tint: dark enough for white copy, weighted to the left where text sits -->
 <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-950 via-navy-950/85 to-navy-950/40"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-36 sm:px-6 sm:pt-44 lg:px-8 lg:pb-28 lg:pt-52">
 <div class="max-w-2xl">
 <p class="kicker mb-5 flex items-center gap-2.5">
 <span class="h-px w-8 bg-gold-500"></span>
 Company Stores &amp; Branded Gear · Vegas Roots, Nationwide
 </p>
 <h1 class="font-heading text-5xl font-extrabold uppercase leading-[0.92] tracking-tight text-white sm:text-6xl lg:text-[5.25rem]">
 Company stores &amp; branded gear for every team that
 <span class="text-gold-400"> wears your logo.</span>
 </h1>
 <p class="mt-7 max-w-xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 Private company stores, embroidery, uniforms, and branded workwear for teams across
 construction, corporate, education, healthcare, and government. Vegas roots, shipping nationwide.
 Easy to reorder. Consistent every time.
 </p>
 <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
 <a href="/contact/" class="btn-primary text-base">
 Get a Free Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
 702.904.8923
 </a>
 </div>
 </div>
 </div>
 </section>

 <!-- ════ TRUSTED-BY STRIP — paper ════ -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-10 max-w-2xl">
 <p class="kicker mb-3">Who We Outfit</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 One partner for <span class="text-gold-600">every team.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Construction crews, corporate offices, schools, hospitals, and public agencies all share the
 same headache — branded gear, sizing, and reorders. We run the store so you don't have to.
 </p>
 </div>
 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
 <a href="/industries/construction-trades/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Construction &amp; Trades</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">GCs, electrical, plumbing, HVAC, roofing, concrete, steel — hi-vis &amp; FR to spec.</p>
 </a>
 <a href="/industries/corporate/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Corporate &amp; Office</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">Employee gear, onboarding kits, client gifts, and event apparel.</p>
 </a>
 <a href="/industries/education/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Education</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">Districts, campuses, and athletics — staff apparel and spirit wear.</p>
 </a>
 <a href="/industries/healthcare/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Healthcare</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">Embroidered scrubs, lab coats, and admin gear across multiple sites.</p>
 </a>
 <a href="/industries/government/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Government &amp; Public</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">Agency uniforms, public-works field gear, and ANSI hi-vis safety apparel.</p>
 </a>
 <a href="/industries/gaming-hospitality/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Gaming &amp; Hospitality</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">Casinos, resorts, and F&amp;B — front-of-house to back-of-house uniforms.</p>
 </a>
 <a href="/industries/events/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">Events &amp; Teams</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">Trade shows, activations, and team uniforms — on deadline, sized right.</p>
 </a>
 <a href="/industries/" class="group flex items-center justify-between border border-hairline bg-charcoal p-6 transition-colors hover:bg-navy-900">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-concrete">See all industries</h3>
 <svg class="h-5 w-5 text-gold-400 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 </div>
 </div>
 </section>

 <!-- ════ SERVICES — concrete ════ -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">What We Do</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 One partner. Every piece of gear. <span class="text-ash">Every reorder.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 From first crew order to full company store — screen printing, embroidery, hi-vis,
 PPE-compatible gear, and branded workwear for Las Vegas trades. Your files, your screens,
 your color standards held on our end so every reorder matches.
 </p>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
 {services.map((service) => (
 <a href={service.href} class="group flex flex-col border border-hairline bg-panel transition-colors duration-200 hover:border-gold-500">
 <div class="relative aspect-[5/4] overflow-hidden">
 <img src={service.img} alt={service.title} width="600" height="480" loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
 <span class="spec absolute left-3 top-3 bg-concrete/95 px-2 py-1 text-charcoal">{service.tag}</span>
 </div>
 <div class="flex flex-1 flex-col p-6">
 <h3 class="font-heading text-xl font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">{service.title}</h3>
 <p class="mt-2 flex-1 text-sm leading-relaxed text-ash">{service.desc}</p>
 <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs font-medium uppercase tracking-wider text-gold-600 transition-all group-hover:gap-2.5">
 Learn more
 <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </span>
 </div>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- ════ COMPANY STORES — paper ════ -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-3xl">
 <p class="kicker mb-3">Company Stores</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 How a Bighorn company store <span class="text-gold-600">actually works.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Most "company stores" are glorified PDF catalogs. Ours is a real portal your crew uses and your ops team controls.
 </p>
 </div>

 <ol class="grid gap-5 md:grid-cols-3">
 {storeSteps.map((step) => (
 <li class="border border-hairline bg-panel p-7">
 <div class="mb-5 flex items-baseline justify-between">
 <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
 <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
 </div>
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
 <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
 </li>
 ))}
 </ol>

 <div class="mt-8">
 <a href="/company-stores/" class="btn-secondary text-sm">
 See a live demo portal
 <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 </div>
 </div>
 </section>

 <!-- ════ INDUSTRIES — concrete ════ -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Industries We Serve</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 Built for the companies that <span class="text-gold-600">build Vegas.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 We specialize in construction and trades. If your crew shows up to a job site, we make sure they look like they belong to something.
 </p>
 </div>

 <!-- Featured: Construction -->
 <div class="mb-5 border-l-4 border-gold-500 bg-panel">
 <div class="flex flex-col gap-6 border border-l-0 border-hairline p-7 sm:p-9 lg:flex-row lg:items-center">
 <div class="flex-1">
 <span class="spec mb-3 inline-block bg-gold-500 px-2 py-1 text-charcoal">Our Specialty</span>
 <h3 class="font-heading text-2xl font-bold uppercase tracking-tight text-charcoal sm:text-3xl">General Contractors &amp; Construction</h3>
 <p class="mt-3 text-ash">
 Your crew is your brand on every job site. We outfit general contractors with branded hard hats,
 hi-vis tees, polos for the office, and company stores so every crew member — from the foreman to
 the newest hire — looks professional.
 </p>
 <div class="mt-4 flex flex-wrap gap-2">
 {['Hi-vis safety wear', 'Branded hard hats', 'Company stores', 'Crew uniforms', 'Client gifts'].map((tag) => (
 <span class="spec border border-hairline px-2.5 py-1 text-ash">{tag}</span>
 ))}
 </div>
 </div>
 <a href="/contact/" class="btn-primary shrink-0 text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 </div>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
 {industries.map((industry) => (
 <a href="/industries/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">{industry.name}</h3>
 <p class="mt-1.5 text-sm leading-relaxed text-ash">{industry.desc}</p>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- ════ WHY BIGHORN — paper, with photo ════ -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
 <div>
 <p class="kicker mb-3">Why Bighorn Threads</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 Not another online catalog. <span class="text-gold-600">We show up.</span>
 </h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 We're at your job site, your office, your golf tournament. When you call, a real person picks up — someone who knows your account and your crew.
 </p>
 <div class="mt-8 divide-y divide-hairline border-y border-hairline">
 {whyPoints.map((item) => (
 <div class="flex gap-4 py-5">
 <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
 <div>
 <h3 class="font-heading text-base font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
 <p class="mt-1 text-sm leading-relaxed text-ash">{item.desc}</p>
 </div>
 </div>
 ))}
 </div>
 </div>

 <div class="border border-hairline bg-panel p-2">
 <Picture
 src={foremanPhoto}
 alt="Construction foreman in branded work shirt and hard hat reviewing blueprints at a Las Vegas job site"
 widths={[480, 768, 1024]}
 sizes="(min-width: 1024px) 50vw, 100vw"
 formats={['avif', 'webp']}
 fallbackFormat="jpg"
 loading="lazy"
 decoding="async"
 class="h-full w-full object-cover"
 />
 </div>
 </div>
 </div>
 </section>

 <!-- ════ GEAR BY INDUSTRY — concrete ════ -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-3xl">
 <p class="kicker mb-3">Gear by Industry</p>
 <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
 What the trades that build Vegas <span class="text-gold-600">actually order.</span>
