---
import LandingLayout from '@/layouts/LandingLayout.astro'
import LeadCaptureForm from '@/components/LeadCaptureForm.astro'

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Get Started — Corporate', item: 'https://bighornthreads.com/get-started/corporate/' },
  ],
}

const problems = [
  {
    title: 'Chasing Sizes by Email.',
    desc: 'Someone in ops spends days collecting shirt sizes in a spreadsheet. A new hire starts and the cycle repeats. Your managers become the size-collection department.',
  },
  {
    title: 'Swag Nobody Wears.',
    desc: 'Cheap blanks ordered in bulk sit in a closet. Wrong sizes, wrong styles. Your brand ends up on gear people quietly throw out.',
  },
  {
    title: 'Brand Drift Across Vendors.',
    desc: 'Marketing buys polos one place, HR buys onboarding kits another. Logos drift, colors drift, and your brand looks inconsistent everywhere it shows up.',
  },
  {
    title: 'New-Hire Kits Done by Hand.',
    desc: 'Every start date means a manual order, a guess at sizes, and a scramble to get gear there in time. It does not scale with your headcount.',
  },
]

const storeSteps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We Build Your Store — Free',
    desc: 'Your logo, your colors, your approved products, your budget rules. We set up your branded company store free and keep your logo on file so every reorder matches.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Your People Order Their Own Sizes',
    desc: 'Each person logs in, picks their own size, and submits. No spreadsheets, no size-guessing, no email chains for your managers to run.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships Direct — You Control Budget',
    desc: 'Gear ships to the office or each person’s home. You cap spend per person, see every order in one place, and reorder in a click.',
  },
]

const offerings = [
  {
    title: 'Embroidered Polos & Softshells',
    desc: 'Embroidered polos, button-ups, quarter-zips, and softshell jackets. Your logo digitized once and held on file for consistent reorders.',
    tag: 'Apparel',
  },
  {
    title: 'Recognizable Brands',
    desc: 'Brands your team actually wants to wear — Port Authority polos and outerwear, YETI drinkware, and more. Branded, not bargain-bin.',
    tag: 'Premium',
  },
  {
    title: 'New-Hire Onboarding Kits',
    desc: 'A branded welcome kit ready to ship the day someone starts. Polo, drinkware, the essentials — sized by the new hire, not guessed by you.',
    tag: 'Onboarding',
  },
  {
    title: 'Event & Trade-Show Apparel',
    desc: 'Matching gear for conferences, booths, and company events. Order what you need and ship to the venue or to each attendee.',
    tag: 'Events',
  },
  {
    title: 'Client Gifts',
    desc: 'Branded gifts that get used, not tossed. Drinkware, bags, and premium pieces that keep your brand in front of the people who matter.',
    tag: 'Gifts',
  },
]

const objections = [
  {
    q: 'What does "free" actually cover?',
    a: 'Free store setup and your first logo digitizing are on us. You only pay for the gear your people order — nothing to set up, no monthly fee, no per-user fee.',
  },
  {
    q: 'Is there a minimum to start?',
    a: 'No. We build your store for teams of every size. Small office or large company, your people order what they need, when they need it.',
  },
  {
    q: 'What about remote or multi-site teams?',
    a: 'Each person picks their own size and ships to their own address. Remote staff, multiple locations, and field teams all order the same way.',
  },
  {
    q: 'Can we cap how much each person spends?',
    a: 'Yes. You set a budget per person — a balance or a spend limit. People order within it, and you see every order in one place.',
  },
  {
    q: 'Who actually follows up?',
    a: 'A real person — Bighorn Threads, based in Las Vegas. Founder Steven Dodson answers the phone himself. No call center, no phone tree.',
  },
]

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<LandingLayout
  title="Branded Company Store for Your Team — Free Setup | Bighorn Threads"
  description="Stop chasing sizes by email. We build your branded company store free — your people order their own sizes, gear ships direct, you control the budget. Tell us about your team."
  canonical="https://bighornthreads.com/get-started/corporate/"
  noindex={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- ════ HERO — 2-col pitch + sticky form ════ -->
  <section class="min-h-[100svh] bg-concrete pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">

        <!-- Left: pitch -->
        <div>
          <p class="kicker mb-3">Corporate Company Stores</p>
          <h1 class="mb-6 font-heading text-4xl font-extrabold uppercase leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Your Team's <span class="text-gold-600">Branded Gear</span> — Without You Chasing a Single Size.
          </h1>
          <p class="mb-8 text-lg leading-relaxed text-ash sm:text-xl">
            We build your branded company store free. Your people order their own sizes, gear ships
            direct, and you control the budget. No spreadsheets, no closet inventory.
          </p>

          <ul class="mb-8 space-y-3 text-base text-ash">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Your people order their own sizes</strong> — shipped to the office or their home, so your managers stop being the size-collection department</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Your logo stays on file</strong> — same colors, same placement, every reorder, so your brand never drifts across vendors again</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">You control the budget</strong> — cap spend per person and see every order in one place, so apparel stops being a guessing game</span>
            </li>
          </ul>

          <p class="font-mono text-xs uppercase tracking-[0.15em] text-ash">No commitment · Free store setup · A real person follows up</p>
        </div>

        <!-- Right: form (sticky on desktop) -->
        <div class="lg:sticky lg:top-24">
          <LeadCaptureForm
            vertical="corporate"
            heading="Get your company store plan"
            qualifiers={[
              { name: 'gear_for', label: "Who's the gear for?", type: 'select', required: true, options: ['Employees', 'Clients & partners', 'An event or conference', 'Not sure yet'] },
              { name: 'headcount', label: 'Roughly how many people would order?', type: 'select', required: true, isHeadcount: true, options: ['Under 25', '25-100', '100-500', '500+'] },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ════ THE PROBLEM — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">The Problem</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Branded gear shouldn’t be <span class="text-gold-600">an ops headache.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          If you run office or people ops, you know the drill. Branded apparel turns into a spreadsheet
          you maintain by hand — and your brand pays for it.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {problems.map((item) => (
          <div class="border border-hairline bg-panel p-7">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ HOW IT WORKS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          How a company store works <span class="text-gold-600">for your team.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Your logo on file, consistent reorders, and a store your people run themselves. You set the
          budget. We handle the rest.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {storeSteps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-8">
        <a href="#lp-form-card" class="btn-secondary text-sm">
          Build my company store plan
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 11l7-7 7 7M12 4v16" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ WHAT YOU STOCK — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">What You Stock</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          What you can put in <span class="text-gold-600">your store.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Pick the gear that fits your team and your brand. Stock as much or as little as you want —
          add and swap products any time.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {offerings.map((item) => (
          <div class="flex flex-col border border-hairline bg-panel p-6">
            <span class="spec mb-3 inline-block self-start border border-hairline px-2 py-1 text-ash">{item.tag}</span>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ OBJECTIONS / TRUST — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <p class="kicker mb-3">Straight Answers</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Your questions, <span class="text-gold-600">answered.</span>
        </h2>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {objections.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CLOSING CTA — charcoal band ════ -->
  <section class="border-y border-hairline bg-charcoal py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-xl">
          <p class="kicker mb-3">Get Started</p>
          <h2 class="font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-4xl">
            Ready to give your team <span class="text-gold-400">a real company store?</span>
          </h2>
          <p class="mt-4 text-base leading-relaxed text-navy-200">
            Free store setup. Your people order their own sizes. A real Las Vegas person follows up. Tell
            us about your team and we’ll build your plan.
          </p>
        </div>
        <div class="flex shrink-0 flex-col gap-3 sm:items-end">
          <a href="#lp-form-card" class="btn-primary text-base">
            Build my company store plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 11l7-7 7 7M12 4v16" /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 font-mono text-sm font-medium tracking-wide text-concrete transition-colors hover:text-gold-400">
            <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
