---
import LandingLayout from '@/layouts/LandingLayout.astro'
import LeadCaptureForm from '@/components/LeadCaptureForm.astro'

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Get Started — Events', item: 'https://bighornthreads.com/get-started/events/' },
  ],
}

const problems = [
  {
    title: 'The Date Does Not Move.',
    desc: 'Doors open when they open. Gear has to be on-site and ready before then, or your crew shows up in plain clothes on the one day it matters.',
  },
  {
    title: 'Everybody Is a Different Size.',
    desc: 'Booth staff, volunteers, players, attendees — every body is different. Guess sizes for the group and half your people end up in gear that does not fit.',
  },
  {
    title: 'Counts Change to the Last Minute.',
    desc: 'People get added, people drop, the headcount shifts right up to the deadline. Lock the order too early and you are short or sitting on extras.',
  },
  {
    title: 'Next Time You Start From Scratch.',
    desc: 'Most vendors make you re-send your logo, re-approve the artwork, and rebuild the whole order every event. You redo the same work over and over.',
  },
]

const steps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We Build the Store or Run the Order',
    desc: 'Tell us the event, the gear, and the date. We set up your event store or run the order direct, and your logo and artwork stay on file for the next one.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Everyone Picks Their Own Size',
    desc: 'Each person picks their own size and submits — booth staff, volunteers, players, attendees. No spreadsheets, no size-guessing, no chasing counts from a hundred people.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Produced & Shipped to Hit Your Date',
    desc: 'Gear is produced and shipped to land before doors open — to the venue or to each person. Artwork is on file, so the next event is a click.',
  },
]

const faqs = [
  {
    q: 'Can you hit my date?',
    a: 'Tell us your date and we will tell you straight. Some timelines work and some are too tight to do right — we would rather be honest up front than miss your event. Give us the date early and we will build a plan that lands gear before doors open.',
  },
  {
    q: 'Do I have to collect everyone’s sizes?',
    a: 'No. Each person orders their own size and submits — staff, volunteers, players, or attendees. You skip the spreadsheet, and everyone gets gear that actually fits instead of a guess. Shipping goes to the venue or to each person’s door.',
  },
  {
    q: 'What about the next event?',
    a: 'Your logo and artwork stay on file. For a recurring event, series, or season, the next order is a click — same artwork, consistent branding, no starting over and no re-sending files each time.',
  },
  {
    q: 'Is this for a single event or a season-long team?',
    a: 'Both. A one-off conference and a season-long league are different jobs, and we handle each on its own terms. For teams we can do names and numbers where you need them, with artwork on file for every new roster.',
  },
]

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<LandingLayout
  title="Event Gear That Ships to Hit Your Date | Bighorn Threads"
  description="Free event store setup. Everyone orders their own size, gear ships to the venue or their door, and your artwork stays on file for the next one. Tell us your date and we'll tell you straight."
  canonical="https://bighornthreads.com/get-started/events/"
  noindex={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- ════ HERO + FORM — concrete ════ -->
  <section class="min-h-[100svh] bg-concrete pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">

        <!-- Left: pitch -->
        <div>
          <p class="kicker mb-3">Event apparel &amp; stores</p>
          <h1 class="mb-6 font-heading text-4xl font-extrabold uppercase leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Your Event Has a Date. Your Gear <span class="text-gold-600">Ships to Hit It.</span>
          </h1>
          <p class="mb-8 text-lg leading-relaxed text-ash sm:text-xl">
            Hard date, lots of people, no time to chase sizes. We build your event store or run the
            order, everyone picks their own gear, and it ships to land before doors open. Single
            events, recurring series, trade shows, and teams.
          </p>

          <ul class="mb-8 space-y-3 text-base text-ash">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Free store setup</strong> — your logo and artwork held on file, ready to reorder for the next event</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Everyone orders their own size</strong> — shipped to the venue or their door, no size-guessing on your end</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Built around your date</strong> — tell us when and we’ll tell you straight, then ship to land before doors open</span>
            </li>
          </ul>

          <p class="font-mono text-xs uppercase tracking-[0.15em] text-ash">No commitment · Free store setup · A real person follows up</p>
        </div>

        <!-- Right: form (sticky on desktop) -->
        <div class="lg:sticky lg:top-24">
          <LeadCaptureForm
            vertical="events"
            heading="Get your event gear plan"
            submitLabel="Build my event gear plan →"
            qualifiers={[
              { name: 'event_type', label: "What's the gear for?", type: 'select', required: true, options: ['A single event', 'Recurring events', 'Trade show or conference', 'Sports team or league', 'Other'] },
              { name: 'headcount', label: 'Roughly how many pieces?', type: 'select', required: true, isHeadcount: true, options: ['Under 50', '50-250', '251-1,000', '1,000+'] },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ════ THE PROBLEM — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">The Problem</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Event gear shouldn’t be <span class="text-gold-600">a last-minute scramble.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          If you run events, you know the drill. The date is fixed, the headcount keeps shifting, and
          the gear order always lands on your plate too late. It costs you time and the event pays for it.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {problems.map((item) => (
          <div class="border border-hairline bg-panel p-7">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ HOW IT WORKS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          How it works <span class="text-gold-600">for your event.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Your logo and artwork on file, sizes handled by the people wearing the gear, and a plan built
          around your date. You give us the event. We handle the rest.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {steps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-8">
        <a href="#lp-form-card" class="btn-secondary text-sm">
          Build my event gear plan
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ OBJECTIONS / TRUST — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <p class="kicker mb-3">Straight Answers</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          The questions <span class="text-gold-600">everyone asks.</span>
        </h2>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>

      <div class="mt-10 border border-hairline bg-panel p-7">
        <p class="text-sm leading-relaxed text-ash">
          <strong class="text-charcoal">Bighorn Threads</strong> is a Las Vegas shop run by VP Promos LLC.
          When you reach out, founder <strong class="text-charcoal">Steven Dodson</strong> — a real
          person, not a call center — follows up to talk through your event. Call him direct at
          <a href="tel:+17029048923" class="font-mono text-charcoal hover:text-gold-600">702.904.8923</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- ════ CLOSING CTA — charcoal band ════ -->
  <section class="bg-charcoal py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="kicker mb-3">Get Started</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-5xl">
          You’ve got a date. <span class="text-gold-400">Let’s get the gear right.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-navy-200">
          Free store setup, first digitizing on us, no contract and no inventory to hold. Everyone
          orders their own size, drinkware and giveaways like Yeti round out the kit, and your artwork
          stays on file for next time. Tell us your date and we’ll tell you straight.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="#lp-form-card" class="btn-primary text-base">
            Build my event gear plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-concrete transition-colors hover:text-gold-400">
            <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
