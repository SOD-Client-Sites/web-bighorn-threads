---
import LandingLayout from '@/layouts/LandingLayout.astro'
import LeadCaptureForm from '@/components/LeadCaptureForm.astro'

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'

const problems = [
  {
    title: 'Role Colors That Don’t Hold',
    desc: 'You set scrub colors by role and department, then turnover and one-off orders erode them. Within a year nobody remembers which color belongs to which unit.',
  },
  {
    title: 'Names & Logos Across Every Hire',
    desc: 'Embroidered names and a logo on every scrub and lab coat sounds simple — until you’re re-explaining placement and re-digitizing artwork on each new round of staff.',
  },
  {
    title: 'Multi-Site Ordering Chaos',
    desc: 'Every clinic and floor orders its own way — different vendors, different garments, different embroidery. Nobody’s running the system, everybody’s chasing it.',
  },
  {
    title: 'Reorders Reset Every Time',
    desc: 'Staff turn over, and the next order starts from scratch — logo re-matched, colors re-picked, names re-typed. Consistency leaks out with every reorder.',
  },
]

const storeSteps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We Build Your Store, Free',
    desc: 'Your logo, your role and department colors, your approved scrubs and lab coats — set up once, on us. One branded store for every site, with the first digitizing on us.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Staff Order Their Own',
    desc: 'Each person logs in, picks their size and role apparel, and submits. No size-guessing, no HR middleman, no spreadsheet — the store only shows the right options for their unit.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships Embroidered, Names on File',
    desc: 'Gear ships straight to the site or to each person’s home — logo and name embroidery already on file. Reorders match the first order, every time staff turn over.',
  },
]

const faqs = [
  {
    q: 'What does “free” actually cover?',
    a: 'Free store setup and your first digitizing are on us — we build the branded store, load your logo and role colors, and get your artwork stitch-ready at no cost. You only pay for the apparel your team actually orders, at your team’s pricing. No setup fee, no monthly fee, no per-user fee.',
  },
  {
    q: 'Can we add names and credentials to scrubs and lab coats?',
    a: 'Yes. We embroider first name, last name, role, and credentials onto scrubs, lab coats, and jackets. Your logo and each staff member’s name are saved on file, so every reorder matches without re-explaining placement.',
  },
  {
    q: 'Can different roles or departments have different colors?',
    a: 'Yes. You set the color rules — by role, by department, or by site — and the store enforces them. Staff only see the right options for their unit, so color-coding holds up as people come and go.',
  },
  {
    q: 'Can multi-site staff order to their own location or home?',
    a: 'Yes. Each person chooses to ship to their site or to their home address at checkout. One store covers every clinic, floor, and building — no separate vendors or order forms per location.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Get Started', item: 'https://bighornthreads.com/get-started/' },
    { '@type': 'ListItem', position: 3, name: 'Healthcare', item: 'https://bighornthreads.com/get-started/healthcare/' },
  ],
}
---

<LandingLayout
  title="Free Healthcare Company Store — Bighorn Threads"
  description="Take staff uniforms off your plate. Embroidered scrubs and lab coats, role colors, names on file. Staff order their own sizes, ships direct. Free store setup, no contract."
  canonical="https://bighornthreads.com/get-started/healthcare/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- ════ HERO + FORM — concrete ════ -->
  <section class="min-h-[100svh] bg-concrete pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">

        <!-- Left: pitch -->
        <div>
          <p class="kicker mb-3">Healthcare Company Stores</p>
          <h1 class="mb-6 font-heading text-4xl font-extrabold uppercase leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Take staff uniforms off your plate — <span class="text-gold-600">for good.</span>
          </h1>
          <p class="mb-8 text-lg leading-relaxed text-ash sm:text-xl">
            One branded store for your whole team. Embroidered scrubs and lab coats,
            color-coded to your roles, with names and logo on file. Staff order their own
            sizes. We’ll build your store free.
          </p>

          <ul class="mb-8 space-y-3 text-base text-ash">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Names &amp; logo on file</strong> — every scrub and lab coat ships embroidered and consistent, even as staff turn over</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Role &amp; department colors that hold</strong> — set the rules once, the store enforces them across every site</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Staff order their own sizes</strong> — shipped to the site or their home, off your HR team’s plate</span>
            </li>
          </ul>

          <p class="font-mono text-xs uppercase tracking-[0.15em] text-ash">Free store setup · A real person builds it with you · No contract, no commitment</p>
        </div>

        <!-- Right: form (sticky on desktop) -->
        <div class="lg:sticky lg:top-24">
          <LeadCaptureForm
            vertical="healthcare"
            heading="Get your company store plan"
            qualifiers={[
              { name: 'org_type', label: 'Type of organization?', type: 'select', required: true, options: ['Hospital', 'Clinic or practice', 'Multi-site group', 'Dental or specialty', 'Other'] },
              { name: 'headcount', label: 'Roughly how many staff would order?', type: 'select', required: true, isHeadcount: true, options: ['Under 50', '50-250', '251-1,000', '1,000+'] },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ════ THE PROBLEM — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">The Problem</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Staff apparel shouldn’t be <span class="text-gold-600">an ops headache.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Clinics and hospitals run on consistency. Uniforms are where it slips — drifting
          role colors, embroidered names across every hire, multi-site reorders, and
          turnover that resets it all. Here’s what we hear most.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {problems.map((item) => (
          <div class="border border-hairline bg-panel p-6">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ HOW IT WORKS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Three steps to a store that <span class="text-gold-600">runs itself.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          One free branded store, set up once. Your staff do the ordering. Your logo,
          names, and role colors stay on file so every piece matches the last.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {storeSteps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-8">
        <a href="#lp-form-card" class="btn-secondary text-sm">
          Get your store plan
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ TRUST + OBJECTIONS — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">Built By a Real Shop</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Built and run by a <span class="text-gold-600">real Las Vegas shop.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          Bighorn Threads is VP Promos LLC — founded and run by Steven Dodson out of Las
          Vegas. You work with a real person, you see a demo store before you commit, and
          there’s no contract. If it’s not right, you walk.
        </p>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CLOSING CTA — charcoal band ════ -->
  <section class="bg-charcoal py-20 sm:py-28">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <p class="kicker mb-3 justify-center">Get Started</p>
      <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-paper sm:text-5xl">
        Take it off your plate <span class="text-gold-500">for good.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-concrete">
        We’ll build your free company store — scrubs and lab coats, embroidered and
        color-coded to your roles, names and logo on file. Staff order their own sizes,
        gear ships direct. No contract, no commitment.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="#lp-form-card" class="btn-primary text-base">
          Build my company store plan
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
        <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-paper transition-colors hover:text-gold-500">
          <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          702.904.8923
        </a>
      </div>
    </div>
  </section>
</LandingLayout>
