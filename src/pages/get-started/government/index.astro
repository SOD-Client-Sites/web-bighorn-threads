---
import LandingLayout from '@/layouts/LandingLayout.astro'
import LeadCaptureForm from '@/components/LeadCaptureForm.astro'

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Get Started — Government', item: 'https://bighornthreads.com/get-started/government/' },
  ],
}

const problems = [
  {
    title: 'Every department buys its own way',
    desc: 'Public works orders one place, parks another, transit a third. Nobody owns the standard and the agency ends up looking like ten different brands.',
  },
  {
    title: 'Chasing sizes all over again',
    desc: 'A new hire starts, a vest wears out, and someone is back to collecting sizes by email and guessing on the reorder.',
  },
  {
    title: 'Hi-vis class confusion',
    desc: 'Field crews need the right ANSI class for the job. Guessing between Class 2 and Class 3 slows the crew and risks the wrong gear on site.',
  },
  {
    title: 'Budget and brand drift',
    desc: 'Without approved items per department, garments wander off-spec and spend is hard to see across the whole agency.',
  },
]

const steps = [
  {
    n: '01',
    meta: 'Setup',
    title: 'We build your free branded store',
    desc: 'Your agency seal or logo goes on file. We stand up a private store with your approved garments, your colors, and a section per department. Free store setup — the first digitizing is on us.',
  },
  {
    n: '02',
    meta: 'Ongoing',
    title: 'Each department orders its own sizes',
    desc: 'Staff log in, pick the right size, and submit. You decide which items each department can order, so everything stays on-spec without an email chain for every request.',
  },
  {
    n: '03',
    meta: 'Ongoing',
    title: 'Ships direct, no inventory to hold',
    desc: 'Gear ships direct to the yard, office, or employee. You hold no stock and pay no monthly or per-user fee — you only pay for the gear that gets ordered.',
  },
]

const faqs = [
  {
    q: 'Is this a bid or RFP response?',
    a: 'No. This is a free store plan with no obligation. We build it so you can see exactly how ordering would work for your departments. If you later need a formal quote, we work within your procurement process.',
  },
  {
    q: 'What does setup cost?',
    a: 'The store setup is free and the first logo digitizing is on us. There is no monthly fee and no per-user fee. You only pay for the gear your departments actually order.',
  },
  {
    q: 'Can one store serve every department?',
    a: 'Yes. One store can serve public works, parks, water, transit, and admin together. Each department orders its own approved items and sizes while the agency keeps one consistent identity.',
  },
  {
    q: 'Can it hold ANSI hi-vis and safety apparel?',
    a: 'Yes. The store can hold ANSI hi-vis and safety apparel for field crews right alongside your standard uniforms, so the right safety class is built into what staff can order — including brands like ML Kishigo and Bulwark FR where they fit the job.',
  },
  {
    q: 'Who are we?',
    a: 'Bighorn Threads, operated by VP Promos LLC, a Las Vegas team. Our founder is Steven Dodson. When you reach out, a real person follows up — not a call center.',
  },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<LandingLayout
  title="Branded Company Stores for Public Agencies | Bighorn Threads"
  description="One free branded store for every department — uniforms and ANSI hi-vis together, your seal on file, staff order their own sizes, ships direct. No obligation. Las Vegas team."
  canonical="https://bighornthreads.com/get-started/government/"
  noindex={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- ════ HERO + FORM — concrete ════ -->
  <section class="min-h-[100svh] bg-concrete pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">

        <!-- Left: pitch -->
        <div>
          <p class="kicker mb-3">Public-Sector Company Stores</p>
          <h1 class="mb-6 font-heading text-4xl font-extrabold uppercase leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Outfit every department from <span class="text-gold-600">one branded store.</span>
          </h1>
          <p class="mb-8 text-lg leading-relaxed text-ash sm:text-xl">
            Cities, counties, state agencies, public works, utilities, and transit. We build a private
            store with your seal on file, so every department orders its own sizes under one agency
            identity — uniforms and ANSI hi-vis safety apparel in one place.
          </p>

          <ul class="mb-8 space-y-3 text-base text-ash">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">One store, every department</strong> — public works, parks, water, transit, and admin order under a single agency identity</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">Hi-vis and uniforms together</strong> — the store can hold ANSI hi-vis and safety apparel for field crews alongside your standard uniforms</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
              <span><strong class="text-charcoal">You set what's orderable</strong> — decide the approved items per department and gear ships direct, no email chains</span>
            </li>
          </ul>

          <p class="font-mono text-xs uppercase tracking-[0.15em] text-ash">Free store setup · Logo on file · A Las Vegas team — a real person follows up, not a call center</p>
        </div>

        <!-- Right: form (sticky on desktop) -->
        <div class="lg:sticky lg:top-24">
          <LeadCaptureForm
            vertical="government"
            heading="Get your company store plan"
            qualifiers={[
              { name: 'org_type', label: 'Type of agency?', type: 'select', required: true, options: ['City or county', 'State agency', 'Federal', 'Public works or utility', 'Other'] },
              { name: 'headcount', label: 'Roughly how many people would order?', type: 'select', required: true, isHeadcount: true, options: ['Under 50', '50-250', '251-1,000', '1,000+'] },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ════ THE PROBLEM — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <p class="kicker mb-3">The Problem</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Outfitting an agency is harder than <span class="text-gold-600">it should be.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          A public agency runs many departments, many crews, and one public identity. Without a system,
          uniforms drift off-spec, safety gear gets guessed at, and the budget is hard to see.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {problems.map((item) => (
          <div class="border border-hairline bg-panel p-6">
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ HOW IT WORKS — concrete ════ -->
  <section class="bg-concrete py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="kicker mb-3">How It Works</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          One store your departments use, <span class="text-gold-600">your ops team controls.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ash">
          A real ordering portal with your seal on file. Each department orders its own sizes, gear
          ships direct, and you decide the approved items per department.
        </p>
      </div>

      <ol class="grid gap-5 md:grid-cols-3">
        {steps.map((step) => (
          <li class="border border-hairline bg-panel p-7">
            <div class="mb-5 flex items-baseline justify-between">
              <span class="font-heading text-5xl font-extrabold leading-none text-gold-600">{step.n}</span>
              <span class="spec border border-hairline px-2 py-1 text-ash">{step.meta}</span>
            </div>
            <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ash">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-10">
        <a href="#lp-form-card" class="btn-secondary text-base">
          Get your company store plan
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ OBJECTIONS / TRUST — paper ════ -->
  <section class="border-y border-hairline bg-paper py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <p class="kicker mb-3">Questions</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-5xl">
          Straight answers <span class="text-gold-600">before you ask.</span>
        </h2>
      </div>

      <div class="divide-y divide-hairline border-y border-hairline">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
              <span class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal">{item.q}</span>
              <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </summary>
            <p class="pb-5 leading-relaxed text-ash">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CLOSING CTA — charcoal band ════ -->
  <section class="bg-charcoal py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="kicker mb-3">Get Started</p>
        <h2 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-concrete sm:text-5xl">
          One branded store for <span class="text-gold-600">every department.</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-navy-200">
          Free store setup, your seal on file, staff order their own sizes, hi-vis and uniforms in one
          place. No obligation — we build the plan and a real person follows up.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="#lp-form-card" class="btn-primary text-base">
            Get your company store plan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
          </a>
          <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-concrete transition-colors hover:text-gold-600">
            <svg class="h-4 w-4 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            702.904.8923
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</LandingLayout>
