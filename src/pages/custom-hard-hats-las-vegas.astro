---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Hard Hats in Las Vegas | ANSI Z89.1 Branded Decals — Bighorn Threads',
 description:
 'Custom hard hats for Las Vegas crews — ANSI Z89.1 shells from MSA, Honeywell, Bullard, 3M, and Pyramex, branded with manufacturer-approved vinyl decals. Type I or Type II, Class E for electrical. Get a quote.',
 hero: '/images/generated/kit-electrical.jpg',
 url: 'https://bighornthreads.com/custom-hard-hats-las-vegas/',
}

const stack = [
 { label: 'The shell', body: 'ANSI/ISEA Z89.1-certified hard hats from MSA, Honeywell (North), Bullard, 3M, and Pyramex. Stocked in white, yellow, orange, blue, red, and black. Full-brim and cap-style.' },
 { label: 'The branding', body: 'Manufacturer-approved vinyl decals — front, back, and sides. Reflective vinyl options for night-shift and DOT crews. The shell stays untouched, so the ANSI rating stays valid.' },
 { label: 'Class & type', body: 'Type I (top impact) for general construction. Type II (top + lateral) for data centers, high-rise, and refining. Class E for electrical work up to 20,000V. Class G for everyone else.' },
 { label: 'Program-ready', body: 'Re-order spares with the same decals so the visual ID holds across years. Per-employee allowances available through a private company store. Replacement-rate planning on request.' },
]

const ansiTable = [
 { row: 'Type I', meaning: 'Top-of-head impact only', use: 'General construction, framing, finish trades, GC' },
 { row: 'Type II', meaning: 'Top + lateral impact', use: 'Data centers, high-rise, refining, swinging-load operations' },
 { row: 'Class G', meaning: 'Up to 2,200V (general)', use: 'Most non-electrical trades' },
 { row: 'Class E', meaning: 'Up to 20,000V (electrical)', use: 'Electricians, linemen, solar, utility' },
 { row: 'Class C', meaning: 'No electrical (conductive)', use: 'Aluminum-shell — niche, rare on Vegas sites' },
]

const decoration = [
 { ok: true, label: 'Vinyl decals', body: 'Front, back, sides. Manufacturer-approved on every major shell. Standard for branded hard hat programs.' },
 { ok: true, label: 'Reflective vinyl', body: '3M reflective stripes on front, sides, back. Pairs with hi-vis for night work and DOT-adjacent visibility programs.' },
 { ok: true, label: 'Pre-printed stickers', body: 'For project-specific IDs (gate badges, cert stickers). Removable without residue.' },
 { ok: false, label: 'Paint or screen print', body: 'Voids the ANSI rating. Solvents and cured inks change the shell chemistry.' },
 { ok: false, label: 'Drilling or screws', body: 'Voids the ANSI rating. Penetrates the shell. Never approved.' },
 { ok: false, label: 'Heat-applied transfers', body: 'Voids the ANSI rating on most thermoplastic shells. Skip it.' },
]

const faqs = [
 { q: 'Are custom hard hats OSHA compliant?', a: 'Yes — when the underlying shell carries an ANSI/ISEA Z89.1 marking and the decoration follows the manufacturer\'s written guidance. OSHA enforces ANSI Z89.1 through 29 CFR 1926.100. Vinyl decals are accepted by every major U.S. hard hat manufacturer; paint, screen print, and shell drilling are not.' },
 { q: 'Type I vs Type II — which one does my crew need?', a: 'Type I protects against impact from above. Type II protects against impact from above and the side. General construction defaults to Type I. Data center, high-rise, refinery, and any project with side-strike risk should spec Type II. Many Vegas hyperscaler data center jobs require Type II.' },
 { q: 'Do you supply Class E electrical hard hats for linemen?', a: 'Yes. Class E hard hats are rated for incidental contact up to 20,000V and are the standard for electricians, linemen, solar installers, and utility crews. Stocked in white, yellow, and orange. Pairs cleanly with our FR shirt programs for full electrical-trade kit.' },
 { q: 'Can you put reflective stickers on a hard hat?', a: 'Yes — ANSI/ISEA Z89.1 explicitly permits retroreflective decals. We use 3M reflective vinyl on front, sides, and back for night-shift, road-construction, and DOT-adjacent programs. Common pair-up with ANSI 107 hi-vis vests for full visibility programs.' },
 { q: 'How do you brand a hard hat without voiding ANSI Z89.1?', a: 'Vinyl decals or pre-printed reflective stickers — applied to the shell within the manufacturer\'s placement zones, never within ½" of any drainage channel or shell edge. No drilling, no painting, no screen printing, no heat. We follow the published guidance for every shell brand we stock.' },
 { q: 'Can you supply hard hats with our company logo and a worker name?', a: 'Yes. Standard layout: front decal carries the company logo, side decals carry crew or project ID, back decal carries the worker\'s last name. Every decal goes on without affecting the certification.' },
 { q: 'Do you offer safety helmets (climbing-style) instead of traditional hard hats?', a: 'Yes. Safety helmets wrap the sides of the head, include a chinstrap, and meet either Type I or Type II ANSI Z89.1 — gaining adoption on Vegas data center, solar, and high-rise projects. Branded the same way as traditional hard hats: vinyl decals on approved zones.' },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Custom Hard Hats Las Vegas', item: page.url },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Hard Hats in Las Vegas',
 serviceType: 'Branded ANSI Z89.1 hard hats with vinyl decal decoration',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Summerlin' },
 { '@type': 'City', name: 'Spring Valley' },
 ],
 description: page.description,
 url: page.url,
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
