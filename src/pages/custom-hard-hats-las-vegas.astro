 <!-- ANSI table -->
 <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-10 max-w-2xl">
 <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">ANSI Z89.1</span>
 <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Type and Class — what to spec.</h2>
 <p class="mt-4 text-lg leading-relaxed text-gray-300">
 Every ANSI hard hat carries a Type (impact protection) and a Class (electrical protection). You spec both at order time.
 </p>
 </div>

 <div class="overflow-hidden rounded-2xl border border-navy-700/40">
 <table class="w-full">
 <thead class="bg-navy-900/60">
