 <!-- Decoration rules -->
 <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Decoration Rules</span>
 <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What's allowed on an ANSI shell — and what voids the rating.</h2>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
 {decoration.map((d) => (
 <div class={`rounded-2xl border p-6 transition-all ${d.ok ? 'border-navy-700/40 bg-navy-900/40 hover:border-gold-500/30' : 'border-red-900/40 bg-navy-900/30'}`}>
