 <span class={`flex h-6 w-6 items-center justify-center rounded-full text-xs font-bold ${d.ok ? 'bg-gold-500 text-navy-950' : 'bg-red-900/50 text-red-300'}`}>
 {d.ok ? '✓' : '✕'}
 </span>
