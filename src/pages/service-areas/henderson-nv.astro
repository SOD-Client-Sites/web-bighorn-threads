---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Custom Workwear and Branded Apparel in Henderson, NV',
  description:
    'Embroidered uniforms, screen-printed crew gear, and FR/hi-vis workwear for Henderson contractors and service trades. Free local delivery to Henderson commercial addresses. 24-hour quotes.',
  h1Pre: 'Henderson, NV',
  hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
  {
    code: 'Major Projects',
    title: 'Master-planned community build-out is the work',
    body: 'Cadence, Inspirada, Skye Canyon, Tuscany — Henderson is one of the busiest residential build environments in the valley. GCs and the subs trailing them (electrical, plumbing, HVAC, framing, concrete) are running multiple phases concurrently. The Henderson Hospital expansion and the Henderson Pavilion arts district add commercial fit-out volume on top.',
  },
  {
    code: 'Active Trades',
    title: 'Who we already outfit out here',
    body: 'Subs running for Martin-Harris, McCarthy, and the regional GCs working Henderson tracts. Service trades anchored on the south side — HVAC and plumbing shops covering Anthem, Green Valley, and MacDonald Highlands. We know the foremen by name on a few of these crews.',
  },
  {
    code: 'What Crews Need Locally',
    title: 'Sharper presentation, faster turnaround',
    body: 'Henderson commercial work runs cleaner than off-Strip industrial — owners and superintendents notice uniformed crews. We deliver free to Henderson commercial addresses (Eastgate, Gibson, Stephanie corridor) and run same-week reorders for shops that already have a spec on file.',
  },
]

const trades = [
  {
    name: 'General Contractors',
    detail: 'Crew shirts, sub branding, foreman/super differentiation for Henderson tract work and commercial fit-out.',
    href: '/industries/general-contractors-las-vegas/',
    img: '/images/generated/kit-office-sales.jpg',
  },
  {
    name: 'Electrical Contractors',
    detail: 'NFPA 70E FR, ANSI Class 2 hi-vis, and embroidered service polos for crews running Cadence and Inspirada.',
    href: '/industries/electrical-contractors-las-vegas/',
    img: '/images/generated/kit-electrical.jpg',
  },
  {
    name: 'Plumbing & HVAC',
    detail: 'Embroidered service polos with name + title for residential service techs working Anthem and Green Valley.',
    href: '/industries/plumbing-hvac-las-vegas/',
    img: '/images/generated/kit-plumbing-hvac.jpg',
  },
  {
    name: 'Roofing & Solar',
    detail: 'Sun-protective hi-vis and crew tees for rooftop work across MacDonald Highlands and Seven Hills installs.',
    href: '/industries/roofing-solar-las-vegas/',
    img: '/images/generated/service-screen-printing.jpg',
  },
]

const useCases = [
  'New-tract framing crews getting branded tees + hats before the first slab pours in Cadence',
  'HVAC service techs in embroidered polos for Green Valley and Anthem residential routes',
  'Electrical subs running FR layers on hospital expansion and Henderson Hospital build-out',
  'GC superintendents in differentiated polos walking jobs in Inspirada and Skye Canyon',
  'Concrete and framing companies reordering branded long-sleeves for sun-exposed Henderson tract work',
  'Office staff and estimators in lighter-weight polos for Eastgate and Gibson corridor offices',
]

const faqs = [
  {
    q: 'Do you deliver to Henderson, or do we have to drive to your shop?',
    a: 'We deliver free to Henderson commercial addresses on orders over $250 — Eastgate, Gibson, Stephanie, the south Henderson industrial pockets. For residential or smaller orders, pickup at our Las Vegas shop is fastest. Either way, no shipping costs hidden in the quote.',
  },
  {
    q: 'How fast can you turn an order around for a Henderson contractor?',
    a: '24-hour quote turnaround. Standard production is 7–10 business days from artwork approval. Rush is 72 hours on orders up to 200 pieces — we have repeat Henderson clients who reorder on a 48-hour cycle for new-hire kits.',
  },
  {
    q: 'We\'re a sub running multiple Cadence and Inspirada phases. Can you keep our gear consistent across reorders?',
    a: 'Yes — that\'s exactly what our spec sheets are for. Once you approve the first run, we keep the garment, color, thread, and decoration locked. Phase 4 looks identical to phase 1, even if it\'s 18 months later.',
  },
  {
    q: 'Can you handle a fleet of service trucks getting wrapped at the same time as the crew gets uniforms?',
    a: 'Yes. We coordinate with truck wrap shops in Henderson regularly so the logo, colorway, and license number layout match across both. Send us the wrap proof and we\'ll align the uniform program to it.',
  },
  {
    q: 'Do you stock anything for hot-weather Henderson summer work?',
    a: 'Yes — Port Authority K500 micro-mesh polos, lightweight long-sleeve sun shirts, ANSI hi-vis in moisture-wicking poly. We also carry FR-rated lightweight options for crews that need arc-rated layers without cooking in 110°.',
  },
  {
    q: 'What\'s the minimum order for branded gear?',
    a: '24 pieces for screen printing, 12 for embroidery. Most Henderson shops we work with order in 25–50 piece runs and reorder quarterly. Smaller is fine — we just don\'t waive setup under 25.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
    { '@type': 'ListItem', position: 3, name: 'Henderson, NV', item: 'https://bighornthreads.com/service-areas/henderson-nv/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear and Branded Apparel in Henderson, NV',
  serviceType: 'Branded apparel, embroidered uniforms, and FR/hi-vis workwear',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: {
    '@type': 'City',
    name: 'Henderson',
    address: { '@type': 'PostalAddress', addressRegion: 'NV', addressCountry: 'US' },
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/service-areas/henderson-nv/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/service-areas/" class="hover:text-gold-400">Service Areas</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Henderson, NV</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Custom Workwear and Branded Apparel <span class="text-gold-500">in Henderson, NV.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        Embroidered uniforms, screen-printed crew gear, and FR/hi-vis workwear for Henderson contractors and service trades. Free delivery to Henderson commercial addresses. We know the master-planned community build-out — Cadence, Inspirada, Skye Canyon — and we keep your spec on file for clean reorders.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Local context -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Local Context</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Why Henderson is its own market.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Henderson isn't just "south of Las Vegas." It's the master-planned-community capital of the valley, with its own GCs, its own permit office, and its own pace. We outfit crews working the tracts, the hospital expansion, and the Pavilion-area commercial pockets.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {localContext.map((c) => (
          <div class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <span class="mb-4 inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{c.code}</span>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white">{c.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trades we serve here -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Trades</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Trades we serve in Henderson.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Most Henderson work falls into one of these four buckets. Click through for the gear, brands, and compliance specifics for each trade.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {trades.map((t) => (
          <a href={t.href} class="group block overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
              <img src={t.img} alt={t.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="mb-2 font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">{t.name}</h3>
              <p class="text-sm leading-relaxed text-gray-400">{t.detail}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Typical orders -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Typical Orders</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we run for Henderson crews every week.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Tract framing crews, residential service techs, commercial fit-out subs, hospital-expansion electrical and mechanical. The Henderson order mix leans residential and master-planned — different from off-Strip industrial.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">All Services →</a>
            <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Company Stores →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {useCases.map((u, i) => (
            <li class="flex items-start gap-4 rounded-xl border border-navy-700/30 bg-navy-900/30 p-4 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-base leading-relaxed text-gray-200">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Local context -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Local Context</span>
      <h2 class="mb-8 font-heading text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        Custom branded apparel for Henderson contractors and trade businesses.
      </h2>

      <div class="space-y-5 text-lg leading-relaxed text-navy-200">
        <p>
          Henderson is the second-largest city in Nevada and home to one of the densest concentrations of trade contractors in the Vegas metro — general contractors building out the Inspirada and Cadence master-planned communities, electrical contractors wiring the Black Mountain residential boom, mechanical and plumbing shops servicing the Green Valley commercial corridor, and the data center contractors working the Henderson hyperscaler campuses east of the 95. Bighorn Threads delivers free to every Henderson business address inside the Las Vegas Valley on orders over $500 — production happens in our Las Vegas shop and the truck rolls out as part of our daily delivery route.
        </p>
        <p>
          Henderson construction has a different mix than central Las Vegas. The residential development scale is enormous — Inspirada alone is 2,000 acres of master-planned community, with 12,000+ homes planned at buildout. That drives sustained demand for residential framing crews, concrete subs, MEP coordination teams, and finish trades that all need branded crew apparel. Bighorn supplies these residential-focused crews with the same Carhartt, Bayside, and Port Authority programs we run for commercial primes — but with a sizing and reorder cadence tuned to residential build velocity.
        </p>
        <p>
          For Henderson HOA grounds-maintenance, irrigation specialists, and landscape design firms working the master-planned communities, branded uniforms are a competitive requirement. Anthem, Sun City Anthem, MacDonald Highlands, and the Lake Las Vegas communities all expect service contractors to show up in identifiable, professional apparel — and that branding directly influences which firms get the next project. We outfit Henderson landscape companies with embroidered polos, branded caps, and ANSI 107 hi-vis for crews working near vehicle traffic on community projects.
        </p>
        <p>
          The Henderson hyperscaler data center cluster east of the 95 — including Switch's Citadel campus and the Google Henderson facility — drives heavy demand for FR-rated electrical apparel and ANSI 107 hi-vis for the trades working those projects. We supply Bulwark Excel-FR, Carhartt FR Lightweight, ML Kishigo Class 2 hi-vis, and the full company-store program for contractors deploying crews into Henderson hyperscaler builds. Decoration on FR uses Nomex thread; decoration on hi-vis preserves retroreflective tape coverage; documentation on every order keeps your safety binder audit-ready.
        </p>
        <p>
          Free local delivery to every Henderson business address on orders over $500 — Eastside, Westside, Anthem, Green Valley, Inspirada, Cadence, Lake Las Vegas, the works. Drop-off direct to your office, warehouse, or active jobsite. Most Henderson clients run weekly delivery cycles for ongoing company-store programs, and we coordinate delivery to project lay-down yards for crews working data center, residential mass-build, and commercial multifamily projects.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Questions Henderson contractors ask us.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Nearby &amp; Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/service-areas/summerlin/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Summerlin</h3>
          <p class="mt-2 text-sm text-gray-400">High-end residential and commercial — Howard Hughes Corp territory across the valley.</p>
        </a>
        <a href="/service-areas/boulder-city/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Boulder City</h3>
          <p class="mt-2 text-sm text-gray-400">Solar farm and utility work just down US-93 from Henderson.</p>
        </a>
        <a href="/industries/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">All Industries</h3>
          <p class="mt-2 text-sm text-gray-400">Trade-specific gear, brands, and compliance — pick your industry.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Free delivery to Henderson. 24-hour quotes.</h2>
      <p class="mb-8 text-lg text-gray-300">Talk to a real human who knows the Henderson market — Cadence, Inspirada, Skye Canyon, the Pavilion district.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
