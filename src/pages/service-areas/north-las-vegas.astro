---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Workwear and Branded Apparel in North Las Vegas',
 description:
 'FR shirts, ANSI hi-vis, and embroidered crew uniforms for North Las Vegas industrial, warehouse, and data center contractors. Apex, VVSEP, and the I-15 data center alley.',
 h1Pre: 'North Las Vegas',
 hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
 {
 code: 'Major Projects',
 title: 'Industrial, warehouse, and data center heavy',
 body: 'Apex Industrial Park keeps adding tenants. Valley View / VVSEP and the I-15 corridor are the data center alley of the Southwest — Vegas hyperscaler and colo campuses, and the contractors building and maintaining them. Big-box warehouse, e-comm fulfillment, cold storage. The work is industrial and the safety spec is real.',
 },
 {
 code: 'Active Trades',
 title: 'Who we already outfit out here',
 body: 'Industrial electrical contractors running data center fit-out (medium voltage, switchgear). Mechanical and process piping subs on warehouse builds. Steel erectors, concrete tilt-up crews, fire-protection sprinkler shops. Anything pulling permits in NLV is on a tight schedule and needs gear that arrives when promised.',
 },
 {
 code: 'What Crews Need Locally',
 title: 'Compliance-first, not aesthetics-first',
 body: 'Data center general contractors and warehouse owners run tight safety programs. ANSI Class 2 hi-vis, NFPA 70E FR for the electrical, OSHA-spec hard hat decals, and clean uniformed sub identification at the gate. We carry every brand the safety officer wants on file and we lay decoration up to the spec.',
 },
]

const trades = [
 {
 name: 'Electrical Contractors',
 detail: 'NFPA 70E FR shirts and ANSI hi-vis for medium-voltage, switchgear, and data center fit-out crews.',
 href: '/industries/electrical-contractors-las-vegas/',
 img: '/images/generated/kit-electrical.jpg',
 },
 {
 name: 'General Contractors',
 detail: 'Sub identification, foreman differentiation, and onboarding kits for industrial and warehouse builds.',
 href: '/industries/general-contractors-las-vegas/',
 img: '/images/generated/kit-office-sales.jpg',
 },
 {
 name: 'Plumbing & HVAC',
 detail: 'Mechanical and process piping crews on Apex and VVSEP warehouse and data center mechanical packages.',
 href: '/industries/plumbing-hvac-las-vegas/',
 img: '/images/generated/kit-plumbing-hvac.jpg',
 },
 {
 name: 'Roofing & Solar',
 detail: 'TPO and rooftop solar crews on industrial and warehouse roof systems across NLV.',
 href: '/industries/roofing-solar-las-vegas/',
 img: '/images/generated/service-screen-printing.jpg',
 },
]

const useCases = [
 'Data center electrical subs in FR layers, ANSI hi-vis, and gate-visible sub-ID polos',
 'Steel erection crews in heavy hi-vis tees + branded long-sleeves for Apex tilt-up sites',
 'Warehouse mechanical contractors in embroidered work shirts with name patches',
 'Fire sprinkler crews in branded button-downs with license number on the sleeve',
 'GC superintendents in differentiated polos walking VVSEP and I-15 corridor jobs',
 'Onboarding kits — 5 shirts, hat, hoodie, FR layer — for new hires on long industrial builds',
]

const faqs = [
 {
 q: 'We\'re running an electrical crew at a Vegas data center. Can you do FR-rated gear with our company branding?',
 a: 'Yes. We embroider on Bulwark, Carhartt FR, and other CAT 1/CAT 2 garments using FR-compatible thread (Nomex/aramid blend) and placement that preserves the certification. We also keep the spec sheet on file so the safety manager has documentation.',
 },
 {
 q: 'How fast can you turn around hi-vis for a North Las Vegas industrial crew that just landed a new contract?',
 a: 'Standard production runs from our local Las Vegas shop. Rush options available — we\'ve hit rushs for repeat NLV industrial clients with files already on hand.',
 },
 {
 q: 'Do you stock ANSI Class 2 hi-vis in bulk? We need 80+ shirts at once.',
 a: 'Yes. ML Kishigo, PIP, and Pioneer in adult S–4XL, lime and orange. 80 shirts is a normal weekly run for us — no waiting on backorder.',
 },
 {
 q: 'Can you do gate-visible sub identification — different shirts for each subcontractor on the same data center build?',
 a: 'Yes. We run sub-specific colorways and embroidery so each company\'s crew is identifiable at the gate and on-site. GC keeps the spec on file with us so identifying new sub crews mid-project is a fast turn.',
 },
 {
 q: 'Do you deliver to Apex Industrial Park and the VVSEP corridor?',
 a: 'Yes — local delivery on qualifying orders to North Las Vegas commercial addresses including Apex, Speedway industrial, and the VVSEP / I-15 corridor. Otherwise pickup at our Las Vegas shop is 15–20 min from most NLV job sites.',
 },
 {
 q: 'What\'s the minimum for branded crew gear?',
 a: '24 pieces for screen printing, 12 for embroidery. Most NLV industrial crews we work with run 50–150 pieces per order and reorder every 60–90 days as new hires roll on.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
 { '@type': 'ListItem', position: 3, name: 'North Las Vegas', item: 'https://bighornthreads.com/service-areas/north-las-vegas/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear and Branded Apparel in North Las Vegas',
 serviceType: 'Branded apparel, FR-rated workwear, and ANSI hi-vis for industrial trades',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: {
 '@type': 'City',
 name: 'North Las Vegas',
 address: { '@type': 'PostalAddress', addressRegion: 'NV', addressCountry: 'US' },
 },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/service-areas/north-las-vegas/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-16 sm:px-6 sm:pb-28 sm:pt-16 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <a href="/service-areas/" class="hover:text-gold-400">Service Areas</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">North Las Vegas</span>
 </nav>

 <p class="kicker mb-3">{page.h1Pre}</p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Custom Workwear and Branded Apparel <span class="text-gold-400">in North Las Vegas.</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 FR shirts, ANSI hi-vis, and embroidered crew uniforms for the industrial trades running Apex, VVSEP, and the I-15 data center alley. We speak data center safety spec — Vegas hyperscaler and colo campuses — and we deliver free to NLV commercial addresses.
 </p>

 <div class="mt-10 flex flex-wrap items-center gap-3">
 <a href="/contact/" class="btn-primary text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
 702.904.8923
 </a>
 </div>
 </div>
 </section>

 <!-- Local context — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Local Context</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">North Las Vegas is <span class="text-gold-600">industrial Vegas.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Different rhythm than the Strip or Henderson tracts. Apex, VVSEP, the I-15 data center corridor — this is industrial fit-out, warehouse, and data center construction. Safety spec is non-negotiable and gear has to arrive on schedule.
 </p>
 </div>

 <div class="grid gap-5 md:grid-cols-3">
 {localContext.map((c) => (
 <div class="border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <span class="spec mb-4 inline-block border border-hairline px-2.5 py-1 text-gold-600">{c.code}</span>
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal">{c.title}</h3>
 <p class="text-sm leading-relaxed text-ash">{c.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Trades we serve here — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">The Trades</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Trades we serve in <span class="text-gold-600">North Las Vegas.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Industrial-heavy mix: electrical and mechanical lead, with GC and roofing/solar filling out the data center and warehouse work. Click through for trade-specific gear, brands, and compliance.
 </p>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
 {trades.map((t) => (
 <a href={t.href} class="group flex flex-col border border-hairline bg-panel transition-colors hover:border-gold-500">
 <div class="aspect-[4/3] overflow-hidden">
 <img src={t.img} alt={t.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
 </div>
 <div class="p-5">
 <h3 class="mb-2 font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">{t.name}</h3>
 <p class="text-sm leading-relaxed text-ash">{t.detail}</p>
 </div>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Typical orders — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
 <div>
 <p class="kicker mb-3">Typical Orders</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">What we run for <span class="text-gold-600">NLV industrial crews.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Bigger orders, longer schedules, tighter safety specs. Most NLV crews reorder every 60–90 days as new hires roll on for the next phase.
 </p>
 <div class="mt-8 flex flex-wrap gap-3">
 <a href="/services/" class="btn-secondary text-sm">All Services →</a>
 <a href="/company-stores/" class="btn-secondary text-sm">Company Stores →</a>
 </div>
 </div>

 <ul class="space-y-3">
 {useCases.map((u, i) => (
 <li class="flex items-start gap-4 border border-hairline bg-panel p-4 transition-colors hover:border-gold-500">
 <span class="shrink-0 font-mono text-xs font-bold text-gold-600">{String(i + 1).padStart(2, '0')}</span>
 <span class="text-base leading-relaxed text-charcoal">{u}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Local context — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">Local Context</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase leading-tight tracking-tight text-charcoal sm:text-4xl">
 Custom branded apparel for North Las Vegas contractors and industrial trades.
 </h2>

 <div class="space-y-5 text-lg leading-relaxed text-ash">
 <p>
 North Las Vegas is the industrial backbone of the Vegas metro — Apex Industrial Park alone covers 18,000+ acres of sustained industrial development, with hyperscaler data centers, distribution warehouses, and manufacturing facilities driving continuous trade contractor demand. Bighorn Threads delivers free to every North Las Vegas business address on qualifying orders, with daily routes covering the Cheyenne corridor, Craig Road industrial zone, the Apex campus, and the Speedway-adjacent commercial development. Production runs out of our Las Vegas shop and in stock on most orders.
 </p>
 <p>
 The trade contractor mix in North Las Vegas leans heavily industrial. Steel erectors building the warehouse and data center frames, electrical contractors wiring the hyperscaler power infrastructure, mechanical and HVAC shops handling the chilled-water cooling systems, and the structural concrete crews pouring the slabs and tilt-walls. Every one of these trades runs FR-rated, hi-vis, or heavy-duty workwear programs at scale. We supply Bulwark Excel-FR, ML Kishigo Class 2 and Class 3 hi-vis, Carhartt heavyweight cotton tees, and Red Kap industrial uniforms — decorated with embroidered company logos and (often) project-specific identifiers for crews deployed across multiple jobsites.
 </p>
 <p>
 The Apex Industrial Park and Faraday Future facility area alone runs continuous build-out at scale. Hyperscaler data centers (multiple operators), Amazon distribution, and manufacturing facilities all drive sustained demand for FR electrical crews, structural steel teams, and mechanical contractors. The standard apparel package per crew member on these projects: 5 hi-vis tees, 5 work pants, 1 hi-vis jacket for night shifts, all decorated and shipped on hire date. We coordinate delivery to project lay-down yards on the Apex campus and to per-employee home addresses for crews flying in from out of state.
 </p>
 <p>
 North Las Vegas also has a heavy mechanical and HVAC service contractor presence — shops running residential and commercial service routes through the entire north metro. For these service-trade fleet operations, the spec is Red Kap industrial work shirts and pants with embroidered logos and woven name patches, processed through industrial laundry programs. We integrate with the major industrial laundry partners in the North Las Vegas market and pre-decorate shirts to match their inventory tagging — your service trucks roll out clean and identifying every Monday morning.
 </p>
 <p>
 Local delivery available anywhere in North Las Vegas inside the Vegas Valley on qualifying orders. Direct drop to your office, warehouse, Apex jobsite, or service-truck staging lot. Most North Las Vegas industrial accounts run weekly delivery cycles tied to ongoing company-store programs, and we batch decorated apparel weekly to keep the per-piece economics reasonable on long-running industrial projects.
 </p>
 <p>
 Common requests in North Las Vegas: <a href="/blog/ansi-107-class-2-vs-class-3-hi-vis-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Class 2 hi-vis</a>, <a href="/blog/rush-order-shirts-las-vegas-whats-possible/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">rush orders</a>, <a href="/blog/new-hire-workwear-checklist-las-vegas-contractors/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">new hire checklist</a>, and <a href="/industries/oil-gas-mechanical-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">oil, gas &amp; mechanical uniforms</a>.
 </p>
 </div>
 </div>
 </section>

 <!-- FAQs — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Questions NLV industrial contractors ask us.</h2>

 <div class="divide-y divide-hairline border-y border-hairline">
 {faqs.map((f) => (
 <details class="group">
 <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
 <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{f.q}</h3>
 <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
 </summary>
 <p class="pb-5 text-base leading-relaxed text-ash">{f.a}</p>
 </details>
 ))}
 </div>
 </div>
 </section>

