---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Workwear and Branded Apparel in Spring Valley, Las Vegas',
 description:
 'Embroidered service-tech uniforms and branded crew apparel for Spring Valley HVAC, plumbing, electrical, and residential service trades. Frequent reorder cycle.',
 h1Pre: 'Spring Valley',
 hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
 {
 code: 'Major Activity',
 title: 'Mixed residential and a service-trade base',
 body: 'Spring Valley is established residential — built-out neighborhoods, mixed-use along Rainbow and Tropicana, condo conversions and apartment retrofit. The big build-out happened a generation ago, but the service work never stops. Roof replacements, HVAC swap-outs, re-pipes, electrical upgrades — Spring Valley keeps the trades busy.',
 },
 {
 code: 'Active Trades',
 title: 'Service-truck country',
 body: 'Higher concentration of service-trade vans per square mile than almost anywhere in the valley. Residential HVAC, plumbing service, electrical service, pest, pool. A lot of small-to-mid shops headquartered here because rent is cheaper than Summerlin and the customer base is right next door.',
 },
 {
 code: 'What Crews Need Locally',
 title: 'Frequent reorder, local production, no drama',
 body: 'Service shops here run lean — most don\'t want a closet full of shirts they have to manage. They want a known supplier with their spec on file who can drop 24 polos in under a week when a new tech starts. We do that. Most Spring Valley shops run on a 60-day reorder cycle.',
 },
]

const trades = [
 {
 name: 'Plumbing & HVAC',
 detail: 'Embroidered service polos with name + title for residential service techs running daily routes through Spring Valley.',
 href: '/industries/plumbing-hvac-las-vegas/',
 img: '/images/generated/kit-plumbing-hvac.jpg',
 },
 {
 name: 'Electrical Contractors',
 detail: 'Service polos and branded tees for residential electrical service shops covering the central valley.',
 href: '/industries/electrical-contractors-las-vegas/',
 img: '/images/generated/kit-electrical.jpg',
 },
 {
 name: 'General Contractors',
 detail: 'Smaller residential-remodel GCs and TI contractors working Spring Valley apartments and mixed-use.',
 href: '/industries/general-contractors-las-vegas/',
 img: '/images/generated/kit-office-sales.jpg',
 },
 {
 name: 'Roofing & Solar',
 detail: 'Re-roof and residential solar crews working established Spring Valley neighborhoods.',
 href: '/industries/roofing-solar-las-vegas/',
 img: '/images/generated/service-screen-printing.jpg',
 },
]

const useCases = [
 'Residential HVAC techs in embroidered polos with name + title for Spring Valley service routes',
 'Plumbing service trucks getting wrapped + crew uniformed at the same time, license-visible chest layout',
 'Residential electricians in branded polos with truck-matching colorway for service calls',
 'New-hire onboarding kits dropped fast when the next tech starts mid-month',
 'Smaller remodel GCs in branded polos that look professional on apartment-complex walk-throughs',
 'Pool and pest service crews in lightweight moisture-wicking polos for summer route work',
]

const faqs = [
 {
 q: 'We\'re a small Spring Valley HVAC shop — only 6 techs. Is that too small for you to bother with?',
 a: 'Not at all. We work shops as small as 2 trucks. Minimums are 12 pieces for embroidery and 24 for screen printing — for 6 techs you\'re typically ordering 12–18 polos at a clip and reordering every 60 days. That\'s a normal-size order for us.',
 },
 {
 q: 'A new tech starts next week. How fast can you get me 4 polos with his name on them?',
 a: 'If we already have your logo and spec on file, name embroidery on a stocked polo color in stock. Rush is on rush if you need it. Once you\'re a regular, we keep the artwork hot and reorders fly.',
 },
 {
 q: 'Do you carry moisture-wicking polos that hold up to Vegas summer route work?',
 a: 'Yes. Port Authority K500 and Sport-Tek ST650 in 100% poly micro-mesh — stocked S–4XL in 8 colors. Cotton blend looks nicer week one but it\'s soaked through by lunch in July. Service techs end up in the poly polo every time.',
 },
 {
 q: 'Can you put our license number and service line on every shirt?',
 a: 'Yes. Standard layout is license number on the sleeve and the service phone on the back collar or hem tag. Keeps the chest clean for the logo and tech name, and customers still see the contact info when the tech turns to grab a tool.',
 },
 {
 q: 'Where do we pick up if we don\'t want to wait on delivery?',
 a: 'Our Las Vegas shop is 10–15 min from most Spring Valley addresses. Pickup is usually quick on a stocked-polo embroidery run. We\'ll text you when it\'s ready.',
 },
 {
 q: 'Do you set up company stores for service shops with 15+ techs?',
 a: 'Yes — that\'s the sweet spot. Each tech logs in, sees only their approved kit (with allowance if you set one), and orders direct. We embroider and ship — no closet inventory or sizing-spreadsheet headaches on your end. Most shops save more in admin time than the store costs.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
 { '@type': 'ListItem', position: 3, name: 'Spring Valley', item: 'https://bighornthreads.com/service-areas/spring-valley/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear and Branded Apparel in Spring Valley',
 serviceType: 'Embroidered service-tech uniforms and branded crew apparel for residential service trades',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: {
 '@type': 'Place',
 name: 'Spring Valley, Las Vegas, NV',
 address: { '@type': 'PostalAddress', addressLocality: 'Las Vegas', addressRegion: 'NV', addressCountry: 'US' },
 },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/service-areas/spring-valley/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-16 sm:px-6 sm:pb-28 sm:pt-16 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <a href="/service-areas/" class="hover:text-gold-400">Service Areas</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Spring Valley</span>
 </nav>

 <p class="kicker mb-3">{page.h1Pre}</p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Custom Workwear and Branded Apparel <span class="text-gold-400">in Spring Valley.</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 Embroidered service-tech uniforms and branded crew apparel for the HVAC, plumbing, electrical, and residential service shops headquartered across Spring Valley. Lean reorder cycle, fast new-hire turnaround, no drama. We keep your spec on file and ship when you need it.
 </p>

 <div class="mt-10 flex flex-wrap items-center gap-3">
 <a href="/contact/" class="btn-primary text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
 702.904.8923
 </a>
 </div>
 </div>
 </section>

 <!-- Local context — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Local Context</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Spring Valley is <span class="text-gold-600">service-trade central.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Less new-construction work than Henderson, less industrial than NLV, less premium than Summerlin. What Spring Valley has is density — service-trade vans on every block, residential service work that never stops, and a lot of mid-size shops headquartered along Rainbow, Tropicana, and Decatur.
 </p>
 </div>

 <div class="grid gap-5 md:grid-cols-3">
 {localContext.map((c) => (
 <div class="border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <span class="spec mb-4 inline-block border border-hairline px-2.5 py-1 text-gold-600">{c.code}</span>
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal">{c.title}</h3>
 <p class="text-sm leading-relaxed text-ash">{c.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Trades we serve here — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">The Trades</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Trades we serve in <span class="text-gold-600">Spring Valley.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Service shops dominate the mix. Embroidered polos for the customer-facing techs, branded tees for shop and ride-along. Click through for trade-specific gear and brands.
 </p>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
 {trades.map((t) => (
 <a href={t.href} class="group flex flex-col border border-hairline bg-panel transition-colors hover:border-gold-500">
 <div class="aspect-[4/3] overflow-hidden">
 <img src={t.img} alt={t.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
 </div>
 <div class="p-5">
 <h3 class="mb-2 font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">{t.name}</h3>
 <p class="text-sm leading-relaxed text-ash">{t.detail}</p>
 </div>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Typical orders — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
 <div>
 <p class="kicker mb-3">Typical Orders</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">What we run for <span class="text-gold-600">Spring Valley shops.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Smaller, more frequent runs. New-hire kits in fives. Reorders every 60–90 days as routes grow. The shops here don\'t want a closet full of inventory — they want a known supplier and a fast turn.
 </p>
 <div class="mt-8 flex flex-wrap gap-3">
 <a href="/services/" class="btn-secondary text-sm">All Services →</a>
 <a href="/company-stores/" class="btn-secondary text-sm">Company Stores →</a>
 </div>
 </div>

 <ul class="space-y-3">
 {useCases.map((u, i) => (
 <li class="flex items-start gap-4 border border-hairline bg-panel p-4 transition-colors hover:border-gold-500">
 <span class="shrink-0 font-mono text-xs font-bold text-gold-600">{String(i + 1).padStart(2, '0')}</span>
 <span class="text-base leading-relaxed text-charcoal">{u}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Local context — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">Local Context</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase leading-tight tracking-tight text-charcoal sm:text-4xl">
 Custom branded apparel for Spring Valley contractors and service trades.
 </h2>

 <div class="space-y-5 text-lg leading-relaxed text-ash">
 <p>
 Spring Valley is one of the largest unincorporated communities in Clark County and a major service-trade hub for the west side of the Vegas Valley. Residential service contractors — plumbing, HVAC, electrical, pool service, pest control, landscape — run high-volume route-based businesses serving the Spring Valley, Enterprise, and Mountain's Edge communities. Bighorn Threads offers local delivery to Spring Valley business addresses on qualifying orders, and we supply the industrial work shirts, branded service uniforms, and ANSI 107 hi-vis that the dense service-trade economy in this market depends on.
 </p>
 <p>
 The dominant trade contractor profile in Spring Valley is the residential service-truck business: a fleet of branded vans servicing 20-50 calls a day across the southwest valley. For these operations, the apparel spec is Red Kap industrial work shirts (SP14 short sleeve or SC30 contrast collar), Red Kap PT20 work pants, embroidered company logo on the left chest with name patches on the right. The uniform processes through industrial laundry every week and lasts 2-3 years before the seams give out. We integrate with the major industrial laundry programs in the southwest valley and pre-decorate shirts to match their inventory codes.
 </p>
 <p>
 For Spring Valley plumbing, HVAC, and electrical service shops, the brand impression matters as much as the technical work. Homeowners in the Mountain's Edge and Spring Valley Ranch communities expect service techs to show up in identifying, professional uniforms — and that branding supports repeat-work and referral economics. We build full uniform programs that scale from small-truck operations up through larger fleets, with company-store programs handling new-hire onboarding, replacement shirts, and seasonal apparel adjustments.
 </p>
 <p>
 Spring Valley landscape and grounds-maintenance contractors operate at the same intensity. The Mountain's Edge and Spring Valley HOA communities require professional-grade contractor apparel — embroidered polos for supervisors, branded performance long-sleeve shirts for crew, ANSI 107 hi-vis vests for crews working near vehicle traffic on community streets. We supply the full kit and run quarterly reorder cycles tied to seasonal work volume for the larger southwest-valley landscape companies.
 </p>
 <p>
 We deliver to every Spring Valley business address inside the Vegas Valley on qualifying orders. Drop direct to your office, your service-truck staging lot, or your active jobsite. Most Spring Valley service-trade accounts run weekly delivery cycles tied to ongoing company-store programs, and we coordinate local production on rush orders for new-hire kits or replacement uniforms when something gets ruined on the job.
 </p>
 <p>
 Common requests in Spring Valley: <a href="/blog/ansi-107-class-2-vs-class-3-hi-vis-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Class 2 hi-vis</a>, <a href="/blog/rush-order-shirts-las-vegas-whats-possible/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">rush orders</a>, <a href="/blog/new-hire-workwear-checklist-las-vegas-contractors/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">new hire checklist</a>, and <a href="/industries/plumbing-hvac-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">plumbing &amp; HVAC service uniforms</a>.
 </p>
 </div>
 </div>
 </section>

 <!-- FAQs — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Questions Spring Valley shops ask us.</h2>

 <div class="divide-y divide-hairline border-y border-hairline">
 {faqs.map((f) => (
 <details class="group">
 <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
 <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{f.q}</h3>
 <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
 </summary>
 <p class="pb-5 text-base leading-relaxed text-ash">{f.a}</p>
 </details>
 ))}
 </div>
 </div>
 </section>

 <!-- Related — paper -->
 <section class="border-y border-hairline bg-paper py-16">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-6">Nearby &amp; Related</p>
 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
 <a href="/service-areas/summerlin/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Summerlin</h3>
 <p class="mt-2 text-sm text-ash">High-end residential and commercial — the sharp end of the same valley.</p>
 </a>
 <a href="/service-areas/north-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">North Las Vegas</h3>
 <p class="mt-2 text-sm text-ash">Industrial and data center fit-out — different rhythm, same call.</p>
 </a>
 <a href="/service-areas/boulder-city/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Boulder City</h3>
 <p class="mt-2 text-sm text-ash">Solar-farm and utility crews along the US-93 corridor.</p>
 </a>
 <a href="/industries/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">All Industries</h3>
 <p class="mt-2 text-sm text-ash">Trade-specific gear, brands, and compliance — pick your industry.</p>
 </a>
 </div>
 </div>
 </section>

 <!-- CTA — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/cta-bluehour.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/80"></div>
 <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
 <h2 class="mb-4 font-heading text-3xl font-extrabold uppercase tracking-tight text-white sm:text-4xl">Spec on file. <span class="text-gold-400">Reorders in days, not weeks.</span></h2>
 <p class="mb-8 text-lg text-navy-200">Talk to a real human who knows what service-tech polos need to do all day in Vegas.</p>
 <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
 <a href="/contact/" class="btn-primary text-base">Get a Free Quote</a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-base font-medium tracking-wide text-white transition-colors hover:text-gold-400">702.904.8923</a>
 </div>
 </div>
 </section>
</BaseLayout>
