---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Workwear and Branded Apparel in Boulder City, NV',
 description:
 'FR shirts, ANSI hi-vis, and branded crew uniforms for Boulder City utility, dam, and Eldorado Valley solar farm contractors. Federal-spec gear, planning-friendly delivery from Las Vegas.',
 h1Pre: 'Boulder City, NV',
 hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
 {
 code: 'Major Projects',
 title: 'Solar farms, the dam, and federal contracts',
 body: 'Eldorado Valley is one of the densest concentrations of utility-scale solar in the country — utility-scale solar farms. Hoover Dam ongoing maintenance and Bureau of Reclamation work. Federal land, federal contracts, federal safety spec.',
 },
 {
 code: 'Active Trades',
 title: 'Utility electrical, solar PV, and federal subs',
 body: 'Medium-voltage and high-voltage electrical contractors. Solar PV installation crews, racking and tracker subs. Civil and grading for new solar arrays in the valley. Federal subcontractors running ongoing dam and substation maintenance. Tightly specced, well-organized — these crews don\'t guess at what to wear.',
 },
 {
 code: 'What Crews Need Locally',
 title: 'Plan ahead — but fast is doable',
 body: 'Boulder City is ~25 minutes from our Las Vegas shop. Local delivery is achievable, but planning matters more here than in-town. Standing reorders work great. Sun is brutal in Eldorado Valley — we lean toward lightweight FR, hi-vis with UPF, and long-sleeve sun shirts even on non-PPE crews.',
 },
]

const trades = [
 {
 name: 'Electrical Contractors',
 detail: 'NFPA 70E FR and ANSI Class 2 hi-vis for utility electrical and dam-area substation crews.',
 href: '/industries/electrical-contractors-las-vegas/',
 img: '/images/generated/kit-electrical.jpg',
 },
 {
 name: 'Roofing & Solar',
 detail: 'Solar PV install crews and racking subs working Eldorado Valley utility-scale arrays.',
 href: '/industries/roofing-solar-las-vegas/',
 img: '/images/generated/service-screen-printing.jpg',
 },
 {
 name: 'General Contractors',
 detail: 'Civil, grading, and federal-sub GC crews on dam, substation, and solar farm builds.',
 href: '/industries/general-contractors-las-vegas/',
 img: '/images/generated/kit-office-sales.jpg',
 },
 {
 name: 'Plumbing & HVAC',
 detail: 'Mechanical service for federal facilities, dam-area infrastructure, and Boulder City municipal work.',
 href: '/industries/plumbing-hvac-las-vegas/',
 img: '/images/generated/kit-plumbing-hvac.jpg',
 },
]

const useCases = [
 'Utility-scale solar PV install crews in branded long-sleeve UPF tees + ANSI hi-vis',
 'Medium-voltage electrical subs in CAT 2 FR shirts on Eldorado Valley substation work',
 'Civil and grading crews in heavy hi-vis with company name + license-plate sleeve embroidery',
 'Federal-sub GC crews in clean foreman polos for dam and Bureau of Reclamation walk-throughs',
 'Solar racking and tracker subs in branded sun shirts that hold up in 110°+ valley heat',
 'Standing reorders for long-running solar builds — gear ships every 60 days without you asking',
]

const faqs = [
 {
 q: 'Do you actually deliver to Boulder City, or do we have to drive into Las Vegas?',
 a: 'We deliver to Boulder City commercial addresses on qualifying orders — the drive is ~25 min from our shop. For smaller orders, pickup is your fastest option. We also run delivery directly to Eldorado Valley solar farm laydown yards if that\'s easier than the Boulder City office.',
 },
 {
 q: 'How fast can you turn around an order for an Eldorado Valley solar crew?',
 a: 'Standard production runs from our local Las Vegas shop. Boulder City delivery is achievable on rush orders — but the more lead time you give us, the cleaner the run. Most solar crews here run on standing reorders so the gear arrives before the next phase even starts.',
 },
 {
 q: 'We\'re running a federal sub on dam-area work. Can you handle the safety spec our prime needs on file?',
 a: 'Yes. We carry Bulwark, Carhartt FR, ML Kishigo, PIP, Pioneer — every brand the federal primes typically want documented. We keep the spec sheets on file and decoration follows the manufacturer placement rules so the certification stays intact.',
 },
 {
 q: 'Eldorado Valley summer is brutal. What do you stock for crews working open desert in 110°+?',
 a: 'Lightweight FR-rated shirts (Bulwark iQ Series, Carhartt Force FR), long-sleeve UPF sun shirts, ANSI Class 2 hi-vis in moisture-wicking poly. The cotton-blend hi-vis you see at big-box stores doesn\'t hold up out there — we steer crews toward poly micro-mesh and lightweight FR every time.',
 },
 {
 q: 'Can we set up a standing reorder so gear ships every 60 days without me having to call?',
 a: 'Yes. Tell us the kit, the cadence, and the recipient list. We run the order on schedule, ship to your Boulder City address or laydown yard, and email an invoice. Most long-running solar builds and federal subs work this way.',
 },
 {
 q: 'What\'s the minimum for branded crew gear?',
 a: '24 pieces for screen printing, 12 for embroidery. Most Boulder City crews we work with order in 50–150 piece runs and reorder every 60 days. Solar build phases sometimes drive single orders of 200+.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
 { '@type': 'ListItem', position: 3, name: 'Boulder City, NV', item: 'https://bighornthreads.com/service-areas/boulder-city/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear and Branded Apparel in Boulder City, NV',
 serviceType: 'FR-rated workwear, ANSI hi-vis, and branded uniforms for utility, solar, and federal subs',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: {
 '@type': 'City',
 name: 'Boulder City',
 address: { '@type': 'PostalAddress', addressRegion: 'NV', addressCountry: 'US' },
 },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/service-areas/boulder-city/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-32 sm:px-6 sm:pb-28 sm:pt-36 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <a href="/service-areas/" class="hover:text-gold-400">Service Areas</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Boulder City, NV</span>
 </nav>

 <p class="kicker mb-3">{page.h1Pre}</p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Custom Workwear and Branded Apparel <span class="text-gold-400">in Boulder City, NV.</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 FR shirts, ANSI hi-vis, and branded crew uniforms for the utility, dam, and Eldorado Valley solar farm contractors working out of Boulder City. Federal-spec gear, lightweight FR for desert work, standing-reorder programs that ship before the next phase starts.
 </p>

 <div class="mt-10 flex flex-wrap items-center gap-3">
 <a href="/contact/" class="btn-primary text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
 702.904.8923
 </a>
 </div>
 </div>
 </section>

 <!-- Local context — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Local Context</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Boulder City is <span class="text-gold-600">utility country.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Smaller town, bigger work. Solar arrays sprawl across Eldorado Valley. The dam and substation infrastructure feed the Southwest. Federal contracts move slow but they don\'t stop. The crews working out here have a known cadence — standing reorders and federal-spec gear are the norm.
 </p>
 </div>

 <div class="grid gap-5 md:grid-cols-3">
 {localContext.map((c) => (
 <div class="border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <span class="spec mb-4 inline-block border border-hairline px-2.5 py-1 text-gold-600">{c.code}</span>
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal">{c.title}</h3>
 <p class="text-sm leading-relaxed text-ash">{c.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Trades we serve here — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">The Trades</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Trades we serve in <span class="text-gold-600">Boulder City.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Utility electrical and solar PV lead the mix. Civil/grading and federal-sub GC crews fill out the dam and substation work. Click through for trade-specific gear and brands.
 </p>
 </div>

 <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
 {trades.map((t) => (
 <a href={t.href} class="group flex flex-col border border-hairline bg-panel transition-colors hover:border-gold-500">
 <div class="aspect-[4/3] overflow-hidden">
 <img src={t.img} alt={t.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
 </div>
 <div class="p-5">
 <h3 class="mb-2 font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">{t.name}</h3>
 <p class="text-sm leading-relaxed text-ash">{t.detail}</p>
 </div>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Typical orders — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
 <div>
 <p class="kicker mb-3">Typical Orders</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">What we run for <span class="text-gold-600">Boulder City crews.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Bigger phase orders, standing reorders, federal-spec FR. Solar build phases drive 200+ piece runs. Substation and dam work is steadier — 50–80 piece reorders every 60–90 days.
 </p>
 <div class="mt-8 flex flex-wrap gap-3">
 <a href="/services/" class="btn-secondary text-sm">All Services →</a>
 <a href="/company-stores/" class="btn-secondary text-sm">Company Stores →</a>
 </div>
 </div>

 <ul class="space-y-3">
 {useCases.map((u, i) => (
 <li class="flex items-start gap-4 border border-hairline bg-panel p-4 transition-colors hover:border-gold-500">
 <span class="shrink-0 font-mono text-xs font-bold text-gold-600">{String(i + 1).padStart(2, '0')}</span>
 <span class="text-base leading-relaxed text-charcoal">{u}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Local context — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">Local Context</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase leading-tight tracking-tight text-charcoal sm:text-4xl">
 Custom branded apparel for Boulder City contractors and Hoover Dam-adjacent trades.
 </h2>

 <div class="space-y-5 text-lg leading-relaxed text-ash">
 <p>
 Boulder City sits at the southeast edge of the Vegas Valley and serves as a hub for Hoover Dam-adjacent contractors, Bureau of Reclamation work, the Eldorado solar corridor, and the marine and recreation contractors operating Lake Mead. Bighorn Threads serves Boulder City contractors from our Las Vegas shop, with delivery range that covers Boulder City's compact business district and the Eldorado Valley industrial sites south of town.
 </p>
 <p>
 The trade contractor mix in Boulder City is unusual. Hoover Dam maintenance and Bureau of Reclamation contracts drive demand for FR-rated electrical apparel, hi-vis safety wear, and specialty PPE for the federal contractors working dam infrastructure. The Eldorado solar corridor — one of the largest concentrations of utility-scale solar in the southwest — drives sustained demand for FR-rated combiner-tech apparel, ANSI 107 Class 3 hi-vis for crews working near desert two-lane highway traffic, and lightweight UPF performance shirts for the long Mojave summer construction season.
 </p>
 <p>
 For Boulder City solar EPCs and operations crews, the FR baseline is Bulwark Excel-FR ComforTouch SLU2 or Carhartt FR Lightweight in 6.5 oz fabric — light enough for desert summer combiner work, dual NFPA 70E + 2112 certified for arc-flash and flash-fire exposure, decorated with FR-safe Nomex thread that retains the rating after laundering. We ship to Boulder City lay-down yards and to per-employee home addresses for crews working remote sites in the Eldorado, Searchlight, and Primm corridors.
 </p>
 <p>
 The marine and recreation contractor sector in Boulder City — Lake Mead Marina operations, boat service, lake-recreation outfitters — has different apparel needs. UV-resistant performance polos for marina staff, embroidered Carhartt for boat-service techs, lightweight long-sleeve UPF shirts for crews working full days in direct sun on the water. We supply the full kit with embroidered logos that hold up to lake-water exposure and sustained UV without fading or peeling.
 </p>
 <p>
 For Boulder City municipal contractors and city services contractors, branded uniforms support the small-town professional impression that the Boulder City community expects. We outfit landscape, public works, and municipal services contractors with embroidered polos, branded service uniforms, and ANSI 107 hi-vis for crews working on city streets and federal property. Reorder-friendly workflow, local delivery from Las Vegas, and a phone line that rings a real person.
 </p>
 <p>
 Common requests in Boulder City: <a href="/blog/ansi-107-class-2-vs-class-3-hi-vis-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Class 2 hi-vis</a>, <a href="/blog/rush-order-shirts-las-vegas-whats-possible/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">rush orders</a>, <a href="/blog/new-hire-workwear-checklist-las-vegas-contractors/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">new hire checklist</a>, and <a href="/industries/general-contractors-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">general contractor uniforms</a>.
 </p>
 </div>
 </div>
 </section>

 <!-- FAQs — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Questions Boulder City crews ask us.</h2>

 <div class="divide-y divide-hairline border-y border-hairline">
 {faqs.map((f) => (
 <details class="group">
 <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
 <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{f.q}</h3>
 <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
 </summary>
 <p class="pb-5 text-base leading-relaxed text-ash">{f.a}</p>
 </details>
 ))}
 </div>
 </div>
 </section>

 <!-- Related — paper -->
 <section class="border-y border-hairline bg-paper py-16">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-6">Nearby &amp; Related</p>
 <div class="grid gap-5 md:grid-cols-3">
 <a href="/service-areas/henderson-nv/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Henderson, NV</h3>
 <p class="mt-2 text-sm text-ash">Right up US-93 — master-planned community build-out.</p>
 </a>
 <a href="/service-areas/north-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">North Las Vegas</h3>
 <p class="mt-2 text-sm text-ash">Industrial and data center fit-out — big electrical and mechanical.</p>
 </a>
 <a href="/industries/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">All Industries</h3>
 <p class="mt-2 text-sm text-ash">Trade-specific gear, brands, and compliance — pick your industry.</p>
 </a>
 </div>
 </div>
 </section>

 <!-- CTA — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/cta-bluehour.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/80"></div>
 <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
 <h2 class="mb-4 font-heading text-3xl font-extrabold uppercase tracking-tight text-white sm:text-4xl">Standing reorders. <span class="text-gold-400">Federal-spec FR.</span></h2>
 <p class="mb-8 text-lg text-navy-200">Talk to a real human who knows desert work and federal safety spec.</p>
 <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
 <a href="/contact/" class="btn-primary text-base">Get a Free Quote</a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-base font-medium tracking-wide text-white transition-colors hover:text-gold-400">702.904.8923</a>
 </div>
 </div>
 </section>
</BaseLayout>
