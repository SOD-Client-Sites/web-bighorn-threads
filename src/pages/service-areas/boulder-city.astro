---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Custom Workwear and Branded Apparel in Boulder City, NV',
  description:
    'FR shirts, ANSI hi-vis, and branded crew uniforms for Boulder City utility, dam, and Eldorado Valley solar farm contractors. Federal-spec gear, planning-friendly delivery from Las Vegas.',
  h1Pre: 'Boulder City, NV',
  hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
  {
    code: 'Major Projects',
    title: 'Solar farms, the dam, and federal contracts',
    body: 'Eldorado Valley is one of the densest concentrations of utility-scale solar in the country — Switch Station, Boulder Solar, Copper Mountain, the Sempra and Berkshire-affiliated farms. Hoover Dam ongoing maintenance and Bureau of Reclamation work. Federal land, federal contracts, federal safety spec.',
  },
  {
    code: 'Active Trades',
    title: 'Utility electrical, solar PV, and federal subs',
    body: 'Medium-voltage and high-voltage electrical contractors. Solar PV installation crews, racking and tracker subs. Civil and grading for new solar arrays in the valley. Federal subcontractors running ongoing dam and substation maintenance. Tightly specced, well-organized — these crews don\'t guess at what to wear.',
  },
  {
    code: 'What Crews Need Locally',
    title: 'Plan ahead — but same-week is doable',
    body: 'Boulder City is ~25 minutes from our Las Vegas shop. Same-week delivery is achievable but planning matters more here than in-town. Standing reorders work great. Sun is brutal in Eldorado Valley — we lean toward lightweight FR, hi-vis with UPF, and long-sleeve sun shirts even on non-PPE crews.',
  },
]

const trades = [
  {
    name: 'Electrical Contractors',
    detail: 'NFPA 70E FR and ANSI Class 2 hi-vis for utility electrical and dam-area substation crews.',
    href: '/industries/electrical-contractors-las-vegas/',
    img: '/images/generated/kit-electrical.jpg',
  },
  {
    name: 'Roofing & Solar',
    detail: 'Solar PV install crews and racking subs working Eldorado Valley utility-scale arrays.',
    href: '/industries/roofing-solar-las-vegas/',
    img: '/images/generated/service-screen-printing.jpg',
  },
  {
    name: 'General Contractors',
    detail: 'Civil, grading, and federal-sub GC crews on dam, substation, and solar farm builds.',
    href: '/industries/general-contractors-las-vegas/',
    img: '/images/generated/kit-office-sales.jpg',
  },
  {
    name: 'Plumbing & HVAC',
    detail: 'Mechanical service for federal facilities, dam-area infrastructure, and Boulder City municipal work.',
    href: '/industries/plumbing-hvac-las-vegas/',
    img: '/images/generated/kit-plumbing-hvac.jpg',
  },
]

const useCases = [
  'Utility-scale solar PV install crews in branded long-sleeve UPF tees + ANSI hi-vis',
  'Medium-voltage electrical subs in CAT 2 FR shirts on Eldorado Valley substation work',
  'Civil and grading crews in heavy hi-vis with company name + license-plate sleeve embroidery',
  'Federal-sub GC crews in clean foreman polos for dam and Bureau of Reclamation walk-throughs',
  'Solar racking and tracker subs in branded sun shirts that hold up in 110°+ valley heat',
  'Standing reorders for long-running solar builds — gear ships every 60 days without you asking',
]

const faqs = [
  {
    q: 'Do you actually deliver to Boulder City, or do we have to drive into Las Vegas?',
    a: 'We deliver to Boulder City commercial addresses on orders over $250 — the drive is ~25 min from our shop. For smaller orders, pickup is your fastest option. We also run delivery directly to Eldorado Valley solar farm laydown yards if that\'s easier than the Boulder City office.',
  },
  {
    q: 'How fast can you turn around an order for an Eldorado Valley solar crew?',
    a: '24-hour quote. Standard production is 7–10 business days. Boulder City same-week delivery is achievable on rush orders — but the more lead time you give us, the cleaner the run. Most solar crews here run on standing reorders so the gear arrives before the next phase even starts.',
  },
  {
    q: 'We\'re running a federal sub on dam-area work. Can you handle the safety spec our prime needs on file?',
    a: 'Yes. We carry Bulwark, Carhartt FR, ML Kishigo, PIP, Pioneer — every brand the federal primes typically want documented. We keep the spec sheets on file and decoration follows the manufacturer placement rules so the certification stays intact.',
  },
  {
    q: 'Eldorado Valley summer is brutal. What do you stock for crews working open desert in 110°+?',
    a: 'Lightweight FR-rated shirts (Bulwark iQ Series, Carhartt Force FR), long-sleeve UPF sun shirts, ANSI Class 2 hi-vis in moisture-wicking poly. The cotton-blend hi-vis you see at big-box stores doesn\'t hold up out there — we steer crews toward poly micro-mesh and lightweight FR every time.',
  },
  {
    q: 'Can we set up a standing reorder so gear ships every 60 days without me having to call?',
    a: 'Yes. Tell us the kit, the cadence, and the recipient list. We run the order on schedule, ship to your Boulder City address or laydown yard, and email an invoice. Most long-running solar builds and federal subs work this way.',
  },
  {
    q: 'What\'s the minimum for branded crew gear?',
    a: '24 pieces for screen printing, 12 for embroidery. Most Boulder City crews we work with order in 50–150 piece runs and reorder every 60 days. Solar build phases sometimes drive single orders of 200+.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
    { '@type': 'ListItem', position: 3, name: 'Boulder City, NV', item: 'https://bighornthreads.com/service-areas/boulder-city/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear and Branded Apparel in Boulder City, NV',
  serviceType: 'FR-rated workwear, ANSI hi-vis, and branded uniforms for utility, solar, and federal subs',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: {
    '@type': 'City',
    name: 'Boulder City',
    address: { '@type': 'PostalAddress', addressRegion: 'NV', addressCountry: 'US' },
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/service-areas/boulder-city/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/service-areas/" class="hover:text-gold-400">Service Areas</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Boulder City, NV</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Custom Workwear and Branded Apparel <span class="text-gold-500">in Boulder City, NV.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        FR shirts, ANSI hi-vis, and branded crew uniforms for the utility, dam, and Eldorado Valley solar farm contractors working out of Boulder City. Federal-spec gear, lightweight FR for desert work, standing-reorder programs that ship before the next phase starts.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Local context -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Local Context</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Boulder City is utility country.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Smaller town, bigger work. Solar arrays sprawl across Eldorado Valley. The dam and substation infrastructure feed the Southwest. Federal contracts move slow but they don\'t stop. The crews working out here have a known cadence — standing reorders and federal-spec gear are the norm.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {localContext.map((c) => (
          <div class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <span class="mb-4 inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{c.code}</span>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white">{c.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trades we serve here -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Trades</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Trades we serve in Boulder City.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Utility electrical and solar PV lead the mix. Civil/grading and federal-sub GC crews fill out the dam and substation work. Click through for trade-specific gear and brands.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {trades.map((t) => (
          <a href={t.href} class="group block overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
              <img src={t.img} alt={t.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="mb-2 font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">{t.name}</h3>
              <p class="text-sm leading-relaxed text-gray-400">{t.detail}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Typical orders -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Typical Orders</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we run for Boulder City crews.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Bigger phase orders, standing reorders, federal-spec FR. Solar build phases drive 200+ piece runs. Substation and dam work is steadier — 50–80 piece reorders every 60–90 days.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">All Services →</a>
            <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Company Stores →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {useCases.map((u, i) => (
            <li class="flex items-start gap-4 rounded-xl border border-navy-700/30 bg-navy-900/30 p-4 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-base leading-relaxed text-gray-200">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Questions Boulder City crews ask us.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Nearby &amp; Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/service-areas/henderson-nv/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Henderson, NV</h3>
          <p class="mt-2 text-sm text-gray-400">Right up US-93 — master-planned community build-out.</p>
        </a>
        <a href="/service-areas/north-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">North Las Vegas</h3>
          <p class="mt-2 text-sm text-gray-400">Industrial and data center fit-out — big electrical and mechanical.</p>
        </a>
        <a href="/industries/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">All Industries</h3>
          <p class="mt-2 text-sm text-gray-400">Trade-specific gear, brands, and compliance — pick your industry.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Standing reorders. Federal-spec FR. 24-hour quotes.</h2>
      <p class="mb-8 text-lg text-gray-300">Talk to a real human who knows desert work and federal safety spec.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
