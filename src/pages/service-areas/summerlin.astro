---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Custom Workwear and Branded Apparel in Summerlin, Las Vegas',
  description:
    'Embroidered uniforms and branded crew apparel for Summerlin contractors and high-end residential trades. Howard Hughes Corp builds, Downtown Summerlin commercial. Sharp foreman polos, 24-hour quotes.',
  h1Pre: 'Summerlin',
  hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
  {
    code: 'Major Projects',
    title: 'Howard Hughes Corp territory',
    body: 'Downtown Summerlin office and retail keeps adding pads. The Cliffs, Mesa Ridge, Stonebridge, and the upcoming villages are still phasing in. Higher-end commercial fit-out around the 215 corridor and the medical campuses. Owner-rep teams are sharp and the GCs follow suit — Martin-Harris, Whiting-Turner, the higher-end commercial regulars.',
  },
  {
    code: 'Active Trades',
    title: 'Premium-residential and commercial subs',
    body: 'Custom-home GCs working Summerlin Cliffs estates. Commercial electrical, mechanical, and finish trades on Downtown Summerlin retail and office fit-out. Pool and landscape, high-end millwork. The crews here trade on appearance more than the rest of the valley — clean uniforms close more callbacks.',
  },
  {
    code: 'What Crews Need Locally',
    title: 'Cleaner foreman uniforms are standard here',
    body: 'Summerlin owners and HOAs notice what the crew wears on the property. Embroidered polos beat printed tees for any trade that touches a customer at this end of the valley. We carry Port Authority, Carhartt, and OGIO in colors that don\'t clash with high-end stucco and we keep your spec tight across reorders.',
  },
]

const trades = [
  {
    name: 'General Contractors',
    detail: 'Foreman/super differentiation and clean sub branding for Howard Hughes Corp builds and Downtown Summerlin fit-out.',
    href: '/industries/general-contractors-las-vegas/',
    img: '/images/generated/kit-office-sales.jpg',
  },
  {
    name: 'Plumbing & HVAC',
    detail: 'Embroidered service polos for techs walking into Summerlin Cliffs and Mesa Ridge custom homes.',
    href: '/industries/plumbing-hvac-las-vegas/',
    img: '/images/generated/kit-plumbing-hvac.jpg',
  },
  {
    name: 'Electrical Contractors',
    detail: 'Service polos and FR layers for residential and commercial electrical across the Summerlin master plan.',
    href: '/industries/electrical-contractors-las-vegas/',
    img: '/images/generated/kit-electrical.jpg',
  },
  {
    name: 'Roofing & Solar',
    detail: 'Branded crew tees and hi-vis for tile, solar, and high-end residential roof work in Summerlin estates.',
    href: '/industries/roofing-solar-las-vegas/',
    img: '/images/generated/service-screen-printing.jpg',
  },
]

const useCases = [
  'Custom-home GCs in embroidered button-downs walking estate clients through Cliffs and Stonebridge',
  'Pool and landscape crews in branded polos with company name + license number on the chest',
  'Commercial fit-out subs in clean foreman polos for Downtown Summerlin retail and office',
  'Service techs (HVAC, plumbing, electrical) in polished embroidered polos for high-end residential routes',
  'Millwork and finish trades in branded long-sleeves that hold up on punch-list weeks',
  'Branded swag for Summerlin Council, BIA, and chamber events around the master plan',
]

const faqs = [
  {
    q: 'We work high-end Summerlin residential. Will printed crew tees cost us callbacks?',
    a: 'For estate clients in The Cliffs, Mesa Ridge, and Stonebridge — yes, often. Owners and HOAs notice. Embroidered polos signal "established business" in a way that printed tees don\'t at this end of the valley. We typically run two programs for Summerlin shops: polos for the customer-facing techs, branded tees for shop and ride-along.',
  },
  {
    q: 'Do you have polo colors that work on light stucco and natural-stone properties?',
    a: 'Yes — we stock 8 colors in Port Authority K500 including stone, sand, navy, and charcoal that read clean on Summerlin-style properties. Our designer will lay the embroidery placement so the logo reads sharp without overpowering.',
  },
  {
    q: 'How fast can you turn around a new uniform program for a Summerlin commercial fit-out crew?',
    a: '24-hour quote. Standard production is 7–10 business days. Rush is 72 hours on orders up to 200 pieces. For repeat clients with files on hand, we\'ve hit 48-hour turnarounds.',
  },
  {
    q: 'Can you do company-store setup so each crew can order their own approved kit?',
    a: 'Yes. Particularly useful for mid-size and growing Summerlin shops where you want each tech to log in, see only what you\'ve approved (with allowances if you set them), and order direct. We embroider and ship — no closet inventory on your end.',
  },
  {
    q: 'Do you deliver to Summerlin commercial addresses?',
    a: 'Yes — free delivery to Summerlin commercial addresses on orders over $250. Downtown Summerlin, Pavilion Center, the 215-corridor offices. Residential pickup at our Las Vegas shop is 20–25 min east depending on your village.',
  },
  {
    q: 'What\'s the minimum for an embroidered polo run?',
    a: '12 pieces for embroidery, 24 for screen printing. Most Summerlin shops we work with order in 25–50 piece runs and reorder quarterly as new hires roll on.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
    { '@type': 'ListItem', position: 3, name: 'Summerlin', item: 'https://bighornthreads.com/service-areas/summerlin/' },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Workwear and Branded Apparel in Summerlin',
  serviceType: 'Embroidered uniforms and branded crew apparel for high-end residential and commercial trades',
  provider: { '@id': 'https://bighornthreads.com/#organization' },
  areaServed: {
    '@type': 'Place',
    name: 'Summerlin, Las Vegas, NV',
    address: { '@type': 'PostalAddress', addressLocality: 'Las Vegas', addressRegion: 'NV', addressCountry: 'US' },
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/service-areas/summerlin/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/service-areas/" class="hover:text-gold-400">Service Areas</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Summerlin</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Custom Workwear and Branded Apparel <span class="text-gold-500">in Summerlin.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        Embroidered uniforms and branded crew apparel for Summerlin contractors and high-end residential trades. Howard Hughes Corp builds, Downtown Summerlin commercial, custom-home GCs in The Cliffs and Mesa Ridge. Cleaner foreman polos are the standard out here — we know the colorways and the spec.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Local context -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Local Context</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Summerlin is the high-end build market.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Different game than Henderson tracts or NLV warehouses. Summerlin is custom-home estates, premium commercial fit-out, and Howard Hughes Corp master-plan execution. Cleaner uniforms, higher-end colorways, sharper foreman presentation.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {localContext.map((c) => (
          <div class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <span class="mb-4 inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{c.code}</span>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white">{c.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trades we serve here -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Trades</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Trades we serve in Summerlin.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          The Summerlin mix leans residential-custom and commercial-fit-out. Service trades that work this end of the valley typically run a polo program for customer-facing techs and a branded-tee program for shop and warehouse.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {trades.map((t) => (
          <a href={t.href} class="group block overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="aspect-[4/3] overflow-hidden bg-navy-800">
              <img src={t.img} alt={t.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="mb-2 font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">{t.name}</h3>
              <p class="text-sm leading-relaxed text-gray-400">{t.detail}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Typical orders -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Typical Orders</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">What we run for Summerlin shops.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Smaller, sharper orders. Polos beat tees for anything customer-facing in this market. Most Summerlin clients run quarterly reorders with the spec already locked.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">All Services →</a>
            <a href="/company-stores/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Company Stores →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {useCases.map((u, i) => (
            <li class="flex items-start gap-4 rounded-xl border border-navy-700/30 bg-navy-900/30 p-4 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-base leading-relaxed text-gray-200">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Local context -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Local Context</span>
      <h2 class="mb-8 font-heading text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        Custom branded apparel for Summerlin contractors, service trades, and HOA operations.
      </h2>

      <div class="space-y-5 text-lg leading-relaxed text-navy-200">
        <p>
          Summerlin is one of the most demanding markets in the Vegas Valley for service-trade branding. The 22,500-acre master-planned community spans some of the highest-end residential addresses in Nevada — The Ridges, Red Rock Country Club, The Vistas, the Summerlin South villages — and the homeowners and HOAs in those communities expect service contractors to show up looking like an established professional business, not a side hustle in a t-shirt. Bighorn Threads delivers free to every Summerlin business address on orders over $500, and we supply the embroidered polos, branded service uniforms, and professional-tier apparel that gets service trades repeat work in this market.
        </p>
        <p>
          For Summerlin landscape, irrigation, pool service, and pest control crews — the most-requested service trades in the community — the right uniform spec is an embroidered moisture-wicking polo with company logo on the left chest and (optionally) the technician's name on the right chest. Port Authority K540 Silk Touch Performance Polo and Cutter & Buck DryTec Performance are the two most-ordered SKUs for Summerlin service contractors because they look professional at a homeowner's front door and breathe well enough to handle a 110° afternoon route. Pants run khaki cargos or Carhartt B144 Rugged Flex shorts with embroidered logos on the back pocket for fleet visibility.
        </p>
        <p>
          For Summerlin residential general contractors and luxury home builders, the apparel spec leans premium. Custom-home GCs working in The Ridges or Red Rock Country Club send project managers and superintendents to client meetings expecting them to look the part — embroidered Cutter & Buck or Travis Mathew polos for client-facing roles, embroidered Eddie Bauer softshells for cold-weather walkthroughs, premium Carhartt for the field crew. We outfit Summerlin custom-home builders with full apparel programs that scale from solo-PM operations to 50-person commercial-quality residential firms.
        </p>
        <p>
          Summerlin HOA grounds-maintenance and community services contracts have specific branding requirements that differ from typical commercial landscape work. The HOAs frequently require the contractor's name, license number, and (sometimes) the HOA's preferred uniform color on field-crew apparel. We handle these multi-element decoration specs as a single coordinated embroidery program — left chest logo, sleeve-mounted license number, back-yoke contact info — all kept on file for the duration of the contract.
        </p>
        <p>
          Free local delivery to every Summerlin business address inside the Vegas Valley on orders over $500. Drop direct to your office, your service truck staging area, or your active jobsite anywhere in Summerlin proper, Summerlin West, The Ridges, Red Rock Country Club, or any of the surrounding villages. Most Summerlin service-trade accounts run a company-store program with per-employee allowances and quarterly reorder cycles tied to seasonal work volume.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Questions Summerlin contractors ask us.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="border-b border-navy-800 bg-navy-950 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-6 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Nearby &amp; Related</span>
      <div class="grid gap-5 md:grid-cols-3">
        <a href="/service-areas/spring-valley/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Spring Valley</h3>
          <p class="mt-2 text-sm text-gray-400">Service-trade dense — neighbors to the east, frequent reorder cycle.</p>
        </a>
        <a href="/service-areas/henderson-nv/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">Henderson, NV</h3>
          <p class="mt-2 text-sm text-gray-400">Master-planned community build-out — the other end of the valley.</p>
        </a>
        <a href="/industries/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="font-heading text-lg font-bold tracking-tight text-white group-hover:text-gold-400">All Industries</h3>
          <p class="mt-2 text-sm text-gray-400">Trade-specific gear, brands, and compliance — pick your industry.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Sharper crew, sharper callbacks. 24-hour quotes.</h2>
      <p class="mb-8 text-lg text-gray-300">Talk to a real human who knows what closes on a Summerlin estate doorstep.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
