---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Workwear and Branded Apparel in Summerlin, Las Vegas',
 description:
 'Embroidered uniforms and branded crew apparel for Summerlin contractors and high-end residential trades. master-planned community builds, Downtown Summerlin commercial. Sharp foreman polos.',
 h1Pre: 'Summerlin',
 hero: '/images/generated/cta-bluehour.jpg',
}

const localContext = [
 {
 code: 'Major Projects',
 title: 'master-planned community territory',
 body: 'Downtown Summerlin office and retail keeps adding pads. The Cliffs, Mesa Ridge, Stonebridge, and the upcoming villages are still phasing in. Higher-end commercial fit-out around the 215 corridor and the medical campuses. Owner-rep teams are sharp and the GCs follow suit — regional GCs.',
 },
 {
 code: 'Active Trades',
 title: 'Premium-residential and commercial subs',
 body: 'Custom-home GCs working Summerlin Cliffs estates. Commercial electrical, mechanical, and finish trades on Downtown Summerlin retail and office fit-out. Pool and landscape, high-end millwork. The crews here trade on appearance more than the rest of the valley — clean uniforms close more callbacks.',
 },
 {
 code: 'What Crews Need Locally',
 title: 'Cleaner foreman uniforms are standard here',
 body: 'Summerlin owners and HOAs notice what the crew wears on the property. Embroidered polos beat printed tees for any trade that touches a customer at this end of the valley. We carry Port Authority, Carhartt, and OGIO in colors that don\'t clash with high-end stucco and we keep your spec tight across reorders.',
 },
]

const trades = [
 {
 name: 'General Contractors',
 detail: 'Foreman/super differentiation and clean sub branding for master-planned community builds and Downtown Summerlin fit-out.',
 href: '/industries/general-contractors-las-vegas/',
 img: '/images/generated/kit-office-sales.jpg',
 },
 {
 name: 'Plumbing & HVAC',
 detail: 'Embroidered service polos for techs walking into Summerlin Cliffs and Mesa Ridge custom homes.',
 href: '/industries/plumbing-hvac-las-vegas/',
 img: '/images/generated/kit-plumbing-hvac.jpg',
 },
 {
 name: 'Electrical Contractors',
 detail: 'Service polos and FR layers for residential and commercial electrical across the Summerlin master plan.',
 href: '/industries/electrical-contractors-las-vegas/',
 img: '/images/generated/kit-electrical.jpg',
 },
 {
 name: 'Roofing & Solar',
 detail: 'Branded crew tees and hi-vis for tile, solar, and high-end residential roof work in Summerlin estates.',
 href: '/industries/roofing-solar-las-vegas/',
 img: '/images/generated/service-screen-printing.jpg',
 },
]

const useCases = [
 'Custom-home GCs in embroidered button-downs walking estate clients through Cliffs and Stonebridge',
 'Pool and landscape crews in branded polos with company name + license number on the chest',
 'Commercial fit-out subs in clean foreman polos for Downtown Summerlin retail and office',
 'Service techs (HVAC, plumbing, electrical) in polished embroidered polos for high-end residential routes',
 'Millwork and finish trades in branded long-sleeves that hold up on punch-list weeks',
 'Branded swag for Summerlin Council, BIA, and chamber events around the master plan',
]

const faqs = [
 {
 q: 'We work high-end Summerlin residential. Will printed crew tees cost us callbacks?',
 a: 'For estate clients in The Cliffs, Mesa Ridge, and Stonebridge — yes, often. Owners and HOAs notice. Embroidered polos signal "established business" in a way that printed tees don\'t at this end of the valley. We typically run two programs for Summerlin shops: polos for the customer-facing techs, branded tees for shop and ride-along.',
 },
 {
 q: 'Do you have polo colors that work on light stucco and natural-stone properties?',
 a: 'Yes — we stock 8 colors in Port Authority K500 including stone, sand, navy, and charcoal that read clean on Summerlin-style properties. Our designer will lay the embroidery placement so the logo reads sharp without overpowering.',
 },
 {
 q: 'How fast can you turn around a new uniform program for a Summerlin commercial fit-out crew?',
 a: 'Standard production runs from our local Las Vegas shop. Rush options available. For repeat clients with files on hand, we\'ve hit rush turnarounds.',
 },
 {
 q: 'Can you do company-store setup so each crew can order their own approved kit?',
 a: 'Yes. Particularly useful for mid-size and growing Summerlin shops where you want each tech to log in, see only what you\'ve approved (with allowances if you set them), and order direct. We embroider and ship — no closet inventory on your end.',
 },
 {
 q: 'Do you deliver to Summerlin commercial addresses?',
 a: 'Yes — local delivery to Summerlin commercial addresses on qualifying orders. Downtown Summerlin, Pavilion Center, the 215-corridor offices. Residential pickup at our Las Vegas shop is 20–25 min east depending on your village.',
 },
 {
 q: 'What\'s the minimum for an embroidered polo run?',
 a: '12 pieces for embroidery, 24 for screen printing. Most Summerlin shops we work with order in 25–50 piece runs and reorder quarterly as new hires roll on.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://bighornthreads.com/service-areas/' },
 { '@type': 'ListItem', position: 3, name: 'Summerlin', item: 'https://bighornthreads.com/service-areas/summerlin/' },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Workwear and Branded Apparel in Summerlin',
 serviceType: 'Embroidered uniforms and branded crew apparel for high-end residential and commercial trades',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: {
 '@type': 'Place',
 name: 'Summerlin, Las Vegas, NV',
 address: { '@type': 'PostalAddress', addressLocality: 'Las Vegas', addressRegion: 'NV', addressCountry: 'US' },
 },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/service-areas/summerlin/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-32 sm:px-6 sm:pb-28 sm:pt-36 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
