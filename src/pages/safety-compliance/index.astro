---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Safety Apparel Compliance Hub for Las Vegas Trades',
 description:
 'ANSI/ISEA 107, NFPA 70E, NFPA 2112, and Nevada OSHA heat rules — explained by a Vegas uniform shop that decorates compliant gear every day. Guides, brand picks, and what your safety officer actually checks.',
 h1Pre: 'Safety & Compliance',
 hero: '/images/generated/kit-electrical.jpg',
}

const standards = [
 {
 code: 'ANSI/ISEA 107',
 title: 'Hi-vis classes for road, work-zone, and construction crews',
 body: 'Class 1, 2, and 3 vests, t-shirts, and outerwear with reflective striping. We respect the 72 sq-in logo limit so your branding never breaks the cert.',
 },
 {
 code: 'NFPA 70E',
 title: 'Arc-rated apparel for electrical workers',
 body: 'CAT 1 / CAT 2 FR shirts and pants from Bulwark, Carhartt FR, and Wrangler Riggs. FR-compatible thread and placement that preserves the rating.',
 },
 {
 code: 'NFPA 2112',
 title: 'Flash-fire protection for oil, gas, and mechanical',
 body: 'Industrial flash-fire standard for refinery, pipeline, and gas-utility crews. We stock and decorate to manufacturer spec on every garment.',
 },
 {
 code: 'OSHA Nevada Heat',
 title: 'Heat-illness rules for desert outdoor work',
 body: 'Nevada heat-illness regulation, 5 AM start allowance, UPF and breathability spec for fabric that holds up on Vegas rooftops at 110°.',
 },
]

const guides = [
 {
 href: '/safety-compliance/ansi-107-hi-vis-guide/',
 badge: 'ANSI/ISEA 107',
 title: 'Hi-vis Class 1, 2, and 3 — what each one means and when to use it',
 body: 'Coverage area, retroreflective material totals, work-zone pairings, and the 72 sq-in decoration limit explained for shops that actually order this gear.',
 minutes: '12 min read',
 },
 {
 href: '/safety-compliance/nfpa-70e-embroidery-guide/',
 badge: 'NFPA 70E',
 title: 'Embroidering FR shirts without voiding the arc rating',
 body: 'FR-compatible thread, backing material, brand-specific placement spec, and how a safety officer verifies decoration on a job-site walk.',
 minutes: '12 min read',
 },
 {
 href: '/safety-compliance/nevada-osha-heat-rules-2026/',
 badge: 'Nevada OSHA',
 title: 'Nevada heat-illness rules and how uniform choice affects compliance',
 body: 'SB427 overview, the 5 AM construction start, UPF spec, fabrics to avoid on Vegas rooftops, and what employers need to document.',
 minutes: '13 min read',
 },
 {
 href: '/blog/nfpa-70e-fr-shirts-vegas-electricians/',
 badge: 'Field Guide',
 title: 'FR shirt compliance for Vegas electricians — the working contractor\'s version',
 body: 'CAT 1 vs CAT 2, Bulwark vs Carhartt FR, and the five compliance mistakes we see weekly on commercial electrical crews.',
 minutes: '11 min read',
 },
]

const whyMatters = [
 {
 title: 'The wrong garment is a documentation failure',
 body: 'A safety officer doing a walk-through can spot a non-compliant shirt in 10 seconds — wrong cal rating, wrong thread, logo over the placement limit. That\'s a write-up, a re-buy, or worse.',
 },
 {
 title: 'Compliance is the cheap version of injury',
 body: 'A CAT 2 shirt costs a premium. An arc-flash burn injury costs six-figure+ and a year of OSHA paperwork. The math has never been close.',
 },
 {
 title: 'Reorders only work if specs stay matched',
 body: 'The job site doesn\'t care that "we used to buy this." Spec sheets drift. We keep yours on file so the third reorder matches the first one — same fabric, same rating, same decoration.',
 },
 {
 title: 'Vegas is its own climate',
 body: 'Most FR and most hi-vis is built for moderate weather. We pick brands and weights that hold rating and stay wearable in 110° rooftop conditions, because gear nobody wears protects nobody.',
 },
]

const faqs = [
 {
 q: 'Why does a uniform shop have a compliance hub?',
 a: 'Because the wrong shirt voids the standard, and most shops won\'t tell you. We decorate FR, hi-vis, and flash-fire garments every week for Vegas trades — the spec sheets, the thread types, and the placement rules are part of our daily workflow, not something we look up after the order is placed.',
 },
 {
 q: 'Which standards do you cover in detail?',
 a: 'ANSI/ISEA 107 (hi-vis), NFPA 70E (electrical arc-rated), NFPA 2112 (industrial flash-fire), and Nevada OSHA heat-illness. Those four cover roughly 95% of the trades work we see in Las Vegas — electrical, roofing, solar, oil and gas, mechanical, and construction.',
 },
 {
 q: 'Do you keep brand spec sheets on file?',
 a: 'Yes. Every FR and hi-vis order we run has the manufacturer spec verified before production — placement, thread, backing, and ink type. We keep the spec on the customer record so reorders match without re-asking.',
 },
 {
 q: 'Can you help write a uniform spec for our safety program?',
 a: 'Yes. If you\'re building a safety program from scratch or re-writing your apparel section, we\'ll sit down with your safety officer and put together a spec sheet that covers brand, rating, decoration method, and reorder cadence. No charge for existing customers.',
 },
 {
 q: 'What about brands you don\'t carry?',
 a: 'We can source most major FR and hi-vis lines — Bulwark, Carhartt FR, Wrangler Riggs, ML Kishigo, Pioneer, PIP, Tingley, Lakeland. If your safety officer specs a brand we don\'t stock, we\'ll quote it. We won\'t substitute without telling you.',
 },
 {
 q: 'Do you decorate customer-supplied FR or hi-vis garments?',
 a: 'Yes, with caveats. We need the manufacturer spec for the garment so we can verify our decoration method is compliant. If the garment is unmarked or counterfeit, we won\'t run it — that\'s a liability for both of us.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Safety & Compliance', item: 'https://bighornthreads.com/safety-compliance/' },
 ],
}

const collectionSchema = {
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: page.title,
 description: page.description,
 url: 'https://bighornthreads.com/safety-compliance/',
 about: [
 { '@type': 'Thing', name: 'ANSI/ISEA 107 hi-visibility apparel' },
 { '@type': 'Thing', name: 'NFPA 70E arc-rated apparel' },
 { '@type': 'Thing', name: 'NFPA 2112 flash-fire apparel' },
 { '@type': 'Thing', name: 'Nevada OSHA heat-illness prevention' },
 ],
 hasPart: guides.map((g) => ({
 '@type': 'Article',
 headline: g.title,
 name: g.title,
 url: `https://bighornthreads.com${g.href}`,
 author: { '@type': 'Organization', name: 'Bighorn Threads' },
 })),
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/safety-compliance/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-16 sm:px-6 sm:pb-28 sm:pt-16 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Safety &amp; Compliance</span>
 </nav>

 <p class="kicker mb-3">{page.h1Pre}</p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Safety Apparel Compliance, <span class="text-gold-400">Done by a Shop That Lives in the Spec Sheets.</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 ANSI hi-vis, NFPA 70E arc-rated, NFPA 2112 flash-fire, and Nevada heat rules — explained by a Vegas uniform shop that decorates compliant gear every day for the trades.
 </p>

 <div class="mt-10 flex flex-wrap items-center gap-3">
 <a href="/contact/" class="btn-primary text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
 702.904.8923
 </a>
 </div>
 </div>
 </section>

 <!-- Standards we cover — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">The Standards</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Four standards that cover almost <span class="text-gold-600">every Vegas job site.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Most trades work in Vegas falls under one of these. We carry the brands, hold the spec sheets, and decorate the way the manufacturer requires — so your gear stays compliant from the first run through every reorder.
 </p>
 </div>

 <div class="grid gap-5 md:grid-cols-2">
 {standards.map((s) => (
 <div class="border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <span class="spec mb-4 inline-block border border-hairline px-2.5 py-1 text-gold-600">{s.code}</span>
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal">{s.title}</h3>
 <p class="text-sm leading-relaxed text-ash">{s.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Guide cards — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Deep Guides</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">In-depth references for the standards you actually <span class="text-gold-600">work under.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Long-form guides written for safety officers, foremen, and shop owners — the people writing the spec or signing the PO. Skip the marketing fluff; we get into the rating math, brand picks, and decoration rules.
 </p>
 </div>

 <div class="grid gap-5 sm:grid-cols-2">
 {guides.map((g) => (
 <a href={g.href} class="group flex flex-col border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <div class="mb-4 flex items-center gap-3">
 <span class="spec border border-hairline px-2.5 py-1 text-gold-600">{g.badge}</span>
 <span class="font-mono text-xs text-ash">{g.minutes}</span>
 </div>
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal group-hover:text-gold-600">{g.title}</h3>
 <p class="mb-4 flex-1 text-sm leading-relaxed text-ash">{g.body}</p>
 <span class="inline-flex items-center gap-1.5 font-mono text-xs font-bold uppercase tracking-[0.15em] text-gold-600">
 Read the guide
 <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </span>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Why compliance matters — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
 <div>
 <p class="kicker mb-3">Why It Matters</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Why we treat compliance as part of the order, <span class="text-gold-600">not an afterthought.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 Every shop says they "do safety apparel." Most of them mean they sell hi-vis shirts in lime. The difference between selling and being compliant lives in the spec sheet — and that\'s where most orders fail before they ever ship.
 </p>
 <div class="mt-8 flex flex-wrap gap-3">
 <a href="/services/embroidery-las-vegas/" class="btn-secondary text-sm">Embroidery →</a>
 <a href="/services/screen-printing-las-vegas/" class="btn-secondary text-sm">Screen Printing →</a>
 <a href="/industries/" class="btn-secondary text-sm">Industries →</a>
 </div>
 </div>

 <ul class="space-y-3">
 {whyMatters.map((w, i) => (
 <li class="border border-hairline bg-panel p-5 transition-colors hover:border-gold-500">
 <div class="flex items-start gap-4">
 <span class="shrink-0 font-mono text-xs font-bold text-gold-600">{String(i + 1).padStart(2, '0')}</span>
 <div>
 <h3 class="mb-2 font-heading text-base font-bold uppercase tracking-tight text-charcoal">{w.title}</h3>
 <p class="text-sm leading-relaxed text-ash">{w.body}</p>
 </div>
 </div>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Industries we serve — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Who This Is For</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Trades we outfit <span class="text-gold-600">under these standards.</span></h2>
 </div>

 <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
 <a href="/industries/electrical-contractors-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="mb-2 font-heading text-base font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Electrical Contractors</h3>
 <p class="text-sm text-ash">NFPA 70E + ANSI Class 2 hi-vis</p>
 </a>
 <a href="/industries/roofing-solar-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="mb-2 font-heading text-base font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Roofing &amp; Solar</h3>
 <p class="text-sm text-ash">Heat-rule UPF + ANSI Class 2/3</p>
 </a>
 <a href="/industries/oil-gas-mechanical-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="mb-2 font-heading text-base font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Oil, Gas &amp; Mechanical</h3>
 <p class="text-sm text-ash">NFPA 2112 flash-fire + FR layering</p>
 </a>
 <a href="/industries/general-contractors-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="mb-2 font-heading text-base font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">General Contractors</h3>
 <p class="text-sm text-ash">ANSI hi-vis + Nevada heat rules</p>
 </a>
 </div>
 </div>
 </section>

 <!-- Topic deep-dives — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">Field Reading</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Compliance topics our customers ask about most.</h2>
 <div class="space-y-5 text-lg leading-relaxed text-ash">
 <p>
 On hi-vis: read our side-by-side <a href="/blog/ansi-107-class-2-vs-class-3-hi-vis-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Class 2 vs Class 3 hi-vis</a>, our <a href="/blog/hi-vis-class-3-when-you-need-it-over-class-2/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Class 3 upgrade guide</a>, and our <a href="/blog/custom-safety-vests-ansi-compliance/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">custom safety vests with ANSI compliance</a> writeup.
 </p>
 <p>
 On FR / NFPA: see our <a href="/blog/nfpa-2112-fr-coveralls-buyer-guide/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">NFPA 2112 FR coveralls buyer guide</a> and <a href="/blog/nfpa-70e-fr-shirts-vegas-electricians/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">NFPA 70E FR shirts for Vegas electricians</a>.
 </p>
 <p>
 On hard hats and PPE: details on <a href="/blog/custom-hard-hats-osha-z89-decals-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">OSHA Z89 hard hat decal rules</a> and <a href="/blog/nevada-osha-heat-rules-2026-workwear/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Nevada OSHA heat rules for 2026 workwear</a>.
 </p>
 </div>
 </div>
 </section>

 <!-- FAQs — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Compliance questions we get every week.</h2>

 <div class="divide-y divide-hairline border-y border-hairline">
 {faqs.map((f) => (
 <details class="group">
 <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
 <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{f.q}</h3>
 <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
 </summary>
 <p class="pb-5 text-base leading-relaxed text-ash">{f.a}</p>
 </details>
 ))}
 </div>
 </div>
 </section>

 <!-- CTA — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/cta-bluehour.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/80"></div>
 <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
 <h2 class="mb-4 font-heading text-3xl font-extrabold uppercase tracking-tight text-white sm:text-4xl">Need a uniform spec your safety officer <span class="text-gold-400">will sign off on?</span></h2>
 <p class="mb-8 text-lg text-navy-200">Send the standard, the crew size, and the conditions. We come back with brands, decoration plan, and pricing fast.</p>
 <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
 <a href="/get-a-quote/" class="btn-primary text-base">Get a Free Quote</a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-base font-medium tracking-wide text-white transition-colors hover:text-gold-400">702.904.8923</a>
 </div>
 </div>
 </section>
</BaseLayout>
