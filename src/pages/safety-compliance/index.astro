---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
  title: 'Safety Apparel Compliance Hub for Las Vegas Trades',
  description:
    'ANSI/ISEA 107, NFPA 70E, NFPA 2112, and Nevada OSHA heat rules — explained by a Vegas uniform shop that decorates compliant gear every day. Guides, brand picks, and what your safety officer actually checks.',
  h1Pre: 'Safety & Compliance',
  hero: '/images/generated/kit-electrical.jpg',
}

const standards = [
  {
    code: 'ANSI/ISEA 107',
    title: 'Hi-vis classes for road, work-zone, and construction crews',
    body: 'Class 1, 2, and 3 vests, t-shirts, and outerwear with reflective striping. We respect the 72 sq-in logo limit so your branding never breaks the cert.',
  },
  {
    code: 'NFPA 70E',
    title: 'Arc-rated apparel for electrical workers',
    body: 'CAT 1 / CAT 2 FR shirts and pants from Bulwark, Carhartt FR, and Wrangler Riggs. FR-compatible thread and placement that preserves the rating.',
  },
  {
    code: 'NFPA 2112',
    title: 'Flash-fire protection for oil, gas, and mechanical',
    body: 'Industrial flash-fire standard for refinery, pipeline, and gas-utility crews. We stock and decorate to manufacturer spec on every garment.',
  },
  {
    code: 'OSHA Nevada Heat',
    title: 'Heat-illness rules for desert outdoor work',
    body: 'Nevada heat-illness regulation, 5 AM start allowance, UPF and breathability spec for fabric that holds up on Vegas rooftops at 110°.',
  },
]

const guides = [
  {
    href: '/safety-compliance/ansi-107-hi-vis-guide/',
    badge: 'ANSI/ISEA 107',
    title: 'Hi-vis Class 1, 2, and 3 — what each one means and when to use it',
    body: 'Coverage area, retroreflective material totals, work-zone pairings, and the 72 sq-in decoration limit explained for shops that actually order this gear.',
    minutes: '12 min read',
  },
  {
    href: '/safety-compliance/nfpa-70e-embroidery-guide/',
    badge: 'NFPA 70E',
    title: 'Embroidering FR shirts without voiding the arc rating',
    body: 'FR-compatible thread, backing material, brand-specific placement spec, and how a safety officer verifies decoration on a job-site walk.',
    minutes: '12 min read',
  },
  {
    href: '/safety-compliance/nevada-osha-heat-rules-2026/',
    badge: 'Nevada OSHA',
    title: 'Nevada heat-illness rules and how uniform choice affects compliance',
    body: 'SB427 overview, the 5 AM construction start, UPF spec, fabrics to avoid on Vegas rooftops, and what employers need to document.',
    minutes: '13 min read',
  },
  {
    href: '/blog/nfpa-70e-fr-shirts-vegas-electricians/',
    badge: 'Field Guide',
    title: 'FR shirt compliance for Vegas electricians — the working contractor\'s version',
    body: 'CAT 1 vs CAT 2, Bulwark vs Carhartt FR, and the five compliance mistakes we see weekly on commercial electrical crews.',
    minutes: '11 min read',
  },
]

const whyMatters = [
  {
    title: 'The wrong garment is a documentation failure',
    body: 'A safety officer doing a walk-through can spot a non-compliant shirt in 10 seconds — wrong cal rating, wrong thread, logo over the placement limit. That\'s a write-up, a re-buy, or worse.',
  },
  {
    title: 'Compliance is the cheap version of injury',
    body: 'A CAT 2 shirt costs a premium. An arc-flash burn injury costs six-figure+ and a year of OSHA paperwork. The math has never been close.',
  },
  {
    title: 'Reorders only work if specs stay matched',
    body: 'The job site doesn\'t care that "we used to buy this." Spec sheets drift. We keep yours on file so the third reorder matches the first one — same fabric, same rating, same decoration.',
  },
  {
    title: 'Vegas is its own climate',
    body: 'Most FR and most hi-vis is built for moderate weather. We pick brands and weights that hold rating and stay wearable in 110° rooftop conditions, because gear nobody wears protects nobody.',
  },
]

const faqs = [
  {
    q: 'Why does a uniform shop have a compliance hub?',
    a: 'Because the wrong shirt voids the standard, and most shops won\'t tell you. We decorate FR, hi-vis, and flash-fire garments every week for Vegas trades — the spec sheets, the thread types, and the placement rules are part of our daily workflow, not something we look up after the order is placed.',
  },
  {
    q: 'Which standards do you cover in detail?',
    a: 'ANSI/ISEA 107 (hi-vis), NFPA 70E (electrical arc-rated), NFPA 2112 (industrial flash-fire), and Nevada OSHA heat-illness. Those four cover roughly 95% of the trades work we see in Las Vegas — electrical, roofing, solar, oil and gas, mechanical, and construction.',
  },
  {
    q: 'Do you keep brand spec sheets on file?',
    a: 'Yes. Every FR and hi-vis order we run has the manufacturer spec verified before production — placement, thread, backing, and ink type. We keep the spec on the customer record so reorders match without re-asking.',
  },
  {
    q: 'Can you help write a uniform spec for our safety program?',
    a: 'Yes. If you\'re building a safety program from scratch or re-writing your apparel section, we\'ll sit down with your safety officer and put together a spec sheet that covers brand, rating, decoration method, and reorder cadence. No charge for existing customers.',
  },
  {
    q: 'What about brands you don\'t carry?',
    a: 'We can source most major FR and hi-vis lines — Bulwark, Carhartt FR, Wrangler Riggs, ML Kishigo, Pioneer, PIP, Tingley, Lakeland. If your safety officer specs a brand we don\'t stock, we\'ll quote it. We won\'t substitute without telling you.',
  },
  {
    q: 'Do you decorate customer-supplied FR or hi-vis garments?',
    a: 'Yes, with caveats. We need the manufacturer spec for the garment so we can verify our decoration method is compliant. If the garment is unmarked or counterfeit, we won\'t run it — that\'s a liability for both of us.',
  },
]

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Safety & Compliance', item: 'https://bighornthreads.com/safety-compliance/' },
  ],
}

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: page.title,
  description: page.description,
  url: 'https://bighornthreads.com/safety-compliance/',
  about: [
    { '@type': 'Thing', name: 'ANSI/ISEA 107 hi-visibility apparel' },
    { '@type': 'Thing', name: 'NFPA 70E arc-rated apparel' },
    { '@type': 'Thing', name: 'NFPA 2112 flash-fire apparel' },
    { '@type': 'Thing', name: 'Nevada OSHA heat-illness prevention' },
  ],
  hasPart: guides.map((g) => ({
    '@type': 'Article',
    name: g.title,
    url: `https://bighornthreads.com${g.href}`,
  })),
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical="https://bighornthreads.com/safety-compliance/"
  heroImage={page.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
    <div class="absolute inset-0">
      <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">Safety &amp; Compliance</span>
      </nav>

      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">{page.h1Pre}</span>
      <h1 class="mb-6 max-w-4xl font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Safety Apparel Compliance, <span class="text-gold-500">Done by a Shop That Lives in the Spec Sheets.</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
        ANSI hi-vis, NFPA 70E arc-rated, NFPA 2112 flash-fire, and Nevada heat rules — explained by a Vegas uniform shop that decorates compliant gear every day for the trades.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-7 py-3 text-base font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/25">
          Get a Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gold-500/40 px-6 py-3 font-mono text-sm font-medium text-gold-500 transition-all hover:border-gold-500 hover:bg-gold-500/5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          725.235.6196
        </a>
      </div>
    </div>
  </section>

  <!-- Standards we cover -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">The Standards</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Four standards that cover almost every Vegas job site.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Most trades work in Vegas falls under one of these. We carry the brands, hold the spec sheets, and decorate the way the manufacturer requires — so your gear stays compliant from the first run through every reorder.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {standards.map((s) => (
          <div class="group relative overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <span class="mb-4 inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{s.code}</span>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white">{s.title}</h3>
            <p class="text-sm leading-relaxed text-gray-300">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guide cards -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Deep Guides</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">In-depth references for the standards you actually work under.</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-300">
          Long-form guides written for safety officers, foremen, and shop owners — the people writing the spec or signing the PO. Skip the marketing fluff; we get into the rating math, brand picks, and decoration rules.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {guides.map((g) => (
          <a href={g.href} class="group block overflow-hidden rounded-2xl border border-navy-700/40 bg-navy-900/40 p-7 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
            <div class="mb-4 flex items-center gap-3">
              <span class="inline-block rounded-md border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-gold-500">{g.badge}</span>
              <span class="font-mono text-xs text-gray-500">{g.minutes}</span>
            </div>
            <h3 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white group-hover:text-gold-400">{g.title}</h3>
            <p class="mb-4 text-sm leading-relaxed text-gray-300">{g.body}</p>
            <span class="inline-flex items-center gap-1.5 font-mono text-xs font-bold uppercase tracking-[0.15em] text-gold-500">
              Read the guide
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why compliance matters -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Why It Matters</span>
          <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Why we treat compliance as part of the order, not an afterthought.</h2>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Every shop says they "do safety apparel." Most of them mean they sell hi-vis shirts in lime. The difference between selling and being compliant lives in the spec sheet — and that\'s where most orders fail before they ever ship.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/services/embroidery-las-vegas/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Embroidery →</a>
            <a href="/services/screen-printing-las-vegas/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Screen Printing →</a>
            <a href="/industries/" class="inline-flex items-center gap-2 rounded-lg border border-gray-600 px-5 py-2.5 text-sm font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">Industries →</a>
          </div>
        </div>

        <ul class="space-y-3">
          {whyMatters.map((w, i) => (
            <li class="rounded-xl border border-navy-700/30 bg-navy-900/30 p-5 transition-all hover:border-gold-500/30 hover:bg-navy-900/50">
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 font-mono text-xs font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h3 class="mb-2 font-heading text-base font-bold tracking-tight text-white">{w.title}</h3>
                  <p class="text-sm leading-relaxed text-gray-300">{w.body}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Industries we serve -->
  <section class="border-b border-navy-800 bg-navy-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Who This Is For</span>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Trades we outfit under these standards.</h2>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/industries/electrical-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="mb-2 font-heading text-base font-bold tracking-tight text-white group-hover:text-gold-400">Electrical Contractors</h3>
          <p class="text-sm text-gray-400">NFPA 70E + ANSI Class 2 hi-vis</p>
        </a>
        <a href="/industries/roofing-solar-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="mb-2 font-heading text-base font-bold tracking-tight text-white group-hover:text-gold-400">Roofing &amp; Solar</h3>
          <p class="text-sm text-gray-400">Heat-rule UPF + ANSI Class 2/3</p>
        </a>
        <a href="/industries/oil-gas-mechanical-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="mb-2 font-heading text-base font-bold tracking-tight text-white group-hover:text-gold-400">Oil, Gas &amp; Mechanical</h3>
          <p class="text-sm text-gray-400">NFPA 2112 flash-fire + FR layering</p>
        </a>
        <a href="/industries/general-contractors-las-vegas/" class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-6 transition-all hover:border-gold-500/40 hover:bg-navy-900/60">
          <h3 class="mb-2 font-heading text-base font-bold tracking-tight text-white group-hover:text-gold-400">General Contractors</h3>
          <p class="text-sm text-gray-400">ANSI hi-vis + Nevada heat rules</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-b border-navy-800 bg-navy-950 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">FAQ</span>
      <h2 class="mb-12 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Compliance questions we get every week.</h2>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-navy-700/40 bg-navy-900/40 p-5 transition-all hover:border-gold-500/30 open:border-gold-500/40">
            <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
              <h3 class="font-heading text-lg font-bold leading-tight tracking-tight text-white">{f.q}</h3>
              <span class="mt-1 flex-shrink-0 text-gold-500 transition-transform group-open:rotate-45">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-gray-300">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900/60 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">Need a uniform spec your safety officer will sign off on?</h2>
      <p class="mb-8 text-lg text-gray-300">Send the standard, the crew size, and the conditions. We come back with brands, decoration plan, and pricing fast.</p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-base font-bold text-navy-950 transition-all hover:bg-gold-400">Get a Free Quote</a>
        <a href="tel:+17252356196" class="inline-flex min-h-[48px] items-center gap-2 rounded-lg border border-gray-600 px-8 py-4 font-mono text-base font-medium text-white transition-all hover:border-gold-500 hover:text-gold-500">725.235.6196</a>
      </div>
    </div>
  </section>
</BaseLayout>
