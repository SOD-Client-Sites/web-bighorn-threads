---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'DTF Printing in Las Vegas | Direct-to-Film Custom Apparel — Bighorn Threads',
 description:
 'DTF (direct-to-film) printing in Las Vegas — full-color prints on cotton, poly, blends, dark fabrics. No screen-setup fees. Photo-detail decoration on small runs. Get a quote.',
 hero: '/images/generated/service-screen-printing.jpg',
 url: 'https://bighornthreads.com/dtf-printing-las-vegas/',
}

const stack = [
 { label: 'The method', body: 'Design printed onto PET film, hot-melt adhesive applied, cured, then heat-pressed onto the garment. The film transfers a full-color, photo-detail image — no screen, no setup per color.' },
 { label: 'Where it wins', body: 'Small-batch runs (under 24 pieces), full-color or photo-realistic art, mixed garment programs (tees + hoodies + bags in one run), and decorating dark fabrics where light prints fade.' },
 { label: 'Fabric range', body: 'Cotton, polyester, blends, denim, canvas, leather, nylon — adheres cleanly to nearly every common apparel substrate. Light or dark colored garment, no contrast issues.' },
 { label: 'Decoration program', body: 'Same artwork file works across t-shirts, polos, hoodies, hats, and tote bags. One digitization, every garment in the order. Reorder transfers separately and apply on demand.' },
]

const dtfVsOthers = [
 { row: 'DTF', meaning: 'Full-color, photo-detail, any fabric color', use: 'Small to mid runs, mixed garment programs, complex art, dark fabrics' },
 { row: 'Screen printing', meaning: 'Spot-color inks, very large runs', use: 'High-volume single-design runs (50+), bold one-to-three color graphics' },
 { row: 'Embroidery', meaning: 'Stitched thread, dimensional finish', use: 'Polos, jackets, hats, FR garments, premium logo placement' },
 { row: 'DTG (direct-to-garment)', meaning: 'Inkjet directly onto cotton', use: 'Cotton-only runs, photo prints; struggles on poly and dark fabrics' },
 { row: 'Sublimation', meaning: 'Dye into white polyester only', use: 'White or light polyester; cannot decorate cotton or dark fabric' },
 { row: 'Heat-transfer vinyl', meaning: 'Cut vinyl applied with heat', use: 'Names, numbers, simple shapes; not for full color or fine detail' },
]

const useCases = [
 { name: 'Small-run team apparel', detail: '12–48 piece team shirts, raglans, or hoodies in full color. No screen-setup penalty for low volume.' },
 { name: 'Photo + gradient logos', detail: 'Brand marks with shadows, gradients, or photographic elements that screen printing can\'t hold cleanly.' },
 { name: 'Mixed garment programs', detail: 'Same logo across tees, hoodies, polos, hats, and tote bags in one run. One file, every garment.' },
 { name: 'Dark-fabric decoration', detail: 'Black, navy, charcoal, forest tees with full-color logos that pop. White underbase printed automatically.' },
 { name: 'Event + gang-sheet orders', detail: 'Buy DTF transfers as a gang sheet. Apply on demand — useful for new-hire shirts, event-day pop-up runs, name additions.' },
 { name: 'On-demand reorders', detail: 'Transfer sheets stay shelf-stable. Apply later, ship after. Useful for event SWAG with unknown final headcount.' },
]

const faqs = [
 { q: 'What is DTF printing?', a: 'DTF — direct-to-film printing — prints a design onto a special PET film coated with hot-melt adhesive, then heat-presses the film onto the garment. The result is a full-color, photo-detail decoration that adheres to almost any fabric. No screens, no setup fees per color, and works on dark fabrics where most other methods fail.' },
 { q: 'DTF vs screen printing — which one should I use?', a: 'DTF wins on small runs (under 24 pieces), full-color or photo-realistic art, mixed garment programs, and dark fabrics. Screen printing wins on large single-design runs (50+) where setup cost is amortized over volume and the per-piece cost drops below DTF. Most production shops use both methods depending on the order.' },
 { q: 'How durable is a DTF print?', a: 'Properly applied DTF transfers survive 50+ wash cycles in normal home laundering. Wash inside-out in cold water and tumble dry low for the best lifespan. Industrial laundering at high temperatures shortens lifespan; for industrial-laundry programs (uniform rentals), embroidery or screen print holds up longer.' },
 { q: 'What fabrics can you DTF on?', a: 'Cotton, polyester, polyester-cotton blends, tri-blends, denim, canvas, nylon, leather, and most synthetic substrates. The transfer adheres to nearly every common apparel material. Light or dark colored fabric — no contrast issues. The handful of materials that don\'t take DTF well are silicone-coated technical fabrics and some treated water-resistant shells.' },
 { q: 'Can DTF print on FR garments?', a: 'Standard DTF adhesives are not generally approved for NFPA 2112 FR-rated garments — the adhesive can melt and drip in arc events, voiding the certification. For FR garments, we use Nomex thread embroidery instead. See our welder uniforms page for FR decoration specifics.' },
 { q: 'What\'s the minimum DTF order?', a: 'No formal minimum. Single pieces are economical with DTF in a way that screen printing isn\'t. Per-piece pricing softens with volume — typical breakpoints at 12, 24, 48, and 100+ pieces.' },
 { q: 'Where can I get DTF printing in Las Vegas?', a: 'Bighorn Threads runs DTF printing for Vegas contractors, event promoters, sports teams, and small-batch promotional programs. Same artwork file across mixed garments — t-shirts, hoodies, polos, hats, tote bags. Send your art file and quantity for a quote.' },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'DTF Printing Las Vegas', item: page.url },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'DTF Printing in Las Vegas',
 serviceType: 'Direct-to-film custom apparel printing',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Summerlin' },
 { '@type': 'City', name: 'Spring Valley' },
 ],
 description: page.description,
 url: page.url,
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical={page.url}
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

