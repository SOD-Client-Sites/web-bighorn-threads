---
import BaseLayout from '@/layouts/BaseLayout.astro'

const trades = [
 'General Contractor',
 'Electrical Contractor',
 'Plumbing / HVAC',
 'Roofing / Solar',
 'Landscaping',
 'Concrete / Masonry',
 'Steel / Ironworkers',
 'Oil / Gas / Mechanical',
 'Other',
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Preview Your Branded Store', item: 'https://bighornthreads.com/demo/' },
 ],
}
---

<BaseLayout
 title="Preview Your Branded Apparel Store — Bighorn Threads"
 description="See what your company's branded apparel store would look like. Free preview built in 30 seconds — your company name, your gear, no commitment. For Las Vegas trades and contractors."
 canonical="https://bighornthreads.com/demo/"
 noindex={true}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

 <!-- Hero + Form combined -->
 <section class="min-h-[100svh] bg-concrete pt-32 pb-20 sm:pt-36 sm:pb-28">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-600">Home</a>
 <span class="px-2 text-ash/60">/</span>
 <span class="text-gold-600">Preview Your Branded Store</span>
 </nav>

 <div class="grid items-start gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">

 <!-- Left: pitch -->
 <div>
 <p class="kicker mb-3">Free Preview · 30 Seconds</p>
 <h1 class="mb-6 font-heading text-4xl font-extrabold uppercase leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
 See What <span class="text-gold-600">Your Branded Store</span> Would Look Like.
 </h1>
 <p class="mb-8 text-lg leading-relaxed text-ash sm:text-xl">
 We'll build a private preview page with your company name on the header, your gear in the catalog, and a private URL you can share with your team. No commitment, 
 </p>

 <ul class="mb-8 space-y-3 text-base text-ash">
 <li class="flex items-start gap-3">
 <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
 <span><strong class="text-charcoal">Branded for your company</strong> — your name throughout, ready to share with your foreman or ops manager</span>
 </li>
 <li class="flex items-start gap-3">
 <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
 <span><strong class="text-charcoal">Curated to your trade</strong> — workwear, hi-vis, FR, and gear that fits how your crew actually works</span>
 </li>
 <li class="flex items-start gap-3">
 <span class="mt-1.5 flex h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gold-500"></span>
 <span><strong class="text-charcoal">Convert when you're ready</strong> — your preview becomes a real ordering portal once you give us the go-ahead</span>
 </li>
 </ul>

 <p class="font-mono text-xs uppercase tracking-[0.15em] text-ash">No password · No account · Private link emailed to you</p>
 </div>

 <!-- Right: form card -->
 <div class="border border-hairline bg-paper p-7 sm:p-8">
 <h2 class="mb-2 font-heading text-2xl font-extrabold uppercase tracking-tight text-charcoal">Build my preview</h2>
 <p class="mb-6 text-sm text-ash">Tell us about your crew. We'll generate your branded store page instantly.</p>

 <form id="preview-form" class="space-y-4" novalidate>
 <div>
 <label for="company" class="mb-1 block font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-700">Company name *</label>
 <input id="company" name="company" type="text" required maxlength="80" class="w-full rounded border border-hairline bg-panel px-4 py-2.5 text-base text-charcoal placeholder:text-ash focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25" placeholder="ABC Electrical, LLC" />
 </div>

 <div class="grid gap-4 sm:grid-cols-2">
 <div>
 <label for="contact" class="mb-1 block font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-700">Your name *</label>
 <input id="contact" name="contact" type="text" required maxlength="80" class="w-full rounded border border-hairline bg-panel px-4 py-2.5 text-base text-charcoal placeholder:text-ash focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25" placeholder="John Doe" />
 </div>
 <div>
 <label for="phone" class="mb-1 block font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-700">Phone</label>
 <input id="phone" name="phone" type="tel" inputmode="tel" maxlength="20" class="w-full rounded border border-hairline bg-panel px-4 py-2.5 text-base text-charcoal placeholder:text-ash focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25" placeholder="725.555.0123" />
 </div>
 </div>

 <div>
 <label for="email" class="mb-1 block font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-700">Email *</label>
 <input id="email" name="email" type="email" required maxlength="120" class="w-full rounded border border-hairline bg-panel px-4 py-2.5 text-base text-charcoal placeholder:text-ash focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25" placeholder="john@abcelectrical.com" />
 </div>

 <div class="grid gap-4 sm:grid-cols-2">
 <div>
 <label for="trade" class="mb-1 block font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-700">Trade *</label>
 <select id="trade" name="trade" required class="w-full rounded border border-hairline bg-panel px-4 py-2.5 text-base text-charcoal focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25">
 <option value="">Select…</option>
 {trades.map((t) => <option value={t}>{t}</option>)}
 </select>
 </div>
 <div>
 <label for="crewSize" class="mb-1 block font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-700">Crew size</label>
 <input id="crewSize" name="crewSize" type="number" min="1" max="9999" inputmode="numeric" class="w-full rounded border border-hairline bg-panel px-4 py-2.5 text-base text-charcoal placeholder:text-ash focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25" placeholder="25" />
 </div>
 </div>

 <!-- Logo upload (optional) -->
 <div>
 <label for="logo" class="mb-1 flex items-center justify-between font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-gold-500">
 <span>Logo <span class="text-ash">(optional)</span></span>
 <span id="logo-status" class="text-[10px] text-ash">PNG, JPG, WEBP · max 5MB</span>
 </label>

 <div class="flex items-center gap-3">
 <label for="logo" class="inline-flex flex-1 cursor-pointer items-center justify-center gap-2 rounded border border-dashed border-hairline bg-panel px-4 py-2.5 text-sm text-ash transition-colors hover:border-gold-500 hover:text-gold-600">
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
 <span id="logo-label">Choose a logo file</span>
 </label>
 <button type="button" id="logo-clear" class="hidden rounded border border-hairline bg-panel px-3 py-2.5 text-sm text-ash transition-colors hover:border-gold-500 hover:text-gold-600" aria-label="Remove logo">
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
 </button>
 </div>
 <input id="logo" name="logo" type="file" accept="image/png,image/jpeg,image/webp" class="sr-only" />

 <!-- Logo preview -->
 <div id="logo-preview-wrap" class="mt-3 hidden items-center gap-3 border border-hairline bg-panel p-3">
 <img id="logo-preview" alt="Logo preview" class="h-12 w-12 rounded border border-hairline bg-white object-contain" />
 <div class="flex-1 text-xs">
 <p class="font-bold text-gold-700">Logo ready</p>
 <p class="text-ash">Will appear on every product card.</p>
 </div>
 </div>
 </div>

 <div class="cf-turnstile" data-sitekey="0x4AAAAAADW_K97ZyhlAHC4I" data-theme="light"></div>

 <button type="submit" id="submit-btn" class="btn-primary mt-2 w-full justify-center text-base disabled:cursor-not-allowed disabled:opacity-60">
 <span id="submit-label">Generate my branded store →</span>
 </button>

 <p class="text-center font-mono text-[10px] uppercase tracking-[0.15em] text-ash">Takes 5 seconds · Private URL · Share with your team</p>
 </form>
 </div>
 </div>
 </div>
 </section>
</BaseLayout>

<script>
 const form = document.getElementById('preview-form') as HTMLFormElement | null
 const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null
 const submitLabel = document.getElementById('submit-label')
 const logoInput = document.getElementById('logo') as HTMLInputElement | null
 const logoLabel = document.getElementById('logo-label')
 const logoStatus = document.getElementById('logo-status')
 const logoPreview = document.getElementById('logo-preview') as HTMLImageElement | null
 const logoPreviewWrap = document.getElementById('logo-preview-wrap')
 const logoClear = document.getElementById('logo-clear')

 let logoDataUrl: string | null = null
 const MAX_FILE_BYTES = 5 * 1024 * 1024 // 5MB raw cap before compression
 // Keep tiny — full data URL goes into URL slug. 120×120 q0.6 ≈ 2-4KB base64.
 const TARGET_DIMENSION = 120
 const JPEG_QUALITY = 0.6

 function setLogoStatus(text: string, isError = false) {
 if (!logoStatus) return
 logoStatus.textContent = text
 logoStatus.className = `text-[10px] ${isError ? 'text-red-600' : 'text-ash'}`
 }

 function clearLogo() {
 logoDataUrl = null
 if (logoInput) logoInput.value = ''
 if (logoLabel) logoLabel.textContent = 'Choose a logo file'
 logoPreviewWrap?.classList.add('hidden')
 logoPreviewWrap?.classList.remove('flex')
 logoClear?.classList.add('hidden')
 setLogoStatus('PNG, JPG, WEBP · max 5MB')
 }

 async function processLogoFile(file: File): Promise<void> {
 if (file.size > MAX_FILE_BYTES) {
 setLogoStatus('File too large (max 5MB)', true)
 clearLogo()
 return
 }

 const url = URL.createObjectURL(file)
 try {
 const img = await new Promise<HTMLImageElement>((resolve, reject) => {
 const i = new Image()
 i.onload = () => resolve(i)
 i.onerror = () => reject(new Error('Could not read image'))
 i.src = url
 })

 // Resize to fit within TARGET_DIMENSION × TARGET_DIMENSION, preserve aspect ratio
 const scale = Math.min(TARGET_DIMENSION / img.width, TARGET_DIMENSION / img.height, 1)
 const w = Math.round(img.width * scale)
 const h = Math.round(img.height * scale)

 const canvas = document.createElement('canvas')
 canvas.width = w
 canvas.height = h
 const ctx = canvas.getContext('2d')
 if (!ctx) throw new Error('Canvas not supported')
 // White background to preserve transparent PNG visibility against any bg
 ctx.fillStyle = '#ffffff'
 ctx.fillRect(0, 0, w, h)
 ctx.drawImage(img, 0, 0, w, h)

 logoDataUrl = canvas.toDataURL('image/jpeg', JPEG_QUALITY)
 if (logoPreview) logoPreview.src = logoDataUrl
 logoPreviewWrap?.classList.remove('hidden')
 logoPreviewWrap?.classList.add('flex')
 logoClear?.classList.remove('hidden')
 if (logoLabel) logoLabel.textContent = file.name.length > 32 ? file.name.slice(0, 29) + '…' : file.name

 // Approximate URL impact
 const sizeKb = Math.round(logoDataUrl.length / 1024)
 setLogoStatus(`Resized to ${w}×${h} · ~${sizeKb}KB`)
 } catch (err) {
 console.error('[demo] logo processing failed:', err)
 setLogoStatus(`Error: ${err instanceof Error ? err.message : 'could not read image'}`, true)
 clearLogo()
 } finally {
 URL.revokeObjectURL(url)
 }
 }

 logoInput?.addEventListener('change', async (e) => {
 const file = (e.target as HTMLInputElement).files?.[0]
 console.log('[demo] file picked:', file?.name, file?.size, file?.type)
 if (file) await processLogoFile(file)
 })
 logoClear?.addEventListener('click', clearLogo)

 function encodeSlug(payload: object): string {
 const json = JSON.stringify(payload)
 return btoa(unescape(encodeURIComponent(json)))
.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '')
 }

 form?.addEventListener('submit', async (e) => {
 e.preventDefault()
 if (!form.checkValidity()) { form.reportValidity(); return }
 if (submitBtn) submitBtn.disabled = true
 if (submitLabel) submitLabel.textContent = 'Building your store…'

 const fd = new FormData(form)
 const payload = {
 v: 1,
 createdAt: new Date().toISOString(),
 lead: {
 company: String(fd.get('company') || '').trim(),
 contact: String(fd.get('contact') || '').trim(),
 email: String(fd.get('email') || '').trim(),
 phone: String(fd.get('phone') || '').trim() || null,
 trade: String(fd.get('trade') || '').trim(),
 crewSize: fd.get('crewSize') ? Number(fd.get('crewSize')) : null,
 logoDataUrl, // null if user didn't upload one
 },
 }
 const slug = encodeSlug(payload)
 const finalUrl = `/preview/?s=${slug}`
 console.log('[demo] submit URL length:', finalUrl.length, '· logo present:', !!logoDataUrl)

 // Sync the lead to GHL before showing the preview. Logo is intentionally
 // omitted from the GHL payload (too large; it lives in the preview URL).
 // Await briefly, but never trap the user's preview on a CRM hiccup.
 try {
 await fetch('/api/demo-optin', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify({
 company: payload.lead.company,
 contact: payload.lead.contact,
 email: payload.lead.email,
 phone: payload.lead.phone,
 trade: payload.lead.trade,
 crewSize: payload.lead.crewSize,
 sourceUrl: window.location.href,
 'cf-turnstile-response': (form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | null)?.value || '',
 }),
 signal: AbortSignal.timeout(8000),
 })
 } catch (err) {
 console.warn('[demo] GHL sync failed (non-fatal):', err)
 }

 window.location.href = finalUrl
 })
</script>
