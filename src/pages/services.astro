---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Picture } from 'astro:assets'
import productStack from '@/assets/generated/product-stack.jpg'

const services = [
 {
 name: 'Screen Printing',
 serviceType: 'Screen printing for construction branded apparel',
 description: 'Multi-color screen printing on tees, hi-vis vests, hoodies, and workwear. Plastisol and water-based inks. PMS color matching. 24-piece minimums. Rush options available.',
 },
 {
 name: 'Embroidery',
 serviceType: 'Embroidery for construction uniforms, polos, headwear',
 description: 'Commercial embroidery on polos, softshells, hats, beanies, and bags. on first order. Up to 15 thread colors per design. 12-piece minimums for most garments, no minimum for caps.',
 },
 {
 name: 'Branded Apparel',
 serviceType: 'Branded workwear & uniforms for Las Vegas trades',
 description: 'Full uniform programs for construction and trades: hi-vis ANSI Class 2/3, FR-rated shirts (NFPA 70E CAT 1/2), polos, jackets, hard hats, beanies. Sourced from Carhartt, Port Authority, Red Kap, Bulwark, ML Kishigo, and other trade-trusted brands.',
 },
 {
 name: 'Company Stores',
 serviceType: 'Private branded apparel store for contractors',
 description: 'Custom online storefront where each crew member orders their own gear on a per-employee credit or company-paid budget. Print-on-demand or stocked inventory. Ship to office, job site, or employee home. No platform or per-seat fees.',
 },
 {
 name: 'Promotional Products',
 serviceType: 'Branded promotional products & corporate gifts',
 description: 'Drinkware, safety gear, tech accessories, tote bags, awards, and trade show giveaways. 1M+ product catalog, branded to your specs. Ideal for client gifts, crew appreciation, open-house events, and networking.',
 },
]

const faqs = [
 {
 q: 'What services does Bighorn Threads offer?',
 a: 'Five services for Vegas construction crews: screen printing, embroidery, branded workwear programs, company stores, and promotional products. One partner, local production, files held on our end for matching reorders.',
 },
 {
 q: 'What’s the minimum order?',
 a: '24 pieces for screen printing and 12 for embroidery. Most promotional products and company-store items have no minimum. Setup fees waived on qualifying first orders — ask when you quote.',
 },
 {
 q: 'How fast can you turn around a rush job?',
 a: 'Rush options are available on screen print and embroidery. Tell us your deadline up front and we’ll tell you straight if we can hit it before you commit.',
 },
 {
 q: 'Do you handle FR-rated and ANSI hi-vis decoration?',
 a: 'Yes. We embroider and screen print on NFPA 70E FR shirts and ANSI/ISEA 107 Class 2 and 3 hi-vis using FR-compatible thread and compliance-safe placement so the rating stays valid.',
 },
 {
 q: 'Should I pick screen printing, embroidery, or DTF?',
 a: 'Embroidery for polos, jackets, and headwear that need to read professional. Screen print for tees, hi-vis, and high-volume crew runs. DTF for full-color artwork on small batches. We’ll spec the right method when you quote.',
 },
 {
 q: 'How does a company store work?',
 a: 'We build a private branded portal with your approved gear and price rules. Crew members log in, pick sizes, and orders ship direct to office, job trailer, or home. No inventory, no platform fee, no per-seat charge.',
 },
]

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@graph': services.map((s, idx) => ({
 '@type': 'Service',
 '@id': `https://bighornthreads.com/services#${s.name.toLowerCase().replace(/\s+/g, '-')}`,
 name: s.name,
 serviceType: s.serviceType,
 description: s.description,
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Boulder City' },
 ],
 audience: {
 '@type': 'BusinessAudience',
 name: 'General contractors, electrical contractors, plumbing companies, HVAC service companies, roofing contractors, and trade businesses',
 },
 })),
}

const arrow = 'M13 7l5 5m0 0l-5 5m5-5H6'
---

<BaseLayout
 title="Screen Printing, Embroidery & Branded Workwear Services — Las Vegas"
 description="Five services for Vegas construction crews: screen printing, embroidery, branded workwear programs, company stores, and promotional products. Local production, in-house art, rush options."
>
 <!-- ════ HERO — full-bleed photographic dark band ════ -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <Picture
 src={productStack}
 alt=""
 aria-hidden="true"
 widths={[768, 1280, 1920]}
 sizes="100vw"
 formats={['avif', 'webp']}
 fallbackFormat="jpg"
 loading="eager"
 fetchpriority="high"
 decoding="async"
 class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
 />
 <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-950 via-navy-950/85 to-navy-950/45"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-16 sm:px-6 sm:pt-20 lg:px-8 lg:pb-28 lg:pt-24">
 <div class="max-w-2xl">
 <p class="kicker mb-5 flex items-center gap-2.5">
 <span class="h-px w-8 bg-gold-500"></span>
 Our Services
 </p>
 <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Screen Printing, Embroidery &amp; <span class="text-gold-400">Branded Gear</span> in Las Vegas
 </h1>
 <p class="mt-7 max-w-xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 One partner, local Vegas production. From a single embroidered hat to outfitting your entire crew — we handle it all.
 </p>
 </div>
 </div>
 </section>

 <!-- ════ ANSWER-FIRST SUMMARY + JUMP LINKS — paper ════ -->
 <section class="border-y border-hairline bg-paper py-14 sm:py-16">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <p class="mb-7 max-w-3xl text-base leading-relaxed text-ash sm:text-lg">
 Bighorn Threads runs five services for Las Vegas construction and trade crews. Pick the one you need — or call and we’ll spec the mix.
 </p>
 <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
 {[
 { href: '#screen-printing', name: 'Screen Printing', detail: 'Tees, hi-vis, hoodies — 24-piece min.' },
 { href: '#embroidery', name: 'Embroidery', detail: 'Polos, jackets, hats — 12-piece min.' },
 { href: '#branded-apparel', name: 'Branded Apparel', detail: 'FR & ANSI hi-vis crew uniforms.' },
 { href: '/company-stores/', name: 'Company Stores', detail: 'Private portals — no platform fees.' },
 { href: '#promotional-products', name: 'Promotional Products', detail: 'Drinkware, swag, client gifts.' },
 ].map((j) => (
 <li>
 <a href={j.href} class="block h-full border border-hairline bg-panel px-4 py-3 transition-colors hover:border-gold-500">
 <span class="block font-heading text-sm font-bold uppercase tracking-tight text-charcoal">{j.name}</span>
 <span class="mt-0.5 block text-xs text-ash">{j.detail}</span>
 </a>
 </li>
 ))}
 </ul>
 <p class="mt-6 max-w-3xl text-sm leading-relaxed text-ash">
 Need help deciding? See how <a href="/services/screen-printing-las-vegas/" class="text-gold-600 hover:underline">screen printing</a>, <a href="/services/embroidery-las-vegas/" class="text-gold-600 hover:underline">embroidery</a>, and <a href="/services/rush-orders-las-vegas/" class="text-gold-600 hover:underline">rush orders</a> stack up — or read the <a href="/blog/screen-printing-vs-embroidery-construction/" class="text-gold-600 hover:underline">screen print vs. embroidery</a> and <a href="/blog/dtf-printing-vs-screen-printing-custom-apparel/" class="text-gold-600 hover:underline">DTF vs. screen print</a> breakdowns.
 </p>
 </div>
 </section>

 <!-- ════ FLAGSHIP: COMPANY STORES — concrete ════ -->
 <section class="bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="border-l-4 border-gold-500 bg-panel">
 <div class="grid gap-0 border border-l-0 border-hairline lg:grid-cols-[1.4fr_1fr]">
 <div class="p-9 sm:p-12">
 <span class="spec mb-4 inline-block bg-gold-500 px-2 py-1 text-charcoal">Flagship Service</span>
 <h2 class="mb-5 font-heading text-3xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-4xl lg:text-5xl">
 Company Stores — <span class="text-gold-600">Private Online Storefronts for Your Crew</span>
 </h2>
 <p class="mb-5 text-lg leading-relaxed text-ash">
 Your team logs into a branded storefront, picks their approved gear at sizes they actually want, and it ships direct. You set the catalog, the budget, and the spending rules. We handle decoration, fulfillment, and reporting.
 </p>
 <p class="mb-8 text-base leading-relaxed text-ash">
 No inventory in your closet. No weekend runs to the shop for the new hire. No more guessing XL vs. 2XL for a crew lead you've never met. Zero monthly platform fee, and setup is free for qualifying crews.
 </p>
 <div class="mb-8 flex flex-wrap gap-2">
 {['Quick launch', 'No monthly fee', 'Per-employee credit', 'Ship anywhere', 'Reports included'].map((tag) => (
 <span class="spec border border-hairline px-2.5 py-1 text-ash">{tag}</span>
 ))}
 </div>
 <div class="flex flex-wrap gap-3">
 <a href="/company-stores/" class="btn-primary text-base">
 How company stores work
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow}/></svg>
 </a>
 <a href="/demo/" class="btn-secondary text-base">
 Request a demo store
 </a>
 </div>
 </div>
 <div class="border-t border-hairline bg-paper p-9 sm:p-12 lg:border-l lg:border-t-0">
 <div class="kicker mb-2">Who it's for</div>
 <h3 class="mb-5 font-heading text-xl font-bold uppercase tracking-tight text-charcoal">Multi-crew contractors &amp; service trades</h3>
 <ul class="space-y-4 text-ash">
 {[
 '50+ employees across multiple job sites',
 'Regular new-hire onboarding that needs a starter kit',
 'Multi-location operations (Vegas, Henderson, regional yards)',
 'Per-employee annual apparel budgets you want to automate',
 ].map((item) => (
 <li class="flex gap-3">
 <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
 <span>{item}</span>
 </li>
 ))}
 </ul>

 <div class="mt-8 border-t border-hairline pt-6">
 <div class="kicker mb-3">Setup steps</div>
 <ul class="space-y-2.5 text-sm text-ash">
 <li class="flex gap-3">
 <span class="w-20 flex-shrink-0 font-mono text-xs font-bold text-gold-600">Kickoff</span>
 <span>Kickoff call + logo files locked in</span>
 </li>
 <li class="flex gap-3">
 <span class="w-20 flex-shrink-0 font-mono text-xs font-bold text-gold-600">Catalog</span>
 <span>Catalog review + negotiated pricing</span>
 </li>
 <li class="flex gap-3">
 <span class="w-20 flex-shrink-0 font-mono text-xs font-bold text-gold-600">QA</span>
 <span>Test order run + QA sign-off</span>
 </li>
 <li class="flex gap-3">
 <span class="w-20 flex-shrink-0 font-mono text-xs font-bold text-gold-600">Launch</span>
 <span>Store live, invite your crew</span>
 </li>
 </ul>
 </div>
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- ════ SCREEN PRINTING — paper ════ -->
 <section id="screen-printing" class="scroll-mt-20 border-y border-hairline bg-paper py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid items-start gap-12 lg:grid-cols-2">
 <div>
 <div class="mb-4 flex h-14 w-14 items-center justify-center bg-gold-500/15 text-gold-700">
 <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
 <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-8.25 0h.008v.008H10.5V12z" />
 </svg>
 </div>
 <h2 class="mb-4 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Screen Printing</h2>
 <p class="mb-4 text-lg leading-relaxed text-ash">
 Multi-color screen printing on tees, hi-vis vests, hoodies, and workwear. Bold, opaque prints that survive job-site abuse, industrial laundry cycles, and Nevada sun. Plastisol for punch and water-based for soft-hand crew tees — we pick the ink system that fits the job, not the one that's easiest.
 </p>
 <p class="mb-6 text-base leading-relaxed text-ash">
 PMS color matching on runs of 48+ pieces. Up to 8 ink colors per placement. Large-format back prints, left-chest, pocket, and sleeve hits all available. Specialty inks — metallic, glow-in-the-dark, puff, and high-density — for events, crew-pride orders, or brand activations.
 </p>
 <div class="mb-6 grid grid-cols-3 gap-3">
 <div class="border border-hairline bg-panel p-3">
 <div class="spec text-gold-600">Minimum</div>
 <div class="mt-1 font-heading text-sm font-bold uppercase tracking-tight text-charcoal">24 pieces</div>
 </div>
 <div class="border border-hairline bg-panel p-3">
 <div class="spec text-gold-600">Turnaround</div>
 <div class="mt-1 font-heading text-sm font-bold uppercase tracking-tight text-charcoal">Fast</div>
 </div>
 <div class="border border-hairline bg-panel p-3">
 <div class="spec text-gold-600">Rush</div>
 <div class="mt-1 font-heading text-sm font-bold uppercase tracking-tight text-charcoal">Available</div>
 </div>
 </div>
 <a href="/contact/" class="btn-primary text-sm">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d={arrow} /></svg>
 </a>
 </div>
 <div class="border border-hairline bg-panel p-8">
 <h3 class="kicker mb-5">What's Included</h3>
 <ul class="space-y-3">
 {['Multi-color prints up to 8 colors', 'Plastisol & water-based inks', 'Specialty inks (metallic, glow, puff)', 'Large format back prints', 'Left chest & pocket prints', 'As low as 24-piece minimums'].map((item) => (
 <li class="flex items-center gap-3 text-ash">
 <svg class="h-5 w-5 flex-shrink-0 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
 {item}
 </li>
 ))}
 </ul>
 </div>
 </div>
 </div>
 </section>

 <!-- ════ EMBROIDERY — concrete ════ -->
 <section id="embroidery" class="scroll-mt-20 bg-concrete py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid items-start gap-12 lg:grid-cols-2">
