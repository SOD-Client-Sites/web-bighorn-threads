---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Screen Printing, Embroidery & Branded Apparel Services"
  description="In-house screen printing, embroidery, branded apparel, company stores, and promotional products for Las Vegas construction companies. Fast turnaround, no minimums on most products."
>
  <!-- Hero -->
  <section class="relative border-b border-navy-700/30 bg-navy-900/50 py-20 sm:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_70%_-10%,_rgba(200,150,14,0.08),_transparent)]" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Our Services</span>
      <h1 class="mb-4 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Screen Printing, Embroidery & <span class="text-gold-500">Branded Gear</span> in Las Vegas
      </h1>
      <p class="max-w-2xl text-lg text-navy-300 sm:text-xl">
        One shop. In-house production. Fast turnaround. From a single embroidered hat to outfitting your entire crew — we handle it all.
      </p>
    </div>
  </section>

  <!-- Screen Printing -->
  <section id="screen-printing" class="py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div>
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10">
            <svg class="h-7 w-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-8.25 0h.008v.008H10.5V12z" />
            </svg>
          </div>
          <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Screen Printing</h2>
          <p class="mb-6 text-lg text-navy-300">
            Bold, durable prints that survive the job site. In-house production means fast turnaround and consistent quality every time.
          </p>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-gold-500/10 px-4 py-1.5 text-sm font-medium text-gold-500">
            In-house production — no middleman
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-5 py-3 text-sm font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20">
            Get a Quote
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
        <div class="rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8">
          <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">What's Included</h3>
          <ul class="space-y-3">
            {['Multi-color prints up to 8 colors', 'Plastisol & water-based inks', 'Specialty inks (metallic, glow, puff)', 'Large format back prints', 'Left chest & pocket prints', 'As low as 24-piece minimums'].map((item) => (
              <li class="flex items-center gap-3 text-navy-200">
                <svg class="h-5 w-5 flex-shrink-0 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Embroidery -->
  <section id="embroidery" class="border-y border-navy-700/30 bg-navy-900/30 py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div class="order-2 lg:order-1 rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8">
          <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">What's Included</h3>
          <ul class="space-y-3">
            {['Free logo digitizing on first order', 'Up to 15 thread colors', 'Left chest, sleeves, back placement', 'Hats, beanies & headwear', 'Bags & backpacks', 'No minimum order required'].map((item) => (
              <li class="flex items-center gap-3 text-navy-200">
                <svg class="h-5 w-5 flex-shrink-0 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="order-1 lg:order-2">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10">
            <svg class="h-7 w-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </div>
          <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Embroidery</h2>
          <p class="mb-6 text-lg text-navy-300">
            Professional logo embroidery that looks sharp on polos, jackets, hats, and bags. We handle digitizing so you don't have to.
          </p>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-gold-500/10 px-4 py-1.5 text-sm font-medium text-gold-500">
            Free digitizing on first order
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-5 py-3 text-sm font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20">
            Get a Quote
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Branded Apparel -->
  <section id="branded-apparel" class="py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div>
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10">
            <svg class="h-7 w-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
          </div>
          <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Branded Apparel</h2>
          <p class="mb-6 text-lg text-navy-300">
            From hi-vis tees on the job site to polos at the office — your brand on everything your team wears.
          </p>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-gold-500/10 px-4 py-1.5 text-sm font-medium text-gold-500">
            Most popular with construction crews
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-5 py-3 text-sm font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20">
            Get a Quote
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
        <div class="rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8">
          <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">What's Included</h3>
          <ul class="space-y-3">
            {['T-shirts & tank tops', 'Polos & dress shirts', 'Hoodies & jackets', 'Hi-vis safety wear', 'Hard hats & beanies', 'Work pants & coveralls'].map((item) => (
              <li class="flex items-center gap-3 text-navy-200">
                <svg class="h-5 w-5 flex-shrink-0 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Promotional Products -->
  <section id="promotional-products" class="border-y border-navy-700/30 bg-navy-900/30 py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div class="order-2 lg:order-1 rounded-2xl border border-navy-700/50 bg-navy-800/30 p-8">
          <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-navy-400">What's Included</h3>
          <ul class="space-y-3">
            {['Drinkware & tumblers', 'Tote bags & coolers', 'Pens & office supplies', 'Safety gear & first aid kits', 'Tech accessories', 'Awards & recognition'].map((item) => (
              <li class="flex items-center gap-3 text-navy-200">
                <svg class="h-5 w-5 flex-shrink-0 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="order-1 lg:order-2">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10">
            <svg class="h-7 w-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Promotional Products</h2>
          <p class="mb-6 text-lg text-navy-300">
            Branded swag that gets used, not tossed. Perfect for trade shows, client gifts, and networking events.
          </p>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-gold-500/10 px-4 py-1.5 text-sm font-medium text-gold-500">
            Perfect for trade shows & client gifts
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-5 py-3 text-sm font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20">
            Get a Quote
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_110%,_rgba(200,150,14,0.1),_transparent)]" />
    <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Not Sure What You Need?</h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-navy-300">
        Tell us about your crew and we'll put together a custom recommendation. No pressure, no minimums on most products.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-lg font-bold text-navy-950 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/20 hover:-translate-y-0.5">
        Talk to Us
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </section>
</BaseLayout>
