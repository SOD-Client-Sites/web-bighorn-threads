---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Picture } from 'astro:assets'
import productStack from '@/assets/generated/product-stack.jpg'

const services = [
 {
 name: 'Screen Printing',
 serviceType: 'Screen printing for construction branded apparel',
 description: 'Multi-color screen printing on tees, hi-vis vests, hoodies, and workwear. Plastisol and water-based inks. PMS color matching. 24-piece minimums. Rush options available.',
 },
 {
 name: 'Embroidery',
 serviceType: 'Embroidery for construction uniforms, polos, headwear',
 description: 'Commercial embroidery on polos, softshells, hats, beanies, and bags. on first order. Up to 15 thread colors per design. 12-piece minimums for most garments, no minimum for caps.',
 },
 {
 name: 'Branded Apparel',
 serviceType: 'Branded workwear & uniforms for Las Vegas trades',
 description: 'Full uniform programs for construction and trades: hi-vis ANSI Class 2/3, FR-rated shirts (NFPA 70E CAT 1/2), polos, jackets, hard hats, beanies. Sourced from Carhartt, Port Authority, Red Kap, Bulwark, ML Kishigo, and other trade-trusted brands.',
 },
 {
 name: 'Company Stores',
 serviceType: 'Private branded apparel store for contractors',
 description: 'Custom online storefront where each crew member orders their own gear on a per-employee credit or company-paid budget. Print-on-demand or stocked inventory. Ship to office, job site, or employee home. No platform or per-seat fees.',
 },
 {
 name: 'Promotional Products',
 serviceType: 'Branded promotional products & corporate gifts',
 description: 'Drinkware, safety gear, tech accessories, tote bags, awards, and trade show giveaways. 1M+ product catalog, branded to your specs. Ideal for client gifts, crew appreciation, open-house events, and networking.',
 },
]

const faqs = [
 {
 q: 'What services does Bighorn Threads offer?',
 a: 'Five services for Vegas construction crews: screen printing, embroidery, branded workwear programs, company stores, and promotional products. One partner, local production, files held on our end for matching reorders.',
 },
 {
 q: 'What’s the minimum order?',
 a: '24 pieces for screen printing and 12 for embroidery. Most promotional products and company-store items have no minimum. Setup fees waived on qualifying first orders — ask when you quote.',
 },
 {
 q: 'How fast can you turn around a rush job?',
 a: 'Rush options are available on screen print and embroidery. Tell us your deadline up front and we’ll tell you straight if we can hit it before you commit.',
 },
 {
 q: 'Do you handle FR-rated and ANSI hi-vis decoration?',
 a: 'Yes. We embroider and screen print on NFPA 70E FR shirts and ANSI/ISEA 107 Class 2 and 3 hi-vis using FR-compatible thread and compliance-safe placement so the rating stays valid.',
 },
 {
 q: 'Should I pick screen printing, embroidery, or DTF?',
 a: 'Embroidery for polos, jackets, and headwear that need to read professional. Screen print for tees, hi-vis, and high-volume crew runs. DTF for full-color artwork on small batches. We’ll spec the right method when you quote.',
 },
 {
 q: 'How does a company store work?',
 a: 'We build a private branded portal with your approved gear and price rules. Crew members log in, pick sizes, and orders ship direct to office, job trailer, or home. No inventory, no platform fee, no per-seat charge.',
 },
]

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({
 '@type': 'Question',
 name: f.q,
 acceptedAnswer: { '@type': 'Answer', text: f.a },
 })),
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@graph': services.map((s, idx) => ({
 '@type': 'Service',
 '@id': `https://bighornthreads.com/services#${s.name.toLowerCase().replace(/\s+/g, '-')}`,
 name: s.name,
 serviceType: s.serviceType,
 description: s.description,
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Boulder City' },
 ],
 audience: {
 '@type': 'BusinessAudience',
 name: 'General contractors, electrical contractors, plumbing companies, HVAC service companies, roofing contractors, and trade businesses',
 },
 })),
}
---

<BaseLayout
 title="Screen Printing, Embroidery & Branded Workwear Services — Las Vegas"
