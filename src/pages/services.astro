 <!-- ════ BRANDED APPAREL — paper ════ -->
 <section id="branded-apparel" class="scroll-mt-20 border-y border-hairline bg-paper py-20 sm:py-28">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="grid items-start gap-12 lg:grid-cols-2">
