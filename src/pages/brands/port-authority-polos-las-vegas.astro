---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Port Authority Polos and Embroidery in Las Vegas',
 description:
 'Custom Port Authority polos for Vegas office staff, sales reps, and project managers. Embroidered K500 silk-touch, K420 pique, K540 performance — stocked S–4XL, 6-piece minimum, week-long turnaround.',
 hero: '/images/generated/workwear-flatlay.jpg',
}

const products = [
 { sku: 'K500', name: 'Port Authority Silk Touch Polo', detail: 'The corporate workhorse. Pique knit, anti-snag finish, holds embroidery flat. Stocked S–4XL in core colors.', method: 'Embroidery (left chest, optional sleeve)' },
 { sku: 'K420', name: 'Port Authority Pique Knit Polo', detail: 'Heavier 7 oz pique. The traditional country-club fit for sales reps and PMs who want substance over softness.', method: 'Embroidery (left chest)' },
 { sku: 'K540', name: 'Port Authority Silk Touch Performance Polo', detail: 'Snag-resistant moisture-wicking. For outdoor field staff and trade-show booth crews in Vegas summer.', method: 'Embroidery (left chest)' },
 { sku: 'L500', name: 'Port Authority Ladies Silk Touch Polo', detail: 'Cut for women — the K500 in a tailored silhouette. Same fabric, same color matching, no awkward unisex fit.', method: 'Embroidery (left chest)' },
 { sku: 'K100', name: 'Port Authority Core Classic Pique Polo', detail: 'Budget-friendly entry polo. Used for events, volunteers, and high-volume promotional rollouts.', method: 'Embroidery or screen print (chest)' },
 { sku: 'K8000', name: 'Port Authority EZCotton Polo', detail: 'Soft cotton-poly blend. Premium hand-feel for executive teams and client-facing roles.', method: 'Embroidery (left chest)' },
]

const why = [
 { title: 'Embroiders cleanly every time', body: 'Port Authority pique knit is dense and stable. Logos stay flat — no puckering, no distortion, no thread sinking into the weave. The K500 is what we run when the customer says "make it look corporate."' },
 { title: 'Color matching across SKUs', body: 'Port Authority colors hold across the K500, K420, K540, and L500. Order the men\'s and ladies\' polos at the same time and they actually match — not "close enough" match.' },
 { title: 'Stocked, sized, and ready', body: 'We carry K500 and L500 in adult and ladies S–4XL in the most-ordered corporate colors. New hire ramping up or tradeshow date moved? Tell us your deadline and we\'ll quote a real timeline, with rush options on stocked items.' },
 { title: 'Corporate quality at workwear pricing', body: 'Port Authority gives you a a workwear-priced polo that looks like a high-end golf brand. For 50-person sales teams and trade-show rollouts, the math just works.' },
]

const faqs = [
 {
 q: 'What\'s the minimum order for custom Port Authority polos?',
 a: '6 pieces for embroidery, 24 for screen printing. Most polo orders run embroidery — that\'s the right decoration for the garment and what the corporate look calls for.',
 },
 {
 q: 'How does Port Authority compare to Cutter & Buck or Nike Golf?',
 a: 'Cutter & Buck and Nike Golf carry brand cachet and are 2–3x the cost. Port Authority gives you the same corporate look and fit at a price that works for 50-person rollouts. Use the premium brands for executive teams; use Port Authority for the broader org.',
 },
 {
 q: 'What\'s the difference between K500, K420, and K540?',
 a: 'K500 is the silk-touch — soft hand, mid-weight, the most popular for office staff. K420 is heavier 7 oz pique with a more traditional fit, better for outdoor wear and PMs. K540 is the performance version — moisture-wicking, snag-resistant, for trade shows and field reps in the Vegas heat.',
 },
 {
 q: 'Can you match women\'s and men\'s polo colors for a mixed team?',
 a: 'Yes. The L500 ladies polo color-matches the K500 men\'s polo across all core colors. Same dye lot reliability when ordered together. We also offer the L420 and L540 for the K420/K540 equivalents.',
 },
 {
 q: 'Do you keep Port Authority in stock or order each time?',
 a: 'We stock K500 and L500 in adult and ladies S–4XL in core colors (navy, black, white, royal, red, charcoal). Other colors and SKUs are special order at fast.',
 },
 {
 q: 'Can you set up a Port Authority company store for a sales team?',
 a: 'Yes — that\'s one of our most common stores. Approved Port Authority SKUs, your logo locked in, men\'s + ladies versions, optional name personalization. Reps order what they need, you set the budget. See company stores for the full setup.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://bighornthreads.com/brands/' },
 { '@type': 'ListItem', position: 3, name: 'Port Authority', item: 'https://bighornthreads.com/brands/port-authority-polos-las-vegas/' },
 ],
}

const productSchema = {
 '@context': 'https://schema.org',
 '@type': 'Product',
 name: 'Custom Port Authority Polos — Las Vegas',
 description: page.description,
 brand: { '@type': 'Brand', name: 'Port Authority' },
 manufacturer: { '@type': 'Organization', name: 'Port Authority' },
 offers: {
 '@type': 'AggregateOffer',
 priceCurrency: 'USD',
 lowPrice: 18,
 highPrice: 55,
 offerCount: products.length,
 seller: { '@id': 'https://bighornthreads.com/#organization' },
 },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/brands/port-authority-polos-las-vegas/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-16 sm:px-6 sm:pb-28 sm:pt-16 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-navy-400">Brands</span>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Port Authority</span>
 </nav>

 <p class="kicker mb-3">Brand</p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Custom Port Authority Polos <span class="text-gold-400">for Vegas Sales Teams and Office Staff.</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 Embroidered K500 silk-touch. K420 pique for the traditional fit. K540 performance for trade shows and field reps. Stocked S–4XL in core corporate colors — week-long turnaround, color-matched men's and ladies' versions.
 </p>

 <div class="mt-10 flex flex-wrap items-center gap-3">
 <a href="/contact/" class="btn-primary text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 702.904.8923
 </a>
 </div>
 </div>
 </section>

 <!-- Why Port Authority — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Why Port Authority</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Four reasons it's the <span class="text-gold-600">corporate-polo default.</span></h2>
 </div>

 <div class="grid gap-5 md:grid-cols-2">
 {why.map((w) => (
 <div class="border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal">{w.title}</h3>
 <p class="text-base leading-relaxed text-ash">{w.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Deep dive — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">The Buyer's Guide</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase leading-tight tracking-tight text-charcoal sm:text-4xl">
 Why Port Authority is the default polo for Las Vegas project teams and office staff.
 </h2>

 <div class="space-y-5 text-lg leading-relaxed text-ash">
 <p>
 Port Authority is the workhorse polo brand for Las Vegas construction, professional services, and trade companies — not because it's flashy, but because the catalog is deep, the sizing runs true, the colorways are consistent year over year, and the decoration takes embroidery cleanly without the placket distortion you get on cheaper imports. For project managers, estimators, superintendents, office staff, and any role that needs to look professional without changing out of jobsite clothes, Port Authority is the spec.
 </p>
 <p>
 The K500 Silk Touch Polo is the bestseller — a 5-oz pique cotton-poly blend that hits the right balance between professional appearance and durability. We embroider tens of thousands of K500s per year for Vegas contractors, real estate developers, fleet companies, and trade associations. It's the polo you put on a new hire when they start, on the project manager attending a client meeting, and on the office team at a trade show. Standard left-chest logo placement is included; sleeve hits, back yokes, and pocket polos are all available.
 </p>
 <p>
 For outdoor field work in Vegas summer, the K540 Silk Touch Performance Polo is the right swap — same cut as the K500 but in a moisture-wicking, snag-resistant performance fabric. Crews working in 110° July heat keep performance polos on through the day; standard cotton polos get pulled off by 11am. The K455 Rapid Dry Polo is the lightweight option for trades that work in direct sun all day. We carry all three and we'll quote both options on every polo request so you can decide by season.
 </p>
 <p>
 For trade shows, client gifts, and milestone events, the K557 Heritage Pique Polo and the K567 9-Ounce Heavyweight Cotton Polo are the premium picks — heavier weight, sharper drape, and a more upscale feel. The K100 Core Classic Pique Polo is the budget pick when you need to outfit a large crew on a project rollout without blowing the apparel budget. Same fit family across the line, so sizing chart conversions are clean.
 </p>
 <p>
 What makes Port Authority programs work in the long term is sizing consistency. A medium in 2018 fits like a medium in 2026, which means reorders for replacement shirts after washing or wear-out don't require a new sizing audit. We keep your size matrix on file with employee names and re-quote reorders fast. For larger teams, the company-store program lets you preload approved Port Authority SKUs with employee names already digitized so new hires get their first three shirts when they start.
 </p>
 <p>
 For alternatives + comparisons see <a href="/blog/port-authority-polos-vs-alternatives/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Port Authority polos vs alternatives</a>. For a broader buyer's guide, see <a href="/blog/custom-polo-shirts-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">Las Vegas custom polo shirts</a>.
 </p>
 </div>
 </div>
 </section>

 <!-- Products — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Most-Ordered</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">The Port Authority polos we run <span class="text-gold-600">every week.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 We stock the SKUs Vegas sales teams and corporate offices reorder. Other Port Authority items (woven shirts, jackets, headwear) we order in to match your spec.
 </p>
 </div>

 <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
 {products.map((p) => (
 <div class="border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <div class="mb-3 flex items-center justify-between">
 <span class="spec text-gold-600">{p.sku}</span>
 </div>
 <h3 class="mb-2 font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{p.name}</h3>
 <p class="mb-4 text-sm leading-relaxed text-ash">{p.detail}</p>
 <div class="mt-4 border-t border-hairline pt-3">
 <span class="spec text-gold-600">Decoration</span>
 <p class="mt-1 text-sm text-charcoal">{p.method}</p>
 </div>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- vs Premium Polo Brands — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">vs Cutter &amp; Buck / Nike Golf</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Where Port Authority wins for team rollouts.</h2>

 <div class="overflow-hidden border border-hairline bg-panel">
 <table class="w-full">
 <thead class="bg-concrete">
 <tr class="border-b border-hairline">
 <th class="px-5 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-ash">&nbsp;</th>
 <th class="px-5 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-ash">Cutter &amp; Buck / Nike Golf</th>
 <th class="px-5 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-gold-600">Port Authority</th>
 </tr>
 </thead>
 <tbody class="divide-y divide-hairline">
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Per-piece cost (decorated)</td><td class="px-5 py-4 text-sm text-ash">Premium tier</td><td class="px-5 py-4 text-sm text-charcoal">Workwear tier</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Minimum order</td><td class="px-5 py-4 text-sm text-ash">12+ pieces</td><td class="px-5 py-4 text-sm text-charcoal">6 (embroidery)</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Lead time</td><td class="px-5 py-4 text-sm text-ash">Slower</td><td class="px-5 py-4 text-sm text-charcoal">Fast, with rush options on stock</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Men's + ladies' color match</td><td class="px-5 py-4 text-sm text-ash">Inconsistent</td><td class="px-5 py-4 text-sm text-charcoal">Reliable across SKUs</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Embroidery quality on garment</td><td class="px-5 py-4 text-sm text-ash">Excellent</td><td class="px-5 py-4 text-sm text-charcoal">Excellent — pique stable</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Best fit for</td><td class="px-5 py-4 text-sm text-ash">Executive teams, client gifts</td><td class="px-5 py-4 text-sm text-charcoal">Sales orgs, full-staff rollouts</td></tr>
 </tbody>
 </table>
 </div>
 </div>
 </section>

 <!-- FAQs — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Port Authority customization questions.</h2>

