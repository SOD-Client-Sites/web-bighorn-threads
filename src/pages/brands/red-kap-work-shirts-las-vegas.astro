 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Stain-release fabric</td><td class="px-5 py-4 text-sm text-ash">Some SKUs</td><td class="px-5 py-4 text-sm text-charcoal">Standard on SP14, SC30</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Wash cycles before retirement</td><td class="px-5 py-4 text-sm text-ash">~75–100</td><td class="px-5 py-4 text-sm text-charcoal">200+</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Name patch workflow</td><td class="px-5 py-4 text-sm text-ash">Add-on</td><td class="px-5 py-4 text-sm text-charcoal">Standard, on file forever</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Coverall + jacket coverage</td><td class="px-5 py-4 text-sm text-ash">Limited</td><td class="px-5 py-4 text-sm text-charcoal">Full line (CS10, JT22, SY24)</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Lead time on stocked items</td><td class="px-5 py-4 text-sm text-ash">2–3 weeks</td><td class="px-5 py-4 text-sm text-charcoal">Quoted up front — rush options available</td></tr>
 </tbody>
 </table>
 </div>
 </div>
 </section>

 <!-- FAQs — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Red Kap customization questions.</h2>

 <div class="divide-y divide-hairline border-y border-hairline">
 {faqs.map((f) => (
 <details class="group">
 <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
 <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{f.q}</h3>
 <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
 </summary>
