---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Carhartt Embroidery and Printing in Las Vegas',
 description:
 'Custom Carhartt for Las Vegas contractors. Embroidered Carhartt polos, screen-printed K87 tees, branded SUP01 hoodies, FR Carhartt for electrical. 6-piece embroidery minimum.',
 hero: '/images/generated/workwear-flatlay.jpg',
}

const products = [
 { sku: 'K87', name: 'Carhartt Workwear Pocket T-Shirt', detail: 'The crew workhorse. Cotton, durable, takes screen printing beautifully. Stocked S–4XL.', method: 'Screen print preferred (full back or chest)' },
 { sku: 'K84', name: 'Carhartt Force Cotton Long-Sleeve T-Shirt', detail: 'Moisture-wicking long-sleeve for sun protection. Best for outdoor crews.', method: 'Screen print or embroidery (chest)' },
 { sku: 'K500', name: 'Carhartt Workwear Pique Polo', detail: 'Customer-facing roles. Embroidered logo + name. Holds up wash after wash.', method: 'Embroidery (left chest, optional sleeve)' },
 { sku: 'SUP01', name: 'Carhartt Sweater Knit Pullover', detail: 'Heavyweight quarter-zip. Premium look for ops, sales, project managers.', method: 'Embroidery (left chest)' },
 { sku: 'CTK122', name: 'Carhartt Loose Fit Heavyweight Hoodie', detail: 'The go-to crew hoodie for 5 AM Vegas job-site starts.', method: 'Screen print or embroidery (chest, sleeve)' },
 { sku: 'FRSH13', name: 'Carhartt FR Force Henley', detail: 'NFPA 70E compliant. CAT 2 rated. For electrical and oil-and-gas crews.', method: 'FR-safe embroidery only' },
]

const why = [
 { title: 'Recognized brand on the jobsite', body: 'A Carhartt logo on a polo or hoodie reads as quality before a single stitch goes in. Customers and subs see Carhartt and assume the company invested in real gear.' },
 { title: 'Built for what crews actually do', body: 'Reinforced seams, heavier fabrics, deeper pockets. Not athleisure with a logo — workwear designed for daily abuse.' },
 { title: 'Holds decoration well', body: 'Carhartt cotton takes screen printing crisply. The Pique knit on K500 polos embroiders cleanly without distortion. We dial the press for each garment.' },
 { title: 'Stocked, sized, and available', body: 'We carry Carhartt K87, K84, K500, SUP01, and CTK122 in adult S–4XL. Stocked items move quickly from artwork approval, with rush options when timelines are tight.' },
]

const faqs = [
 {
 q: 'What\'s the minimum order for custom Carhartt?',
 a: '6 pieces for embroidery, 24 for screen printing. We can do smaller embroidery runs at a per-piece premium for one-off promo or sample orders.',
 },
 {
 q: 'How is your pricing compared to Carhartt Company Gear (their direct site)?',
 a: 'Carhartt Company Gear has a higher minimum (typically 12+) and longer lead times (3–4 weeks). Local sourcing has its own advantages — pickup, in-person proofs, and direct access to stocked items.',
 },
 {
 q: 'Can you embroider on Carhartt FR (flame-resistant) shirts without voiding the rating?',
 a: 'Yes — using FR-compatible thread (Nomex or aramid blend) and following Carhartt\'s placement spec for the FRSH13 and FR shirt line. We verify the spec sheet before each FR run.',
 },
 {
 q: 'What Carhartt items do you keep in stock?',
 a: 'K87 t-shirts, K84 long-sleeves, K500 polos, SUP01 quarter-zips, and CTK122 hoodies — all in adult sizes S–4XL, in the most-ordered colors. Other Carhartt items (FR, jackets, bibs, boots) we order in for your project.',
 },
 {
 q: 'How fast can you turn around a Carhartt order?',
 a: 'Stocked items move faster than special-order garments (specific colors, FR, jackets). Tell us the SKU, quantity, and deadline and we\'ll quote a real timeline — including rush options if you need one.',
 },
 {
 q: 'Do you set up Carhartt company stores?',
 a: 'Yes. We build private branded stores stocked with your approved Carhartt items, decoration on file, and per-employee allowances if you want them. See company stores for the full breakdown.',
 },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://bighornthreads.com/brands/' },
 { '@type': 'ListItem', position: 3, name: 'Carhartt', item: 'https://bighornthreads.com/brands/carhartt-custom-las-vegas/' },
 ],
}

const productSchema = {
 '@context': 'https://schema.org',
 '@type': 'Product',
 name: 'Custom Carhartt Apparel — Las Vegas',
 description: page.description,
 brand: { '@type': 'Brand', name: 'Carhartt' },
 manufacturer: { '@type': 'Organization', name: 'Carhartt' },
 offers: {
 '@type': 'AggregateOffer',
 priceCurrency: 'USD',
 lowPrice: 18,
 highPrice: 95,
 offerCount: products.length,
 seller: { '@id': 'https://bighornthreads.com/#organization' },
 },
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical="https://bighornthreads.com/brands/carhartt-custom-las-vegas/"
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src={page.hero} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>

 <div class="mx-auto max-w-7xl px-4 pb-20 pt-16 sm:px-6 sm:pb-28 sm:pt-16 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-navy-400">Brands</span>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Carhartt</span>
 </nav>

 <p class="kicker mb-3">Brand</p>
 <h1 class="mb-6 max-w-4xl font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-6xl">
 Custom Carhartt <span class="text-gold-400">for Vegas Crews That Actually Work.</span>
 </h1>
 <p class="max-w-2xl text-lg leading-relaxed text-navy-200 sm:text-xl">
 Embroidered K500 polos. Screen-printed K87 tees. Branded SUP01 quarter-zips for ops. FR Henleys for electrical. We stock the items Vegas contractors reorder — local production, week-long turnaround.
 </p>

 <div class="mt-10 flex flex-wrap items-center gap-3">
 <a href="/contact/" class="btn-primary text-base">
 Get a Quote
 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
 </a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-sm font-medium tracking-wide text-white transition-colors hover:text-gold-400">
 702.904.8923
 </a>
 </div>
 </div>
 </section>

 <!-- Why Carhartt — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Why Carhartt</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">Four reasons crews ask for it <span class="text-gold-600">by name.</span></h2>
 </div>

 <div class="grid gap-5 md:grid-cols-2">
 {why.map((w) => (
 <div class="border border-hairline bg-panel p-7 transition-colors hover:border-gold-500">
 <h3 class="mb-3 font-heading text-xl font-bold uppercase leading-tight tracking-tight text-charcoal">{w.title}</h3>
 <p class="text-base leading-relaxed text-ash">{w.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- Deep dive — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">The Buyer's Guide</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase leading-tight tracking-tight text-charcoal sm:text-4xl">
 Why Las Vegas contractors put Carhartt on every crew, every season.
 </h2>

 <div class="space-y-5 text-lg leading-relaxed text-ash">
 <p>
 Carhartt is the most-recognized workwear brand in American construction, and there's a real reason it's the default spec for Las Vegas general contractors, framers, concrete crews, MEP subs, and service trades: the brand recognition itself does branding work for you. A crew showing up to a project kickoff in embroidered Carhartt looks like a professional outfit, not a startup with cheap promo tees. That perception matters when you're walking a client through a punch list or shaking hands with a developer at a pre-bid.
 </p>
 <p>
 The K87 Loose Fit Heavyweight Pocket Tee is the workhorse of the catalog — heavyweight 6.75 oz cotton, reinforced double-needle stitching, and a left-chest pocket sized for a phone or a pencil. It's the right answer for any crew that wants a durable everyday tee with embroidery or screen-print decoration. We stock it in the colorways that move (heather gray, black, navy, brown) and we batch orders so a 50-shirt rollout for a new framing crew gets the same per-piece price as a 200-shirt order.
 </p>
 <p>
 For project managers, superintendents, and client-facing staff, the Carhartt Workwear Pocket Polo is the Vegas standard — pique cotton with a left-chest pocket, embroidered with a logo and (optionally) the employee's name. It looks sharp at a kickoff meeting and survives an actual jobsite walkthrough afterward. The Force Series moisture-wicking polo is the lighter-weight alternative for crews that work in direct sun or want a performance-fabric option for summer.
 </p>
 <p>
 Cold-weather coverage — and Vegas does get cold mornings from November through March — comes from the Carhartt Duck Active Jacket, the Pullover Hoodie, and the Force Insulated Vest. All take embroidery cleanly on the left chest, back yoke, or sleeve. The Insulated Vest is the most-ordered piece for crew leads who want layering without bulk. For caps, the Acrylic Watch Hat (beanie) and the FastDry Logo Cap cover concrete crews through office staff with a single brand voice.
 </p>
 <p>
 What separates a good Carhartt program from a bad one is decoration consistency. We keep your logo file, your approved placement spec, and your thread color on file forever — so your fifth reorder looks identical to your first. No "we lost the artwork" calls, no inconsistent logo sizes between summer and winter rollouts. For larger crews, we set up a company store with the Carhartt SKUs you've approved, employee size profiles, and a simple ordering interface that bypasses your HR team for individual orders.
 </p>
 <p>
 Learn how we <a href="/blog/carhartt-custom-embroidery-las-vegas/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">custom-embroider Carhartt for Las Vegas crews</a>. Embroidery vs DTF on Carhartt — see <a href="/blog/dtf-printing-vs-screen-printing-custom-apparel/" class="text-gold-600 underline decoration-gold-500/40 underline-offset-4 hover:decoration-gold-500">DTF printing vs screen printing</a>.
 </p>
 </div>
 </div>
 </section>

 <!-- Products — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="mb-12 max-w-2xl">
 <p class="kicker mb-3">Most-Ordered</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">The Carhartt items we run <span class="text-gold-600">every week.</span></h2>
 <p class="mt-4 text-lg leading-relaxed text-ash">
 We stock the SKUs Vegas contractors actually reorder. Other Carhartt items (jackets, bibs, FR specialty) we order in to match your project specs.
 </p>
 </div>

 <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
 {products.map((p) => (
 <div class="border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <div class="mb-3 flex items-center justify-between">
 <span class="spec text-gold-600">{p.sku}</span>
 </div>
 <h3 class="mb-2 font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{p.name}</h3>
 <p class="mb-4 text-sm leading-relaxed text-ash">{p.detail}</p>
 <div class="mt-4 border-t border-hairline pt-3">
 <span class="spec text-gold-600">Decoration</span>
 <p class="mt-1 text-sm text-charcoal">{p.method}</p>
 </div>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- vs Carhartt Direct — paper -->
 <section class="border-y border-hairline bg-paper py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">vs Carhartt Company Gear</p>
 <h2 class="mb-8 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Why local beats Carhartt's direct portal for most contractors.</h2>

 <div class="overflow-hidden border border-hairline bg-panel">
 <table class="w-full">
 <thead class="bg-concrete">
 <tr class="border-b border-hairline">
 <th class="px-5 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-ash">&nbsp;</th>
 <th class="px-5 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-ash">Carhartt Direct</th>
 <th class="px-5 py-4 text-left font-mono text-xs font-bold uppercase tracking-wider text-gold-600">Bighorn Threads</th>
 </tr>
 </thead>
 <tbody class="divide-y divide-hairline">
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Minimum order</td><td class="px-5 py-4 text-sm text-ash">12 pieces</td><td class="px-5 py-4 text-sm text-charcoal">6 (embroidery), 24 (print)</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Lead time</td><td class="px-5 py-4 text-sm text-ash">3–4 weeks</td><td class="px-5 py-4 text-sm text-charcoal">Quoted up front, rush options available</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Local delivery</td><td class="px-5 py-4 text-sm text-ash">No</td><td class="px-5 py-4 text-sm text-charcoal">Local Las Vegas delivery available</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">FR-safe decoration</td><td class="px-5 py-4 text-sm text-ash">Limited</td><td class="px-5 py-4 text-sm text-charcoal">Yes — verified per garment</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Reorder file storage</td><td class="px-5 py-4 text-sm text-ash">Account-based</td><td class="px-5 py-4 text-sm text-charcoal">On file forever, no re-setup</td></tr>
 <tr><td class="px-5 py-4 font-mono text-xs uppercase tracking-wider text-ash">Talk to a human</td><td class="px-5 py-4 text-sm text-ash">Ticket queue</td><td class="px-5 py-4 text-sm text-charcoal">Direct phone line</td></tr>
 </tbody>
 </table>
 </div>
 </div>
 </section>

 <!-- FAQs — concrete -->
 <section class="bg-concrete py-20 sm:py-24">
 <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-3">FAQ</p>
 <h2 class="mb-12 font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal sm:text-4xl">Carhartt customization questions.</h2>

 <div class="divide-y divide-hairline border-y border-hairline">
 {faqs.map((f) => (
 <details class="group">
 <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
 <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-charcoal">{f.q}</h3>
 <svg class="h-5 w-5 shrink-0 text-gold-600 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
 </summary>
 <p class="pb-5 text-base leading-relaxed text-ash">{f.a}</p>
 </details>
 ))}
 </div>
 </div>
 </section>

 <!-- Related — paper -->
 <section class="border-y border-hairline bg-paper py-16">
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <p class="kicker mb-6">Related</p>
 <div class="grid gap-5 md:grid-cols-3">
 <a href="/services/embroidery-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Embroidery</h3>
 <p class="mt-2 text-sm text-ash">Best decoration method for Carhartt polos and outerwear.</p>
 </a>
 <a href="/industries/electrical-contractors-las-vegas/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Carhartt FR for Electrical</h3>
 <p class="mt-2 text-sm text-ash">NFPA 70E compliant Carhartt FR with FR-safe stitching.</p>
 </a>
 <a href="/company-stores/" class="group border border-hairline bg-panel p-6 transition-colors hover:border-gold-500">
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal group-hover:text-gold-600">Carhartt Company Stores</h3>
 <p class="mt-2 text-sm text-ash">Private portals stocked with your approved Carhartt items.</p>
 </a>
 </div>
 </div>
 </section>

 <!-- CTA — full-bleed photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/cta-bluehour.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/80"></div>
 <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
 <h2 class="mb-4 font-heading text-3xl font-extrabold uppercase tracking-tight text-white sm:text-4xl">Quote on custom Carhartt <span class="text-gold-400">fast.</span></h2>
 <p class="mb-8 text-lg text-navy-200">Stocked items ship in a week. Talk to a real human.</p>
 <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
 <a href="/get-a-quote/" class="btn-primary text-base">Get a Free Quote</a>
 <a href="tel:+17029048923" class="inline-flex items-center gap-2 px-2 py-3 font-mono text-base font-medium tracking-wide text-white transition-colors hover:text-gold-400">702.904.8923</a>
 </div>
 </div>
 </section>
</BaseLayout>
