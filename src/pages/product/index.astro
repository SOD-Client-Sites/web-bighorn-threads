---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Product Details — Bighorn Threads"
  description="Branded apparel and promotional product details from Bighorn Threads — Las Vegas custom decoration for construction, trades, and industrial crews."
  canonical="https://bighornthreads.com/product/"
  noindex={true}
>
  <section class="border-b border-navy-800/40 bg-navy-950 pt-20 pb-6 sm:pt-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav id="pdp-breadcrumb" class="font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/catalog/" class="hover:text-gold-400">Catalog</a>
      </nav>
    </div>
  </section>

  <section class="bg-navy-950 py-8 sm:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div id="pdp-loading" class="rounded-xl border border-navy-800/60 bg-navy-900/40 p-16 text-center">
        <svg class="mx-auto mb-4 h-6 w-6 animate-spin text-gold-500" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
        <p class="text-sm text-gray-400">Loading product…</p>
      </div>

      <div id="pdp-error" class="hidden rounded-xl border border-red-500/40 bg-red-500/5 p-10 text-center">
        <p class="font-heading text-lg text-white">We couldn't load this product.</p>
        <p class="mt-2 text-sm text-gray-400">It may have been discontinued or the link is invalid.</p>
        <a href="/catalog/" class="mt-5 inline-block font-mono text-xs font-bold uppercase tracking-[0.2em] text-gold-500 hover:text-gold-400">← Back to catalog</a>
      </div>

      <div id="pdp-content" class="hidden"></div>
    </div>
  </section>

  <script type="module" src="/scripts/product-detail.js"></script>
</BaseLayout>
