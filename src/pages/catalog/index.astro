---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SearchBar from '@/components/SearchBar.astro'
import { bighornCategories } from '@/data/sage-categories'
---

<BaseLayout
 title="Catalog — Branded Apparel & Promotional Products for Teams | Bighorn Threads"
 description="Browse a huge catalog of branded apparel and promotional products. Polos, caps, drinkware, embroidery, hi-vis, FR, and workwear custom-decorated for teams across Las Vegas and nationwide."
 canonical="https://bighornthreads.com/catalog/"
>
 <!-- Hero — compact photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/workwear-flatlay.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="eager" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/85"></div>
 <div class="mx-auto max-w-6xl px-4 pb-12 pt-16 sm:px-6 sm:pb-16 sm:pt-20 lg:px-8">
 <nav class="mb-5 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">Catalog</span>
 </nav>
 <p class="kicker mb-3">Catalog · Real-Time</p>
 <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl">
 Branded apparel &amp; gear for the crews that <span class="text-gold-400">build Las Vegas.</span>
 </h1>
 <p class="mt-4 max-w-2xl text-base leading-relaxed text-navy-200 sm:text-lg">
 1.7 million products, filtered to what actually works on a jobsite. Search by keyword or browse by category. Pricing and availability update live.
 </p>
 <div class="mt-7 max-w-2xl">
 <SearchBar size="lg" action="/catalog/search/" />
 </div>
 </div>
 </section>

 <!-- Browse by Category — concrete -->
 <section class="bg-concrete py-16 sm:py-20">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <div class="mb-8">
 <p class="kicker mb-2">Browse by Category</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight">Curated for construction &amp; trades.</h2>
 </div>
 <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
 {bighornCategories.map((cat) => (
 <a
 href={`/catalog/${cat.slug}/`}
 class="group flex flex-col border border-hairline bg-panel p-6 transition-colors hover:border-gold-500"
 >
 <h3 class="font-heading text-lg font-bold uppercase tracking-tight text-charcoal transition-colors group-hover:text-gold-600">{cat.title}</h3>
 <p class="mt-2 line-clamp-2 flex-1 text-sm leading-relaxed text-ash">{cat.blurb}</p>
 <span class="spec mt-4 inline-flex items-center gap-1.5 text-gold-600">
 Browse {cat.shortTitle}
 <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
 </span>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Featured — paper -->
 <section class="border-t border-hairline bg-paper py-16 sm:py-20">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <div class="mb-7">
 <p class="kicker mb-2">Featured Picks</p>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight">Popular with Las Vegas contractors right now.</h2>
 </div>
 <div id="featured-grid" class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
 <div class="col-span-full flex items-center justify-center py-12 text-sm text-ash">
 <svg class="mr-3 h-4 w-4 animate-spin text-gold-500" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
 Loading featured products…
 </div>
 </div>
 </div>
 </section>

 <script type="module" src="/scripts/catalog-home.js"></script>
</BaseLayout>
