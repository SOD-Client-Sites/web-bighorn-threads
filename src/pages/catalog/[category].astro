---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SearchBar from '@/components/SearchBar.astro'
import { bighornCategories, findCategory } from '@/data/sage-categories'

export function getStaticPaths() {
 return bighornCategories.map((c) => ({ params: { category: c.slug }, props: { category: c } }))
}

const { category } = Astro.props as { category: ReturnType<typeof findCategory> }

if (!category) {
 return Astro.redirect('/catalog/', 302)
}

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Catalog', item: 'https://bighornthreads.com/catalog/' },
 { '@type': 'ListItem', position: 3, name: category.title, item: `https://bighornthreads.com/catalog/${category.slug}/` },
 ],
}

const related = bighornCategories.filter((c) => c.slug !== category.slug).slice(0, 6)

const sortVal = category.sort || 'BESTMATCH'
---

<BaseLayout
 title={`${category.title} — Custom Branded for Teams | Bighorn Threads`}
 description={`${category.blurb} Browse live catalog with real pricing and decoration options.`}
 canonical={`https://bighornthreads.com/catalog/${category.slug}/`}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

 <!-- Hero — compact photographic dark band -->
 <section class="relative isolate overflow-hidden bg-navy-950">
 <img src="/images/generated/workwear-flatlay.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="eager" decoding="async" />
 <div class="absolute inset-0 -z-10 bg-navy-950/88"></div>
 <div class="mx-auto max-w-6xl px-4 pb-10 pt-16 sm:px-6 sm:pb-14 sm:pt-20 lg:px-8">
 <nav class="mb-5 font-mono text-xs text-navy-300" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-400">Home</a>
 <span class="px-2 text-navy-500">/</span>
 <a href="/catalog/" class="hover:text-gold-400">Catalog</a>
 <span class="px-2 text-navy-500">/</span>
 <span class="text-gold-400">{category.shortTitle}</span>
 </nav>
 <p class="kicker mb-3">Category · Live Catalog</p>
 <h1 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-white sm:text-5xl">
 {category.title}
 </h1>
 <p class="mt-4 max-w-2xl text-base leading-relaxed text-navy-200 sm:text-lg">
 {category.blurb}
 </p>
 <div class="mt-6 max-w-xl">
 <SearchBar action={`/catalog/${category.slug}/`} size="md" placeholder={`Search within ${category.shortTitle.toLowerCase()}…`} />
 </div>
 </div>
 </section>

 <!-- Static SEO intro — concrete -->
 <section class="bg-concrete py-12 sm:py-16">
 <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-3 lg:gap-12 lg:px-8">
 <div class="lg:col-span-2">
 <h2 class="font-heading text-2xl font-extrabold uppercase tracking-tight sm:text-3xl">
 Custom <span class="text-gold-600">{category.shortTitle}</span> for teams of every kind
 </h2>
 <p class="mt-4 text-base leading-relaxed text-ash sm:text-[17px]">
 {category.seoIntro}
 </p>
 </div>
 <aside class="border border-hairline bg-panel p-6">
 <div class="kicker mb-4">What You Get</div>
 <ul class="space-y-3">
 {category.seoBullets.map((b) => (
 <li class="flex gap-2.5 text-sm leading-relaxed text-ash">
 <svg class="mt-0.5 h-4 w-4 shrink-0 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
 <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
 </svg>
 <span>{b}</span>
 </li>
 ))}
 </ul>
 <a href="/get-a-quote/" class="btn-primary mt-5 w-full justify-center">Get a Quote</a>
 </aside>
 </div>
 </section>

 <!-- Product grid — paper -->
 <section class="border-t border-hairline bg-paper py-12 sm:py-14">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
 <p id="result-meta" class="font-mono text-xs text-ash">Loading products…</p>
 <div id="pagination-meta" class="font-mono text-xs text-ash"></div>
 </div>

 <div id="products-grid" class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
 <div class="col-span-full flex items-center justify-center py-12 text-sm text-ash">
 <svg class="mr-3 h-4 w-4 animate-spin text-gold-500" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
 Loading {category.shortTitle}…
 </div>
 </div>

 <div id="pagination" class="mt-10 flex items-center justify-center gap-2"></div>
 </div>
 </section>

 <!-- Other categories — concrete -->
 <section class="border-t border-hairline bg-concrete py-12">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <h2 class="mb-4 font-heading text-lg font-bold uppercase tracking-tight">Other categories</h2>
 <div class="flex flex-wrap gap-2">
 {related.map((r) => (
 <a href={`/catalog/${r.slug}/`} class="spec border border-hairline bg-panel px-4 py-2 text-ash transition-colors hover:border-gold-500 hover:text-gold-600">
 {r.shortTitle}
 </a>
 ))}
 </div>
 </div>
 </section>

 <script type="application/json" id="cat-config" set:html={JSON.stringify({ slug: category.slug, shortTitle: category.shortTitle, search: category.search, sort: sortVal })} />
 <script type="module" src="/scripts/catalog-category.js"></script>
</BaseLayout>
