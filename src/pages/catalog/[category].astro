---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SearchBar from '@/components/SearchBar.astro'
import { bighornCategories, findCategory } from '@/data/sage-categories'

export function getStaticPaths() {
  return bighornCategories.map((c) => ({ params: { category: c.slug }, props: { category: c } }))
}

const { category } = Astro.props as { category: ReturnType<typeof findCategory> }

if (!category) {
  return Astro.redirect('/catalog/', 302)
}

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
    { '@type': 'ListItem', position: 2, name: 'Catalog', item: 'https://bighornthreads.com/catalog/' },
    { '@type': 'ListItem', position: 3, name: category.title, item: `https://bighornthreads.com/catalog/${category.slug}/` },
  ],
}

const related = bighornCategories.filter((c) => c.slug !== category.slug).slice(0, 6)

const searchParamsJson = JSON.stringify(category.search)
const sortVal = category.sort || 'BESTMATCH'
---

<BaseLayout
  title={`${category.title} — Custom Branded for Las Vegas Contractors | Bighorn Threads`}
  description={`${category.blurb} Browse live catalog with real pricing and decoration options.`}
  canonical={`https://bighornthreads.com/catalog/${category.slug}/`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <section class="relative border-b border-navy-800/40 bg-navy-900/60 pt-20 pb-10 sm:pt-24 sm:pb-14">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-950/50"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold-400">Home</a>
        <span class="px-2 text-gray-600">/</span>
        <a href="/catalog/" class="hover:text-gold-400">Catalog</a>
        <span class="px-2 text-gray-600">/</span>
        <span class="text-gold-500">{category.shortTitle}</span>
      </nav>
      <span class="mb-3 inline-block font-mono text-xs font-bold uppercase tracking-[0.25em] text-gold-500">Category · Live Catalog</span>
      <h1 class="mb-4 font-heading text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
        {category.title}
      </h1>
      <p class="mb-6 max-w-3xl text-base leading-relaxed text-navy-200 sm:text-lg">
        {category.blurb}
      </p>
      <SearchBar action={`/catalog/${category.slug}/`} size="md" placeholder={`Search within ${category.shortTitle.toLowerCase()}…`} />
    </div>
  </section>

  <!-- Static SEO intro — indexable above the JS-rendered grid -->
  <section class="border-b border-navy-800/40 bg-navy-950 py-10 sm:py-14">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-3 lg:gap-12 lg:px-8">
      <div class="lg:col-span-2">
        <h2 class="mb-4 font-heading text-2xl font-bold tracking-tight text-white sm:text-3xl">
          Custom <span class="text-gold-500">{category.shortTitle}</span> for Las Vegas Crews
        </h2>
        <p class="text-base leading-relaxed text-gray-300 sm:text-[17px]">
          {category.seoIntro}
        </p>
      </div>
      <aside class="rounded-2xl border border-navy-700/40 bg-navy-900/40 p-6">
        <div class="mb-4 font-mono text-[10px] font-bold uppercase tracking-[0.22em] text-gold-400">
          What You Get
        </div>
        <ul class="space-y-3">
          {category.seoBullets.map((b) => (
            <li class="flex gap-2.5 text-sm leading-relaxed text-gray-300">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>{b}</span>
            </li>
          ))}
        </ul>
        <a href="/contact/" class="mt-5 inline-flex w-full items-center justify-center min-h-[44px] rounded-lg bg-gold-500 px-5 py-3 text-sm font-bold uppercase tracking-[0.1em] text-navy-950 transition-all hover:bg-gold-400">
          Get a Quote
        </a>
      </aside>
    </div>
  </section>

  <section class="bg-navy-950 py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <p id="result-meta" class="font-mono text-xs text-gray-400">Loading products…</p>
        <div id="pagination-meta" class="font-mono text-xs text-gray-400"></div>
      </div>

      <div id="products-grid" class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        <div class="col-span-full flex items-center justify-center py-12 text-sm text-gray-400">
          <svg class="mr-3 h-4 w-4 animate-spin text-gold-500" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
          Loading {category.shortTitle}…
        </div>
      </div>

      <div id="pagination" class="mt-10 flex items-center justify-center gap-2"></div>
    </div>
  </section>

  <section class="border-t border-navy-800/40 bg-navy-900/30 py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-lg font-bold text-white">Other Categories</h2>
      <div class="flex flex-wrap gap-2">
        {related.map((r) => (
          <a href={`/catalog/${r.slug}/`} class="rounded-full border border-navy-700 bg-navy-900 px-4 py-1.5 text-xs text-gray-300 hover:border-gold-500/40 hover:text-gold-400">
            {r.shortTitle}
          </a>
        ))}
      </div>
    </div>
  </section>

  <script type="application/json" id="cat-config" set:html={JSON.stringify({ slug: category.slug, shortTitle: category.shortTitle, search: category.search, sort: sortVal })} />
  <script type="module" src="/scripts/catalog-category.js"></script>
</BaseLayout>
