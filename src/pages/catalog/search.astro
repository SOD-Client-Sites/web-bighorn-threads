---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SearchBar from '@/components/SearchBar.astro'
import { bighornCategories } from '@/data/sage-categories'
---

<BaseLayout
 title="Search Products — Bighorn Threads"
 description="Search 1.7M+ branded apparel and promotional products custom-decorated for Las Vegas trades."
 canonical="https://bighornthreads.com/catalog/search/"
 noindex={true}
>
 <section class="border-b border-hairline bg-paper pt-20 pb-10 sm:pt-24">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
 <a href="/" class="hover:text-gold-600">Home</a>
 <span class="px-2 text-ash/60">/</span>
 <a href="/catalog/" class="hover:text-gold-600">Catalog</a>
 <span class="px-2 text-ash/60">/</span>
 <span class="text-gold-600">Search</span>
 </nav>
 <h1 id="search-title" class="mb-5 font-heading text-2xl font-extrabold uppercase tracking-tight text-charcoal sm:text-3xl">Search Products</h1>
 <SearchBar action="/catalog/search/" size="lg" />
 </div>
 </section>

 <section class="bg-concrete py-10">
 <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <p id="result-meta" class="mb-5 font-mono text-xs text-ash"></p>
 <div id="products-grid" class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4"></div>
 <div id="empty-state" class="hidden border border-hairline bg-panel p-8 text-center">
 <p class="font-heading text-lg uppercase tracking-tight text-charcoal">Enter a keyword to search</p>
 <p class="mt-2 text-sm text-ash">Try "hi-vis vest", "polo shirt", "tumbler", or a supplier name.</p>
 <p class="mt-6 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-ash">Or Browse Categories</p>
 <div class="mt-4 flex flex-wrap justify-center gap-2">
 {bighornCategories.slice(0, 8).map((c) => (
 <a href={`/catalog/${c.slug}/`} class="border border-hairline bg-concrete px-4 py-1.5 text-xs text-charcoal transition-colors hover:border-gold-500 hover:text-gold-600">
 {c.shortTitle}
 </a>
 ))}
 </div>
 </div>
 <div id="pagination" class="mt-10 flex items-center justify-center gap-2"></div>
 </div>
 </section>

 <script type="module" src="/scripts/catalog-search.js"></script>
</BaseLayout>
