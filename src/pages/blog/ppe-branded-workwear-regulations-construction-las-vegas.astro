>
 <script type="application/ld+json" set:html={JSON.stringify(schema)} />

 <article class="bg-concrete">
  <header class="border-b border-hairline bg-paper">
   <div class="mx-auto max-w-3xl px-4 pt-32 pb-12 sm:px-6 sm:pt-40 lg:px-8">
    <nav class="mb-6 font-mono text-xs text-ash" aria-label="Breadcrumb">
     <a href="/" class="hover:text-gold-600">Home</a>
     <span class="px-2">/</span>
