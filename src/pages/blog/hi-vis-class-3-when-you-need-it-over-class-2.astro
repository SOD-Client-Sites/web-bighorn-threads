---
import BaseLayout from '@/layouts/BaseLayout.astro'

const post = {
 title: 'Hi-Vis Class 3 Apparel: When You Need Class 3 Over Class 2',
 description:
 'ANSI 107 Class 3 hi-vis is required when workers are exposed to traffic over 50 mph, in low-visibility conditions, or near heavy equipment. Here\'s the rule, the exceptions, and how to spec a Class 3 garment that passes inspection.',
 category: 'Compliance',
 readTime: '9 min read',
 date: 'May 9, 2026',
 isoDate: '2026-05-09',
 image: '/images/generated/workwear-flatlay.jpg',
 slug: 'hi-vis-class-3-when-you-need-it-over-class-2',
}

const faqs = [
 { q: 'When do I need ANSI 107 Class 3 over Class 2?', a: 'Class 3 is required when workers are exposed to traffic over 50 mph, working in low-visibility conditions (night, fog, dust), or operating near heavy equipment with limited operator sightlines. ANSI 107 also requires Class 3 for any worker whose tasks place them in close proximity to traffic moving at high speed regardless of road type.' },
 { q: 'What\'s the difference between Class 2 and Class 3 garments?', a: 'Class 3 requires more background fabric (1,240 sq inches vs 775 for Class 2) and more retroreflective tape (310 sq inches vs 201). Class 3 must cover the torso, arms (full sleeves), and either legs or be paired with Class E pants. Class 2 is a vest-only style with no sleeve requirement.' },
 { q: 'Is a Class 2 vest plus Class E pants the same as Class 3?', a: 'Yes — that combination meets Class 3 requirements per ANSI 107. The pants supply the lower-body retroreflective area, and the vest covers the torso. Many road crews use this combo because the pants stay on and the vest can come off in cooler conditions while still meeting Class 2 alone.' },
 { q: 'Does OSHA require Class 3 on highway work?', a: 'Federal OSHA defers to MUTCD (Manual on Uniform Traffic Control Devices) for federal-aid highway work, which requires ANSI 107 Class 2 or Class 3 depending on speed and exposure. State DOTs in Nevada, Arizona, and California specify Class 3 on most highway projects above 45 mph. Always check the project spec.' },
 { q: 'Can I embroider a logo on a Class 3 shirt or jacket?', a: 'Yes, but only on the background fabric — never on retroreflective tape. ANSI 107 caps total embroidery and screen-printed logo area at 12 sq inches per side and prohibits any decoration that reduces the required 1,240 sq inches of background or 310 sq inches of tape. Use a chest logo around 4 inches wide.' },
 { q: 'What colors qualify for ANSI 107 Class 3?', a: 'Fluorescent yellow-green and fluorescent orange-red are the two compliant background colors. Fluorescent red was added in the 2020 revision. The colors must meet specific chromaticity and luminance values measured under standardized conditions — generic "safety yellow" t-shirts that haven\'t been tested don\'t qualify.' },
 { q: 'Do night-shift workers always need Class 3?', a: 'Not always — but if night-shift workers are exposed to vehicle traffic or moving equipment, Class 3 is the practical default. ANSI 107 also has a Class E (pants/shorts) and a separate ANSI 207 standard for public safety. For data center, warehouse, or yard work at night without traffic exposure, Class 2 is typically sufficient.' },
 { q: 'How long does Class 3 hi-vis last in Vegas heat?', a: 'Manufacturers rate Class 3 garments for 25 industrial wash cycles or 6 months of typical wear, whichever comes first. Vegas UV exposure shortens this — fluorescent dyes fade faster in 110°F sun. Plan to replace Class 3 garments every 4-6 months for outdoor crews running daily shifts in summer.' },
]

const schema = {
 '@context': 'https://schema.org',
 '@graph': [
 { '@type': 'Article', headline: post.title, description: post.description, image: `https://bighornthreads.com${post.image}`, datePublished: post.isoDate, dateModified: post.isoDate, author: { '@type': 'Organization', name: 'Bighorn Threads', url: 'https://bighornthreads.com/' }, publisher: { '@type': 'Organization', name: 'Bighorn Threads', logo: { '@type': 'ImageObject', url: 'https://bighornthreads.com/images/logos/bighorn-logo-color.png' } }, mainEntityOfPage: `https://bighornthreads.com/blog/${post.slug}/` },
 { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' }, { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://bighornthreads.com/blog/' }, { '@type': 'ListItem', position: 3, name: post.title, item: `https://bighornthreads.com/blog/${post.slug}/` }] },
 { '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
 ],
}
---

