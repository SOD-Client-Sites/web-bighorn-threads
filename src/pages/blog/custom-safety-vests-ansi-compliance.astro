---
import BaseLayout from '@/layouts/BaseLayout.astro'

const post = {
 title: 'Custom Safety Vests: ANSI 107 Compliance and Where to Place Logos',
 description:
 'Branded safety vests must follow ANSI/ISEA 107 placement rules — 72 square inches max for non-retroreflective decoration on Class 2, with similar limits on Class 3. Here\'s how to add a company logo without breaking the certification.',
 category: 'Compliance',
 readTime: '7 min read',
 date: 'May 9, 2026',
 isoDate: '2026-05-09',
 image: '/images/generated/service-screen-printing.jpg',
 slug: 'custom-safety-vests-ansi-compliance',
}

const faqs = [
 { q: 'Can you put a logo on an ANSI 107 safety vest?', a: 'Yes — within the published placement limits. ANSI/ISEA 107 limits non-retroreflective decoration on a Class 2 vest to 72 square inches total across all placements, and the decoration cannot cover or obstruct any of the retroreflective tape required for the certification. Embroidered logos and screen-printed logos are both compliant if they fit within the area limit.' },
 { q: 'What\'s the size limit for a logo on a hi-vis vest?', a: 'ANSI/ISEA 107 caps non-retroreflective decoration at 72 square inches total on a Class 2 garment. Most company logos use roughly 8-12 square inches at 3-3.5 inches wide on the chest, well within the limit. Adding a back logo can push closer to the cap on larger vests.' },
 { q: 'Can decoration affect ANSI compliance on a safety vest?', a: 'Yes if it\'s done wrong. Decoration that covers any part of the retroreflective tape voids the certification immediately. Exceeding the 72-square-inch non-retroreflective decoration limit also voids it. Working within published manufacturer placement guides keeps the certification intact.' },
 { q: 'Where on a safety vest can I put my company logo?', a: 'Standard placements that comply: left chest panel (3-3.5 inches wide logo), right chest panel (employee name or department), back yoke above the retroreflective tape lines, and rear lower panel below the lowest reflective stripe. Avoid any placement that crosses or covers the retroreflective tape.' },
 { q: 'Can you embroider on a safety vest?', a: 'Yes — embroidery is fine on the mesh polyester fabric of most ANSI 107 vests, within the same placement and size limits as screen printing. Embroidery actually has an advantage for vests because it doesn\'t add ink that could be misread as retroreflective material under headlights.' },
 { q: 'What\'s the difference between Class 2 and Class 3 hi-vis decoration limits?', a: 'Both limit non-retroreflective decoration to a maximum total area; the specific square-inch caps and placement zones vary slightly. Class 3 garments have more retroreflective area and longer-sleeve coverage requirements, which means slightly less surface area available for decoration. The published manufacturer guide for each garment lists specific placement zones.' },
 { q: 'Where can I get ANSI 107-compliant custom safety vests in Las Vegas?', a: 'Bighorn Threads supplies and decorates ANSI 107 Class 2 and Class 3 safety vests for Vegas contractors, road crews, and night-work operations. We follow the 72-square-inch decoration limit and ensure retroreflective tape coverage is preserved through decoration.' },
]

const schema = {
