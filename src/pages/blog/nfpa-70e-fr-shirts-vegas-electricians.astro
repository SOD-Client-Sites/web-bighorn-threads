  title: 'FR Shirt Compliance for Vegas Electricians: NFPA 70E Without the Headache',
  description:
    'A working contractor\'s guide to NFPA 70E flame-resistant apparel for Las Vegas electrical crews. CAT 1 vs CAT 2, brand picks, decoration that doesn\'t void the rating, and what your safety officer actually checks.',
  category: 'Compliance',
  readTime: '11 min read',
  date: 'Apr 7, 2026',
  isoDate: '2026-04-07',
  image: '/images/generated/kit-electrical.jpg',
  slug: 'nfpa-70e-fr-shirts-vegas-electricians',
}

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: post.title,
      description: post.description,
      image: `https://bighornthreads.com${post.image}`,
      datePublished: post.isoDate,
      dateModified: post.isoDate,
