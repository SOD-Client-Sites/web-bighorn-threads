 <tr><td class="px-5 py-3 font-bold">Executive / ownership</td><td class="px-5 py-3">Peter Millar / Travis Mathew</td><td class="px-5 py-3">Industry events, authority signal</td></tr>
 <tr><td class="px-5 py-3 font-bold">High-volume crew (100+)</td><td class="px-5 py-3">Sport-Tek ST650</td><td class="px-5 py-3">Per-piece economics, wicking, color retention</td></tr>
 <tr><td class="px-5 py-3 font-bold">Messy trade (plumber, painter)</td><td class="px-5 py-3">Port Authority K100</td><td class="px-5 py-3">Stain-release extends wear between laundries</td></tr>
 </tbody>
