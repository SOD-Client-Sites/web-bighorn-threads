 slug: 'what-is-a-company-shirt',
}

const faqs = [
 { q: 'What is a company shirt?', a: 'A company shirt is any branded shirt that identifies a business — typically a polo, t-shirt, work shirt, or hoodie with the company name and logo applied via embroidery or screen printing. Crews wear them so customers, suppliers, and sub-contractors can identify the business at a glance.' },
 { q: 'What are company shirts called?', a: 'They go by several names: branded apparel, corporate apparel, custom workwear, uniform shirts, logo wear, or company uniforms. In trades and construction, "crew shirts" or "service shirts" are common. The category is broader than just t-shirts — it includes polos, button-downs, hoodies, jackets, hi-vis vests, and hats.' },
 { q: 'What\'s the difference between embroidered and screen-printed company shirts?', a: 'Embroidery stitches the logo into the fabric using thread — durable, premium look, ideal for polos and button-downs. Screen printing applies ink to the surface — lower per-piece cost at volume, ideal for tees, hoodies, and high-quantity runs. Most companies use both: embroidery for client-facing roles, screen printing for field crews.' },
