---
import BaseLayout from '@/layouts/BaseLayout.astro'

const post = {
 title: 'Trade Show Apparel: How to Outfit Your Booth Crew',
 description:
 'Trade show apparel is a brand asset, not a uniform. Here\'s how Vegas contractors outfit booth crews for AGC, IBS, World of Concrete, AHR Expo, and similar events — garment picks, embroidery placement, and the booth-to-booth visual game.',
 category: 'Use Cases',
 readTime: '8 min read',
 date: 'May 9, 2026',
 isoDate: '2026-05-09',
 image: '/images/generated/service-embroidery.jpg',
 slug: 'trade-show-apparel-booth-crew',
}

const faqs = [
 { q: 'What should trade show booth crews wear?', a: 'Branded polos for senior reps and customer-facing roles, branded long-sleeve button-downs or quarter-zips for executives, branded tees for booth setup and breakdown crews. All three should share the same logo placement, color palette, and embroidery style. Match the booth visual identity — if your booth is navy and gold, the apparel is navy with gold-stitched logos.' },
 { q: 'How many shirts should each booth person have?', a: 'Three minimum for a 3-day event: one for setup day, one for show floor day 1, one for show floor day 2. Vegas trade show events run 12-hour days and shirts get sweat-wrecked, especially during setup. Bring a fourth as a spare. Industry-typical orders run 4-5 shirts per crew member for a major event.' },
 { q: 'What trade shows do Vegas contractors attend?', a: 'World of Concrete (Vegas every January, ~57,000 attendees), AHR Expo (HVAC, rotates locations), International Builders\' Show / IBS (Vegas every other February, ~70,000 attendees), AGC Annual Convention, ConExpo-Con/Agg (Vegas every 3 years, ~140,000 attendees), and SEMA Show (auto/aftermarket, Vegas November). Each draws different crew apparel needs.' },
 { q: 'Should the booth crew all wear identical shirts?', a: 'Mostly yes — visual unity reads as professional. Tier the shirts by role: identical polo for booth reps, slightly different garment (vest, jacket, button-down) for the executive lead, and a "STAFF" or "SETUP" tee for breakdown crew. Name embroidery on each shirt is the new standard — it humanizes the crew and helps attendees remember conversations.' },
 { q: 'What\'s the best polo for trade show wear?', a: 'Three picks: (1) Port Authority K500 Silk Touch Polo for budget-conscious large crews, (2) Cutter & Buck DryTec polo for executive-tier customer-facing roles, (3) Nike Dri-FIT polo for fashion-forward brands wanting recognizable swoosh-adjacent quality. All embroider cleanly. See our Port Authority comparison piece for tradeoffs.' },
 { q: 'Should we put names on trade show shirts?', a: 'Yes — name embroidery has become the industry standard for major trade shows. Standard placement: company logo left chest, first name + last initial right chest. Letter height: 0.4-0.5 inches. Helps attendees who collect business cards remember which conversation went with which person. Costs add ~$3-6 per shirt.' },
 { q: 'Do we need different apparel for setup and show floor?', a: 'Different garments, same brand language. Setup crew: branded heavyweight tees and work pants — dirty work, hauling crates, climbing scaffolds. Show floor crew: branded polos and pressed pants. Most exhibitors order both as one apparel program with consistent logo treatment.' },
 { q: 'What\'s a realistic order timeline for trade show apparel?', a: 'Industry standard: 4-6 weeks before the show for embroidery, 2-3 weeks for screen printing. Add a week if you\'re digitizing a logo for the first time. Vegas-area shops can sometimes turn rush in 7-10 days for premium fees. World of Concrete and IBS hit annually — order in October for January, December for February shows.' },
]

const schema = {
 '@context': 'https://schema.org',
 '@graph': [
 { '@type': 'Article', headline: post.title, description: post.description, image: `https://bighornthreads.com${post.image}`, datePublished: post.isoDate, dateModified: post.isoDate, author: { '@type': 'Organization', name: 'Bighorn Threads', url: 'https://bighornthreads.com/' }, publisher: { '@type': 'Organization', name: 'Bighorn Threads', logo: { '@type': 'ImageObject', url: 'https://bighornthreads.com/images/logos/bighorn-logo-color.png' } }, mainEntityOfPage: `https://bighornthreads.com/blog/${post.slug}/` },
 { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' }, { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://bighornthreads.com/blog/' }, { '@type': 'ListItem', position: 3, name: post.title, item: `https://bighornthreads.com/blog/${post.slug}/` }] },
 { '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
 ],
}
---

<BaseLayout title={post.title} description={post.description} canonical={`https://bighornthreads.com/blog/${post.slug}/`} ogImage={post.image} type="article" publishedDate={post.isoDate}>
 <script type="application/ld+json" set:html={JSON.stringify(schema)} />
 <article class="bg-navy-950">
