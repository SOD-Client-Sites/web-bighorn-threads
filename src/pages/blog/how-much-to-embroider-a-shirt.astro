---
import BaseLayout from '@/layouts/BaseLayout.astro'

const post = {
 title: 'How Much Does It Cost to Embroider a Shirt? The 5 Factors That Drive Pricing',
 description:
 'Embroidery pricing varies by stitch count, garment cost, setup fees, decoration complexity, and quantity. Here\'s how each one moves the number — so you can read a quote and know what to ask.',
 category: 'Pricing',
 readTime: '8 min read',
 date: 'May 9, 2026',
 isoDate: '2026-05-09',
 image: '/images/generated/service-embroidery.jpg',
 slug: 'how-much-to-embroider-a-shirt',
}

const faqs = [
 { q: 'What does it cost to embroider a shirt?', a: 'Embroidery cost on a single shirt depends on stitch count (logo complexity), garment cost, setup or digitizing fee, and quantity. Industry rule of thumb: about $1 per 1,000 stitches once digitizing is done, plus the cost of the shirt and any one-time digitizing fee. Larger orders bring the per-piece cost down.' },
 { q: 'How long does it take to embroider 1,000 stitches?', a: 'Standard commercial multi-needle embroidery machines run roughly 600–1,000 stitches per minute, so 1,000 stitches takes about 1–2 minutes of machine time per piece. A typical left-chest logo (5,000–8,000 stitches) takes 5–12 minutes per shirt. Production capacity at a commercial shop is measured in pieces per hour, not minutes per shirt.' },
 { q: 'What\'s a digitizing fee?', a: 'Digitizing converts your logo into a stitch file the embroidery machine can read. It\'s a one-time fee per logo, typically $30–80 depending on complexity. Once digitized, the file is reused for every reorder. A good digitizing job is the single biggest factor in how clean your embroidery looks.' },
 { q: 'Why does my logo cost more to embroider than my friend\'s?', a: 'Stitch count. A logo with fine detail, gradients, or large filled areas takes more stitches than a simple bold mark. More stitches = more thread + more machine time = higher per-piece cost. Simplifying a logo for embroidery (or having a clean version digitized for stitch) brings costs down.' },
 { q: 'Is embroidery cheaper than screen printing?', a: 'For small batches (under 24 pieces), embroidery and screen printing are often comparable. At higher volumes, screen printing wins on per-piece cost because the cost is mostly in setup. Embroidery pricing scales more linearly because every shirt requires the same machine time. For polos, button-downs, and hats, embroidery is usually the right call regardless.' },
]

const schema = {
