---
import BaseLayout from '@/layouts/BaseLayout.astro'

const post = {
 title: 'Red Kap Industrial Work Shirts: A Buyer\'s Guide for Service Trades',
 description:
 'Red Kap is the industrial-laundry standard for plumbing, HVAC, mechanical, and service trade uniforms. Here\'s the actual SP14 vs SP24 vs SY24 spec, why industrial laundries spec Red Kap by default, and how to brand them for crew programs.',
 category: 'Brands',
 readTime: '7 min read',
 date: 'May 9, 2026',
 isoDate: '2026-05-09',
 image: '/images/generated/kit-plumbing-hvac.jpg',
 slug: 'red-kap-industrial-work-shirts-buyer-guide',
}

const faqs = [
 { q: 'What is Red Kap?', a: 'Red Kap is a Workwear Outfitters (formerly VF Imagewear) brand specializing in industrial-laundry workwear for service trades. The brand is the de facto standard for HVAC, plumbing, mechanical, and refrigeration service techs because the major industrial laundry companies process Red Kap on standard programs without special handling.' },
 { q: 'Why do industrial laundries prefer Red Kap?', a: 'Red Kap garments are designed specifically for industrial laundry rotation — durable construction, fade-resistant dyes, consistent sizing across runs, and standard pocket/closure configurations the laundry equipment handles cleanly. Other workwear brands can be processed but often require special handling that adds incremental cost per garment.' },
 { q: 'What\'s the most popular Red Kap shirt?', a: 'The Red Kap SP14 Industrial Work Shirt — short sleeve in summer, long sleeve in winter. Cotton-poly blend, button-front, two chest pockets, available in dozens of colors S-6XL. Pair with PT20 Industrial Work Pant or PT88 Touchtex pant for a complete coordinated uniform.' },
 { q: 'Can you do name patches and embroidery on Red Kap?', a: 'Yes — Red Kap supports both. Standard placement is woven name patches on the right chest and embroidered company logo on the left chest. Industrial laundries typically prefer woven patches because they handle the wash cycle better than direct embroidery on the work shirt fabric.' },
 { q: 'What\'s the difference between SP14 and SY24?', a: 'SP14 is the standard cotton-poly Industrial Work Shirt — comfortable, durable, classic work shirt feel. SY24 is the Performance Plus version with moisture-wicking fabric — same cut, same decoration spec, dramatically better for Vegas summer rooftop and attic work where the standard SP14 soaks through. We typically recommend SY24 for service crews working June-September.' },
 { q: 'How does Red Kap compare to Carhartt for crew uniforms?', a: 'Different aesthetics for different roles. Red Kap is the industrial-laundry-friendly standard for service techs — looks like a "service tech" instantly. Carhartt is the trade-friendly brand for general construction and skilled trades. Many companies run Red Kap for service crews on a laundry program plus Carhartt for project managers and customer-facing roles.' },
 { q: 'Where can I get custom Red Kap work shirts in Las Vegas?', a: 'Bighorn Threads supplies and decorates Red Kap apparel for Vegas service trades, mechanical contractors, and HVAC/plumbing shops. We integrate with industrial laundry programs and pre-decorate shirts to match laundry partner inventory codes when needed.' },
]

const schema = {
 '@context': 'https://schema.org',
 '@graph': [
 { '@type': 'Article', headline: post.title, description: post.description, image: `https://bighornthreads.com${post.image}`, datePublished: post.isoDate, dateModified: post.isoDate, author: { '@type': 'Organization', name: 'Bighorn Threads', url: 'https://bighornthreads.com/' }, publisher: { '@type': 'Organization', name: 'Bighorn Threads', logo: { '@type': 'ImageObject', url: 'https://bighornthreads.com/images/logos/bighorn-logo-color.png' } }, mainEntityOfPage: `https://bighornthreads.com/blog/${post.slug}/` },
 { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' }, { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://bighornthreads.com/blog/' }, { '@type': 'ListItem', position: 3, name: post.title, item: `https://bighornthreads.com/blog/${post.slug}/` }] },
 { '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
 ],
