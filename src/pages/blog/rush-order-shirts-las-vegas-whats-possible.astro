---
import BaseLayout from '@/layouts/BaseLayout.astro'

const post = {
 title: 'Rush Order Shirts in Las Vegas: What\'s Actually Possible',
 description:
 'Rush-order custom shirts depend on artwork readiness, blank availability, and the shop\'s production queue. Here\'s what realistic turnaround looks like — same-day, next-day, 3-day rush — and what breaks rush orders.',
 category: 'Operational',
 readTime: '7 min read',
 date: 'May 9, 2026',
 isoDate: '2026-05-09',
 image: '/images/generated/service-screen-printing.jpg',
 slug: 'rush-order-shirts-las-vegas-whats-possible',
}

const faqs = [
 { q: 'What is a rush order for t-shirts?', a: 'A rush order is a custom apparel order produced and delivered faster than the shop\'s standard turnaround time. Standard custom embroidery and screen printing typically ships within 7-10 business days; rush orders cut that to 1-5 business days depending on quantity, complexity, and how much of the production prep is already done.' },
 { q: 'How fast can you get rush shirts in Las Vegas?', a: 'Same-day or next-day for small orders (10-20 shirts) when artwork is ready, the blank is in stock, and the shop has open press time. 2-3 days for medium runs (50-100 shirts). 5-7 days for larger runs (100-500 shirts). New artwork that requires digitizing or color separation adds 1-2 days regardless of quantity.' },
 { q: 'What breaks a rush order?', a: 'Five things: artwork that needs revision or digitizing from scratch, blank garments not in stock at the shop or wholesaler, color matching for non-standard pantone colors, embroidery thread not on hand for the colorway needed, and a production queue that\'s already booked. The shop should tell you up front which (if any) of these apply to your specific job.' },
 { q: 'Is RushOrderTees legitimate?', a: 'RushOrderTees (rushordertees.com) is a national online custom apparel retailer that specializes in fast turnaround. They\'re a legitimate operation. Trade-off: they\'re a national online shop, so you\'re shipping from out of state. For Las Vegas buyers needing rush turnaround on local crews, a Vegas commercial shop typically beats national mail-order on speed simply because there\'s no cross-country shipping.' },
 { q: 'How long does RushOrderTees take to deliver?', a: 'RushOrderTees publishes 4-day production turnaround on their fastest tier plus shipping time (typically 2-3 business days from Pennsylvania to Vegas). So total turnaround from order to delivery is roughly 6-7 business days even on rush. A local Vegas shop with files on file can often beat that with same-day or next-day production.' },
 { q: 'Can you rush embroidery?', a: 'Yes — embroidery rushes the same way screen printing does, with the same five constraints (artwork readiness, blank availability, color matching, thread availability, queue). New logos require digitizing first which adds prep time; existing logos with files on record skip that step.' },
 { q: 'What does a rush order surcharge cost?', a: 'Most shops charge a rush surcharge between 15-50% on top of the standard per-piece price, depending on how aggressive the rush is and what production prep has to be expedited. Same-day or next-day rushes typically carry the highest surcharge; 3-5 day rushes often carry minimal or no surcharge for repeat customers with files on record.' },
]

const schema = {
 '@context': 'https://schema.org',
 '@graph': [
 { '@type': 'Article', headline: post.title, description: post.description, image: `https://bighornthreads.com${post.image}`, datePublished: post.isoDate, dateModified: post.isoDate, author: { '@type': 'Organization', name: 'Bighorn Threads', url: 'https://bighornthreads.com/' }, publisher: { '@type': 'Organization', name: 'Bighorn Threads', logo: { '@type': 'ImageObject', url: 'https://bighornthreads.com/images/logos/bighorn-logo-color.png' } }, mainEntityOfPage: `https://bighornthreads.com/blog/${post.slug}/` },
 { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' }, { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://bighornthreads.com/blog/' }, { '@type': 'ListItem', position: 3, name: post.title, item: `https://bighornthreads.com/blog/${post.slug}/` }] },
 { '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
