 <!-- TOC -->
 <aside class="mb-12 border border-hairline bg-panel p-6 lg:sticky lg:top-24">
 <h2 class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-gold-600">In this article</h2>
 <ol class="space-y-2 font-mono text-sm text-charcoal">
