 { slug: 'custom-hard-hats-las-vegas-buyer-guide', category: 'Compliance', title: 'Custom Hard Hats in Las Vegas: A Buyer\'s Guide for Contractors', excerpt: 'ANSI Z89.1 types and classes, decoration methods that don\'t void the rating, hat styles, and how to spec a branded hard hat program for a Vegas crew.', readTime: '9 min read', date: 'May 9, 2026', image: '/images/generated/kit-electrical.jpg', imageAlt: 'Custom branded hard hats with company logo decals on a Las Vegas construction site' },
 { slug: 'welder-uniforms-las-vegas-buyer-guide', category: 'Compliance', title: 'Welder Uniforms in Las Vegas: A Buyer\'s Guide for Welding Shops & Contractors', excerpt: 'The layered FR + leather welder system — NFPA 2112 base, leather over-layer, brand picks, and how to brand FR garments without voiding the rating.', readTime: '10 min read', date: 'May 9, 2026', image: '/images/generated/kit-electrical.jpg', imageAlt: 'Welder in NFPA 2112 FR shirt and leather welding jacket on a Las Vegas job site' },
 { slug: 'rush-order-shirts-las-vegas-2-day-3-day-options', category: 'Operational', title: 'Rush Order Shirts in Las Vegas: 2-Day vs 3-Day vs Same-Day Options', excerpt: 'Decision matrix for same-day, 2-day, and 3-day rush — what each tier means, what breaks rush orders, and how to pick the right speed for your event.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/service-screen-printing.jpg', imageAlt: 'Rush order custom shirts in production at a Las Vegas screen printing shop' },
 { slug: 'hi-vis-class-3-when-you-need-it-over-class-2', category: 'Compliance', title: 'Hi-Vis Class 3 Apparel: When You Need Class 3 Over Class 2', excerpt: 'Class 3 is required when crews face traffic over 50 mph, work in low-visibility conditions, or operate near heavy equipment. Spec rules, exceptions, and logo placement that holds the rating.', readTime: '9 min read', date: 'May 9, 2026', image: '/images/generated/workwear-flatlay.jpg', imageAlt: 'ANSI 107 Class 3 hi-vis safety shirt with reflective tape on fluorescent fabric' },
 { slug: 'foreman-supervisor-shirts-visual-authority', category: 'Crew Outfitting', title: 'Foreman & Supervisor Shirts: Visual Authority on the Jobsite', excerpt: 'Foremen need to be visually distinct so subs, inspectors, and visitors find them fast. Color, garment, embroidery, and hard hat coordination — the full playbook.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/kit-gc.jpg', imageAlt: 'Construction foreman in embroidered work shirt with FOREMAN callout on a Las Vegas jobsite' },
 { slug: 'apprentice-journeyman-uniforms-differentiation', category: 'Crew Outfitting', title: 'Apprentice & Journeyman Uniforms: Differentiation in Crew Programs', excerpt: 'Union shops and merit shops both differentiate apprentices from journeymen visually. IBEW, UA, ironworkers, plus merit-shop tier programs — the patterns that work.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/kit-electrical.jpg', imageAlt: 'Electrical apprentice and journeyman in differentiated FR shirts on a Las Vegas jobsite' },
 { slug: 'embroidery-file-formats-explained', category: 'How-To', title: 'Embroidery File Formats Explained: DST, EXP, JEF, PES', excerpt: 'Embroidery machines read stitch files, not logos. DST is the universal commercial format. EXP, JEF, PES are brand-specific. Which to send your shop and why.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/service-embroidery.jpg', imageAlt: 'Commercial embroidery machine reading a DST stitch file with thread cones loaded' },
 { slug: 'trade-show-apparel-booth-crew', category: 'Use Cases', title: 'Trade Show Apparel: How to Outfit Your Booth Crew', excerpt: 'World of Concrete, IBS, AHR Expo, ConExpo, SEMA. Garment picks, embroidery placement, name customization, and order timeline for Vegas trade show exhibitors.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/service-embroidery.jpg', imageAlt: 'Trade show booth crew in matching embroidered polos at a Las Vegas convention center' },
 { slug: 'sublimation-printing-custom-apparel-guide', category: 'Decoration Methods', title: 'Sublimation Printing for Custom Apparel: When It Wins, When It Doesn\'t', excerpt: 'Sublimation dyes polyester fibers permanently — vivid, no-feel, but only on white/light polyester. Wins for athletic wear, photographic designs, small-batch.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/service-screen-printing.jpg', imageAlt: 'Sublimation printing transfer being heat-pressed onto polyester' },
 { slug: 'dtf-printing-vs-screen-printing-custom-apparel', category: 'Decoration Methods', title: 'DTF Printing vs Screen Printing for Custom Apparel: When to Use Which', excerpt: 'DTF wins on small-batch and dark fabrics. Screen printing wins on volume cotton runs. Crossover point ~24-36 pieces. Decision matrix inside.', readTime: '8 min read', date: 'May 9, 2026', image: '/images/generated/service-screen-printing.jpg', imageAlt: 'DTF transfer being heat-pressed onto a black cotton tee' },
 { slug: 'vector-logo-file-setup-for-embroidery', category: 'How-To', title: 'Vector Logo File Setup for Embroidery — How to Prep Your Logo', excerpt: 'Send vector (.ai, .eps, .pdf, .svg) for cleanest embroidery. Convert text to outlines, simplify fine detail, limit to 6-12 colors.', readTime: '7 min read', date: 'May 9, 2026', image: '/images/generated/service-embroidery.jpg', imageAlt: 'Vector logo file being prepared for embroidery digitizing' },
 { slug: 'custom-embroidered-aprons-trade-businesses', category: 'Products', title: 'Custom Embroidered Aprons for Service & Trade Businesses', excerpt: '10 oz cotton canvas bib apron with cross-back straps and embroidered chest logo. Industries that wear them and how to spec.', readTime: '7 min read', date: 'May 9, 2026', image: '/images/generated/service-embroidery.jpg', imageAlt: 'Custom embroidered cotton canvas bib apron with company logo' },
 { slug: 'custom-branded-sweatshirts-vs-embroidered-hoodies', category: 'Comparison', title: 'Custom Branded Sweatshirts vs Embroidered Hoodies — Which Wins?', excerpt: 'Crewnecks for office, hoodies for field crews. Carhartt SUP01 vs Independent IND4000 vs Champion S700 vs Gildan 18500.', readTime: '7 min read', date: 'May 9, 2026', image: '/images/generated/service-embroidery.jpg', imageAlt: 'Custom embroidered crewneck sweatshirt and pullover hoodie' },
