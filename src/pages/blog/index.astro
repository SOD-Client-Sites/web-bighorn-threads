---
import BaseLayout from '@/layouts/BaseLayout.astro'

const posts = [
  {
    slug: 'nevada-osha-heat-rules-2026-workwear',
    category: 'Compliance',
    title: 'Nevada OSHA Heat Rules 2026: What Las Vegas Contractors Need to Know About Workwear',
    excerpt: "Nevada's heat illness standard takes effect in 2026 and changes what construction crews must wear. A practical guide for Las Vegas contractors — fabric weight, color, hi-vis, FR, and what your safety officer will ask about.",
    readTime: '12 min read',
    date: 'Apr 27, 2026',
    image: '/images/generated/workwear-flatlay.jpg',
    imageAlt: 'Breathable hi-vis and FR workwear flat-lay for Nevada OSHA heat rule compliance',
  },
  {
    slug: 'logo-digitizing-101-embroidery',
    category: 'Decoration Methods',
    title: 'Logo Digitizing 101: Why Your First File Matters More Than Your Tenth Order',
    excerpt: 'The single biggest predictor of how good your embroidered shirts will look isn\'t your logo, your fabric, or your shop. It\'s the digitizing file behind it.',
    readTime: '7 min read',
    date: 'Apr 28, 2026',
    image: '/images/generated/service-embroidery.jpg',
    imageAlt: 'Industrial embroidery machine stitching a contractor logo onto a navy work polo',
  },
  {
    slug: 'plastisol-vs-water-based-ink-workwear',
    category: 'Decoration Methods',
    title: 'Plastisol vs Water-Based Ink for Workwear: What Holds Up on a Vegas Job Site',
    excerpt: 'Two ink families behind almost every printed work shirt in Vegas. Different chemistry, different feel, very different lifespan.',
    readTime: '9 min read',
    date: 'Apr 21, 2026',
    image: '/images/generated/service-screen-printing.jpg',
    imageAlt: 'Screen printing press laying down ink on a heavyweight cotton work tee',
  },
  {
    slug: 'how-many-shirts-per-crew-member-vegas',
    category: 'Operations',
    title: 'How Many Shirts Should You Order Per Crew Member? (Vegas GC Rule of Thumb)',
    excerpt: 'A field-tested formula for outfitting construction crews in Las Vegas — by role, by season, with realistic wash rotations.',
    readTime: '8 min read',
    date: 'Apr 14, 2026',
    image: '/images/generated/product-stack.jpg',
    imageAlt: 'Stacked folded branded work shirts ready for delivery to a Las Vegas construction crew',
  },
  {
    slug: 'nfpa-70e-fr-shirts-vegas-electricians',
    category: 'Compliance',
    title: 'FR Shirt Compliance for Vegas Electricians: NFPA 70E Without the Headache',
    excerpt: 'CAT 1 vs CAT 2, the brands that actually hold up in Vegas heat, and how to embroider on FR without voiding the certification.',
    readTime: '11 min read',
    date: 'Apr 7, 2026',
    image: '/images/generated/kit-electrical.jpg',
    imageAlt: 'NFPA 70E flame-resistant electrical contractor kit with FR shirt and arc-rated gloves',
  },
  {
    slug: 'company-store-vs-bulk-ordering',
    category: 'Operations',
    title: 'Bulk Ordering vs Company Store: The Real Math for Contractors',
    excerpt:
      'Ordering 500 tees at once still looks cheaper on paper. Here\'s why the spreadsheet lies — and the actual cost per wearable piece when you add shrinkage and dead stock.',
    readTime: '8 min read',
    date: 'Apr 1, 2026',
    image: '/images/generated/service-company-stores.jpg',
    imageAlt: 'Branded company-store apparel program — folded polos and tees on shelves',
  },
  {
    slug: 'screen-printing-vs-embroidery-construction',
    category: 'Decoration Methods',
    title: 'Screen Printing vs Embroidery: Which Is Right for Construction Gear?',
    excerpt:
      'The real difference isn\'t price — it\'s durability, garment type, and how your logo reads on a jobsite. A straight-talk comparison from 15 years of Vegas crews.',
    readTime: '7 min read',
    date: 'Mar 15, 2026',
    image: '/images/generated/workwear-flatlay.jpg',
    imageAlt: 'Flat-lay of branded construction workwear including shirts hi-vis vest cap and tape measure',
  },
  {
    slug: 'how-to-outfit-a-construction-crew-vegas',
    category: 'Crew Outfitting',
    title: 'How to Outfit a Construction Crew in Las Vegas (Without Losing Your Mind)',
    excerpt:
      'Sizing chaos, rush orders, dead inventory in a back closet. A practical playbook for outfitting 10, 50, or 500 people — built for Vegas contractors.',
    readTime: '9 min read',
    date: 'Mar 1, 2026',
    image: '/images/generated/kit-gc.jpg',
    imageAlt: 'General contractor crew outfit kit with embroidered polo softshell jacket and hard hat',
  },
]

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://bighornthreads.com/blog/#blog',
  name: 'Field Notes — Bighorn Threads',
  description: 'Practical insights on outfitting construction crews and trades in Las Vegas. Screen printing, embroidery, company stores, and bulk apparel — straight from the shop floor.',
  url: 'https://bighornthreads.com/blog/',
  inLanguage: 'en-US',
  publisher: { '@id': 'https://bighornthreads.com/#organization' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    '@id': `https://bighornthreads.com/blog/${p.slug}/`,
    headline: p.title,
    description: p.excerpt,
    datePublished: new Date(p.date).toISOString(),
    url: `https://bighornthreads.com/blog/${p.slug}/`,
    author: { '@type': 'Organization', name: 'Bighorn Threads' },
  })),
}

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': 'https://bighornthreads.com/blog/#itemlist',
  numberOfItems: posts.length,
  itemListElement: posts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://bighornthreads.com/blog/${p.slug}/`,
    name: p.title,
  })),
}
---

<BaseLayout
  title="Field Notes — Bighorn Threads Blog"
  description="Practical insights on outfitting construction crews and trades in Las Vegas. Screen printing, embroidery, company stores, and bulk apparel — straight from the shop floor."
  canonical="https://bighornthreads.com/blog/"
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-navy-800">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-gray-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_40%,_rgba(193,155,61,0.05),_transparent)]"></div>

    <div class="relative mx-auto max-w-5xl px-4 pt-24 pb-16 sm:px-6 sm:pt-28 lg:px-8 lg:pt-32">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-gold-500">Field Notes</span>
      <h1 class="mb-6 font-heading text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Insights for <span class="bg-gradient-to-r from-gold-500 to-gold-300 bg-clip-text text-transparent">Construction & Trades</span>
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-gray-400 sm:text-xl">
        Practical playbooks on branded apparel, decoration methods, and company store logistics — written for the people actually running crews in Las Vegas.
      </p>
    </div>
  </section>

  <!-- Editorial intro -->
  <section class="border-b border-navy-800 bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="mb-5 text-lg leading-relaxed text-gray-300">
        Field Notes is our working archive for the stuff promo salespeople usually bury in a brochure. Decoration methods that hold up on a concrete crew. The real per-garment cost of a company store versus a bulk buy. ANSI hi-vis rules that get contractors fined. FR ratings that actually protect an electrician.
      </p>
      <p class="mb-5 text-lg leading-relaxed text-gray-300">
        We write for general contractors, electrical shops, plumbing and HVAC companies, roofing crews, landscapers, ironworkers, and everyone in between — the companies building, wiring, and servicing Las Vegas. If you've got 10 people or 300, if you're running two vans or six yards, this is the kind of material we wish somebody had written for us fifteen years ago.
      </p>
      <p class="text-lg leading-relaxed text-gray-300">
        Every post is written to be useful on its own. No fluff, no pivot-to-upsell, no "definitive guide" nonsense. If a section doesn't teach you something usable in the next quote you send or the next PPE decision you make, it doesn't go live.
      </p>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="bg-navy-950 py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group flex flex-col overflow-hidden rounded-2xl border border-navy-700/50 bg-navy-900/40 transition-all hover:-translate-y-1 hover:border-gold-500/40 hover:bg-navy-800/60"
          >
            <div class="relative aspect-[16/10] overflow-hidden bg-navy-950/60">
              <img
                src={post.image}
                alt={post.imageAlt}
                width="800"
                height="500"
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-950/50 via-transparent to-transparent"></div>
              <span class="absolute left-4 top-4 inline-block rounded-full border border-gold-500/30 bg-navy-950/80 px-3 py-1 text-xs font-bold uppercase tracking-wider text-gold-400 backdrop-blur-sm">
                {post.category}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h2 class="mb-3 font-heading text-xl font-bold leading-tight tracking-tight text-white group-hover:text-gold-300">
                {post.title}
              </h2>
              <p class="mb-6 line-clamp-2 text-sm leading-relaxed text-gray-400">
                {post.excerpt}
              </p>
              <div class="mt-auto flex items-center justify-between border-t border-navy-800 pt-4">
                <span class="font-mono text-xs uppercase tracking-wider text-gray-500">
                  {post.readTime}
                </span>
                <span class="text-sm font-bold text-gold-500 group-hover:text-gold-400">
                  Read more &rarr;
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Cadence footer -->
      <div class="mt-16 border-t border-navy-800 pt-10 text-center">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-gray-300">New posts every two weeks</p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <!-- CTA band -->
  <section class="border-t border-navy-800 bg-navy-900/60 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">
        Ready to outfit your crew?
      </h2>
      <p class="mb-8 text-lg text-gray-400">
        Talk to a real human who has been outfitting Vegas trades since 2010.
      </p>
      <a
        href="/contact/"
        class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-gold-500 px-8 py-4 text-lg font-bold text-navy-950 transition-all hover:bg-gold-400"
      >
        Get a Free Quote
      </a>
    </div>
  </section>
</BaseLayout>
