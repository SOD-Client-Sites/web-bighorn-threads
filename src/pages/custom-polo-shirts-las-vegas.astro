---
import BaseLayout from '@/layouts/BaseLayout.astro'

const page = {
 title: 'Custom Polo Shirts in Las Vegas | Embroidered Company Polos — Bighorn Threads',
 description:
 'Custom embroidered polo shirts for Las Vegas service techs, account managers, and customer-facing staff. Port Authority, Sport-Tek, Carhartt, Nike, Cutter & Buck — embroidered cleanly, named on request. Get a quote.',
 hero: '/images/generated/service-embroidery.jpg',
 url: 'https://bighornthreads.com/custom-polo-shirts-las-vegas/',
}

const stack = [
 { label: 'The blank', body: 'Port Authority K500 Silk Touch (the workhorse), K540 Performance for Vegas summer wicking, Sport-Tek ST650, Carhartt Workwear Pocket Polo for trades, Nike Dri-FIT and Cutter & Buck DryTec for executive tier.' },
 { label: 'The decoration', body: 'Embroidered chest logo on every polo. Optional name embroidery on the right chest. Pantone-matched thread on file once approved — every reorder lines up.' },
 { label: 'Sizing', body: 'XS through 6XL on most blanks. Tall sizes on Port Authority and Sport-Tek. Women\'s cuts available across all stocked brands.' },
 { label: 'Program-ready', body: 'Re-order at the same per-piece cost from a private company store. New hires get fully-decorated polos when they start, without HR chasing approvals.' },
]

const blanks = [
 { row: 'Port Authority K500', use: 'The workhorse — pique knit, embroiders cleanly, 30+ stock colors', notes: 'Cotton-poly blend; the default for service tech and account-manager polos' },
 { row: 'Port Authority K540', use: 'Performance moisture-wicking for Vegas summer service work', notes: 'Polyester; wicks sweat, dries fast, doesn\'t soak through by 11am' },
 { row: 'Sport-Tek ST650', use: 'Performance polo at a workwear price', notes: 'Snag-resistant polyester; popular for crews running outdoors year-round' },
 { row: 'Carhartt Force Cotton Delmont', use: 'Trades-friendly polo, reads as workwear not corporate', notes: 'Cotton-poly with FastDry sweat-wicking; fits over base layers' },
 { row: 'Nike Dri-FIT', use: 'Premium polo with the recognizable swoosh-adjacent quality', notes: 'For client-facing roles where the brand association is the point' },
 { row: 'Cutter & Buck DryTec', use: 'Executive-tier polo, golf-shirt feel', notes: 'For VP, owner, and high-touch sales roles' },
]

const placements = [
 { name: 'Left chest logo', detail: 'The standard. ~3.5" wide. Fits every polo program.' },
 { name: 'Right chest name', detail: 'First name + last initial in 0.4–0.5" letters. Standard for service techs and trade show crews.' },
 { name: 'Sleeve mark', detail: 'Cap sleeve or full sleeve. Cert badges, secondary brand marks, project IDs.' },
 { name: 'Back yoke', detail: 'For larger logos on heavier polos. Common on jacket programs that match the polo line.' },
]

const faqs = [
 { q: 'Should custom polo shirts be embroidered or screen printed?', a: 'Embroidery — almost always. Stitched thread on a pique-knit polo reads as established business in a way a screen-printed polo never does. Screen printing on polos is reserved for high-volume promotional runs where cost beats feel. For client-facing roles, embroidery is the standard.' },
 { q: 'What\'s the best polo blank for Las Vegas summer?', a: 'Moisture-wicking polyester — Port Authority K540 Silk Touch Performance or Sport-Tek ST650. They wick sweat, dry fast, and don\'t soak through by 11am the way 100% cotton polos do. Cotton looks nice in week one but loses by July.' },
 { q: 'Can you embroider names on every polo?', a: 'Yes. Once digitizing is done, name embroidery adds about a day to the standard run. We stitch each name to order; the per-shirt cost is fixed regardless of name length. Worth doing for service techs, trade show crews, and any customer-facing role where the name is the trust signal.' },
 { q: 'Do you stock women\'s cut polos?', a: 'Yes — across all major brands. Port Authority L500 (women\'s K500), L540 (women\'s K540), Sport-Tek LST650. Same embroidery treatment, same per-piece pricing as men\'s sizes.' },
 { q: 'Can you match my Pantone brand color in the thread?', a: 'Yes. We carry the full Madeira and Robison-Anton thread libraries — over 400 colors between them — with Pantone matching to within ~2 shades on most colors. Brand colors get locked on file once approved.' },
 { q: 'Can you set up a company store for our polos?', a: 'Yes. A private storefront with your approved polos and decoration spec preloaded, employee size profiles on file, and per-employee allowances that match your apparel budget. Reorders run at the same per-piece pricing as the initial order.' },
 { q: 'Where can I get custom polo shirts in Las Vegas?', a: 'Bighorn Threads runs custom embroidered polos for Vegas contractors, service businesses, and trade companies. Port Authority, Sport-Tek, Carhartt, Nike, and Cutter & Buck blanks in stock S–4XL. Send your logo and quantity for a quote.' },
]

const breadcrumb = {
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bighornthreads.com/' },
 { '@type': 'ListItem', position: 2, name: 'Custom Polo Shirts Las Vegas', item: page.url },
 ],
}

const serviceSchema = {
 '@context': 'https://schema.org',
 '@type': 'Service',
 name: 'Custom Embroidered Polo Shirts in Las Vegas',
 serviceType: 'Embroidered company polo shirts for service trades and customer-facing staff',
 provider: { '@id': 'https://bighornthreads.com/#organization' },
 areaServed: [
 { '@type': 'City', name: 'Las Vegas' },
 { '@type': 'City', name: 'Henderson' },
 { '@type': 'City', name: 'North Las Vegas' },
 { '@type': 'City', name: 'Summerlin' },
 { '@type': 'City', name: 'Spring Valley' },
 ],
 description: page.description,
 url: page.url,
}

const faqSchema = {
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}
---

<BaseLayout
 title={page.title}
 description={page.description}
 canonical={page.url}
 heroImage={page.hero}
>
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
 <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="relative overflow-hidden border-b border-navy-700/30 bg-navy-900/50 pt-32 pb-20 sm:pt-36 sm:pb-28">
 <div class="absolute inset-0">
 <img src={page.hero} alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" width="1600" height="900" loading="eager" fetchpriority="high" />
 <div class="absolute inset-0 bg-gradient-to-r from-navy-950 via-navy-950/90 to-navy-950/40" />
 <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_75%_-10%,_rgba(193,155,61,0.15),_transparent)]" />
 </div>

 <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <nav class="mb-6 font-mono text-xs text-gray-400" aria-label="Breadcrumb">
