---
import '@/styles/global.css'
import SmsConsentFields from '@/components/SmsConsentFields.astro'

// Bighorn Threads — Event opt-in landing page (QR target).
// Hardcoded for the current event. To repurpose: change EVENT_TAG + EVENT_LABEL + headline copy.
const EVENT_TAG = 'event-golf-tournament'
const EVENT_LABEL = 'Golf Tournament 2026'
const HEADLINE_LINE_1 = "Drop your info."
const HEADLINE_LINE_2 = "Grab your free gift."
const SUBHEAD =
 "Quick form. No spam. We'll text you when your gift's ready at the Bighorn Threads tent — plus a heads-up on what's new for your crew."

const title = 'Free Gift — Bighorn Threads'
const description = 'Sign up for your free gift from Bighorn Threads at the event.'
---

<!doctype html>
<html lang="en">
 <head>
 <meta charset="utf-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
 <meta name="robots" content="noindex,nofollow" />
 <title>{title}</title>
 <meta name="description" content={description} />
 <link rel="icon" type="image/png" href="/favicon.png" />
 <meta name="theme-color" content="#f4f2ee" />
 <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
 </head>
 <body class="min-h-dvh bg-concrete text-charcoal antialiased">
 <main class="relative isolate min-h-dvh overflow-hidden">
 <div
 aria-hidden="true"
 class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gold-500"
 >
 </div>

 <div class="relative mx-auto flex min-h-dvh max-w-xl flex-col px-5 pb-12 pt-10 sm:px-6 sm:pt-14">
 <!-- Brand -->
 <div class="mb-8 flex items-center justify-between">
 <a href="/" class="flex items-center gap-2.5">
 <img
 src="/images/logo-mark.svg"
 alt=""
 width="32"
 height="32"
 class="h-8 w-8"
 onerror="this.style.display='none'"
 />
 <span class="font-heading text-lg font-bold uppercase tracking-[0.18em] text-charcoal">
 Bighorn <span class="text-gold-600">Threads</span>
 </span>
 </a>
 <span
 class="font-mono text-[10px] uppercase tracking-[0.2em] text-gold-700"
 >
 {EVENT_LABEL}
 </span>
 </div>

 <!-- Headline -->
 <header class="mb-8">
 <span
 class="mb-3 inline-block font-subheading text-xs font-bold uppercase tracking-[0.22em] text-gold-700"
 >
 Free Gift · While Supplies Last
 </span>
 <h1
 class="font-heading text-4xl font-extrabold uppercase leading-[0.95] tracking-tight text-charcoal sm:text-5xl"
 >
 {HEADLINE_LINE_1}<br />
 <span class="text-gold-600">{HEADLINE_LINE_2}</span>
 </h1>
 <p class="mt-5 text-base leading-relaxed text-ash sm:text-lg">
 {SUBHEAD}
 </p>
 </header>

 <!-- Form -->
 <form
 id="optinForm"
 class="border border-hairline bg-panel p-5 sm:p-6"
 novalidate
 >
 <!-- Honeypot: name kept obscure to avoid password-manager / browser autofill -->
 <div class="absolute -left-[9999px]" aria-hidden="true">
 <label for="bh_hp_field">Leave blank</label>
 <input type="text" name="bh_hp_field" id="bh_hp_field" tabindex="-1" autocomplete="off" />
 </div>

 <input type="hidden" name="eventTag" value={EVENT_TAG} />
 <input type="hidden" name="eventLabel" value={EVENT_LABEL} />

 <div class="grid gap-4 sm:grid-cols-2">
 <div class="sm:col-span-1">
 <label for="firstName" class="block font-subheading text-xs font-bold uppercase tracking-[0.15em] text-charcoal">
 First name
 </label>
 <input
 type="text"
 name="firstName"
 id="firstName"
 required
 autocomplete="given-name"
 inputmode="text"
 class="mt-1.5 block w-full min-h-[48px] rounded border border-hairline bg-panel px-4 py-3 text-base text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25"
 placeholder="Jordan"
 />
 </div>
 <div class="sm:col-span-1">
 <label for="lastName" class="block font-subheading text-xs font-bold uppercase tracking-[0.15em] text-charcoal">
 Last name
 </label>
 <input
 type="text"
 name="lastName"
 id="lastName"
 required
 autocomplete="family-name"
 class="mt-1.5 block w-full min-h-[48px] rounded border border-hairline bg-panel px-4 py-3 text-base text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25"
 placeholder="Reyes"
 />
 </div>
 <div class="sm:col-span-2">
 <label for="phone" class="block font-subheading text-xs font-bold uppercase tracking-[0.15em] text-charcoal">
 Phone
 </label>
 <input
 type="tel"
 name="phone"
 id="phone"
 autocomplete="tel"
 inputmode="tel"
 class="mt-1.5 block w-full min-h-[48px] rounded border border-hairline bg-panel px-4 py-3 text-base text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25"
 placeholder="(702) 555-0187"
 />
 </div>
 <div class="sm:col-span-2">
 <label for="email" class="block font-subheading text-xs font-bold uppercase tracking-[0.15em] text-charcoal">
 Email
 </label>
 <input
 type="email"
 name="email"
 id="email"
 required
 autocomplete="email"
 inputmode="email"
 class="mt-1.5 block w-full min-h-[48px] rounded border border-hairline bg-panel px-4 py-3 text-base text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25"
 placeholder="jordan@reyesgrading.com"
 />
 </div>
 <div class="sm:col-span-2">
 <label for="business" class="block font-subheading text-xs font-bold uppercase tracking-[0.15em] text-charcoal">
 Business
 </label>
 <input
 type="text"
 name="business"
 id="business"
 required
 autocomplete="organization"
 class="mt-1.5 block w-full min-h-[48px] rounded border border-hairline bg-panel px-4 py-3 text-base text-charcoal placeholder-ash transition-colors focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/25"
 placeholder="Reyes Concrete & Grading"
 />
 </div>
 </div>

 <SmsConsentFields tone="compact" />

 <div class="cf-turnstile mt-6" data-sitekey="0x4AAAAAADW_K97ZyhlAHC4I" data-theme="light"></div>

 <button
 type="submit"
 class="btn-primary mt-6 w-full justify-center text-base disabled:opacity-60"
 >
 Claim My Free Gift
 </button>

 <p class="mt-4 text-center text-xs text-ash">
 We won't share your info. Unsubscribe anytime.
 </p>

 <div
 id="formStatus"
 role="status"
 aria-live="polite"
 aria-atomic="true"
 class="mt-4 text-center text-sm"
 >
 </div>
 </form>

 <!-- Success state (hidden by default) -->
 <div
 id="successState"
 class="hidden border border-hairline bg-panel p-8 text-center"
 >
 <div
 class="mx-auto mb-5 flex h-16 w-16 items-center justify-center bg-gold-500 text-charcoal"
 aria-hidden="true"
 >
 <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
 <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
 </svg>
 </div>
 <h2 class="font-heading text-3xl font-extrabold uppercase tracking-tight text-charcoal">
 You're <span class="text-gold-600">In.</span>
 </h2>
 <p class="mx-auto mt-3 max-w-sm text-base text-ash">
 Walk over to the Bighorn Threads tent and grab your gift. Show this screen if anyone asks.
 </p>
 <a
 href="https://bighornthreads.com"
 class="btn-secondary mt-6 text-sm"
 >
 See What We Do →
 </a>
 </div>

 <!-- Footer -->
 <footer class="mt-auto pt-10 text-center">
 <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-ash">
 Bighorn Threads · Las Vegas
 </p>
 <a
 href="tel:+17029048923"
 class="mt-1 inline-block font-mono text-sm text-ash hover:text-gold-600"
 >
 702.904.8923
 </a>
 </footer>
 </div>
 </main>

 <script is:inline>
 (function () {
 const form = document.getElementById('optinForm')
 const status = document.getElementById('formStatus')
 const success = document.getElementById('successState')
 if (!form || !status || !success) return

 const setStatus = (msg, tone) => {
 status.textContent = msg
 status.className =
 'mt-4 text-center text-sm ' +
 (tone === 'error' ? 'text-red-600' : tone === 'success' ? 'text-gold-700' : 'text-ash')
 }

 form.addEventListener('submit', async (e) => {
 e.preventDefault()

 const hp = form.querySelector('input[name="bh_hp_field"]')
 if (hp && hp.value) {
 window.location.href = '/win/thanks'
 return
 }

 const required = ['firstName', 'lastName', 'email', 'business']
 for (const field of required) {
 const el = form.elements.namedItem(field)
 if (!el || !el.value.trim()) {
 setStatus('Please fill in every field so we can reach you.', 'error')
 if (el && typeof el.focus === 'function') el.focus()
 return
 }
 }

 const email = form.elements.namedItem('email')
 if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
 setStatus("That email doesn't look right — mind double-checking?", 'error')
 email.focus()
 return
 }

 setStatus('Sending..', 'info')
 const submitBtn = form.querySelector('button[type="submit"]')
 if (submitBtn) submitBtn.disabled = true

 const smsMarketing = form.querySelector('input[name="smsMarketingConsent"]')
 const smsTransactional = form.querySelector('input[name="smsTransactionalConsent"]')
 const payload = {
 firstName: form.firstName.value.trim(),
 lastName: form.lastName.value.trim(),
 phone: form.phone.value.trim(),
 email: form.email.value.trim(),
 business: form.business.value.trim(),
 eventTag: form.eventTag.value,
 eventLabel: form.eventLabel.value,
 smsMarketingConsent: smsMarketing && smsMarketing.checked ? 'yes' : '',
 smsTransactionalConsent: smsTransactional && smsTransactional.checked ? 'yes' : '',
 consentUrl: window.location.href,
 bh_hp_field: hp ? hp.value : '',
 'cf-turnstile-response': (form.querySelector('[name="cf-turnstile-response"]') || {}).value || '',
 }

 try {
 const res = await fetch('/api/event-optin', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
 body: JSON.stringify(payload),
 })
 if (res.ok) {
 window.location.href = '/win/thanks'
 } else {
 throw new Error('Request failed')
 }
 } catch (err) {
 setStatus(
 "Couldn't submit. Try again, or text us at 702.904.8923.",
 'error'
 )
 } finally {
 if (submitBtn) submitBtn.disabled = false
 }
 })
 })()
 </script>
 </body>
</html>
