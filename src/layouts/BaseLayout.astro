---
import SEOHead from '@/components/SEOHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import '@/styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
  type?: 'website' | 'article'
  publishedDate?: string
  noindex?: boolean
  heroImage?: string
}

const props = Astro.props
const { heroImage } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {...props} />
    {heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZGGY24PN1Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ZGGY24PN1Z');
    </script>
  </head>
  <body class="min-h-screen bg-navy-950 pb-[60px] text-white antialiased lg:pb-0">
    <Header />
    <main class="pt-[65px]">
      <slot />
    </main>
    <Footer />
    <script src="https://api.salesondemand.io/js/external-tracking.js" data-tracking-id="tk_4f091433d8a94642b790fd3fbc56afa7"></script>
  </body>
</html>
